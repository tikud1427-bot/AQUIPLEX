+// GET /project/workspace/:id/events?op=emit&q=user.created
+//   Every emit/listen with event name + file:line; optional op / name filter.
+router.get('/workspace/:id/events', (req, res) => {
+  const workspace = getWorkspace(req.params.id);
+  if (!workspace) return res.status(404).json({ success: false, error: 'Workspace not found' });
+  const { op, q } = req.query;
+  let events = q ? findEvents(req.params.id, q) : getEvents(req.params.id, op ?? null);
+  if (q && op) events = events.filter(e => e.op === op);
+  res.json({ success: true, workspaceId: req.params.id, count: events.length, events });
+});
+
+// GET /project/workspace/:id/jobs?system=bull
+//   Every background job / worker with name + file:line; optional system filter.
+router.get('/workspace/:id/jobs', (req, res) => {
+  const workspace = getWorkspace(req.params.id);
+  if (!workspace) return res.status(404).json({ success: false, error: 'Workspace not found' });
+  const jobs = getJobs(req.params.id, req.query.system ?? null);
+  res.json({ success: true, workspaceId: req.params.id, count: jobs.length, jobs });
+});
