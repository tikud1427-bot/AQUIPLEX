<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= bundle.title %> — Aquiplex</title>
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

  <%- include('partials/nav') %>

  <main class="px-account">
    <div class="px-narrow" style="max-width:820px;">

      <a href="/bundles" class="px-btn px-btn-ghost px-btn-sm" style="margin-bottom:22px;">← Back to projects</a>

      <div class="px-dash-head">
        <h1><%= bundle.title %></h1>
        <% if (bundle.goal) { %>
          <p><%= bundle.goal %></p>
        <% } %>
        <div style="display:flex; gap:8px; margin-top:14px; flex-wrap:wrap;">
          <span class="px-badge"><%= bundle.steps ? bundle.steps.length : 0 %> steps</span>
          <span class="status-pill <%= bundle.status === 'completed' ? 'completed' : (bundle.status === 'running' ? 'pending' : '') %>"><%= (bundle.status || 'draft') %></span>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:12px;">
        <% if (bundle.steps && bundle.steps.length) { %>
          <% bundle.steps.forEach(function(step, i) { %>
            <div class="px-card px-card-pad">
              <div class="px-stat-label">Step <%= i + 1 %></div>
              <h3 style="font-size:15.5px; margin-bottom:8px;"><%= step.title %></h3>
              <p style="font-size:13.5px; color:var(--px-text-2); line-height:1.65; margin:0;"><%= step.description %></p>
              <% if (step.resources && step.resources.length) { %>
                <div style="display:flex; flex-wrap:wrap; gap:7px; margin-top:12px;">
                  <% step.resources.forEach(function(r) { %>
                    <span class="px-badge"><%= r %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <div class="px-empty">No steps found for this project.</div>
        <% } %>
      </div>

    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
