<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- 🔥 THIS -->
    <title>Aqua Project Engine | Aquiplex</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body class="bundle-page">

    <%- include('partials/nav') %>


      <div class="hero">
        <h1>🌊 Aqua Project Engine</h1>
        <p>Turn any idea into a step-by-step AI-powered project plan 🚀</p>
      </div>
  <div class="bundle-box">

    <p style="font-size:13px; color:#94a3b8; text-align:center;">
      Enter any goal — like "start freelancing", "grow Instagram", or "learn coding"
    </p>

    <input id="goalInput" placeholder="What do you want to build? (e.g. YouTube channel, SaaS app, freelancing business)" />
    <button onclick="generateBundle()">🚀 Build Project</button>

    <div class="category-buttons">
      <button onclick="quick('Start a YouTube channel')">🎥 YouTuber</button>
      <button onclick="quick('Learn coding fast')">💻 Developer</button>
      <button onclick="quick('Learn video editing')">🎨 Editor</button>
    </div>

    <!-- 🔥 MOVE THIS HERE -->
    <p style="font-size:12px; color:#64748b; text-align:center; margin-top:10px;">
      Aquiplex will generate a step-by-step AI-powered project plan to help you achieve it faster 🚀
    </p>

  </div>
<div id="result"></div>

      <!-- FOOTER -->    

        <%- include("partials/footer") %>


<script>

  
  async function generateBundle(step = 1) {
  const goal = document.getElementById("goalInput").value.trim(); // ✅ MOVED HERE

  if (!goal) {
    alert("Please enter a goal");
    return;
  }

  console.log("Sending goal:", goal);

  // 🔄 Loading UI
  document.getElementById("result").innerHTML = `
    <div style="text-align:center; padding:30px;">
      <div class="spinner"></div>
      <p style="margin-top:10px; color:#94a3b8;">Generating your AI bundle...</p>
    </div>
  `;

  try {
    const res = await fetch(window.location.origin + "/generate-bundle", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ goal, step, answers })
    });

    const data = await res.json();
    console.log("Response:", data);

    if (data.error) {
      document.getElementById("result").innerHTML = `
        ❌ ${data.error}
        <br><br>
        <small>${data.raw || ""}</small>
      `;
      return;
    }

    if (data.type === "questions") {
      renderQuestions(data.questions);
    } else {
      render(data);
    }

  } catch (err) {
    console.error(err);
    document.getElementById("result").innerText = "❌ Failed to connect to server";
  }
}

function quick(text) {
  document.getElementById("goalInput").value = text;
  generateBundle();
}
  function render(data) {
  if (!data.steps || !Array.isArray(data.steps)) {
    document.getElementById("result").innerText = "❌ Invalid bundle format";
    return;
  }

  // ✅ SAVE FULL BUNDLE (FIXED)
  localStorage.setItem("aqua_bundle_full", JSON.stringify(data));
    let html = `
      <div class="bundle-header">
        <h2>${data.title || "Project Plan"}</h2>

        <div class="xp-box">
          ⚡ XP: <span id="xpValue">0</span> | 
          🏆 Level: <span id="levelValue">1</span>
        </div>

        <div style="background:#1e293b; border-radius:10px; height:10px; margin:10px 0;">
          <div id="progressFill" style="height:10px; width:0%; background:#22c55e; border-radius:10px;"></div>
        </div>

        <button onclick='saveBundle(${JSON.stringify(data).replace(/"/g, '&quot;')})' class="save-btn">
          💾 Save Bundle
        </button>

        <button onclick='shareBundle(${JSON.stringify(data).replace(/"/g, '&quot;')})' class="share-btn">
          🔗 Share
        </button>
      </div>
    `;

    data.steps.forEach(step => {
      html += `
        <div class="step">
          <h3>Step ${step.step || ""}: ${step.title || ""}</h3>
          <p>${step.description || ""}</p>

          <button onclick="completeStep(${step.step}, this)">
            ✅ Mark as Done
          </button>

          <div class="tools">
            ${(step.tools || []).map(t => {
              let name, url;

              if (typeof t === "object") {
                name = t.name;
                url = t.url;
              } else {
                name = t;
                const links = {
                  "PyCharm": "https://www.jetbrains.com/pycharm/",
                  "VS Code": "https://code.visualstudio.com/",
                  "Spyder": "https://www.spyder-ide.org/",
                  "W3Schools": "https://www.w3schools.com/",
                  "Real Python": "https://realpython.com/"
                };
                url = links[name] || `https://www.google.com/search?q=${encodeURIComponent(name)}`;
              }

              return `
                <div class="tool-card-mini recommended">
                  <img 
                    src="https://www.google.com/s2/favicons?sz=64&domain_url=${url}" 
                    onerror="this.src='/images/default-tool.png'"
                  />

                  <div class="tool-info">
                    <span>${name}</span>
                    <button class="use-btn" onclick="openTool('${url}')">Use</button>
                  </div>
                </div>
              `;
            }).join("")}
          </div>
        </div>
      `;
    });

    document.getElementById("result").innerHTML = html;
  }

  async function saveBundle(data) {
    try {
      const res = await fetch("/bundle/save", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          title: data.title,
          steps: data.steps
        })
      });

      const result = await res.json();

      if (result.success) {
        alert("✅ Bundle saved to workspace!");
      } else {
        alert("❌ Failed to save bundle");
      }

    } catch (err) {
      console.error(err);
      alert("❌ Error saving bundle");
    }
  }
  function renderQuestions(questions) {
    let html = "";

    for (let i = 0; i < questions.length; i++) {
      html += `
        <div style="margin: 15px 0;">
          <p style="color: white;">${questions[i]}</p>
          <input id="q${i}" placeholder="Your answer..." style="width:100%; padding:10px;" />
        </div>
      `;
    }

    html += `
      <button onclick="submitAnswers(${questions.length})">
        Continue 🚀
      </button>
    `;

    document.getElementById("result").innerHTML = html;
  }

  let answers = [];

  function submitAnswers(count) {
    answers = [];

    for (let i = 0; i < count; i++) {
      const value = document.getElementById(`q${i}`).value;
      answers.push(value);
    }

    console.log("Answers:", answers);

    // send again with step 2
    generateBundle(2);
  }
</script>


    <script>
    function openTool(url) {
      window.open(url, "_blank");
    }

      async function shareBundle(data){
        try {
          const res = await fetch("/bundle/save", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(data)
          });

          const result = await res.json();

          if(result.success){
            const url = window.location.origin + "/bundle/" + result.id;

            navigator.clipboard.writeText(url);
            alert("🔗 Link copied!");
          }

        } catch(err){
          alert("Error sharing bundle");
        }
      }

      let completedSteps = [];
      let xp = 0;
      let level = 1;

      function completeStep(step, btn){
        if(!completedSteps.includes(step)){
          completedSteps.push(step);

          // ❌ disable button after click
          if(btn){
            btn.disabled = true;
            btn.innerText = "✅ Completed";
          }

          xp += 10;
          level = Math.floor(xp / 50) + 1;

          showReward("+10 XP 🚀");
          updateXPUI();
        }

        localStorage.setItem("aqua_bundle_progress", JSON.stringify({
          title: document.querySelector(".bundle-header h2")?.innerText,
          completedSteps,
          xp,
          level,
          totalSteps: document.querySelectorAll(".step").length
        }));

        const total = document.querySelectorAll(".step").length;
        const progress = (completedSteps.length / total) * 100;

        const bar = document.getElementById("progressFill");
        bar.style.transition = "width 0.4s ease";
        bar.style.width = progress + "%";

        if(progress === 100){
          showReward("🎉 Project Completed!");
        }
      }
      function showResumeBox(data){
        // ❌ remove old if exists
        const old = document.getElementById("resume-box");
        if(old) old.remove();

        const div = document.createElement("div");
        div.id = "resume-box";

        div.innerHTML = `
          <div style="
            background:#0f172a;
            border:1px solid #1e293b;
            padding:15px;
            border-radius:10px;
            margin:20px;
            text-align:center;
          ">
            <h3>🔥 Continue your project</h3>
            <p>${data.title}</p>
            <p>${data.completedSteps.length}/${data.totalSteps} steps completed</p>

            <button onclick="resumeBundle()">
              ▶ Resume
            </button>
          </div>
        `;

        document.querySelector(".bundle-box").appendChild(div);
      }
      function resumeBundle(){
        const savedBundle = localStorage.getItem("aqua_bundle_full");
        const savedProgress = localStorage.getItem("aqua_bundle_progress");
        const resumeBox = document.getElementById("resume-box");
        if(resumeBox) resumeBox.remove();

        if(!savedBundle || !savedProgress){
          alert("No saved project found");
          return;
        }

        const bundleData = JSON.parse(savedBundle);
        const progressData = JSON.parse(savedProgress);

        // 🔥 Re-render bundle
        render(bundleData);

        // 🔥 Restore state AFTER render
        setTimeout(() => {
          restoreProgress(progressData);
        }, 100);
      }
      function updateXPUI(){
        const xpEl = document.getElementById("xpValue");
        const lvlEl = document.getElementById("levelValue");

        xpEl.innerText = xp;
        lvlEl.innerText = level;

        // 🔥 pulse effect
        xpEl.style.transform = "scale(1.2)";
        setTimeout(() => {
          xpEl.style.transform = "scale(1)";
        }, 200);
      }
      function restoreProgress(data){
        completedSteps = data.completedSteps || [];
        xp = data.xp || 0;
        level = data.level || 1;

        updateXPUI();

        const total = data.totalSteps || 1;
        const progress = (completedSteps.length / total) * 100;

        const bar = document.getElementById("progressFill");
        bar.style.transition = "width 0.4s ease";
        bar.style.width = progress + "%";

        // 🔥 Disable completed buttons
        document.querySelectorAll(".step button").forEach((btn, index) => {
          const stepNumber = index + 1;

          if(completedSteps.includes(stepNumber)){
            btn.disabled = true;
            btn.innerText = "✅ Completed";
          }
        });
      }
      function showReward(text){
        const div = document.createElement("div");
        div.innerText = text;

        div.style.position = "fixed";
        div.style.top = "20px";
        div.style.right = "20px";
        div.style.background = "#22c55e";
        div.style.color = "white";
        div.style.padding = "10px 15px";
        div.style.borderRadius = "8px";
        div.style.zIndex = "9999";

        document.body.appendChild(div);

        setTimeout(() => div.remove(), 2000);
      }
      window.addEventListener("load", () => {
        const saved = localStorage.getItem("aqua_bundle_progress");

        if(saved){
          const data = JSON.parse(saved);
          showResumeBox(data);
        }

        const task = setDailyTask();
        if(task){
          showDailyTask();
        }

        // 🔥 STREAK
        showStreak();
      });
        function generateDailyTask(bundle){
          if(!bundle || !bundle.steps) return null;

          const randomStep = bundle.steps[Math.floor(Math.random() * bundle.steps.length)];

          return `👉 Complete: ${randomStep.title}`;
        }
      function setDailyTask(){
        const today = new Date().toDateString();

        const existing = localStorage.getItem("aqua_daily_task"); // ✅ FIX

        if(existing){
          const parsed = JSON.parse(existing);
          if(parsed.date === today){
            return parsed.task;
          }
        }

        const bundleRaw = localStorage.getItem("aqua_bundle_full");
        if(!bundleRaw) return null;

        const bundle = JSON.parse(bundleRaw);
        const task = generateDailyTask(bundle);

        if(task){
          localStorage.setItem("aqua_daily_task", JSON.stringify({
            date: today,
            task
          }));
        }

        return task;
      }
      function showDailyTask(){
        const old = document.getElementById("daily-task");
        if(old) old.remove();

        const data = JSON.parse(localStorage.getItem("aqua_daily_task"));
        if(!data || !data.task) return;

        const doneDate = localStorage.getItem("aqua_daily_task_done");
        const today = new Date().toDateString();
        const isDone = doneDate === today;

        const div = document.createElement("div");
        div.id = "daily-task";

        div.innerHTML = `
          <div style="
            background:#020617;
            border:1px solid #1e293b;
            padding:15px;
            border-radius:10px;
            margin:20px;
            text-align:center;
          ">
            <h3>🧠 Today’s Task</h3>
            <p>${data.task}</p>

            <button onclick="completeDailyTask(this)" ${isDone ? "disabled" : ""}>
              ${isDone ? "🎉 Done!" : "✅ Mark as Done"}
            </button>
          </div>
        `;

        document.querySelector(".bundle-box").appendChild(div);
      }
        function completeDailyTask(btn){
          btn.innerText = "🎉 Done!";
          btn.disabled = true;

          xp += 20;
          updateXPUI();
          updateStreak();
          showStreak();

          // ✅ SAVE COMPLETION
          localStorage.setItem("aqua_daily_task_done", new Date().toDateString());

          showReward("🔥 Daily task completed +20 XP");
        }
      function updateStreak(){
        const today = new Date().toDateString();
        const last = localStorage.getItem("aqua_last_active");
        let streak = parseInt(localStorage.getItem("aqua_streak") || "0");

        if(last === today){
          return streak; // already counted today
        }

        const yesterday = new Date();
        yesterday.setDate(yesterday.getDate() - 1);

        if(last === yesterday.toDateString()){
          streak += 1; // continue streak
        } else {
          streak = 1; // reset streak
        }

        localStorage.setItem("aqua_streak", streak);
        localStorage.setItem("aqua_last_active", today);

        return streak;
      }
      function showStreak(){
        const streak = localStorage.getItem("aqua_streak") || 0;

        const div = document.createElement("div");

        div.innerHTML = `
          <div style="
            background:#020617;
            border:1px solid #1e293b;
            padding:10px;
            border-radius:10px;
            margin:10px 20px;
            text-align:center;
            color:#facc15;
            font-weight:bold;
          ">
            🔥 Streak: ${streak} day${streak == 1 ? "" : "s"}
          </div>
        `;

        document.querySelector(".bundle-box").appendChild(div);
      }
      // 🔥 AUTO RUN FROM HOME PAGE
      window.addEventListener("load", () => {
        const savedGoal = localStorage.getItem("aqua_goal");

        if (savedGoal) {
          document.getElementById("goalInput").value = savedGoal;

          // clear so it doesn't repeat
          localStorage.removeItem("aqua_goal");

          // 🚀 auto generate
          generateBundle();
        }
      });
      
    </script>
      


</body>
</html>