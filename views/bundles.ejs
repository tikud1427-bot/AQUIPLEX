<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- 🔥 THIS -->
    <title>AI Bundles | Aquiplex</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body class="bundle-page">

<h1>✨ AI Bundles</h1>

  <div class="bundle-box">

    <p style="font-size:13px; color:#94a3b8; text-align:center;">
      Enter any goal — like "start freelancing", "grow Instagram", or "learn coding"
    </p>

    <input id="goalInput" placeholder="e.g. Start a YouTube channel..." />
    <button onclick="generateBundle()">Generate Bundle</button>

    <div class="category-buttons">
      <button onclick="quick('Start a YouTube channel')">🎥 YouTuber</button>
      <button onclick="quick('Learn coding fast')">💻 Developer</button>
      <button onclick="quick('Learn video editing')">🎨 Editor</button>
    </div>

    <!-- 🔥 MOVE THIS HERE -->
    <p style="font-size:12px; color:#64748b; text-align:center; margin-top:10px;">
      Aquiplex will generate a step-by-step AI tool bundle to help you achieve it faster 🚀
    </p>

  </div>
<div id="result"></div>

<script>
async function generateBundle() {
  const goal = document.getElementById("goalInput").value.trim();

  if (!goal) {
    alert("Please enter a goal");
    return;
  }

  console.log("Sending goal:", goal);

  // 🔄 Loading UI
  document.getElementById("result").innerHTML = `
    <div style="text-align:center; padding:30px;">
      <div class="spinner"></div>
      <p style="margin-top:10px; color:#94a3b8;">Generating your AI bundle...</p>
    </div>
  `;

  try {
    const res = await fetch(window.location.origin + "/generate-bundle", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ goal })
    });

    const data = await res.json();
    console.log("Response:", data);

    if (data.error) {
      document.getElementById("result").innerHTML = `
        ❌ ${data.error}
        <br><br>
        <small>${data.raw || ""}</small>
      `;
      return;
    }

    render(data);

  } catch (err) {
    console.error(err);
    document.getElementById("result").innerText = "❌ Failed to connect to server";
  }
}

function quick(text) {
  document.getElementById("goalInput").value = text;
  generateBundle();
}

function render(data) {
  if (!data.steps || !Array.isArray(data.steps)) {
    document.getElementById("result").innerText = "❌ Invalid bundle format";
    return;
  }

  let html = `<h2>${data.title || "AI Bundle"}</h2>`;

  data.steps.forEach(step => {
    html += `
      <div class="step">
        <h3>Step ${step.step || ""}: ${step.title || ""}</h3>
        <p>${step.description || ""}</p>
        <div class="tools">
          ${(step.tools || []).map(t => `<span>${t}</span>`).join("")}
        </div>
      </div>
    `;
  });

  document.getElementById("result").innerHTML = html;
}
</script>
  
</body>
</html>