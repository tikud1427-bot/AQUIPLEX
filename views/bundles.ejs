<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AI Bundles | Aquiplex</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<h1>✨ AI Bundles</h1>

<div class="bundle-box">
  <input id="goalInput" placeholder="What do you want to do?" />
  <button onclick="generateBundle()">Generate Bundle</button>
</div>

<div class="suggestions">
  <button onclick="quick('Start a YouTube channel')">🎥 YouTuber</button>
  <button onclick="quick('Learn coding fast')">💻 Developer</button>
  <button onclick="quick('Learn video editing')">🎨 Editor</button>
</div>

<div id="result"></div>

<script>
async function generateBundle() {
  const goal = document.getElementById("goalInput").value.trim();

  if (!goal) {
    alert("Please enter a goal");
    return;
  }

  console.log("Sending goal:", goal);

  // 🔄 Loading UI
  document.getElementById("result").innerHTML = "⏳ Generating bundle...";

  try {
    const res = await fetch(window.location.origin + "/generate-bundle", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ goal })
    });

    const data = await res.json();
    console.log("Response:", data);

    if (data.error) {
      document.getElementById("result").innerHTML = `
        ❌ ${data.error}
        <br><br>
        <small>${data.raw || ""}</small>
      `;
      return;
    }

    render(data);

  } catch (err) {
    console.error(err);
    document.getElementById("result").innerText = "❌ Failed to connect to server";
  }
}

function quick(text) {
  document.getElementById("goalInput").value = text;
  generateBundle();
}

function render(data) {
  if (!data.steps || !Array.isArray(data.steps)) {
    document.getElementById("result").innerText = "❌ Invalid bundle format";
    return;
  }

  let html = `<h2>${data.title || "AI Bundle"}</h2>`;

  data.steps.forEach(step => {
    html += `
      <div class="step">
        <h3>Step ${step.step || ""}: ${step.title || ""}</h3>
        <p>${step.description || ""}</p>
        <div class="tools">
          ${(step.tools || []).map(t => `<span>${t}</span>`).join("")}
        </div>
      </div>
    `;
  });

  document.getElementById("result").innerHTML = html;
}
</script>

<style>
body {
  background: #0b1120;
  color: white;
  font-family: sans-serif;
  padding: 20px;
}

h1 {
  text-align: center;
  margin-bottom: 20px;
}

.bundle-box {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin-bottom: 15px;
}

.bundle-box input {
  padding: 12px;
  width: 60%;
  border-radius: 8px;
  border: none;
  outline: none;
}

.bundle-box button {
  padding: 12px 18px;
  border-radius: 8px;
  border: none;
  background: linear-gradient(135deg, #3b82f6, #06b6d4);
  color: white;
  cursor: pointer;
}

.suggestions {
  text-align: center;
  margin-bottom: 20px;
}

.suggestions button {
  margin: 5px;
  padding: 8px 12px;
  border-radius: 8px;
  border: none;
  background: #1f2937;
  color: white;
  cursor: pointer;
}

.step {
  background: #111827;
  padding: 15px;
  margin: 12px 0;
  border-radius: 12px;
  border: 1px solid #1f2937;
}

.step h3 {
  margin-bottom: 6px;
}

.tools span {
  background: #1f2937;
  padding: 5px 10px;
  margin-right: 5px;
  border-radius: 6px;
  font-size: 12px;
}
</style>

</body>
</html>