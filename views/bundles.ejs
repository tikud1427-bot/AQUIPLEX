<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Projects — Aquiplex</title>
  <meta name="description" content="Turn a goal into a plan Aqua executes — step by step, with memory and context.">
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
  <style>
    /* Projects (Aqua Project Engine) — restyled onto the px design system.
       Class names are preserved because the page's JS renders into them. */

    body.bundle-page { padding-top: 60px; }

    #app-root { max-width: var(--px-w-content); margin: 0 auto; padding: 0 var(--px-gutter); }

    .ape-hero { text-align: center; padding: clamp(40px, 8vw, 64px) 0 clamp(28px, 5vw, 40px); }
    .ape-hero h1 {
      font-family: var(--px-font-display);
      font-size: clamp(28px, 4.5vw, 42px);
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--px-text);
      margin: 0;
    }
    .ape-hero p { margin-top: 12px; color: var(--px-text-2); font-size: 15.5px; }
    .ape-hero em { font-style: normal; color: var(--px-accent-strong); }

    /* ── Goal input ── */
    .goal-card {
      max-width: 720px;
      margin: 0 auto 24px;
      background: var(--px-surface);
      border: 1px solid var(--px-line);
      border-radius: var(--px-radius-lg);
      padding: clamp(20px, 4vw, 28px);
      text-align: center;
    }
    .goal-card label {
      display: block;
      font-size: 14px;
      font-weight: 550;
      color: var(--px-text);
      margin-bottom: 14px;
    }
    .goal-card input {
      width: 100%;
      background: var(--px-bg);
      border: 1px solid var(--px-line-strong);
      border-radius: var(--px-radius-sm);
      color: var(--px-text);
      font-family: var(--px-font-sans);
      font-size: 14.5px;
      padding: 12px 14px;
      margin-bottom: 16px;
      outline: none;
      transition: border-color var(--px-t-fast) var(--px-ease);
    }
    .goal-card input:focus { border-color: var(--px-accent); }
    .goal-card input::placeholder { color: var(--px-text-3); }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--px-text);
      color: var(--px-bg);
      border: 0;
      border-radius: var(--px-radius-sm);
      font-family: var(--px-font-sans);
      font-size: 14px;
      font-weight: 500;
      padding: 11px 22px;
      cursor: pointer;
      transition: background var(--px-t-fast) var(--px-ease), transform var(--px-t-fast) var(--px-ease);
    }
    .btn-primary:hover { background: var(--px-text-2); }
    .btn-primary:active { transform: scale(0.985); }
    .btn-primary:disabled { opacity: 0.55; cursor: default; }

    .quick-btns { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 16px; }
    .quick-btn {
      background: transparent;
      border: 1px solid var(--px-line-strong);
      border-radius: 999px;
      color: var(--px-text-2);
      font-family: var(--px-font-sans);
      font-size: 13px;
      padding: 7px 14px;
      cursor: pointer;
      transition: border-color var(--px-t-fast) var(--px-ease), color var(--px-t-fast) var(--px-ease), background var(--px-t-fast) var(--px-ease);
    }
    .quick-btn:hover { border-color: var(--px-text-3); color: var(--px-text); background: var(--px-surface-2); }

    /* ── Questions ── */
    .questions-card {
      max-width: 720px;
      margin: 0 auto clamp(28px, 5vw, 40px);
      background: var(--px-surface);
      border: 1px solid var(--px-line);
      border-radius: var(--px-radius-lg);
      padding: clamp(20px, 4vw, 28px);
    }
    .questions-card h3 { font-size: 16px; font-weight: 600; color: var(--px-text); margin: 0 0 18px; }
    .q-item { margin-bottom: 16px; }
    .q-item label { display: block; font-size: 13.5px; font-weight: 500; color: var(--px-text-2); margin-bottom: 6px; }
    .q-item input, .q-item textarea, .q-item select {
      width: 100%;
      background: var(--px-bg);
      border: 1px solid var(--px-line-strong);
      border-radius: var(--px-radius-sm);
      color: var(--px-text);
      font-family: var(--px-font-sans);
      font-size: 14px;
      padding: 10px 12px;
      outline: none;
    }
    .q-item input:focus, .q-item textarea:focus, .q-item select:focus { border-color: var(--px-accent); }

    /* ── Dashboard layout ── */
    .dashboard {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 20px;
      padding-bottom: calc(clamp(64px, 11vw, 96px) + env(safe-area-inset-bottom));
    }
    @media (max-width: 860px) {
      .dashboard { grid-template-columns: 1fr; }
    }

    .sidebar { display: flex; flex-direction: column; gap: 14px; }
    .sidebar-card {
      background: var(--px-surface);
      border: 1px solid var(--px-line);
      border-radius: var(--px-radius);
      padding: 18px;
    }
    .sidebar-card h4 {
      font-size: 11.5px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--px-text-3);
      margin: 0 0 14px;
    }

    /* progress ring */
    .progress-ring-wrap { position: relative; text-align: center; margin-bottom: 14px; }
    .progress-ring-wrap svg { transform: rotate(-90deg); }
    .progress-ring-wrap .ring-bg { fill: none; stroke: var(--px-surface-2); stroke-width: 8; }
    .progress-ring-wrap .ring-fill {
      fill: none;
      stroke: var(--px-accent);
      stroke-width: 8;
      stroke-linecap: round;
      stroke-dasharray: 226;
      stroke-dashoffset: 226;
      transition: stroke-dashoffset 500ms var(--px-ease);
    }
    .ring-pct {
      position: absolute;
      top: 26px; left: 0; right: 0;
      font-size: 18px;
      font-weight: 600;
      color: var(--px-text);
    }
    .ring-label { font-size: 12px; color: var(--px-text-3); margin-top: 6px; }

    .step-nav-list { list-style: none; margin: 14px 0 0; padding: 0; }
    .step-nav-item {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 7px 8px;
      border-radius: var(--px-radius-sm);
      cursor: pointer;
      font-size: 13px;
      color: var(--px-text-2);
      transition: background var(--px-t-fast) var(--px-ease), color var(--px-t-fast) var(--px-ease);
    }
    .step-nav-item:hover { background: var(--px-surface-2); color: var(--px-text); }
    .step-nav-item.active { background: var(--px-surface-2); color: var(--px-text); }
    .step-nav-label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .step-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
      background: var(--px-line-strong);
    }
    .step-dot.done    { background: var(--px-success); }
    .step-dot.running { background: var(--px-accent); }
    .step-dot.failed  { background: var(--px-danger); }

    /* memory + context */
    .memory-entry {
      padding: 8px 0;
      border-bottom: 1px solid var(--px-line);
      font-size: 12.5px;
      line-height: 1.5;
    }
    .memory-entry:last-child { border-bottom: 0; }
    .mem-key   { color: var(--px-accent-strong); font-weight: 550; }
    .mem-value { color: var(--px-text-2); }

    /* ── Main panel ── */
    .main-panel { min-width: 0; }
    .project-header {
      background: var(--px-surface);
      border: 1px solid var(--px-line);
      border-radius: var(--px-radius-lg);
      padding: clamp(18px, 3.5vw, 24px) clamp(18px, 4vw, 26px);
      margin-bottom: 16px;
    }
    .project-header h2 {
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--px-text);
      margin: 0 0 6px;
    }
    .project-goal { color: var(--px-text-2); font-size: 14px; line-height: 1.6; }
    .project-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
    .meta-pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border: 1px solid var(--px-line-strong);
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 12px;
      color: var(--px-text-2);
    }
    .meta-pill .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--px-text-3); }
    .meta-pill .dot.blue   { background: var(--px-accent); }
    .meta-pill .dot.purple { background: var(--px-accent-strong); }

    /* ── Step cards ── */
    .step-card {
      background: var(--px-surface);
      border: 1px solid var(--px-line);
      border-radius: var(--px-radius-lg);
      margin-bottom: 14px;
      overflow: hidden;
      transition: border-color var(--px-t) var(--px-ease);
    }
    .step-card:hover { border-color: var(--px-line-strong); }
    .step-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 14px clamp(14px, 3vw, 20px);
      cursor: pointer;
      min-height: 44px;
    }
    .step-card-title { display: flex; align-items: center; gap: 12px; min-width: 0; }
    .step-num {
      flex-shrink: 0;
      width: 26px; height: 26px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--px-line-strong);
      border-radius: 50%;
      font-size: 12px;
      font-weight: 600;
      color: var(--px-text-2);
    }
    .step-card-title p { font-size: 12px; color: var(--px-text-3); margin: 2px 0 0; }
    .step-card-title h3 {
      font-size: 14.5px;
      font-weight: 550;
      color: var(--px-text);
      margin: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .step-badge {
      flex-shrink: 0;
      font-size: 10.5px;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 999px;
      padding: 3px 10px;
      border: 1px solid var(--px-line-strong);
      color: var(--px-text-3);
    }
    .badge-pending { border-color: var(--px-line-strong); color: var(--px-text-3); }
    .badge-running { border-color: color-mix(in srgb, var(--px-accent) 50%, transparent); color: var(--px-accent-strong); }
    .badge-done    { border-color: color-mix(in srgb, var(--px-success) 50%, transparent); color: var(--px-success); }
    .badge-failed  { border-color: color-mix(in srgb, var(--px-danger) 50%, transparent); color: var(--px-danger); }

    .step-card-body { padding: 0 clamp(14px, 3vw, 20px) clamp(16px, 3vw, 20px); }
    .step-desc { color: var(--px-text-2); font-size: 13.5px; line-height: 1.65; margin-bottom: 14px; }
    .step-duration { font-size: 12px; color: var(--px-text-3); }

    .btn-execute, .btn-re-execute {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border-radius: var(--px-radius-sm);
      font-family: var(--px-font-sans);
      font-size: 13px;
      font-weight: 500;
      padding: 8px 16px;
      cursor: pointer;
      transition: background var(--px-t-fast) var(--px-ease), border-color var(--px-t-fast) var(--px-ease);
    }
    .btn-execute { background: var(--px-accent); border: 1px solid var(--px-accent); color: var(--px-accent-ink); }
    .btn-execute:hover { background: var(--px-accent-strong); border-color: var(--px-accent-strong); }
    .btn-execute:disabled { opacity: 0.55; cursor: default; }
    .btn-re-execute { background: transparent; border: 1px solid var(--px-line-strong); color: var(--px-text-2); }
    .btn-re-execute:hover { border-color: var(--px-text-3); color: var(--px-text); background: var(--px-surface-2); }
    @media (pointer: coarse) {
      .btn-execute, .btn-re-execute, .btn-primary, .quick-btn { min-height: 44px; }
    }

    .output-area {
      background: var(--px-bg);
      border: 1px solid var(--px-line);
      border-radius: var(--px-radius);
      padding: 16px 18px;
      margin-top: 14px;
    }
    .output-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--px-text-3);
      margin-bottom: 10px;
    }
    .output-content {
      color: var(--px-text-2);
      font-size: 13.5px;
      line-height: 1.7;
      white-space: pre-wrap;
      word-break: break-word;
      max-height: 420px;
      overflow-y: auto;
    }

    .insights-row, .hints-row { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 12px; }
    .insight-pill {
      border: 1px solid var(--px-line-strong);
      border-radius: 999px;
      padding: 3px 11px;
      font-size: 11.5px;
      color: var(--px-text-2);
    }

    /* spinner */
    .spinner {
      display: inline-block;
      width: 14px; height: 14px;
      border: 2px solid var(--px-line-strong);
      border-top-color: var(--px-accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: -2px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* toast (page-local variants layered on platform toast) */
    .toast {
      position: fixed;
      bottom: 24px; left: 50%;
      transform: translateX(-50%);
      background: var(--px-surface);
      border: 1px solid var(--px-line-strong);
      border-radius: var(--px-radius);
      box-shadow: var(--px-shadow);
      color: var(--px-text);
      font-size: 13.5px;
      padding: 11px 18px;
      z-index: 10000;
      animation: toastIn 0.25s var(--px-ease);
    }
    .toast.success { border-color: color-mix(in srgb, var(--px-success) 50%, transparent); color: var(--px-success); }
    .toast.error   { border-color: color-mix(in srgb, var(--px-danger) 50%, transparent);  color: var(--px-danger); }
    .toast.info    { border-color: color-mix(in srgb, var(--px-accent) 50%, transparent);  color: var(--px-accent-strong); }
    @keyframes toastIn { from { opacity: 0; transform: translate(-50%, 10px); } to { opacity: 1; transform: translate(-50%, 0); } }

    /* skeleton */
    .skeleton {
      background: linear-gradient(90deg, var(--px-surface-2) 25%, var(--px-surface) 50%, var(--px-surface-2) 75%);
      background-size: 400% 100%;
      animation: shimmer 1.4s ease infinite;
      border-radius: var(--px-radius-sm);
    }
    @keyframes shimmer { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }
  </style>
</head>
<body class="px-page bundle-page">


  <%- include('partials/nav') %>

  <!-- SVG gradient defs (hidden) -->
  <svg width="0" height="0" style="position:absolute">
    <defs>
      <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%"   stop-color="#38bdf8"/>
        <stop offset="100%" stop-color="#818cf8"/>
      </linearGradient>
    </defs>
  </svg>

  <div class="ape-hero">
    <h1>Projects</h1>
    <p>Describe a goal. Aqua plans it, then <em>executes every step</em> — with memory of your decisions.</p>
  </div>

  <div id="app-root">

    <!-- ── PHASE 1: Goal input ──────────────────────────────────── -->
    <div id="phase-goal">
      <div class="goal-card">
        <label>What do you want to build?</label>
        <input id="goalInput"
               placeholder="e.g. Launch a SaaS app, Grow a YouTube channel, Start freelancing" />
        <br/>
        <button class="btn-primary" onclick="startGenerate()">
          Build project plan
        </button>
        <div class="quick-btns">
          <button class="quick-btn" onclick="quick('Start a YouTube channel')">YouTube channel</button>
          <button class="quick-btn" onclick="quick('Build a SaaS product from scratch')">SaaS product</button>
          <button class="quick-btn" onclick="quick('Launch a freelancing business')">Freelancing</button>
          <button class="quick-btn" onclick="quick('Learn full-stack development fast')">Full-stack dev</button>
        </div>
      </div>

      <!-- resume banner (shown if localStorage has a saved bundle) -->
      <div id="resume-banner" style="display:none; max-width:720px; margin: 0 auto 24px;">
        <div class="sidebar-card" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
          <div>
            <div style="font-size:11px; color:var(--px-accent-strong); font-weight:600; letter-spacing:0.07em; margin-bottom:4px;">CONTINUE WHERE YOU LEFT OFF</div>
            <div id="resume-title" style="color:var(--px-text); font-weight:600;"></div>
            <div id="resume-meta"  style="color:var(--px-text-3); font-size:12.5px;"></div>
          </div>
          <button class="btn-execute" style="font-size:13px; padding:8px 16px;" onclick="resumeProject()">
            Resume
          </button>
        </div>
      </div>
    </div>

    <!-- ── PHASE 2: Questions ───────────────────────────────────── -->
    <div id="phase-questions" style="display:none;">
      <div class="questions-card">
        <h3>Quick context — 30 seconds, much better results</h3>
        <div id="questions-list"></div>
        <button class="btn-primary" onclick="submitAnswers()">
          Continue
        </button>
      </div>
    </div>

    <!-- ── PHASE 3: Execution Dashboard ────────────────────────── -->
    <div id="phase-dashboard" class="dashboard" style="display:none;">

      <!-- Sidebar -->
      <aside class="sidebar">

        <!-- Progress ring -->
        <div class="sidebar-card">
          <h4>Progress</h4>
          <div class="progress-ring-wrap">
            <svg width="90" height="90" viewBox="0 0 90 90">
              <circle class="ring-bg"   cx="45" cy="45" r="36"/>
              <circle class="ring-fill" cx="45" cy="45" r="36" id="ringFill"/>
            </svg>
            <div class="ring-pct" id="ringPct">0%</div>
            <div class="ring-label" id="ringLabel">0 of 0 steps</div>
          </div>

          <ul class="step-nav-list" id="stepNavList"></ul>
        </div>

        <!-- Memory panel -->
        <div class="sidebar-card" id="memoryPanel" style="display:none;">
          <h4>Project memory</h4>
          <div id="memoryEntries"></div>
        </div>

        <!-- Context summary -->
        <div class="sidebar-card" id="contextPanel" style="display:none;">
          <h4>Context summary</h4>
          <div id="contextText" style="font-size:12.5px; color:var(--px-text-2); line-height:1.6;"></div>
        </div>

        <!-- Actions -->
        <div class="sidebar-card">
          <h4>Actions</h4>
          <button class="btn-primary" style="width:100%; justify-content:center; margin-bottom:8px;"
                  onclick="saveCurrentBundle()">
            Save project
          </button>
          <button class="btn-primary" style="width:100%; justify-content:center; margin-bottom:8px;"
        onclick="handleBuildWebsite()">
  Build website
</button>
          <button class="quick-btn" style="width:100%; justify-content:center;"
                  onclick="resetAll()">
            New project
          </button>
        </div>

      </aside>

      <!-- Main panel -->
      <main class="main-panel">

        <!-- Project header -->
        <div class="project-header">
          <h2 id="dashTitle">Project</h2>
          <div class="project-goal" id="dashGoal"></div>
          <div class="project-meta">
            <span class="meta-pill"><span class="dot blue"></span><span id="metaSteps">— steps</span></span>
            <span class="meta-pill"><span class="dot"></span><span id="metaStatus">Draft</span></span>
            <span class="meta-pill"><span class="dot purple"></span><span id="metaTime">Just created</span></span>
          </div>
        </div>

        <!-- Step cards -->
        <div id="stepCards"></div>

      </main>
    </div><!-- /phase-dashboard -->

  </div><!-- /app-root -->

  <%- include("partials/footer") %>

<script>
// ════════════════════════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════════════════════════
let STATE = {
  goal:      "",
  answers:   [],
  questions: [],
  bundle:    null,     // { _id?, title, goal, steps[], outputs[], progress[], memory{}, contextSummary }
  running:   false,
};

// ════════════════════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════════════════════
window.addEventListener("load", () => {
  // Auto-fill goal from home page shortcut
  const savedGoal = localStorage.getItem("aqua_goal");
  if (savedGoal) {
    document.getElementById("goalInput").value = savedGoal;
    localStorage.removeItem("aqua_goal");
  }

  // Show resume banner if we have a persisted bundle
  const cached = getCachedBundle();
  if (cached) showResumeBanner(cached);
});

// ════════════════════════════════════════════════════════════════════
// PHASE 1 — GOAL INPUT
// ════════════════════════════════════════════════════════════════════
function quick(text) {
  document.getElementById("goalInput").value = text;
  startGenerate();
}

async function startGenerate() {
  const goal = document.getElementById("goalInput").value.trim();
  if (!goal) { toast("Please enter a goal", "error"); return; }
  STATE.goal = goal;
  STATE.answers = [];

  showPhase("questions");
  showLoadingInPhase("questions");

  try {
    const res  = await apiFetch("/generate-bundle", "POST", { goal, step: 1 });
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    if (data.type === "questions") {
      STATE.questions = data.questions;
      renderQuestions(data.questions);
    } else {
      // No questions — go straight to dashboard
      await loadDashboard(data);
    }
  } catch (err) {
    toast("Failed to connect: " + err.message, "error");
    showPhase("goal");
  }
}

function renderQuestions(questions) {
  const list = document.getElementById("questions-list");
  list.innerHTML = questions.map((q, i) => `
    <div class="q-item">
      <p>${i + 1}. ${escHtml(q)}</p>
      <input id="q${i}" placeholder="Your answer…" />
    </div>
  `).join("");
}

async function submitAnswers() {
  const answers = STATE.questions.map((_, i) => {
    const el = document.getElementById(`q${i}`);
    return el ? el.value.trim() : "";
  });
  STATE.answers = answers;

  showPhase("questions");
  showLoadingInPhase("questions");

  try {
    const res  = await apiFetch("/generate-bundle", "POST", { goal: STATE.goal, step: 2, answers });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    await loadDashboard(data);
  } catch (err) {
    toast("Plan generation failed: " + err.message, "error");
    showPhase("goal");
  }
}

// ════════════════════════════════════════════════════════════════════
// PHASE 3 — DASHBOARD
// ════════════════════════════════════════════════════════════════════
async function loadDashboard(data) {
  // data may be a fresh plan OR a resumed bundle
  const isBundle = !!data._id;

  STATE.bundle = {
    _id:            data._id    || null,
    title:          data.title  || "Untitled Project",
    goal:           data.goal   || STATE.goal,
    steps:          data.steps  || [],
    outputs:        data.outputs   || [],
    progress:       data.progress  || (data.steps || []).map((_, i) => ({ step: i, status: "pending" })),
    decisions:      data.decisions || [],
    memory:         data.memory    || {},
    contextSummary: data.contextSummary || "",
  };

  // Auto-save if it's a fresh plan (not yet in DB)
  if (!isBundle && STATE.bundle.steps.length) {
    await autoSaveBundle();
  }

  // Persist to localStorage
  setCachedBundle(STATE.bundle);

  // Render
  renderDashboard();
  showPhase("dashboard");
}

function renderDashboard() {
  const b = STATE.bundle;

  // Header
  document.getElementById("dashTitle").textContent = b.title;
  document.getElementById("dashGoal").textContent  = b.goal ? `Goal: ${b.goal}` : "";
  document.getElementById("metaSteps").textContent = `${b.steps.length} steps`;
  updateStatusMeta();

  // Step cards
  const container = document.getElementById("stepCards");
  container.innerHTML = b.steps.map((step, i) => buildStepCard(step, i)).join("");

  // Restore outputs
  b.outputs.forEach((o) => renderOutputIntoCard(o.stepIndex, o));

  // Sidebar
  updateSidebarNav();
  updateProgress();
  updateMemoryPanel();
  updateContextPanel();

  // Auto-open first non-completed step
  const firstPending = b.progress.findIndex((p) => p.status !== "completed");
  if (firstPending >= 0) openStepCard(firstPending);
  else if (b.steps.length) openStepCard(0);
}

function buildStepCard(step, i) {
  const prog   = getStepProgress(i);
  const status = prog ? prog.status : "pending";
  const cardClass = status === "completed" ? "done" : status === "in-progress" ? "active" : "";
  const numClass  = status === "completed" ? "done"   : status === "in-progress" ? "running" : "";
  const badge     = badgeHTML(status);

  return `
    <div class="step-card ${cardClass}" id="card-${i}">
      <div class="step-card-header" onclick="toggleStepCard(${i})">
        <div class="step-num ${numClass}">${status === "completed" ? "✓" : i + 1}</div>
        <div class="step-card-title">
          <h3>${escHtml(step.title)}</h3>
          <p>Step ${i + 1} of ${STATE.bundle.steps.length}</p>
        </div>
        ${badge}
      </div>
      <div class="step-card-body" id="body-${i}">
        <div class="step-desc">${escHtml(step.description || "")}</div>
        <div id="output-area-${i}"></div>
        <div style="margin-top:14px;">
          <button class="btn-execute" id="btn-exec-${i}" onclick="executeStep(${i})">
            Execute step ${i + 1}
          </button>
        </div>
      </div>
    </div>
  `;
}

function badgeHTML(status) {
  const map = {
    pending:     ["badge-pending",  "Pending"],
    "in-progress": ["badge-running","Running"],
    completed:   ["badge-done",    "Done"],
    failed:      ["badge-failed",  "Failed"],
  };
  const [cls, label] = map[status] || map.pending;
  return `<span class="step-badge ${cls}" id="badge-${status}">${label}</span>`;
}

function toggleStepCard(i) { openStepCard(i); }
function openStepCard(i) {
  document.querySelectorAll(".step-card-body").forEach((el, idx) => {
    el.classList.toggle("open", idx === i);
  });
  document.querySelectorAll(".step-card").forEach((el, idx) => {
    el.classList.toggle("active", idx === i);
  });
  updateSidebarNav(i);
}

// ════════════════════════════════════════════════════════════════════
// EXECUTION ENGINE
// ════════════════════════════════════════════════════════════════════
async function executeStep(stepIndex) {
  if (STATE.running) { toast("A step is already running", "info"); return; }
  if (!STATE.bundle._id) { toast("Bundle not saved yet", "error"); return; }

  STATE.running = true;

  // UI — set running state
  const btn  = document.getElementById(`btn-exec-${stepIndex}`);
  const card = document.getElementById(`card-${stepIndex}`);
  if (btn)  { btn.disabled = true; btn.innerHTML = `<span class="spinner"></span> Executing…`; }
  if (card) { card.classList.add("active"); }

  // Update badge
  setBadge(stepIndex, "in-progress");

  // Show skeleton output
  const outputArea = document.getElementById(`output-area-${stepIndex}`);
  outputArea.innerHTML = `
    <div class="output-area">
      <div class="output-label">AI OUTPUT</div>
      <div class="output-content skeleton" style="min-height:120px;"></div>
    </div>
  `;

  try {
    const res  = await apiFetch("/execute-step", "POST", {
      bundleId:  STATE.bundle._id,
      stepIndex,
    });
    const data = await res.json();
    if (!res.ok || data.error) throw new Error(data.error || data.message || "Execution failed");

    // Merge returned state into local STATE
    mergeExecutionResult(stepIndex, data);

    // Render output
    renderOutputIntoCard(stepIndex, {
      content:       data.output,
      keyInsights:   data.keyInsights,
      nextStepHints: data.nextStepHints,
      durationMs:    data.durationMs,
      title:         STATE.bundle.steps[stepIndex].title,
    });

    // Update sidebar + progress
    updateSidebarNav();
    updateProgress();
    updateMemoryPanel();
    updateContextPanel();

    // Mark card as done
    setBadge(stepIndex, "completed");
    if (card) { card.classList.remove("active"); card.classList.add("done"); }

    // Auto-open next step
    const next = stepIndex + 1;
    if (next < STATE.bundle.steps.length) {
      setTimeout(() => openStepCard(next), 400);
    }

    toast(`Step ${stepIndex + 1} complete ✓`, "success");

  } catch (err) {
    console.error("executeStep error:", err);
    setBadge(stepIndex, "failed");
    outputArea.innerHTML = `
      <div class="output-area">
        <div class="output-label" style="color:var(--px-danger);">EXECUTION FAILED</div>
        <div class="output-content" style="color:var(--px-danger);">${escHtml(err.message)}</div>
      </div>
    `;
    toast("Execution failed: " + err.message, "error");
  } finally {
    STATE.running = false;
    if (btn) {
      const prog = getStepProgress(stepIndex);
      const isDone = prog && prog.status === "completed";
      btn.disabled = false;
      btn.innerHTML = isDone
        ? `Re-execute step ${stepIndex + 1}`
        : `Execute step ${stepIndex + 1}`;
    }
    // Persist updated state to localStorage
    setCachedBundle(STATE.bundle);
  }
}

function renderOutputIntoCard(stepIndex, outputData) {
  const outputArea = document.getElementById(`output-area-${stepIndex}`);
  if (!outputArea) return;

  const durationSec = outputData.durationMs ? (outputData.durationMs / 1000).toFixed(1) : null;

  const insightPills = (outputData.keyInsights || []).map(
    (ins) => `<span class="insight-pill">${escHtml(ins)}</span>`
  ).join("");

  const hints = outputData.nextStepHints || [];
  const hintsBlock = hints.length ? `
    <div class="hints-row">
      <p>↳ Refinements for next step</p>
      <ul>${hints.map((h) => `<li>${escHtml(h)}</li>`).join("")}</ul>
    </div>
  ` : "";

  outputArea.innerHTML = `
    <div class="output-area">
      <div class="output-label">AI OUTPUT — ${escHtml(outputData.title || "")}</div>
      <div class="output-content" id="out-content-${stepIndex}">${formatOutput(outputData.content)}</div>
      ${insightPills ? `<div class="insights-row">${insightPills}</div>` : ""}
      ${hintsBlock}
      ${durationSec ? `<div class="step-duration">Generated in ${durationSec}s</div>` : ""}
    </div>
  `;
}

// ════════════════════════════════════════════════════════════════════
// STATE MERGE
// ════════════════════════════════════════════════════════════════════
function mergeExecutionResult(stepIndex, data) {
  const b = STATE.bundle;

  // Update progress entry
  const prog = b.progress.find((p) => p.step === stepIndex);
  if (prog) prog.status = "completed";
  else b.progress.push({ step: stepIndex, status: "completed" });

  // Update outputs
  b.outputs = b.outputs.filter((o) => o.stepIndex !== stepIndex);
  b.outputs.push({
    stepIndex,
    title:         b.steps[stepIndex].title,
    content:       data.output,
    keyInsights:   data.keyInsights   || [],
    nextStepHints: data.nextStepHints || [],
    durationMs:    data.durationMs    || 0,
    executedAt:    new Date().toISOString(),
  });

  // Merge memory
  if (data.memory) Object.assign(b.memory, data.memory);

  // Context summary
  if (data.contextSummary) b.contextSummary = data.contextSummary;
}

// ════════════════════════════════════════════════════════════════════
// SIDEBAR & PROGRESS
// ════════════════════════════════════════════════════════════════════
function updateSidebarNav(activeIdx) {
  const b    = STATE.bundle;
  const list = document.getElementById("stepNavList");
  if (!list) return;

  list.innerHTML = b.steps.map((step, i) => {
    const prog   = getStepProgress(i);
    const status = prog ? prog.status : "pending";
    const dotCls = status === "completed" ? "done" : status === "in-progress" ? "active" : "";
    const lblCls = status === "completed" ? "done" : i === activeIdx ? "active" : "";
    const icon   = status === "completed" ? "✓" : status === "in-progress" ? "…" : i + 1;
    return `
      <li class="step-nav-item ${i === activeIdx ? "active" : ""}" onclick="openStepCard(${i}); toggleStepCard(${i})">
        <div class="step-dot ${dotCls}">${icon}</div>
        <span class="step-nav-label ${lblCls}">${escHtml(step.title)}</span>
      </li>
    `;
  }).join("");
}

function updateProgress() {
  const b    = STATE.bundle;
  const done = b.progress.filter((p) => p.status === "completed").length;
  const total = b.steps.length;
  const pct   = total ? Math.round((done / total) * 100) : 0;

  // Ring
  const CIRCUMFERENCE = 226;
  const fill = document.getElementById("ringFill");
  if (fill) fill.style.strokeDashoffset = CIRCUMFERENCE - (pct / 100) * CIRCUMFERENCE;

  const ringPct = document.getElementById("ringPct");
  if (ringPct) ringPct.textContent = pct + "%";

  const ringLabel = document.getElementById("ringLabel");
  if (ringLabel) ringLabel.textContent = `${done} of ${total} steps`;

  updateStatusMeta(done, total);
}

function updateStatusMeta(done, total) {
  const b = STATE.bundle;
  const statusEl = document.getElementById("metaStatus");
  if (!statusEl) return;
  const allDone = done !== undefined && done === total && total > 0;
  statusEl.textContent = allDone ? "Completed ✓" : done > 0 ? "In progress" : "Draft";
}

function updateMemoryPanel() {
  const b      = STATE.bundle;
  const panel  = document.getElementById("memoryPanel");
  const entries = document.getElementById("memoryEntries");
  if (!panel || !entries) return;

  const keys = Object.keys(b.memory || {});
  if (!keys.length) { panel.style.display = "none"; return; }

  panel.style.display = "block";
  entries.innerHTML = keys.map((k) => `
    <div class="memory-entry">
      <span class="mem-key">${escHtml(k)}</span>
      <span class="mem-value">${escHtml(b.memory[k])}</span>
    </div>
  `).join("");
}

function updateContextPanel() {
  const b      = STATE.bundle;
  const panel  = document.getElementById("contextPanel");
  const text   = document.getElementById("contextText");
  if (!panel || !text) return;

  if (!b.contextSummary) { panel.style.display = "none"; return; }
  panel.style.display = "block";
  text.textContent    = b.contextSummary;
}

function setBadge(stepIndex, status) {
  const card = document.getElementById(`card-${stepIndex}`);
  if (!card) return;
  const badgeEl = card.querySelector(".step-badge");
  if (!badgeEl) return;
  const map = {
    pending:       ["badge-pending",  "Pending"],
    "in-progress": ["badge-running",  "Running"],
    completed:     ["badge-done",     "Done"],
    failed:        ["badge-failed",   "Failed"],
  };
  const [cls, label] = map[status] || map.pending;
  badgeEl.className  = `step-badge ${cls}`;
  badgeEl.textContent = label;

  // Update step num icon
  const numEl = card.querySelector(".step-num");
  if (numEl) {
    numEl.className  = `step-num ${status === "completed" ? "done" : status === "in-progress" ? "running" : ""}`;
    numEl.textContent = status === "completed" ? "✓" : stepIndex + 1;
  }
}

function getStepProgress(i) {
  return (STATE.bundle.progress || []).find((p) => p.step === i);
}

// ════════════════════════════════════════════════════════════════════
// SAVE / RESUME
// ════════════════════════════════════════════════════════════════════
async function autoSaveBundle() {
  try {
    const b   = STATE.bundle;
    const res = await apiFetch("/bundle/save", "POST", {
      title:   b.title,
      goal:    b.goal,
      answers: b.answers || STATE.answers,
      steps:   b.steps,
    });
    const data = await res.json();
    if (data.success) {
      STATE.bundle._id = data.id;
      toast("Project saved", "success");
    }
  } catch (err) {
    console.warn("Auto-save failed:", err.message);
  }
}

async function saveCurrentBundle() {
  if (STATE.bundle._id) {
    toast("Already saved", "info");
    return;
  }
  await autoSaveBundle();
}

function showResumeBanner(cached) {
  const banner    = document.getElementById("resume-banner");
  const titleEl   = document.getElementById("resume-title");
  const metaEl    = document.getElementById("resume-meta");
  if (!banner || !cached) return;

  const done  = (cached.progress || []).filter((p) => p.status === "completed").length;
  const total = (cached.steps   || []).length;

  titleEl.textContent = cached.title || "Untitled Project";
  metaEl.textContent  = `${done} of ${total} steps completed`;
  banner.style.display = "block";
}

async function resumeProject() {
  const cached = getCachedBundle();
  if (!cached) return;

  if (cached._id) {
    // Fetch latest state from server
    try {
      const res  = await apiFetch(`/resume/${cached._id}`, "GET");
      const data = await res.json();
      if (data.success) {
        await loadDashboard(data.bundle);
        return;
      }
    } catch (_) {}
  }
  // Fallback to cached state
  await loadDashboard(cached);
}

// ════════════════════════════════════════════════════════════════════
// PHASE CONTROLLER
// ════════════════════════════════════════════════════════════════════
function showPhase(phase) {
  document.getElementById("phase-goal").style.display      = phase === "goal"      ? "" : "none";
  document.getElementById("phase-questions").style.display = phase === "questions" ? "" : "none";
  document.getElementById("phase-dashboard").style.display = phase === "dashboard" ? "" : "none";
}

function showLoadingInPhase(phase) {
  if (phase === "questions") {
    document.getElementById("questions-list").innerHTML = `
      <div style="text-align:center; padding:28px 0;">
        <span class="spinner" style="width:28px;height:28px;border-width:3px;"></span>
        <p style="margin-top:12px; color:var(--px-text-3);">Generating your plan…</p>
      </div>
    `;
  }
}

function resetAll() {
  STATE = { goal: "", answers: [], questions: [], bundle: null, running: false };
  localStorage.removeItem("aqua_bundle_cache");
  document.getElementById("goalInput").value = "";
  showPhase("goal");
}

// ════════════════════════════════════════════════════════════════════
// CACHE HELPERS
// ════════════════════════════════════════════════════════════════════
function getCachedBundle() {
  try {
    const raw = localStorage.getItem("aqua_bundle_cache");
    return raw ? JSON.parse(raw) : null;
  } catch { return null; }
}

function setCachedBundle(bundle) {
  try {
    localStorage.setItem("aqua_bundle_cache", JSON.stringify(bundle));
  } catch (_) {}
}

// ════════════════════════════════════════════════════════════════════
// UTILITIES
// ════════════════════════════════════════════════════════════════════
async function apiFetch(url, method = "GET", body = null) {
  const opts = {
    method,
    headers: { "Content-Type": "application/json" },
  };
  if (body) opts.body = JSON.stringify(body);
  return fetch(window.location.origin + url, opts);
}

function escHtml(str) {
  if (!str) return "";
  return String(str)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function formatOutput(text) {
  if (!text) return "";
  // Basic markdown-ish rendering (bold, inline code, newlines)
  return escHtml(text)
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\n/g, "<br/>");
}

let _toastTimer;
function toast(msg, type = "info") {
  clearTimeout(_toastTimer);
  const old = document.querySelector(".toast");
  if (old) old.remove();

  const el = document.createElement("div");
  el.className = `toast ${type}`;
  el.textContent = msg;
  document.body.appendChild(el);
  _toastTimer = setTimeout(() => el.remove(), 3200);
}

// ════════════════════════════════════════════════════════════════════
// AUTO-TRIGGER FROM HOME PAGE
// ════════════════════════════════════════════════════════════════════
window.addEventListener("load", () => {
  const goal = document.getElementById("goalInput").value.trim();
  if (goal) startGenerate();
});

// 🚀 BUILD WEBSITE FUNCTION — FIXED
async function handleBuildWebsite() {
  if (!STATE.bundle || !STATE.bundle._id) {
    toast("Save the project first", "error");
    return;
  }

  // Find and disable the button while working
  const btn = [...document.querySelectorAll("button")]
    .find((b) => b.textContent.includes("Build Website"));
  if (btn) { btn.disabled = true; btn.textContent = "⏳ Building..."; }

  try {
    console.log("🚀 [buildWebsite] calling /bundle/" + STATE.bundle._id + "/execute");

    const res = await fetch(`/bundle/${STATE.bundle._id}/execute`, {
      method:      "POST",
      headers:     { "Content-Type": "application/json" },
      credentials: "include",   // ✅ CRITICAL: sends session cookie
    });

    // Parse JSON safely
    let data;
    try {
      data = await res.json();
    } catch {
      throw new Error("Server returned invalid response (status " + res.status + ")");
    }

    console.log("📦 [buildWebsite] response:", data);

    // Surface backend errors to the user instead of hiding them
    if (!res.ok) {
      throw new Error(data?.error || "Server error " + res.status);
    }

    if (data.redirectUrl) {
      toast("Website built — redirecting…", "success");
      setTimeout(() => { window.location.href = data.redirectUrl; }, 700);
      return; // keep button disabled — we're navigating away
    }

    if (data.webIntent === false) {
      toast("Not detected as a website project. Try adding web-related steps.", "info");
    } else {
      throw new Error(data?.error || "Unexpected response — no redirect URL returned");
    }

  } catch (err) {
    console.error("❌ [buildWebsite] error:", err);
    toast("Build failed: " + err.message, "error");
  }

  // Re-enable button on failure
  if (btn) { btn.disabled = false; btn.textContent = "Build website"; }
}
</script>

