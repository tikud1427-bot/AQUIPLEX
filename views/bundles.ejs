<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- 🔥 THIS -->
    <title>Aqua Project Engine | Aquiplex</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body class="bundle-page">

    <%- include('partials/nav') %>


      <div class="hero">
        <h1>🌊 Aqua Project Engine</h1>
        <p>Turn any idea into a step-by-step AI-powered project plan 🚀</p>
      </div>
  <div class="bundle-box">

    <p style="font-size:13px; color:#94a3b8; text-align:center;">
      Enter any goal — like "start freelancing", "grow Instagram", or "learn coding"
    </p>

    <input id="goalInput" placeholder="What do you want to build? (e.g. YouTube channel, SaaS app, freelancing business)" />
    <button onclick="generateBundle()">🚀 Build Project</button>

    <div class="category-buttons">
      <button onclick="quick('Start a YouTube channel')">🎥 YouTuber</button>
      <button onclick="quick('Learn coding fast')">💻 Developer</button>
      <button onclick="quick('Learn video editing')">🎨 Editor</button>
    </div>

    <!-- 🔥 MOVE THIS HERE -->
    <p style="font-size:12px; color:#64748b; text-align:center; margin-top:10px;">
      Aquiplex will generate a step-by-step AI-powered project plan to help you achieve it faster 🚀
    </p>

  </div>
<div id="result"></div>

      <!-- FOOTER -->    

           <footer class="footer">    
      <p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>    

      </footer>    


<script>

  
  async function generateBundle(step = 1) {
  const goal = document.getElementById("goalInput").value.trim(); // ✅ MOVED HERE

  if (!goal) {
    alert("Please enter a goal");
    return;
  }

  console.log("Sending goal:", goal);

  // 🔄 Loading UI
  document.getElementById("result").innerHTML = `
    <div style="text-align:center; padding:30px;">
      <div class="spinner"></div>
      <p style="margin-top:10px; color:#94a3b8;">Generating your AI bundle...</p>
    </div>
  `;

  try {
    const res = await fetch(window.location.origin + "/generate-bundle", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ goal, step, answers })
    });

    const data = await res.json();
    console.log("Response:", data);

    if (data.error) {
      document.getElementById("result").innerHTML = `
        ❌ ${data.error}
        <br><br>
        <small>${data.raw || ""}</small>
      `;
      return;
    }

    if (data.type === "questions") {
      renderQuestions(data.questions);
    } else {
      render(data);
    }

  } catch (err) {
    console.error(err);
    document.getElementById("result").innerText = "❌ Failed to connect to server";
  }
}

function quick(text) {
  document.getElementById("goalInput").value = text;
  generateBundle();
}
  function render(data) {
    if (!data.steps || !Array.isArray(data.steps)) {
      document.getElementById("result").innerText = "❌ Invalid bundle format";
      return;
    }

    let html = `
      <div class="bundle-header">
        <h2>${data.title || "Project Plan"}</h2>

        <div style="background:#1e293b; border-radius:10px; height:10px; margin:10px 0;">
          <div id="progressFill" style="height:10px; width:0%; background:#22c55e; border-radius:10px;"></div>
        </div>

        <button onclick='saveBundle(${JSON.stringify(data).replace(/"/g, '&quot;')})' class="save-btn">
          💾 Save Bundle
        </button>

        <button onclick='shareBundle(${JSON.stringify(data).replace(/"/g, '&quot;')})' class="share-btn">
          🔗 Share
        </button>
      </div>
    `;

    data.steps.forEach(step => {
      html += `
        <div class="step">
          <h3>Step ${step.step || ""}: ${step.title || ""}</h3>
          <p>${step.description || ""}</p>

          <button onclick="completeStep(${step.step})">
            ✅ Mark as Done
          </button>

          <div class="tools">
            ${(step.tools || []).map(t => {
              let name, url;

              if (typeof t === "object") {
                name = t.name;
                url = t.url;
              } else {
                name = t;
                const links = {
                  "PyCharm": "https://www.jetbrains.com/pycharm/",
                  "VS Code": "https://code.visualstudio.com/",
                  "Spyder": "https://www.spyder-ide.org/",
                  "W3Schools": "https://www.w3schools.com/",
                  "Real Python": "https://realpython.com/"
                };
                url = links[name] || `https://www.google.com/search?q=${encodeURIComponent(name)}`;
              }

              return `
                <div class="tool-card-mini recommended">
                  <img 
                    src="https://www.google.com/s2/favicons?sz=64&domain_url=${url}" 
                    onerror="this.src='/images/default-tool.png'"
                  />

                  <div class="tool-info">
                    <span>${name}</span>
                    <button class="use-btn" onclick="openTool('${url}')">Use</button>
                  </div>
                </div>
              `;
            }).join("")}
          </div>
        </div>
      `;
    });

    document.getElementById("result").innerHTML = html;
  }

  async function saveBundle(data) {
    try {
      const res = await fetch("/bundle/save", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          title: data.title,
          steps: data.steps
        })
      });

      const result = await res.json();

      if (result.success) {
        alert("✅ Bundle saved to workspace!");
      } else {
        alert("❌ Failed to save bundle");
      }

    } catch (err) {
      console.error(err);
      alert("❌ Error saving bundle");
    }
  }
  function renderQuestions(questions) {
    let html = "";

    for (let i = 0; i < questions.length; i++) {
      html += `
        <div style="margin: 15px 0;">
          <p style="color: white;">${questions[i]}</p>
          <input id="q${i}" placeholder="Your answer..." style="width:100%; padding:10px;" />
        </div>
      `;
    }

    html += `
      <button onclick="submitAnswers(${questions.length})">
        Continue 🚀
      </button>
    `;

    document.getElementById("result").innerHTML = html;
  }

  let answers = [];

  function submitAnswers(count) {
    answers = [];

    for (let i = 0; i < count; i++) {
      const value = document.getElementById(`q${i}`).value;
      answers.push(value);
    }

    console.log("Answers:", answers);

    // send again with step 2
    generateBundle(2);
  }
</script>


    <script>
    function openTool(url) {
      window.open(url, "_blank");
    }

      async function shareBundle(data){
        try {
          const res = await fetch("/bundle/save", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(data)
          });

          const result = await res.json();

          if(result.success){
            const url = window.location.origin + "/bundle/" + result.id;

            navigator.clipboard.writeText(url);
            alert("🔗 Link copied!");
          }

        } catch(err){
          alert("Error sharing bundle");
        }
      }

      let completedSteps = [];

      function completeStep(step){
        if(!completedSteps.includes(step)){
          completedSteps.push(step);
        }

        const total = document.querySelectorAll(".step").length;
        const progress = (completedSteps.length / total) * 100;

        document.getElementById("progressFill").style.width = progress + "%";
      }

    </script>
      


</body>
</html>