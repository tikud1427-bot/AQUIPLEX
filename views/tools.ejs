<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>All AI Tools | AIDEX</title>

<link rel="stylesheet" href="/css/styles.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<!-- FAVICON (correct based on your files) -->
<link rel="icon" type="image/png" sizes="96x96" href="https://aquiplex.com/logo/favicon-96x96.png">
<link rel="icon" type="image/svg+xml" href="https://aquiplex.com/logo/favicon.svg">
<link rel="shortcut icon" href="https://aquiplex.com/logo/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="https://aquiplex.com/logo/apple-touch-icon.png">

</head>

<body>

<%- include("partials/nav") %>

<main class="container">

  <!-- HERO -->
  <section class="tools-hero">
    <h1>Explore AI Tools</h1>
    <p>Find the best tools for productivity, coding, design & more</p>
  </section>

  <!-- SEARCH -->
  <form action="/tools" method="GET" class="search-bar advanced-search">

    <div class="search-wrapper">

      <i class="fa-solid fa-magnifying-glass search-icon"></i>

      <input 
        type="text" 
        name="q" 
        id="searchInput"
        placeholder="🔍 Ask anything... e.g. 'AI for startups', 'video editing tools'"
        value="<%= searchQuery %>"
        autocomplete="off"
      >

      <button type="submit" class="search-btn">
        Search
      </button>

    </div>

  </form>

  <!-- CATEGORY -->
  <div class="category-filter">

    <a href="/tools" class="category-btn active">All</a>

    <% if (categories && categories.length > 0) { %>
      <% categories.forEach(function(cat){ %>
        <a href="/tools/category/<%= encodeURIComponent(cat) %>" class="category-btn">
          <%= cat %>
        </a>
      <% }) %>
    <% } %>

  </div>
      <% if (typeof recommended !== "undefined" && recommended.length > 0 && searchQuery) { %>

        <div class="ai-recommend-box">

          <h2>🔥 Aqua AI recommends</h2>
          <p>Best tools for "<%= searchQuery %>"</p>

          <div class="ai-recommend-grid">

            <% recommended.forEach(tool => { %>

              <div class="ai-tool">

                <img src="<%= tool.logo %>" onerror="this.src='/logos/default.png'">

                <div>
                  <h4><%= tool.name %></h4>
                  <p><%= tool.category %></p>
                </div>

                <a href="/visit/<%= tool._id %>" target="_blank">Use</a>

              </div>

            <% }) %>

          </div>

        </div>

      <% } %>
  <!-- GRID -->
  <div class="grid">

  <% if (tools && tools.length > 0) { %>

    <% tools.forEach(function(tool){ %>

    <div class="tool-card">

      <!-- TOP -->
      <div class="tool-top">

        <img 
          src="<%= tool.logo || '/logos/default.png' %>" 
          class="tool-logo"
          onerror="this.src='/logos/default.png'"
        >

        <button class="favorite-btn"
        onclick="addToWorkspace(this,'<%= tool._id %>')">
          <i class="fa-solid fa-star"></i>
        </button>

      </div>

      <!-- CONTENT -->
      <div class="tool-content">

        <h3><%= tool.name %></h3>

        <p class="tool-category"><%= tool.category %></p>

        <p class="tool-description">
          <%= tool.description %>
        </p>

      </div>

      <!-- FOOTER -->
      <div class="tool-footer">

        <a href="/tool/<%= tool._id %>" class="details-btn">
          Details
        </a>

        <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">
          Visit
        </a>
        <button onclick="likeTool('<%= tool._id %>')" class="like-btn">
          👍<span id="likes-<%= tool._id %>"><%= tool.likes || 0 %></span>
        </button>
      </div>

    </div>

    <% }) %>

  <% } else { %>

    <div class="no-tools">
      <h3>No tools found</h3>
      <p>Try a different search or category</p>
    </div>

  <% } %>

  </div>

</main>

<%- include("partials/footer") %>

<script>
async function addToWorkspace(button, toolId){
  try {
    button.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i>';

    const res = await fetch("/workspace/add/"+toolId, { method:"POST" });

    if(res.redirected){
      window.location.href="/login";
      return;
    }

    if(res.ok){
      button.innerHTML='<i class="fa-solid fa-check"></i>';
      button.style.color="#22c55e";
    } else {
      button.innerHTML='<i class="fa-solid fa-xmark"></i>';
    }

  } catch(err){
    console.log(err);
    button.innerHTML='<i class="fa-solid fa-xmark"></i>';
  }
}
</script>
  <script>
  async function likeTool(id) {
    const res = await fetch(`/api/tools/${id}/like`, {
      method: "POST"
    });

    const data = await res.json();

    document.getElementById(`likes-${id}`).innerText = data.likes;
  }
  </script>
  <script>
  let timeout;

  document.getElementById("searchInput").addEventListener("keyup", function() {
    clearTimeout(timeout);

    const query = this.value;

    timeout = setTimeout(() => {
      if (query.length > 2) {
        window.location.href = "/tools?q=" + encodeURIComponent(query);
      }
    }, 500);
  });
  </script>
</body>
</html>