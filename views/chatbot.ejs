<!DOCTYPE html>
<html>
<head>
  <title>Aquiplex AI</title>
  <style>
    body {
      background: #0f172a;
      color: white;
      font-family: Arial;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    #chat {
      width: 400px;
      height: 500px;
      overflow-y: auto;
      border: 1px solid #334155;
      padding: 10px;
      margin-bottom: 10px;
      background: #020617;
    }

    .user { color: #38bdf8; }
    .bot { color: #22c55e; }

    input {
      width: 300px;
      padding: 10px;
    }

    button {
      padding: 10px;
      cursor: pointer;
      margin: 5px;
    }
  </style>
</head>

<body>

<h2>Aquiplex AI Chat</h2>

<!-- ✅ MODE BUTTONS -->

  <div class="modes">
    <button onclick="setMode('chat')">💬 Chat</button>
    <button onclick="setMode('search')">🌐 Search</button>
    <button onclick="setMode('image')">🎨 Image</button>
  </div>

  <p id="modeLabel">Mode: chat</p>

  <div id="chat"></div>
<input id="msg" placeholder="Ask something..." />
<button onclick="send()">Send</button>

<script>
let history = [];
let mode = "chat";

  function setMode(m) {
    mode = m;
    document.getElementById("modeLabel").innerText = "Mode: " + m;
  }
  alert("Mode: " + m); // optional feedback
}

async function send() {
  const input = document.getElementById("msg");
  const chat = document.getElementById("chat");

  const message = input.value;
  if (!message.trim()) return;

  chat.innerHTML += `<p class="user"><b>You:</b> ${message}</p>`;
  input.value = "";
  const loading = `<div class="msg bot" id="loading">Typing...</div>`;
  chat.innerHTML += loading;

  const res = await fetch("/chat", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      message,
      history,
      mode
    })
  });

  document.getElementById("loading")?.remove();

  // ✅ IMAGE SUPPORT
  if (data.image) {
    chat.innerHTML += `<p class="bot"><b>AI:</b> ${data.reply}</p>
                       <img src="${data.image}" width="200" />`;
  } else {
    chat.innerHTML += `<p class="bot"><b>AI:</b> ${data.reply}</p>`;
  }

  // ✅ MEMORY
  history.push({ role: "user", content: message });
  history.push({ role: "assistant", content: data.reply });

  chat.scrollTop = chat.scrollHeight;
}
  document.getElementById("msg").addEventListener("keypress", function(e) {
    if (e.key === "Enter") send();
  });
</script>

</body>
</html>