<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/aqua.css"> <!-- 🔥 NEW -->
  <title>🌊 Aqua AI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

</head>

<body>

<%- include('partials/nav') %>

<div class="main">

<h2>🌊 AQUA by Aquiplex</h2>

<div class="modes">
  <button onclick="setMode('chat')">💬 Chat</button>
  <button onclick="setMode('search')">🌐 Search</button>
  <button onclick="setMode('image')">🎨 Image</button>
  <button onclick="toggleRefiner(this)">✨ Refiner OFF</button>
</div>

<p id="modeLabel">Mode: chat</p>

  <!-- ☰ MENU BUTTON -->
  <button id="menuToggle">☰</button>

  <div class="chat-container">

    <!-- ✅ SIDEBAR -->
    <div class="sidebar" id="sidebar">
      <button class="new-chat-btn" onclick="newChat()">➕ New Chat</button>
      <div id="historyList"></div>
    </div>

    <!-- ✅ CHAT AREA -->
    <div id="chat"></div>

  </div>

<!-- ✅ INPUT AREA -->
<div class="chat-input">

  <input type="file" id="fileUpload" hidden />
  <button onclick="document.getElementById('fileUpload').click()">➕</button>

  <input type="text" id="messageInput" placeholder="Ask anything..." />

  <button class="send-btn" onclick="send()">Send</button>

</div>

</div>

<script>
let messages = [];
let currentChatId = null;
let mode = "chat";

/* MODE */
function setMode(m) {
  mode = m;
  document.getElementById("modeLabel").innerText = "Mode: " + m;
}

/* SEND MESSAGE */
  async function send() {
    const input = document.getElementById("messageInput");
    const chat = document.getElementById("chat");
    const fileInput = document.getElementById("fileUpload");

    const message = input.value.trim();
    const file = fileInput.files[0];

    if (!message && !file) return;

    input.value = "";

    const formData = new FormData();
    formData.append("message", message);
    formData.append("mode", mode);
    formData.append("chatId", currentChatId || "");
    formData.append("history", JSON.stringify(messages));
    formData.append("refiner", useRefiner);
    formData.append("stream", true); // 🔥 important

    if (file) formData.append("file", file);

    // show user message
    if (message) {
      chat.innerHTML += `
        <div class="msg user">
          ${marked.parse(message)}
        </div>
      `;
    }

    chat.scrollTop = chat.scrollHeight;

    // loading
    const loading = document.createElement("div");
    loading.className = "msg bot";
    loading.id = "loading";
    loading.innerHTML = mode === "image"
      ? "🎨 Generating image..."
      : "💬 Thinking...";
    chat.appendChild(loading);

    try {
      const res = await fetch("/chat", {
        method: "POST",
        body: formData
      });

      document.getElementById("loading")?.remove();

      // 🎨 IMAGE MODE
      if (mode === "image") {
        const data = await res.json();

        chat.innerHTML += `
          <div class="msg bot">
            <div class="bot-text">${data.reply}</div>
            <img src="${data.image}" style="max-width:100%; border-radius:10px; margin-top:10px;" />
          </div>
        `;

        chat.scrollTop = chat.scrollHeight;
        return;
      }

      // 💬 STREAM MODE
      const reader = res.body.getReader();
      const decoder = new TextDecoder();

      let botMsg = document.createElement("div");
      botMsg.className = "msg bot";

      let botText = document.createElement("div");
      botText.className = "bot-text markdown-body";

      botMsg.appendChild(botText);
      chat.appendChild(botMsg);

      let fullText = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        const chunk = decoder.decode(value);
        const lines = chunk.split("\n");

        for (let line of lines) {
          if (!line.startsWith("data: ")) continue;

          const data = line.replace("data: ", "").trim();

          if (data === "[DONE]") {
            break;
          }

          fullText += data;

          // ✨ typing effect
          botText.innerHTML = marked.parse(fullText + "▌");
          chat.scrollTop = chat.scrollHeight;
        }

        if (chunk.includes("[DONE]")) break;
      }

      // remove cursor after done
      botText.innerHTML = marked.parse(fullText);

      // ✅ SAVE ONCE (IMPORTANT)
      messages.push({
        role: "assistant",
        content: fullText
      });

      // optional temp id
      currentChatId = currentChatId || Date.now();

      } catch (err) {
        console.error(err);

        document.getElementById("loading")?.remove();

        chat.innerHTML += `
          <div class="msg bot">
            <div class="bot-text">⚠️ Something went wrong</div>
          </div>
        `;
      }

      fileInput.value = "";
      input.focus();
      }
  
/* ENTER KEY */
  document.getElementById("messageInput").addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault(); // 🔥 prevents newline
      send();
    }
  });

/* FILE UPLOAD SHOW IN CHAT */
const fileInput = document.getElementById("fileUpload");

fileInput.addEventListener("change", () => {
  const file = fileInput.files[0];
  if (!file) return;

  const chat = document.getElementById("chat");

  chat.innerHTML += `
    <div class="msg user">
      📎 Uploaded: ${file.name}
    </div>
  `;

  chat.scrollTop = chat.scrollHeight;
});

/* HISTORY */
async function loadHistoryList() {
  const res = await fetch("/history");
  const chats = await res.json();

  const list = document.getElementById("historyList");
  list.innerHTML = "";

  chats.forEach(chat => {
    const div = document.createElement("div");

    div.setAttribute("data-id", chat._id);

    div.innerHTML = `
      <span>${chat.title || "Chat"}</span>
      <button onclick="event.stopPropagation(); deleteChat('${chat._id}')">🗑️</button>
    `;

    div.onclick = (e) => loadChat(chat._id, e);
    list.appendChild(div);
  });
}
  async function deleteChat(id) {
    if (!confirm("Delete this chat?")) return;

    await fetch("/history/" + id, { method: "DELETE" });

    // remove from UI instantly
    document.querySelector(`[data-id='${id}']`)?.remove();

    if (currentChatId === id) {
      currentChatId = null;
      messages = [];
      document.getElementById("chat").innerHTML = "";
    }
  }

  async function loadChat(id, event) {
    const res = await fetch("/history/" + id);
    const data = await res.json();

    currentChatId = id;
    messages = data.messages;

    const chat = document.getElementById("chat");
    chat.innerHTML = "";

    data.messages.forEach(m => {
      if (m.role === "user") {
        chat.innerHTML += `<div class="msg user">${marked.parse(m.content)}</div>`;
      } else {
        chat.innerHTML += `
          <div class="msg bot">
            <div class="bot-text">${marked.parse(m.content)}</div>
            <button onclick="copyText(this)">📋</button>
          </div>`;
      }
    });

    chat.scrollTop = chat.scrollHeight;

    // 🔥 CLOSE SIDEBAR ON MOBILE
    document.getElementById("sidebar").classList.remove("open");
  }
  

function newChat() {
  currentChatId = null;
  messages = [];
  document.getElementById("chat").innerHTML = "";
}

/* INIT */
loadHistoryList();
  
  function copyText(btn) {
    const text = btn.parentElement.querySelector(".bot-text").innerText;

    navigator.clipboard.writeText(text);

    btn.innerText = "✅";
    setTimeout(() => btn.innerText = "📋", 1500);
  }
  function toggleSidebar() {
    const sidebar = document.getElementById("sidebar");
    sidebar.classList.toggle("open");
  }
  document.addEventListener("click", (e) => {
    const sidebar = document.getElementById("sidebar");
    const toggle = document.getElementById("menuToggle");

    if (
      sidebar.classList.contains("active") &&
      !sidebar.contains(e.target) &&
      !toggle.contains(e.target)
    ) {
      sidebar.classList.remove("active");
    }
  });
  const menuBtn = document.getElementById("menuToggle");
  const sidebar = document.getElementById("sidebar");

  menuBtn.addEventListener("click", () => {
    sidebar.classList.toggle("active");
    document.body.classList.toggle("sidebar-open");
  });
  let useRefiner = false;

  function toggleRefiner(btn) {
    useRefiner = !useRefiner;
    btn.innerText = useRefiner ? "✨ Refiner ON" : "✨ Refiner OFF";
  }
  
</script>
  
</body>
</html>