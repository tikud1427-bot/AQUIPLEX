<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/aqua.css">
  <title>🌊 Aqua AI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>

<body>

<%- include('partials/nav') %>

<div class="main">

<h2>🌊 AQUA by Aquiplex</h2>

<div class="modes">
  <button onclick="setMode('chat')">💬 Chat</button>
  <button onclick="setMode('search')">🌐 Search</button>
  <button onclick="setMode('image')">🎨 Image</button>
  <button onclick="toggleRefiner(this)">✨ Refiner OFF</button>
</div>

<p id="modeLabel">Mode: chat</p>

  <!-- ☰ MENU BUTTON -->
  <button id="menuToggle">☰</button>

  <div class="chat-container">

    <!-- ✅ SIDEBAR -->
    <div class="sidebar" id="sidebar">
      <button class="new-chat-btn" onclick="newChat()">➕ New Chat</button>
      <div id="historyList"></div>
    </div>

    <!-- ✅ CHAT AREA -->
    <div id="chat"></div>

  </div>

<!-- ✅ INPUT AREA -->
<div class="chat-input">

  <input type="file" id="fileUpload" hidden />
  <button onclick="document.getElementById('fileUpload').click()">➕</button>

  <input type="text" id="messageInput" placeholder="Ask anything..." />

  <button class="send-btn" onclick="send()">Send</button>

</div>

</div>

<script>
// ─────────────────────────────────────────────
// MARKED CONFIGURATION
// Must be done before any marked.parse() calls.
// - gfm: GitHub Flavored Markdown (tables, fenced code, strikethrough)
// - breaks: converts single \n in source to <br> (like ChatGPT)
// ─────────────────────────────────────────────
marked.setOptions({
  gfm: true,
  breaks: true,
});

let messages = [];
let currentChatId = null;
let mode = "chat";
let useRefiner = false;

/* MODE */
function setMode(m) {
  mode = m;
  document.getElementById("modeLabel").innerText = "Mode: " + m;
}

/* SEND MESSAGE */
async function send() {
  const input = document.getElementById("messageInput");
  const chat = document.getElementById("chat");
  const fileInput = document.getElementById("fileUpload");

  const message = input.value.trim();
  const file = fileInput.files[0];

  if (!message && !file) return;

  input.value = "";

  // ─────────────────────────────────────────────
  // FIX: Push user message to local history BEFORE sending.
  // Previously this was never done, so multi-turn context was broken.
  // ─────────────────────────────────────────────
  if (message) {
    messages.push({ role: "user", content: message });
  }

  const formData = new FormData();
  formData.append("message", message);
  formData.append("mode", mode);
  formData.append("chatId", currentChatId || "");
  formData.append("history", JSON.stringify(messages.slice(-10)));
  formData.append("refiner", useRefiner ? "true" : "false");
  formData.append("stream", mode === "chat" ? "true" : "false");
  if (file) formData.append("file", file);

  // Show user message bubble
  if (message) {
    chat.innerHTML += `
      <div class="msg user">
        ${marked.parse(message)}
      </div>
    `;
  }

  chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });

  // Loading indicator
  const loading = document.createElement("div");
  loading.className = "msg bot";
  loading.id = "loading";
  loading.innerHTML = `
    <div class="typing">
      <span></span>
      <span></span>
      <span></span>
      <span class="typing-text">Thinking...</span>
    </div>
  `;
  chat.appendChild(loading);

  try {
    const res = await fetch("/chat", {
      method: "POST",
      body: formData
    });

    document.getElementById("loading")?.remove();

    // ── IMAGE MODE ──────────────────────────────
    if (mode === "image") {
      const data = await res.json();

      chat.innerHTML += `
        <div class="msg bot">
          <div class="bot-text markdown-body">
            ${marked.parse(data.reply)}
          </div>
          <img src="${data.image}" style="max-width:100%; border-radius:10px; margin-top:10px;" />

          <a href="${data.image}" download="aqua-image.png" class="download-btn">
            ⬇ Download
          </a>
        </div>
      `;

      chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
      return;
    }

    if (mode !== "chat") {
      const data = await res.json();

      chat.innerHTML += `
        <div class="msg bot">
          <div class="bot-text markdown-body">
            ${marked.parse(data.reply)}
          </div>
        </div>
      `;

      chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
      return;
    }

    // ── STREAM MODE ─────────────────────────────
    const reader = res.body.getReader();
    const decoder = new TextDecoder("utf-8", { fatal: false });

    const botMsg = document.createElement("div");
    botMsg.className = "msg bot";

    const botText = document.createElement("div");
    botText.className = "bot-text markdown-body";

    botMsg.appendChild(botText);
    chat.appendChild(botMsg);

    let fullText = "";
    let buffer = "";
    let streamDone = false;

    while (true) {
      const { done, value } = await reader.read();

      if (done || streamDone) break;

      buffer += decoder.decode(value, { stream: true });

      const parts = buffer.split("\n\n");
      buffer = parts.pop();

      for (const part of parts) {
        const lines = part.split("\n");

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed.startsWith("data:")) continue;

          const payload = trimmed.slice(5).trim();
          if (!payload) continue;

          if (payload === "[DONE]") {
            streamDone = true;
            break;
          }

          let parsed;
          try {
            parsed = JSON.parse(payload);
          } catch {
            continue;
          }

          if (parsed && parsed.refined) {
            let refBox = document.getElementById("refinedBox");

            if (!refBox) {
              refBox = document.createElement("div");
              refBox.id = "refinedBox";
              refBox.className = "msg bot";
              chat.appendChild(refBox);
            }

            refBox.innerHTML = `
              <div class="bot-text markdown-body">
                ✨ <b>Refined Prompt:</b><br>
                ${marked.parse(parsed.refined)}
              </div>
            `;
            continue;
          }

          if (typeof parsed === "string") {
            fullText += parsed;

            botText.innerHTML =
              marked.parse(fullText) + "<span class='cursor'>▌</span>";

            chat.scrollTo({
              top: chat.scrollHeight,
              behavior: "smooth"
            });
          }
        }

        if (streamDone) break;
      }
    }
    // ✅ FINAL RENDER
    botText.innerHTML = marked.parse(fullText.trim());
    // ✅ COPY BUTTON
    const copyBtn = document.createElement("button");
    copyBtn.innerText = "📋";
    copyBtn.onclick = () => {
      navigator.clipboard.writeText(fullText);
      copyBtn.innerText = "✅";
      setTimeout(() => (copyBtn.innerText = "📋"), 1500);
    };

    botMsg.appendChild(copyBtn);

    // ✅ SAVE HISTORY
    messages.push({ role: "assistant", content: fullText });

    chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });

  } catch (err) {
    console.error("Stream error:", err);

    document.getElementById("loading")?.remove();

    chat.innerHTML += `
      <div class="msg bot">
        <div class="bot-text markdown-body">⚠️ Something went wrong</div>
      </div>
    `;

    // Roll back the user message we optimistically pushed
    if (messages.length && messages[messages.length - 1].role === "user") {
      messages.pop();
    }
  }

  fileInput.value = "";
  input.focus();
}

/* ENTER KEY */
document.getElementById("messageInput").addEventListener("keydown", e => {
  if (e.key === "Enter" && !e.shiftKey) {
    e.preventDefault();
    send();
  }
});

/* FILE UPLOAD SHOW IN CHAT */
const fileInput = document.getElementById("fileUpload");

fileInput.addEventListener("change", () => {
  const file = fileInput.files[0];
  if (!file) return;

  const chat = document.getElementById("chat");

  chat.innerHTML += `
    <div class="msg user">
      📎 Uploaded: ${file.name}
    </div>
  `;

  chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
});

/* HISTORY */
async function loadHistoryList() {
  const res = await fetch("/history");
  const chats = await res.json();

  const list = document.getElementById("historyList");
  list.innerHTML = "";

  chats.forEach(chat => {
    const div = document.createElement("div");

    div.setAttribute("data-id", chat._id);

    div.innerHTML = `
      <span>${chat.title || "Chat"}</span>
      <button onclick="event.stopPropagation(); deleteChat('${chat._id}')">🗑️</button>
    `;

    div.onclick = (e) => loadChat(chat._id, e);
    list.appendChild(div);
  });
}

async function deleteChat(id) {
  if (!confirm("Delete this chat?")) return;

  await fetch("/history/" + id, { method: "DELETE" });

  document.querySelector(`[data-id='${id}']`)?.remove();

  if (currentChatId === id) {
    currentChatId = null;
    messages = [];
    document.getElementById("chat").innerHTML = "";
  }
}

async function loadChat(id, event) {
  const res = await fetch("/history/" + id);
  const data = await res.json();

  currentChatId = id;
  messages = data.messages;

  const chat = document.getElementById("chat");
  chat.innerHTML = "";

  data.messages.forEach(m => {
    if (m.role === "user") {
      chat.innerHTML += `<div class="msg user">${marked.parse(m.content)}</div>`;
    } else {
      chat.innerHTML += `
      <div class="msg bot">
        <div class="bot-text markdown-body">
          ${marked.parse(m.content)}
        </div>
        <button onclick="copyText(this)">📋</button>
      </div>`;
    }
  });

  chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });

  document.getElementById("sidebar").classList.remove("open");
}

function newChat() {
  currentChatId = null;
  messages = [];
  document.getElementById("chat").innerHTML = "";
}

/* INIT */
loadHistoryList();

function copyText(btn) {
  const text = btn.parentElement.querySelector(".bot-text").innerText;
  navigator.clipboard.writeText(text);
  btn.innerText = "✅";
  setTimeout(() => btn.innerText = "📋", 1500);
}

function toggleSidebar() {
  const sidebar = document.getElementById("sidebar");
  sidebar.classList.toggle("open");
}

document.addEventListener("click", (e) => {
  const sidebar = document.getElementById("sidebar");
  const toggle = document.getElementById("menuToggle");

  if (
    sidebar.classList.contains("active") &&
    !sidebar.contains(e.target) &&
    !toggle.contains(e.target)
  ) {
    sidebar.classList.remove("active");
  }
});

const menuBtn = document.getElementById("menuToggle");
const sidebar = document.getElementById("sidebar");

menuBtn.addEventListener("click", () => {
  sidebar.classList.toggle("active");
  document.body.classList.toggle("sidebar-open");
});

function toggleRefiner(btn) {
  useRefiner = !useRefiner;
  btn.innerText = useRefiner ? "✨ Refiner ON" : "✨ Refiner OFF";
}
</script>

</body>
</html>