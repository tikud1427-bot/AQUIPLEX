<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/css/styles.css">
  <title>🌊Aqua AI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    body {
      background: #020617;
      color: #e2e8f0;
      font-family: 'Segoe UI', sans-serif;
      margin: 0;
    }

    h2 {
      margin-top: 20px;
      color: #38bdf8;
    }

    /* MODE BUTTONS */
    .modes {
      margin: 10px;
    }

    .modes button {
      background: #0f172a;
      color: #e2e8f0;
      border: 1px solid #334155;
      padding: 8px 12px;
      border-radius: 8px;
      margin: 3px;
      cursor: pointer;
      transition: 0.2s;
    }

    .modes button:hover {
      background: #38bdf8;
      color: black;
    }

    #modeLabel {
      margin-bottom: 10px;
      font-size: 14px;
      color: #94a3b8;
    }

    /* CHAT BOX */
    #chat {
      width: 95%;
      max-width: 500px;
      height: 500px;
      overflow-y: auto;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 10px;
      background: #020617;
      box-shadow: 0 0 20px rgba(0,0,0,0.4);
    }

    /* CHAT BUBBLES */
    .msg {
      padding: 10px 14px;
      border-radius: 12px;
      margin: 8px 0;
      max-width: 75%;
      word-wrap: break-word;
    }

    .user {
      background: #38bdf8;
      color: black;
      align-self: flex-end;
      margin-left: auto;
    }

    .bot {
      background: #1e293b;
      color: #22c55e;
      align-self: flex-start;
    }

    /* INPUT AREA */
    .input-area {
      display: flex;
      width: 95%;
      max-width: 500px;
      margin: 10px 0;
    }

    input {
      flex: 1;
      padding: 12px;
      border-radius: 8px;
      border: none;
      outline: none;
      background: #0f172a;
      color: white;
    }

    button.send-btn {
      padding: 12px 16px;
      margin-left: 8px;
      border: none;
      border-radius: 8px;
      background: #22c55e;
      color: black;
      cursor: pointer;
      font-weight: bold;
    }

    button.send-btn:hover {
      background: #16a34a;
    }

    img {
      border-radius: 10px;
      margin-top: 5px;
      max-width: 100%;
    }
    .main {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 20px;
    }
    nav {
      width: 100%;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    
  </style>
</head>

<body>
  
  <%- include('partials/nav') %>

  <div class="main">

<h2> 🌊 AQUA by Aquiplex</h2>

<div class="modes">
  <button onclick="setMode('chat')">💬 Chat</button>
  <button onclick="setMode('search')">🌐 Search</button>
  <button onclick="setMode('image')">🎨 Image</button>
</div>

<p id="modeLabel">Mode: chat</p>

    <div class="chat-container">

      <!-- 🧠 HISTORY SIDEBAR -->
      <div id="historyList" style="
        width:200px;
        height:500px;
        overflow-y:auto;
        border:1px solid #1e293b;
        border-radius:10px;
        padding:10px;
        background:#020617;
      ">
        <b>Chats</b>
      </div>

      <!-- 💬 CHAT AREA -->
      <div id="chat" style="flex:1; max-width:unset;"></div>

    </div>

<div class="input-area">
  <input id="msg" placeholder="Ask something..." />
  <button class="send-btn" onclick="send()">Send</button>
  </div>

  </div> <!-- ✅ CLOSE IT HERE -->

  <footer class="footer">
    <p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>
  </footer>

<script>
  let messages = [];
  let currentChatId = null;
let mode = "chat";

  function setMode(m) {
    mode = m;
    document.getElementById("modeLabel").innerText = "Mode: " + m;
  }

async function send() {
  const input = document.getElementById("msg");
  const chat = document.getElementById("chat");
  if (!currentChatId) {
    messages = []; // new chat
  }

  const message = input.value;
  if (!message.trim()) return;

  input.value = "";

  const loading = document.createElement("div");
  loading.className = "msg bot";
  loading.id = "loading";
  loading.innerText = "Typing...";
  chat.appendChild(loading);

  chat.scrollTop = chat.scrollHeight;

  try {
    const res = await fetch("/chat", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        message,
        history: messages,
        chatId: currentChatId,
        mode
      })
    });

    const data = await res.json(); // ✅ FIXED

    document.getElementById("loading")?.remove();

    if (data.image) {
      chat.innerHTML = `
        <div class="msg bot">
          ${data.reply}
          <br/>
          <img src="${data.image}" />
        </div>`;
    } else {
      chat.innerHTML = "";

      data.messages.forEach(m => {
        chat.innerHTML += `
          <div class="msg ${m.role === "user" ? "user" : "bot"}">
            ${m.content}
          </div>`;
      });
    }

    messages = data.messages;
    currentChatId = data.chatId; // 🔥 VERY IMPORTANT

    chat.scrollTop = chat.scrollHeight;

  } catch (err) {
    document.getElementById("loading")?.remove();
    chat.innerHTML += `<div class="msg bot">⚠️ Error connecting to server</div>`;
  }
}

document.getElementById("msg").addEventListener("keypress", function(e) {
  if (e.key === "Enter") send();
});

  async function loadHistoryList() {
    const res = await fetch("/history");
    const chats = await res.json();

    const list = document.getElementById("historyList");
    list.innerHTML = "";

    chats.forEach(chat => {
      const div = document.createElement("div");
      div.innerText = chat.title || "Chat";

      div.style.cursor = "pointer";
      div.style.padding = "8px";
      div.style.borderBottom = "1px solid #1e293b";
      div.style.marginBottom = "5px";

      div.onmouseover = () => div.style.background = "#0f172a";
      div.onmouseout = () => div.style.background = "transparent";

      div.onclick = (e) => loadChat(chat._id, e);// 🔥 THIS CALLS IT

      list.appendChild(div);
    });
  }

  loadHistoryList();

  
  async function loadChat(id, event) {
    // 🔥 highlight selected chat
    document.querySelectorAll("#historyList div").forEach(d => {
      d.style.background = "transparent";
    });

    if (event) {
      event.currentTarget.style.background = "#1e293b";
    }
    const res = await fetch("/history/" + id);
    const data = await res.json();

    currentChatId = id;
    messages = data.messages;

    const chat = document.getElementById("chat");
    chat.innerHTML = "";

    data.messages.forEach(m => {
      chat.innerHTML += `
        <div class="msg ${m.role === "user" ? "user" : "bot"}">
          ${m.content}
        </div>`;
    });
  }
</script>

</body>
</html>