<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/aqua.css">
  <title>🌊 Aqua AI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg:        #0b0f1a;
      --surface:   #111827;
      --surface2:  #1a2235;
      --border:    #1e2d45;
      --accent:    #00c8ff;
      --accent2:   #7b5ea7;
      --text:      #e2eaf4;
      --muted:     #6b7fa3;
      --user-bg:   #162032;
      --bot-bg:    #111827;
      --radius:    14px;
      --font-body: 'DM Sans', sans-serif;
      --font-head: 'Syne', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      top: -30%;
      left: -20%;
      width: 70%;
      height: 70%;
      background: radial-gradient(ellipse, rgba(0,200,255,0.05) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    body::after {
      content: '';
      position: fixed;
      bottom: -20%;
      right: -10%;
      width: 50%;
      height: 50%;
      background: radial-gradient(ellipse, rgba(123,94,167,0.06) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .aqua-shell {
      display: flex;
      flex-direction: column;
      height: 100vh;
      position: relative;
      z-index: 1;
    }

    /* ── HEADER ── */
    .aqua-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      background: rgba(11,15,26,0.9);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
      flex-wrap: wrap;
    }
    .aqua-logo {
      font-family: var(--font-head);
      font-size: 1.25rem;
      font-weight: 800;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -0.5px;
    }
    .aqua-header-pills {
      display: flex;
      gap: 6px;
      margin-left: auto;
      flex-wrap: wrap;
    }
    .pill-btn {
      padding: 5px 12px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--muted);
      font-size: 0.78rem;
      cursor: pointer;
      transition: all 0.2s;
      font-family: var(--font-body);
    }
    .pill-btn:hover, .pill-btn.active {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(0,200,255,0.07);
    }
    .pill-btn.refiner-on {
      border-color: #ffd700;
      color: #ffd700;
      background: rgba(255,215,0,0.06);
    }
    .pill-btn.compare-on {
      border-color: #a78bfa;
      color: #a78bfa;
      background: rgba(167,139,250,0.08);
    }

    /* ── BODY ── */
    .aqua-body {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* ── SIDEBAR ── */
    .aqua-sidebar {
      width: 240px;
      min-width: 240px;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease, width 0.3s ease, min-width 0.3s ease;
      overflow: hidden;
    }
    .aqua-sidebar.collapsed {
      transform: translateX(-240px);
      min-width: 0;
      width: 0;
    }
    .sidebar-header {
      padding: 14px 14px 10px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
    }
    .new-chat-btn {
      flex: 1;
      padding: 8px 12px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 0.82rem;
      font-family: var(--font-body);
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .new-chat-btn:hover { opacity: 0.88; }

    .sidebar-toggle-btn {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 1rem;
      margin-left: 8px;
      padding: 4px 6px;
      border-radius: 6px;
      transition: color 0.2s;
    }
    .sidebar-toggle-btn:hover { color: var(--text); }

    #historyList {
      flex: 1;
      overflow-y: auto;
      padding: 8px 6px;
    }
    #historyList div {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.82rem;
      color: var(--muted);
      transition: all 0.15s;
    }
    #historyList div:hover { background: var(--surface2); color: var(--text); }
    #historyList div span { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #historyList div button {
      background: none; border: none; color: var(--muted);
      cursor: pointer; font-size: 0.8rem; padding: 2px 4px;
      opacity: 0; transition: opacity 0.15s;
    }
    #historyList div:hover button { opacity: 1; }

    /* ── MAIN ── */
    .aqua-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    #chat {
      flex: 1;
      overflow-y: auto;
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      scroll-behavior: smooth;
    }
    #chat::-webkit-scrollbar { width: 4px; }
    #chat::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    /* ── EMPTY STATE ── */
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1;
      gap: 24px;
      padding: 40px 20px;
      text-align: center;
      animation: fadeUp 0.5s ease both;
    }
    .empty-state h1 {
      font-family: var(--font-head);
      font-size: clamp(1.5rem, 4vw, 2.4rem);
      font-weight: 800;
      background: linear-gradient(135deg, var(--accent), #fff 60%, var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.15;
    }
    .empty-state p { color: var(--muted); font-size: 0.9rem; }
    .starter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 10px;
      max-width: 600px;
      width: 100%;
    }
    .starter-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      cursor: pointer;
      text-align: left;
      transition: all 0.2s;
      font-size: 0.83rem;
      color: var(--text);
      font-family: var(--font-body);
      line-height: 1.35;
    }
    .starter-card .card-icon { font-size: 1.3rem; margin-bottom: 6px; display: block; }
    .starter-card:hover {
      border-color: var(--accent);
      background: rgba(0,200,255,0.05);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,200,255,0.08);
    }

    /* ── MESSAGES ── */
    .msg {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      animation: fadeUp 0.3s ease both;
      max-width: 800px;
      width: 100%;
    }
    .msg.user { margin-left: auto; flex-direction: row-reverse; }

    .msg-avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .msg.user .msg-avatar {
      background: linear-gradient(135deg, #162032, #1e3050);
      border: 1px solid var(--border);
    }
    .msg.bot .msg-avatar {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
    }

    .msg-bubble {
      position: relative;
      border-radius: var(--radius);
      padding: 12px 14px;
      font-size: 0.9rem;
      line-height: 1.6;
      max-width: calc(100% - 44px);
    }
    .msg.user .msg-bubble {
      background: var(--user-bg);
      border: 1px solid var(--border);
      border-top-right-radius: 4px;
    }
    .msg.bot .msg-bubble {
      background: var(--bot-bg);
      border: 1px solid var(--border);
      border-top-left-radius: 4px;
    }

    /* ── MARKDOWN ── */
    .markdown-body h1, .markdown-body h2, .markdown-body h3 {
      font-family: var(--font-head);
      margin: 12px 0 6px;
      color: var(--text);
    }
    .markdown-body h1 { font-size: 1.2rem; }
    .markdown-body h2 { font-size: 1.05rem; }
    .markdown-body h3 { font-size: 0.95rem; color: var(--accent); }
    .markdown-body p { margin-bottom: 8px; }
    .markdown-body ul, .markdown-body ol { padding-left: 18px; margin-bottom: 8px; }
    .markdown-body li { margin-bottom: 3px; }
    .markdown-body code {
      background: rgba(0,200,255,0.08);
      border: 1px solid rgba(0,200,255,0.15);
      border-radius: 5px;
      padding: 1px 5px;
      font-size: 0.82rem;
      color: var(--accent);
      font-family: 'Fira Code', monospace;
    }
    .markdown-body pre {
      background: #0d1525;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px;
      overflow-x: auto;
      margin: 10px 0;
    }
    .markdown-body pre code {
      background: none; border: none; color: #a8d5e2;
      font-size: 0.82rem; padding: 0;
    }
    .markdown-body strong { color: #fff; }
    .markdown-body a { color: var(--accent); text-decoration: underline; }
    .markdown-body blockquote {
      border-left: 3px solid var(--accent2);
      margin: 8px 0;
      padding-left: 12px;
      color: var(--muted);
      font-style: italic;
    }

    /* ── MESSAGE ACTIONS ── */
    .msg-actions {
      display: flex;
      gap: 5px;
      margin-top: 8px;
      flex-wrap: wrap;
    }
    .msg-action-btn {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 4px 9px;
      border-radius: 6px;
      font-size: 0.72rem;
      cursor: pointer;
      transition: all 0.15s;
      font-family: var(--font-body);
    }
    .msg-action-btn:hover { border-color: var(--accent); color: var(--accent); }

    /* ── STREAMING CURSOR ── */
    .stream-cursor {
      display: inline-block;
      width: 2px;
      height: 1em;
      background: var(--accent);
      margin-left: 2px;
      vertical-align: text-bottom;
      animation: blink 0.7s step-end infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* ── TYPING INDICATOR ── */
    .typing-indicator {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 10px 0 4px;
    }
    .typing-indicator span {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: bounce 1.2s infinite;
      opacity: 0.7;
    }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    .typing-indicator .think-text {
      margin-left: 6px;
      font-size: 0.8rem;
      color: var(--muted);
    }
    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-5px); }
    }

    /* ── REFINED BOX ── */
    .refined-box {
      background: rgba(255,215,0,0.05);
      border: 1px solid rgba(255,215,0,0.18);
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 0.78rem;
      color: #d4a800;
      margin-bottom: 6px;
    }

    /* ── TOOL SUGGESTIONS ── */
    .tool-suggestions {
      background: rgba(0,200,255,0.04);
      border: 1px solid rgba(0,200,255,0.14);
      border-radius: 10px;
      padding: 10px 12px;
      margin-top: 10px;
      font-size: 0.8rem;
    }
    .tool-suggestions .ts-label {
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 6px;
      display: block;
    }
    .tool-chip {
      display: inline-block;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 3px 8px;
      margin: 2px;
      font-size: 0.76rem;
      color: var(--text);
      text-decoration: none;
      transition: border-color 0.15s;
    }
    .tool-chip:hover { border-color: var(--accent); color: var(--accent); }

    /* ── COMPARE GRID ── */
    .compare-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
      margin-top: 10px;
    }
    .compare-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px;
      font-size: 0.82rem;
    }
    .compare-card .model-name {
      font-family: var(--font-head);
      font-size: 0.7rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    /* ── INPUT AREA ── */
    .aqua-input-wrap {
      padding: 12px 16px 16px;
      border-top: 1px solid var(--border);
      background: rgba(11,15,26,0.95);
      backdrop-filter: blur(10px);
    }
    .aqua-input-row {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 8px 10px;
      transition: border-color 0.2s;
    }
    .aqua-input-row:focus-within { border-color: var(--accent); }

    #messageInput {
      flex: 1;
      background: none;
      border: none;
      outline: none;
      color: var(--text);
      font-size: 0.9rem;
      font-family: var(--font-body);
      resize: none;
      max-height: 140px;
      min-height: 24px;
      line-height: 1.5;
    }
    #messageInput::placeholder { color: var(--muted); }

    .input-icon-btn {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 1.05rem;
      padding: 4px;
      border-radius: 6px;
      transition: color 0.15s;
      display: flex;
      align-items: center;
    }
    .input-icon-btn:hover { color: var(--text); }

    .send-btn {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border: none;
      color: #fff;
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.85rem;
      padding: 7px 18px;
      border-radius: 9px;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
      white-space: nowrap;
    }
    .send-btn:hover { opacity: 0.88; }
    .send-btn:active { transform: scale(0.97); }
    .send-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .input-meta {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 6px;
      font-size: 0.73rem;
      color: var(--muted);
    }
    #modeIndicator {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 5px;
      padding: 2px 7px;
      color: var(--accent);
      font-size: 0.71rem;
      font-weight: 600;
    }
    .file-name-tag {
      background: rgba(0,200,255,0.07);
      border: 1px solid rgba(0,200,255,0.2);
      border-radius: 5px;
      padding: 2px 7px;
      color: var(--accent);
      font-size: 0.71rem;
    }

    /* ── EXPORT TOOLBAR ── */
    .export-toolbar {
      display: flex;
      gap: 8px;
      padding: 8px 16px 0;
      flex-wrap: wrap;
    }
    .export-btn {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 4px 10px;
      border-radius: 7px;
      font-size: 0.74rem;
      cursor: pointer;
      transition: all 0.15s;
      font-family: var(--font-body);
    }
    .export-btn:hover { border-color: var(--accent2); color: var(--accent2); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── MOBILE ── */
    @media (max-width: 640px) {
      .aqua-sidebar {
        position: absolute; left: 0; top: 0;
        height: 100%; z-index: 200;
        transform: translateX(-100%);
      }
      .aqua-sidebar.mobile-open { transform: translateX(0); }
      .aqua-sidebar.collapsed { transform: translateX(-100%); }
    }

    input[type="file"] { display: none; }
    #modeLabel { display: none; }
  </style>
</head>

<body>
<%- include('partials/nav') %>

<div class="aqua-shell">

  <!-- ── HEADER ── -->
  <div class="aqua-header">
    <button class="input-icon-btn" id="menuToggle" title="Toggle sidebar" onclick="toggleSidebar()">☰</button>
    <span class="aqua-logo">🌊 Aqua AI</span>

    <div class="aqua-header-pills">
      <button class="pill-btn active" id="modeChatBtn"   onclick="setMode('chat')">💬 Chat</button>
      <button class="pill-btn"        id="modeSearchBtn" onclick="setMode('search')">🌐 Search</button>
      <button class="pill-btn"        id="modeImageBtn"  onclick="setMode('image')">🎨 Image</button>
      <button class="pill-btn refiner-on" id="refinerBtn" onclick="toggleRefiner(this)">✨ Enhance Prompt ON</button>
      <button class="pill-btn" id="compareBtn" onclick="toggleCompare(this)">⚖️ Compare AI</button>
    </div>
  </div>

  <!-- ── BODY ── -->
  <div class="aqua-body">

    <!-- ── SIDEBAR ── -->
    <div class="aqua-sidebar" id="sidebar">
      <div class="sidebar-header">
        <button class="new-chat-btn" onclick="newChat()">➕ New Chat</button>
        <button class="sidebar-toggle-btn" onclick="toggleSidebar()" title="Close">✕</button>
      </div>
      <div id="historyList"></div>
    </div>

    <!-- ── MAIN ── -->
    <div class="aqua-main">

      <!-- Export toolbar -->
      <div class="export-toolbar">
        <button class="export-btn" onclick="copyFullConversation()">📋 Copy Chat</button>
        <button class="export-btn" onclick="exportAsText()">⬇ Export .txt</button>
        <button class="export-btn" onclick="shareChat()">🔗 Share</button>
      </div>

      <!-- Chat messages -->
      <div id="chat"></div>

      <!-- ── INPUT ── -->
      <div class="aqua-input-wrap">
        <div class="aqua-input-row">
          <button class="input-icon-btn" onclick="document.getElementById('fileUpload').click()" title="Attach file">📎</button>
          <input type="file" id="fileUpload" />
          <textarea id="messageInput" rows="1" placeholder="Ask anything..."></textarea>
          <button class="send-btn" id="sendBtn" onclick="send()">Send ↑</button>
        </div>
        <div class="input-meta">
          <span id="modeIndicator">MODE: CHAT</span>
          <span id="fileNameTag" class="file-name-tag" style="display:none;"></span>
          <span id="modeLabel"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// ============================================================
// AQUA AI – FIXED FRONTEND
// ============================================================

// ── MARKED CONFIG ──
marked.setOptions({ gfm: true, breaks: true });

// ── STATE ──
let messages      = [];
let currentChatId = null;
let mode          = "chat";
let useRefiner    = true;
let useCompare    = false;
let isSending     = false; // FIX: prevent double-sends

// ── ROTATING PLACEHOLDERS ──
const placeholders = [
  "Ask anything...",
  "Generate a startup idea 💡",
  "Create viral content 🔥",
  "Explain like I'm 10 🧒",
  "Fix my code 🛠️",
  "Design a product roadmap 📋"
];
let phIdx = 0;
setInterval(() => {
  phIdx = (phIdx + 1) % placeholders.length;
  const inp = document.getElementById("messageInput");
  if (document.activeElement !== inp) inp.placeholder = placeholders[phIdx];
}, 3500);

// ── MODE ──
function setMode(m) {
  mode = m;
  document.getElementById("modeIndicator").textContent = "MODE: " + m.toUpperCase();
  ["modeChatBtn","modeSearchBtn","modeImageBtn"].forEach(id => {
    document.getElementById(id).classList.remove("active");
  });
  const map = { chat:"modeChatBtn", search:"modeSearchBtn", image:"modeImageBtn" };
  document.getElementById(map[m])?.classList.add("active");
}

// Auto-detect mode from prompt
function autoDetectMode(text) {
  const t = text.toLowerCase();
  if (/^(generate|create|draw).*(image|photo|art|logo)/.test(t)) return "image";
  if (/\b(latest|news|search|find|who is|current|today|2024|2025|2026)\b/.test(t)) return "search";
  return "chat";
}

function toggleRefiner(btn) {
  useRefiner = !useRefiner;
  btn.textContent = useRefiner ? "✨ Enhance Prompt ON" : "✨ Enhance Prompt OFF";
  btn.classList.toggle("refiner-on", useRefiner);
}

function toggleCompare(btn) {
  useCompare = !useCompare;
  btn.classList.toggle("compare-on", useCompare);
  btn.textContent = useCompare ? "⚖️ Compare ON" : "⚖️ Compare AI";
}

function toggleSidebar() {
  const s = document.getElementById("sidebar");
  s.classList.toggle("collapsed");
  s.classList.toggle("mobile-open");
}

// ── EMPTY STATE ──
const STARTERS = [
  { icon:"🚀", text:"Build a startup idea",        prompt:"Help me brainstorm a startup idea with market validation and a go-to-market strategy." },
  { icon:"📸", text:"Create Instagram content",    prompt:"Create a week of Instagram content ideas for a lifestyle brand with captions and hashtags." },
  { icon:"🧠", text:"Explain a concept simply",    prompt:"Explain quantum computing like I'm 10 years old with a fun analogy." },
  { icon:"🎨", text:"Generate an image",           prompt:"Generate an image of a futuristic city at night with neon lights." },
  { icon:"🛠️", text:"Fix my code",                prompt:"Here is my code. Please review it, find bugs, and suggest improvements:" },
  { icon:"📊", text:"Summarize research",          prompt:"Summarize the key findings of the latest research on AI and productivity." },
];

function renderEmptyState() {
  const chat = document.getElementById("chat");
  chat.innerHTML = `
    <div class="empty-state">
      <div>
        <h1>What can I help<br>you build today?</h1>
        <p style="margin-top:8px;">Powered by Groq · OpenRouter · Gemini</p>
      </div>
      <div class="starter-grid">
        ${STARTERS.map(s => `
          <button class="starter-card" onclick="sendStarter(${JSON.stringify(s.prompt).replace(/"/g, '&quot;')})">
            <span class="card-icon">${s.icon}</span>
            ${s.text}
          </button>
        `).join("")}
      </div>
    </div>
  `;
}

function sendStarter(prompt) {
  document.getElementById("messageInput").value = prompt;
  send();
}

// ── AUTO-RESIZE TEXTAREA ──
document.getElementById("messageInput").addEventListener("input", function() {
  this.style.height = "auto";
  this.style.height = Math.min(this.scrollHeight, 140) + "px";
});

// ── LOCK / UNLOCK SEND BUTTON ──
function setSending(val) {
  isSending = val;
  const btn = document.getElementById("sendBtn");
  btn.disabled = val;
  btn.textContent = val ? "..." : "Send ↑";
}

// ── MAIN SEND FUNCTION ──
async function send() {
  if (isSending) return; // FIX: prevent double sends

  const input     = document.getElementById("messageInput");
  const chat      = document.getElementById("chat");
  const fileInput = document.getElementById("fileUpload");

  const message = input.value.trim();
  const file    = fileInput.files[0];

  if (!message && !file) return;

  // Auto-detect mode
  if (message) {
    const detected = autoDetectMode(message);
    if (detected !== mode) setMode(detected);
  }

  setSending(true);

  input.value = "";
  input.style.height = "auto";

  if (message) messages.push({ role: "user", content: message });

  const formData = new FormData();
  formData.append("message", message);
  formData.append("mode",    mode);
  formData.append("chatId",  currentChatId || "");
  formData.append("history", JSON.stringify(messages.slice(-10)));
  formData.append("refiner", useRefiner ? "true" : "false");
  formData.append("stream",  (mode === "chat" && !useCompare) ? "true" : "false");
  if (file) formData.append("file", file);

  // Clear empty state
  document.querySelector(".empty-state")?.remove();

  // User bubble
  if (message) appendMessage("user", message);

  chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });

  // Typing indicator
  const loading = document.createElement("div");
  loading.className = "msg bot";
  loading.id = "loading";
  loading.innerHTML = `
    <div class="msg-avatar">🌊</div>
    <div class="msg-bubble">
      <div class="typing-indicator">
        <span></span><span></span><span></span>
        <span class="think-text">Aqua is thinking...</span>
      </div>
    </div>
  `;
  chat.appendChild(loading);
  chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });

  try {
    // ── COMPARE AI MODE ──
    if (useCompare) {
      const res  = await fetch("/multi-generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt: message, messages: messages.slice(-10) })
      });

      if (!res.ok) throw new Error("Compare request failed: " + res.status);

      const data = await res.json();
      document.getElementById("loading")?.remove();
      appendCompareResult(data);
      setSending(false);
      fileInput.value = "";
      return;
    }

    const res = await fetch("/chat", { method: "POST", body: formData });
    document.getElementById("loading")?.remove();

    if (!res.ok) {
      throw new Error("Chat request failed: " + res.status);
    }

    // ── IMAGE MODE ──
    if (mode === "image") {
      const data = await res.json();
      const div  = createBotBubble();
      const imgHtml = data.image
        ? `<img src="${data.image}" style="max-width:100%;border-radius:10px;margin-top:10px;" onerror="this.style.display='none'" />
           <div class="msg-actions">
             <a href="${data.image}" target="_blank" class="msg-action-btn">⬇ Download</a>
           </div>`
        : "";
      div.querySelector(".msg-bubble").innerHTML = `
        <div class="markdown-body">${marked.parse(data.reply || "Image generated.")}</div>
        ${imgHtml}
      `;
      chat.appendChild(div);
      chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
      const replyContent = data.reply || "Image generated.";
      messages.push({ role: "assistant", content: replyContent });
      setSending(false);
      fileInput.value = "";
      document.getElementById("fileNameTag").style.display = "none";
      return;
    }

    // ── SEARCH / NON-STREAM MODES ──
    if (mode !== "chat") {
      const data = await res.json();
      const replyContent = data.reply || "⚠️ No response received.";
      const div  = createBotBubble();
      div.querySelector(".msg-bubble").innerHTML = `
        <div class="markdown-body">${marked.parse(replyContent)}</div>
        ${buildActions(replyContent)}
      `;
      chat.appendChild(div);
      messages.push({ role: "assistant", content: replyContent });
      if (data.chatId) currentChatId = data.chatId;
      chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
      setSending(false);
      fileInput.value = "";
      document.getElementById("fileNameTag").style.display = "none";
      await loadHistoryList();
      return;
    }

    // ── STREAM MODE ──
    // FIX: Check response content-type — server may fallback to JSON
    const contentType = res.headers.get("content-type") || "";

    if (!contentType.includes("text/event-stream")) {
      // Server sent JSON fallback instead of SSE
      const data = await res.json();
      const replyContent = data.reply || "⚠️ No response received.";
      const div = createBotBubble();
      div.querySelector(".msg-bubble").innerHTML = `
        <div class="markdown-body">${marked.parse(replyContent)}</div>
        ${buildActions(replyContent)}
      `;
      chat.appendChild(div);
      messages.push({ role: "assistant", content: replyContent });
      if (data.chatId) currentChatId = data.chatId;
      chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
      setSending(false);
      fileInput.value = "";
      document.getElementById("fileNameTag").style.display = "none";
      await loadHistoryList();
      return;
    }

    // True SSE stream
    const reader  = res.body.getReader();
    const decoder = new TextDecoder("utf-8", { fatal: false });

    const botDiv  = createBotBubble();
    const bubble  = botDiv.querySelector(".msg-bubble");
    const textDiv = document.createElement("div");
    textDiv.className = "markdown-body";
    bubble.appendChild(textDiv);
    chat.appendChild(botDiv);

    // FIX: cursor is a real DOM element, not embedded in innerHTML
    const cursorEl = document.createElement("span");
    cursorEl.className = "stream-cursor";
    cursorEl.textContent = "▌";
    textDiv.appendChild(cursorEl);

    let fullText   = "";
    let buffer     = "";
    let streamDone = false;

    while (!streamDone) {
      let done, value;
      try {
        ({ done, value } = await reader.read());
      } catch {
        break; // reader closed (e.g., user navigated away)
      }
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      const parts = buffer.split("\n\n");
      buffer = parts.pop() || "";

      for (const part of parts) {
        if (streamDone) break;
        const lines = part.split("\n");

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed.startsWith("data:")) continue;
          const payload = trimmed.slice(5).trim();
          if (!payload) continue;

          if (payload === "[DONE]") {
            streamDone = true;
            break;
          }

          let parsed;
          try { parsed = JSON.parse(payload); } catch { continue; }

          // Refined prompt preview
          if (parsed && typeof parsed === "object" && parsed.refined) {
            let refBox = bubble.querySelector(".refined-box");
            if (!refBox) {
              refBox = document.createElement("div");
              refBox.className = "refined-box";
              bubble.insertBefore(refBox, textDiv);
            }
            refBox.innerHTML = `✨ <b>Optimized prompt:</b> ${parsed.refined}`;
            continue;
          }

          // Token string
          if (typeof parsed === "string" && parsed) {
            fullText += parsed;
            // FIX: Update innerHTML then re-append cursor separately
            textDiv.innerHTML = marked.parse(fullText);
            textDiv.appendChild(cursorEl);
            chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
          }
        }
      }
    }

    // Remove cursor and render final text
    cursorEl.remove();
    textDiv.innerHTML = marked.parse(fullText.trim() || "⚠️ Empty response received.");

    // Tool suggestions (async, non-blocking)
    fetchToolSuggestions(fullText).then(toolSugg => {
      if (toolSugg) bubble.appendChild(toolSugg);
    });

    // Message actions
    bubble.insertAdjacentHTML("beforeend", buildActions(fullText));

    messages.push({ role: "assistant", content: fullText });
    chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
    await loadHistoryList();

  } catch (err) {
    console.error("Send error:", err);
    document.getElementById("loading")?.remove();

    // Show error bubble
    const div = createBotBubble();
    div.querySelector(".msg-bubble").innerHTML = `
      <div class="markdown-body">⚠️ Something went wrong. Please try again.</div>
    `;
    chat.appendChild(div);

    // Remove last user message from local state if AI failed
    if (messages.length && messages[messages.length - 1].role === "user") {
      messages.pop();
    }

  } finally {
    setSending(false);
    const fileInput2 = document.getElementById("fileUpload");
    fileInput2.value = "";
    document.getElementById("fileNameTag").style.display = "none";
    document.getElementById("messageInput").focus();
  }
}

// ── HELPERS ──
function createBotBubble() {
  const div = document.createElement("div");
  div.className = "msg bot";
  div.innerHTML = `
    <div class="msg-avatar">🌊</div>
    <div class="msg-bubble"></div>
  `;
  return div;
}

function appendMessage(role, content) {
  const chat = document.getElementById("chat");
  const div  = document.createElement("div");
  div.className = `msg ${role}`;

  // FIX: sanitize content before passing to marked
  const safeContent = (content || "").toString();

  div.innerHTML = `
    <div class="msg-avatar">${role === "user" ? "👤" : "🌊"}</div>
    <div class="msg-bubble">
      <div class="markdown-body">${marked.parse(safeContent)}</div>
    </div>
  `;
  chat.appendChild(div);
}

// FIX: buildActions uses a data attribute to avoid JSON-in-onclick escaping issues
function buildActions(text) {
  // Store text in a global map keyed by a random id
  const id = "act_" + Math.random().toString(36).slice(2);
  window.__actionTexts = window.__actionTexts || {};
  window.__actionTexts[id] = text;

  return `
    <div class="msg-actions">
      <button class="msg-action-btn" onclick="copyText('${id}')">📋 Copy</button>
      <button class="msg-action-btn" onclick="regenerate()">🔄 Regenerate</button>
      <button class="msg-action-btn" onclick="improveResponse('${id}')">✨ Improve</button>
      <button class="msg-action-btn" onclick="addToWorkspace()">➕ Workspace</button>
    </div>
  `;
}

function copyText(id) {
  const text = (window.__actionTexts || {})[id] || "";
  navigator.clipboard.writeText(text).catch(() => {});
}

function regenerate() {
  if (isSending) return;
  for (let i = messages.length - 1; i >= 0; i--) {
    if (messages[i].role === "user") {
      const lastUser = messages[i];
      messages = messages.slice(0, i + 1);
      document.getElementById("messageInput").value = lastUser.content;

      const chat = document.getElementById("chat");
      const botMsgs = chat.querySelectorAll(".msg.bot");
      botMsgs[botMsgs.length - 1]?.remove();

      send();
      return;
    }
  }
}

function improveResponse(id) {
  if (isSending) return;
  const text = (window.__actionTexts || {})[id] || "";
  document.getElementById("messageInput").value = `Improve and expand on this response:\n\n${text}`;
  send();
}

function addToWorkspace() {
  alert("Content noted! Add specific tools from the 🔧 Tool Suggestions above to your Workspace.");
}

async function fetchToolSuggestions(responseText) {
  try {
    const q = encodeURIComponent((responseText || "").slice(0, 60));
    const res = await fetch("/api/tools/suggest?q=" + q);
    if (!res.ok) return null;
    const tools = await res.json();

    if (!Array.isArray(tools) || !tools.length) return null;

    const div = document.createElement("div");
    div.className = "tool-suggestions";
    div.innerHTML = `
      <span class="ts-label">🔧 Recommended Tools:</span>
      ${tools.map(t => `
        <a href="/visit/${t._id}" target="_blank" class="tool-chip">${t.name}</a>
      `).join("")}
    `;
    return div;

  } catch {
    return null;
  }
}

// FIX: appendCompareResult — was broken (messages.push was OUTSIDE the function body)
function appendCompareResult(data) {
  // Save best response to messages
  const bestOutput = data.responses?.[0]?.output || "";
  if (bestOutput) {
    messages.push({ role: "assistant", content: bestOutput });
  }

  const chat = document.getElementById("chat");
  const div  = document.createElement("div");
  div.className = "msg bot";
  div.style.maxWidth = "100%";

  const responsesHtml = (data.responses || []).map(r => `
    <div class="compare-card">
      <div class="model-name">${r.model || "Model"}</div>
      <div class="markdown-body">${marked.parse(r.output || "")}</div>
    </div>
  `).join("");

  div.innerHTML = `
    <div class="msg-avatar">⚖️</div>
    <div class="msg-bubble" style="flex:1;">
      <div style="font-size:0.75rem;color:var(--muted);margin-bottom:8px;">
        ⭐ Recommended: <b style="color:var(--accent)">${data.recommended || "—"}</b>
      </div>
      <div class="compare-grid">${responsesHtml}</div>
    </div>
  `;

  chat.appendChild(div);
  chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });

  loadHistoryList().catch(() => {});
}

// ── HISTORY ──
async function loadHistoryList() {
  try {
    const res   = await fetch("/history");
    if (!res.ok) return;
    const chats = await res.json();
    if (!Array.isArray(chats)) return;

    const list  = document.getElementById("historyList");
    list.innerHTML = "";

    chats.forEach(c => {
      const div = document.createElement("div");
      div.setAttribute("data-id", c._id);
      div.innerHTML = `
        <span>${c.title || "Chat"}</span>
        <button onclick="event.stopPropagation(); deleteChat('${c._id}')">🗑️</button>
      `;
      div.onclick = () => loadChat(c._id);
      list.appendChild(div);
    });
  } catch {}
}

async function deleteChat(id) {
  if (!confirm("Delete this chat?")) return;
  try {
    await fetch("/history/" + id, { method: "DELETE" });
    document.querySelector(`[data-id='${id}']`)?.remove();
    if (currentChatId === id) {
      currentChatId = null;
      messages = [];
      renderEmptyState();
    }
  } catch {}
}

async function loadChat(id) {
  try {
    const res  = await fetch("/history/" + id);
    if (!res.ok) return;
    const data = await res.json();
    if (!data) return;

    currentChatId = id;
    messages = data.messages || [];

    const chat = document.getElementById("chat");
    chat.innerHTML = "";

    messages.forEach(m => {
      if (m.role === "system") return;
      appendMessage(m.role, m.content);
    });

    // Add action buttons to last bot message
    const lastBotContent = [...messages].reverse().find(m => m.role === "assistant")?.content;
    if (lastBotContent) {
      const botMsgs = chat.querySelectorAll(".msg.bot");
      const lastBot = botMsgs[botMsgs.length - 1];
      lastBot?.querySelector(".msg-bubble")?.insertAdjacentHTML("beforeend", buildActions(lastBotContent));
    }

    chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
    document.getElementById("sidebar").classList.add("collapsed");
  } catch {}
}

function newChat() {
  currentChatId = null;
  messages = [];
  renderEmptyState();
}

// ── EXPORT / SHARE ──
function copyFullConversation() {
  const text = messages
    .filter(m => m.role !== "system")
    .map(m => `${m.role === "user" ? "You" : "Aqua AI"}: ${m.content}`)
    .join("\n\n");
  navigator.clipboard.writeText(text || "No messages yet.").catch(() => {});
}

function exportAsText() {
  const text = messages
    .filter(m => m.role !== "system")
    .map(m => `${m.role === "user" ? "You" : "Aqua AI"}: ${m.content}`)
    .join("\n\n");
  const blob = new Blob([text], { type: "text/plain" });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement("a");
  a.href = url;
  a.download = "aqua-chat.txt";
  a.click();
  URL.revokeObjectURL(url);
}

function shareChat() {
  if (currentChatId) {
    const url = window.location.origin + "/history/" + currentChatId;
    navigator.clipboard.writeText(url).catch(() => {});
    alert("Link copied! (Note: recipient must be logged in to view)");
  } else {
    alert("Save or send a message first to generate a shareable link.");
  }
}

// ── INPUT EVENTS ──
document.getElementById("messageInput").addEventListener("keydown", e => {
  if (e.key === "Enter" && !e.shiftKey) {
    e.preventDefault();
    send();
  }
});

// File name preview
document.getElementById("fileUpload").addEventListener("change", () => {
  const file = document.getElementById("fileUpload").files[0];
  if (!file) return;
  const tag = document.getElementById("fileNameTag");
  tag.textContent = "📎 " + file.name;
  tag.style.display = "inline-block";

  // Show in chat too
  const chat = document.getElementById("chat");
  document.querySelector(".empty-state")?.remove();
  appendMessage("user", `📎 Attached: **${file.name}**`);
  chat.scrollTo({ top: chat.scrollHeight, behavior: "smooth" });
});

// Close sidebar on outside click (mobile)
document.addEventListener("click", e => {
  const sidebar = document.getElementById("sidebar");
  const toggle  = document.getElementById("menuToggle");
  if (
    sidebar.classList.contains("mobile-open") &&
    !sidebar.contains(e.target) &&
    !toggle.contains(e.target)
  ) {
    sidebar.classList.remove("mobile-open");
  }
});

// ── INIT ──
renderEmptyState();
loadHistoryList();
</script>
</body>
</html>
