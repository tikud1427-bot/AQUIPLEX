<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/css/styles.css">
  <title>🌊 Aqua AI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <style>
    body {
      background: #020617;
      color: #e2e8f0;
      font-family: 'Segoe UI', sans-serif;
      margin: 0;
    }

    h2 {
      color: #38bdf8;
      margin-top: 10px;
    }

    .main {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 10px;
    }

    .modes {
      margin: 10px;
    }

    .modes button {
      background: #0f172a;
      color: #e2e8f0;
      border: 1px solid #334155;
      padding: 8px 12px;
      border-radius: 8px;
      margin: 3px;
      cursor: pointer;
    }

    .modes button:hover {
      background: #38bdf8;
      color: black;
    }

    #modeLabel {
      font-size: 13px;
      color: #94a3b8;
    }

    .chat-container {
      display: flex;
      width: 95%;
      max-width: 1100px;
      gap: 10px;
    }

    .sidebar {
      width: 230px;
      background: #020617;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 10px;
    }

    .new-chat-btn {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: none;
      background: #38bdf8;
      color: black;
      font-weight: bold;
      cursor: pointer;
      margin-bottom: 10px;
    }

    #historyList div {
      display: flex;
      justify-content: space-between;
      padding: 8px;
      border-bottom: 1px solid #1e293b;
      cursor: pointer;
    }

    #historyList div:hover {
      background: #0f172a;
    }

    #historyList button {
      background: none;
      border: none;
      color: red;
      cursor: pointer;
    }

    #chat {
      flex: 1;
      height: 500px;
      overflow-y: auto;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 10px;
    }

    .msg {
      padding: 10px;
      border-radius: 10px;
      margin: 6px 0;
      max-width: 70%;
    }

    .user {
      background: #38bdf8;
      color: black;
      margin-left: auto;
    }

    .bot {
      background: #1e293b;
      color: #22c55e;
    }

    .input-area, .chat-input {
      display: flex;
      width: 95%;
      max-width: 1100px;
      margin-top: 10px;
      gap: 8px;
    }

    input {
      flex: 1;
      padding: 12px;
      border-radius: 8px;
      border: none;
      background: #0f172a;
      color: white;
    }

    button {
      padding: 10px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
    }

    .send-btn {
      background: #22c55e;
      font-weight: bold;
    }

    img {
      max-width: 100%;
      border-radius: 10px;
      margin-top: 5px;
    }
  </style>
</head>

<body>

<%- include('partials/nav') %>

<div class="main">

<h2>🌊 AQUA by Aquiplex</h2>

<div class="modes">
  <button onclick="setMode('chat')">💬 Chat</button>
  <button onclick="setMode('search')">🌐 Search</button>
  <button onclick="setMode('image')">🎨 Image</button>
</div>

<p id="modeLabel">Mode: chat</p>

<div class="chat-container">

  <div class="sidebar">
    <button class="new-chat-btn" onclick="newChat()">➕ New Chat</button>
    <div id="historyList"></div>
  </div>

  <div id="chat"></div>

</div>

<!-- ✅ INPUT AREA -->
<div class="chat-input">

  <input type="file" id="fileUpload" hidden />
  <button onclick="document.getElementById('fileUpload').click()">➕</button>

  <input type="text" id="messageInput" placeholder="Ask anything..." />

  <button class="send-btn" onclick="send()">Send</button>

</div>

</div>

<script>
let messages = [];
let currentChatId = null;
let mode = "chat";

/* MODE */
function setMode(m) {
  mode = m;
  document.getElementById("modeLabel").innerText = "Mode: " + m;
}

/* SEND MESSAGE */
async function send() {
  const input = document.getElementById("messageInput");
  const chat = document.getElementById("chat");
  chat.innerHTML = "";
  const message = input.value.trim();
  const fileInput = document.getElementById("fileUpload");

  if (!message && !fileInput.files[0]) return;

  chat.innerHTML += `<div class="msg user">${message}</div>`;
  input.value = "";

  const loading = document.createElement("div");
  loading.className = "msg bot";
  loading.id = "loading";
  loading.innerHTML = "💬 Thinking...";
  chat.appendChild(loading);

  chat.scrollTop = chat.scrollHeight;

  try {
    const formData = new FormData();

    formData.append("message", message);
    formData.append("chatId", currentChatId);
    formData.append("mode", mode);

    // send history (IMPORTANT)
    formData.append("history", JSON.stringify(messages));

    // get file
    const fileInput = document.getElementById("fileUpload");
    if (fileInput.files[0]) {
      formData.append("file", fileInput.files[0]);
    }

    const res = await fetch("/chat", {
      method: "POST",
      body: formData
    });

    const data = await res.json();
    const data = await res.json();
    document.getElementById("loading")?.remove();

    chat.innerHTML = "";
    if (data.image) {
      chat.innerHTML += `
        <div class="msg bot">
          <div class="bot-text">${data.reply}</div>

          <img src="${data.image}" />

          <br/>

          <a href="${data.image}" download>
            <button>⬇️ Download</button>
          </a>

          <button onclick="copyText(this)">📋</button>
        </div>`;
    }
     else {
       data.messages.forEach(m => {

         if (m.role === "user") {
           chat.innerHTML += `
             <div class="msg user">
               ${marked.parse(m.content)}
             </div>`;
         } else {
           chat.innerHTML += `
             <div class="msg bot">
               <div class="bot-text">${marked.parse(m.content)}</div>
               <button onclick="copyText(this)">📋</button>
             </div>`;
         }

       });
    }

    messages = data.messages;
    currentChatId = data.chatId;

    chat.scrollTop = chat.scrollHeight;
    loadHistoryList();

  } catch {
    document.getElementById("loading")?.remove();
    chat.innerHTML += `<div class="msg bot">⚠️ Error</div>`;
  }
}

/* ENTER KEY */
document.getElementById("messageInput").addEventListener("keypress", e => {
  if (e.key === "Enter") send();
});

/* FILE UPLOAD SHOW IN CHAT */
const fileInput = document.getElementById("fileUpload");

fileInput.addEventListener("change", () => {
  const file = fileInput.files[0];
  if (!file) return;

  const chat = document.getElementById("chat");

  chat.innerHTML += `
    <div class="msg user">
      📎 Uploaded: ${file.name}
    </div>
  `;

  chat.scrollTop = chat.scrollHeight;
});

/* HISTORY */
async function loadHistoryList() {
  const res = await fetch("/history");
  const chats = await res.json();

  const list = document.getElementById("historyList");
  list.innerHTML = "";

  chats.forEach(chat => {
    const div = document.createElement("div");

    div.innerHTML = `
      <span>${chat.title || "Chat"}</span>
      <button onclick="event.stopPropagation(); deleteChat('${chat._id}')">🗑️</button>
    `;

    div.onclick = (e) => loadChat(chat._id, e);
    list.appendChild(div);
  });
}

  async function deleteChat(id) {
    await fetch("/history/" + id, { method: "DELETE" });

    // ✅ if currently open chat is deleted → reset everything
    if (currentChatId === id) {
      currentChatId = null;
      messages = [];
      document.getElementById("chat").innerHTML = "";
    }

    loadHistoryList();
  }

  async function loadChat(id, event) {
    const res = await fetch("/history/" + id);
    const data = await res.json();

    currentChatId = id;
    messages = data.messages;

    const chat = document.getElementById("chat");
    chat.innerHTML = ""; // ✅ THIS LINE YOU ADD

    data.messages.forEach(m => {

      if (m.role === "user") {
        chat.innerHTML += `
          <div class="msg user">
            ${marked.parse(m.content)}
          </div>`;
      } else {
        chat.innerHTML += `
          <div class="msg bot">
            <div class="bot-text">${marked.parse(m.content)}</div>
            <button onclick="copyText(this)">📋</button>
          </div>`;
      }

    });

    chat.scrollTop = chat.scrollHeight;
  }
  

function newChat() {
  currentChatId = null;
  messages = [];
  document.getElementById("chat").innerHTML = "";
}

/* INIT */
loadHistoryList();
  
  function copyText(btn) {
    const text = btn.parentElement.querySelector(".bot-text").innerText;

    navigator.clipboard.writeText(text);

    btn.innerText = "✅";
    setTimeout(() => btn.innerText = "📋", 1500);
  }
</script>

</body>
</html>