<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/css/styles.css">
  <title>🌊 Aqua AI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    body {
      background: #020617;
      color: #e2e8f0;
      font-family: 'Segoe UI', sans-serif;
      margin: 0;
    }

    h2 {
      color: #38bdf8;
      margin-top: 10px;
    }

    .main {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 10px;
    }

    /* 🔥 MODE BUTTONS */
    .modes {
      margin: 10px;
    }

    .modes button {
      background: #0f172a;
      color: #e2e8f0;
      border: 1px solid #334155;
      padding: 8px 12px;
      border-radius: 8px;
      margin: 3px;
      cursor: pointer;
    }

    .modes button:hover {
      background: #38bdf8;
      color: black;
    }

    #modeLabel {
      font-size: 13px;
      color: #94a3b8;
    }

    /* 🔥 LAYOUT */
    .chat-container {
      display: flex;
      width: 95%;
      max-width: 1100px;
      gap: 10px;
    }

    /* 🔥 SIDEBAR */
    .sidebar {
      width: 230px;
      background: #020617;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 10px;
      transition: 0.3s;
    }

    .new-chat-btn {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: none;
      background: #38bdf8;
      color: black;
      font-weight: bold;
      cursor: pointer;
      margin-bottom: 10px;
    }

    #historyList div {
      display: flex;
      justify-content: space-between;
      padding: 8px;
      border-bottom: 1px solid #1e293b;
      cursor: pointer;
    }

    #historyList div:hover {
      background: #0f172a;
    }

    #historyList button {
      background: none;
      border: none;
      color: red;
      cursor: pointer;
    }

    /* 🔥 CHAT */
    #chat {
      flex: 1;
      height: 500px;
      overflow-y: auto;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 10px;
    }

    .msg {
      padding: 10px;
      border-radius: 10px;
      margin: 6px 0;
      max-width: 70%;
    }

    .user {
      background: #38bdf8;
      color: black;
      margin-left: auto;
    }

    .bot {
      background: #1e293b;
      color: #22c55e;
    }

    /* 🔥 INPUT */
    .input-area {
      display: flex;
      width: 95%;
      max-width: 1100px;
      margin-top: 10px;
    }

    input {
      flex: 1;
      padding: 12px;
      border-radius: 8px;
      border: none;
      background: #0f172a;
      color: white;
    }

    .send-btn {
      padding: 12px;
      margin-left: 8px;
      border-radius: 8px;
      border: none;
      background: #22c55e;
      cursor: pointer;
      font-weight: bold;
    }

    /* 🔥 MOBILE */
    .menu-btn {
      display: none;
      background: #38bdf8;
      border: none;
      padding: 8px;
      border-radius: 6px;
      margin-bottom: 5px;
    }

    @media (max-width: 768px) {
      .menu-btn {
        display: block;
      }

      .sidebar {
        position: absolute;
        left: -250px;
        top: 60px;
        height: 80%;
        z-index: 999;
        background: #020617;
      }

      .sidebar.active {
        left: 10px;
      }
    }

    img {
      max-width: 100%;
      border-radius: 10px;
      margin-top: 5px;
    }
  </style>
</head>

<body>

<%- include('partials/nav') %>

<div class="main">

<button class="menu-btn" onclick="toggleSidebar()">☰</button>

<h2>🌊 AQUA by Aquiplex</h2>

<!-- 🔥 MODES -->
<div class="modes">
  <button onclick="setMode('chat')">💬 Chat</button>
  <button onclick="setMode('search')">🌐 Search</button>
  <button onclick="setMode('image')">🎨 Image</button>
</div>
<p id="modeLabel">Mode: chat</p>

<div class="chat-container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <button class="new-chat-btn" onclick="newChat()">➕ New Chat</button>
    <div id="historyList"></div>
  </div>

  <!-- CHAT -->
  <div id="chat"></div>

</div>

<div class="input-area">
  <input id="msg" placeholder="Ask something..." />
  <button class="send-btn" onclick="send()">Send</button>
</div>

</div>

<script>
let messages = [];
let currentChatId = null;
let mode = "chat";

/* 🔥 MODE */
function setMode(m) {
  mode = m;
  document.getElementById("modeLabel").innerText = "Mode: " + m;
}

/* 🔥 SEND */
async function send() {
  const input = document.getElementById("msg");
  const chat = document.getElementById("chat");

  const message = input.value.trim();
  if (!message) return;

  if (!currentChatId) messages = [];

  chat.innerHTML += `<div class="msg user">${message}</div>`;
  input.value = "";

  const loading = document.createElement("div");
  loading.className = "msg bot";
  loading.id = "loading";
  loading.innerText = "Typing...";
  chat.appendChild(loading);

  chat.scrollTop = chat.scrollHeight;

  try {
    const res = await fetch("/chat", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({
        message,
        history: messages.map(m => ({
          role: m.role === "bot" ? "assistant" : m.role,
          content: m.content
        })),
        chatId: currentChatId,
        mode
      })
    });

    const data = await res.json();
    document.getElementById("loading")?.remove();

    chat.innerHTML = "";

    if (data.image) {
      chat.innerHTML += `
        <div class="msg bot">
          ${data.reply}
          <br/>
          <img src="${data.image}" />
        </div>`;
    } else {
      data.messages.forEach(m => {
        chat.innerHTML += `
          <div class="msg ${m.role === "user" ? "user" : "bot"}">
            ${m.content}
          </div>`;
      });
    }

    messages = data.messages;
    currentChatId = data.chatId;

    chat.scrollTop = chat.scrollHeight;
    loadHistoryList();

  } catch {
    document.getElementById("loading")?.remove();
    chat.innerHTML += `<div class="msg bot">⚠️ Error connecting</div>`;
  }
}

/* ENTER */
document.getElementById("msg").addEventListener("keypress", e => {
  if (e.key === "Enter") send();
});

/* HISTORY LIST */
async function loadHistoryList() {
  const res = await fetch("/history");
  const chats = await res.json();

  const list = document.getElementById("historyList");
  list.innerHTML = "";

  chats.forEach(chat => {
    const div = document.createElement("div");

    div.innerHTML = `
      <span>${chat.title || "Chat"}</span>
      <button onclick="event.stopPropagation(); deleteChat('${chat._id}')">🗑️</button>
    `;

    div.onclick = (e) => loadChat(chat._id, e);

    list.appendChild(div);
  });
}

/* DELETE */
async function deleteChat(id) {
  await fetch("/history/" + id, { method: "DELETE" });
  loadHistoryList();
  document.getElementById("chat").innerHTML = "";
}

/* LOAD CHAT */
async function loadChat(id, event) {

  document.querySelectorAll("#historyList div").forEach(d => {
    d.style.background = "transparent";
  });

  if (event) event.currentTarget.style.background = "#1e293b";

  const res = await fetch("/history/" + id);
  const data = await res.json();

  currentChatId = id;
  messages = data.messages;

  const chat = document.getElementById("chat");
  chat.innerHTML = "";

  data.messages.forEach(m => {
    chat.innerHTML += `
      <div class="msg ${m.role === "user" ? "user" : "bot"}">
        ${m.content}
      </div>`;
  });

  chat.scrollTop = chat.scrollHeight;
}

/* NEW CHAT */
function newChat() {
  currentChatId = null;
  messages = [];
  document.getElementById("chat").innerHTML = "";
}

/* SIDEBAR */
function toggleSidebar() {
  document.querySelector(".sidebar").classList.toggle("active");
}

/* INIT */
loadHistoryList();
</script>

</body>
</html>