<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Log in — Aquiplex</title>
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

<%- include("partials/nav") %>

<main class="px-auth-wrap">
  <div class="px-auth-card">
    <h1>Welcome back</h1>
    <p class="px-auth-sub">Log in to your Aquiplex workspace.</p>

    <a href="/auth/google" class="px-auth-google">
      <img src="https://developers.google.com/identity/images/g-logo.png" alt="">
      Continue with Google
    </a>

    <div class="px-auth-divider"><span>or continue with email</span></div>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="px-auth-error"><%= error %></p>
    <% } %>

    <form action="/login" method="POST" class="px-auth-form">
      <div>
        <label class="px-label" for="email">Email</label>
        <input class="px-input" id="email" type="email" name="email" autocomplete="email" required>
      </div>
      <div>
        <label class="px-label" for="password">Password</label>
        <input class="px-input" id="password" type="password" name="password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="px-btn px-btn-primary px-btn-lg" style="width:100%; margin-top:6px;">Log in</button>
    </form>

    <p class="px-auth-switch">New to Aquiplex? <a href="/signup">Create an account</a></p>
  </div>
</main>

</body>
</html>
