<header class="main-header">
  <div class="header-container">

    <!-- LOGO -->
    <a href="/" class="logo">
      <img src="/logo/logo.png" alt="AQUIPLEX" class="logo-img">
      <span class="logo-text">AQUIPLEX</span>
    </a>

    <!-- NAV LINKS (DESKTOP ONLY) -->
    <nav class="nav-links">

      <a href="<%= user ? '/home' : '/' %>">Home</a>
      <a href="/tools">Tools</a>
      <a href="/trending" class="highlight">🔥 Trending</a>

      <!-- 🔥 ADD THIS -->
      <a href="/chatbot" class="ai-link">🌊 Aqua AI</a>

      <% if (typeof user !== "undefined" && user) { %>
        <a href="/workspace">Workspace</a>
      <% } %>

      <!-- MORE DROPDOWN -->
      <div class="nav-more">
        <span>More ▾</span>
        <div class="dropdown">
          <a href="/bundles" class="ai-link">🌊 Aqua Project Engine</a>
          <a href="/submit">Submit</a>
          <a href="/about">About</a>
        </div>
      </div>

    </nav>

    <!-- 🔍 DESKTOP SEARCH -->
    <form action="/tools" method="GET" class="nav-search">
      <input 
        type="text" 
        name="q" 
        placeholder="Search AI tools..." 
        required
      >
    </form>

    <!-- ACTION BUTTONS -->
    <div class="header-actions">

      <% if (typeof user !== "undefined" && user) { %>

        <!-- ✅ Username only on desktop -->
        <span class="user-greet desktop-only">
          Hi, <%= user.username || "User" %>
        </span>

        <a href="/workspace" class="btn ghost">⚡ Workspace</a>
        <a href="/logout" class="btn primary">Logout</a>

      <% } else { %>

        <a href="/login" class="btn ghost">Login</a>
        <a href="/signup" class="btn primary">Sign Up</a>

      <% } %>

    </div>

    <!-- MOBILE MENU BUTTON -->
    <div class="menu-toggle" onclick="toggleMenu()">☰</div>

  </div>

  <!-- ✅ MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu">

    <!-- 🔍 MOBILE SEARCH -->
    <form action="/tools" method="GET" class="mobile-search">
      <input 
        type="text" 
        name="q" 
        placeholder="Search AI tools..."
        required
      >
    </form>

    <a href="<%= user ? '/home' : '/' %>">Home</a>
    <a href="/chatbot" class="btn ai-btn">🌊 Aqua AI</a>
    <a href="/tools">Tools</a>
    <a href="/trending">🔥 Trending</a>
    <a href="/bundles" class="btn ai-btn">🌊 Project Engine</a>

    <% if (typeof user !== "undefined" && user) { %>
      <a href="/workspace">Workspace</a>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/signup">Sign Up</a>
    <% } %>

    <a href="/submit">Submit</a>
    <a href="/about">About</a>

  </div>
</header>

<!-- ✅ GLOBAL SCRIPT (IMPORTANT - OUTSIDE HEADER) -->
<script>
function toggleMenu() {
  const menu = document.getElementById("mobileMenu");
  if (menu) {
    menu.classList.toggle("active");
  }
}
</script>