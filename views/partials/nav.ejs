<header class="main-header" style="background:red;">
  <div class="header-container">

    <!-- LOGO -->
    <a href="/" class="logo">AIDEX</a>

    <!-- NAV -->
    <nav class="nav-links">

      <a href="/" class="nav-item">Home</a>
      <a href="/tools" class="nav-item">Tools</a>
      <a href="/trending" class="nav-item highlight">🔥 Trending</a>

      <% if (typeof user !== "undefined" && user) { %>
        <a href="/workspace" class="nav-item">Workspace</a>
      <% } %>

      <a href="/submit" class="nav-item">Submit</a>
      <a href="/about" class="nav-item">About</a>

    </nav>

    <!-- ACTIONS -->
    <div class="header-actions">

      <% if (typeof user !== "undefined" && user) { %>
        <a href="/workspace" class="btn ghost">⚡ Workspace</a>
        <a href="/logout" class="btn primary">Logout</a>
      <% } else { %>
        <a href="/login" class="btn ghost">Login</a>
        <a href="/signup" class="btn primary">Sign Up</a>
      <% } %>

    </div>

    <!-- MOBILE TOGGLE -->
    <div class="menu-toggle" onclick="toggleMenu()">☰</div>

  </div>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu">

    <a href="/">Home</a>
    <a href="/tools">Tools</a>
    <a href="/trending">🔥 Trending</a>

    <% if (typeof user !== "undefined" && user) { %>
      <a href="/workspace">Workspace</a>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/signup">Sign Up</a>
    <% } %>

    <a href="/submit">Submit</a>
    <a href="/about">About</a>

  </div>
</header>

<script>
function toggleMenu(){
  document.getElementById("mobileMenu").classList.toggle("active");
}
</script>