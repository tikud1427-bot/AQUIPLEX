<header class="main-header">
  <div class="header-container">

    <!-- LOGO -->
    <a href="/" class="logo">
      <img src="/logo/logo.png" alt="AQUIPLEX" class="logo-img">
      <span class="logo-text">AQUIPLEX</span>
    </a>

    <!-- CENTER NAV (DESKTOP) -->
    <nav class="nav-links" aria-label="Main navigation">
      <a href="/aqua" class="aqua-ai-link">
        <img src="/logo/aqua-favicon.png" alt="">
        Aqua AI
      </a>
      <a href="/bundles">Projects</a>
      <a href="/pricing">Pricing</a>

      <!-- More dropdown -->
      <div class="nav-more">
        <span>More ▾</span>
        <div class="dropdown">
          <a href="/tools">🔧 AI Utilities</a>
          <a href="/trending">🔥 Trending</a>
          <a href="/about">About</a>
          <a href="/submit">Submit a Tool</a>
        </div>
      </div>
    </nav>

    <!-- RIGHT ACTIONS -->
    <div class="header-actions">
      <% if (typeof user !== "undefined" && user) { %>

        <!-- Plan badge -->
        <% if (user.plan && user.plan !== 'free') { %>
          <a href="/billing" class="nav-plan-badge nav-plan-<%= user.plan %>"><%= user.plan.toUpperCase() %></a>
        <% } else { %>
          <a href="/pricing" class="nav-upgrade-link">⚡ Upgrade</a>
        <% } %>

        <!-- Primary workspace CTA -->
        <a href="/aqua" class="btn primary nav-workspace-cta" aria-label="Open AQUA">
          ⚡ Open AQUA
        </a>

        <!-- User dropdown -->
        <div class="nav-user-menu">
          <button class="nav-user-btn" onclick="toggleUserMenu(event)" aria-label="User menu" aria-expanded="false" aria-controls="navUserDropdown">
            <span class="nav-avatar"><%= (user.username || user.email || 'U')[0].toUpperCase() %></span>
          </button>
          <div class="nav-user-dropdown" id="navUserDropdown" role="menu">
            <div class="nav-user-email"><%= user.email || user.username %></div>
            <div class="nav-user-plan-row">
              <span class="nav-inline-badge nav-plan-<%= user.plan || 'free' %>"><%= (user.plan || 'free').toUpperCase() %></span>
            </div>
            <a href="/billing" class="nav-dropdown-item" role="menuitem">💳 Billing & Credits</a>
            <a href="/pricing" class="nav-dropdown-item upgrade" role="menuitem">⚡ Upgrade Plan</a>
            <div class="nav-dropdown-divider"></div>
            <a href="/logout" class="nav-dropdown-item" role="menuitem">Logout</a>
          </div>
        </div>

      <% } else { %>
        <a href="/login" class="btn ghost">Login</a>
        <a href="/signup" class="btn primary nav-get-started">Get Started</a>
      <% } %>
    </div>

    <!-- MOBILE TOGGLE -->
    <button class="menu-toggle" onclick="toggleMenu()" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">☰</button>

  </div>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu" role="navigation" aria-label="Mobile navigation">

    <% if (typeof user !== "undefined" && user) { %>
      <a href="/aqua" class="btn ai-btn mobile-primary-cta">⚡ Open Aqua AI</a>
      <% if (user.plan === 'free' || !user.plan) { %>
        <a href="/pricing" class="btn mobile-upgrade-cta">✦ Upgrade to Pro</a>
      <% } else { %>
        <a href="/billing" class="btn mobile-upgrade-cta">💳 <%= (user.plan || 'free').toUpperCase() %> Plan</a>
      <% } %>
    <% } else { %>
      <a href="/aqua" class="btn ai-btn mobile-primary-cta">⚡ Try Aqua AI Free</a>
      <a href="/signup" class="btn primary mobile-workspace-cta">Get Started</a>
      <a href="/login" style="text-align:center;color:#7c8db5;font-size:0.9rem;">Already have an account? Login</a>
    <% } %>

    <div class="mobile-nav-divider"></div>

    <a href="/aqua">Aqua AI</a>
    <a href="/bundles">Projects</a>
    <a href="/pricing">Pricing</a>

    <div class="mobile-nav-divider"></div>

    <a href="/tools" style="color:#7c8db5;font-size:0.88rem;">🔧 AI Utilities</a>
    <a href="/trending" style="color:#7c8db5;font-size:0.88rem;">🔥 Trending</a>
    <a href="/about" style="color:#7c8db5;font-size:0.88rem;">About</a>

    <% if (typeof user !== "undefined" && user) { %>
      <a href="/logout" style="color:#7c8db5;font-size:0.88rem;">Logout</a>
    <% } %>

  </div>
</header>

<style>
/* ── GLOBAL NAV OVERFLOW PROTECTION ── */
.main-header { overflow: visible; }
.header-container {
  flex-wrap: nowrap;
  min-width: 0;
  gap: 8px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
  flex-shrink: 1;
  text-decoration: none;
  color: inherit;
}
.logo-img {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  object-fit: contain;
}
.logo-text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 20px;
  font-weight: 700;
  color: #38bdf8;
}

/* ── Shrink actions on mid-size screens ── */
@media (max-width: 900px) and (min-width: 769px) {
  .nav-workspace-cta { padding: 7px 12px !important; font-size: 12px !important; }
  .nav-upgrade-link { font-size: 0.78rem !important; }
  .nav-plan-badge { font-size: 0.65rem !important; }
}

/* ── Mobile menu max-height + scroll ── */
.mobile-menu {
  position: absolute;
  top: 70px;
  left: 0;
  width: 100%;
  max-height: calc(100vh - 70px);
  overflow-y: auto;
  overflow-x: hidden;
  box-sizing: border-box;
  z-index: 9998;
  -webkit-overflow-scrolling: touch;
}

/* ── Touch-friendly tap targets in mobile menu ── */
.mobile-menu a,
.mobile-menu .btn {
  min-height: 44px;
  display: flex !important;
  align-items: center;
  box-sizing: border-box;
  width: 100%;
}

/* ── Prevent logo text overflow on very small screens ── */
@media (max-width: 375px) {
  .logo-text { font-size: 16px; }
  .logo-img  { width: 24px; height: 24px; }
}
@media (max-width: 320px) {
  .logo-text { font-size: 14px; }
}

/* ── NAV WORKSPACE CTA ── */
.nav-workspace-cta {
  background: linear-gradient(135deg, #38bdf8, #6366f1) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 8px !important;
  padding: 8px 18px !important;
  font-weight: 700 !important;
  letter-spacing: 0.01em !important;
  box-shadow: 0 0 14px rgba(56,189,248,0.3) !important;
  transition: box-shadow 0.2s, transform 0.15s !important;
  white-space: nowrap;
}
.nav-workspace-cta:hover {
  box-shadow: 0 0 24px rgba(56,189,248,0.5) !important;
  transform: translateY(-1px) !important;
}

/* ── GET STARTED CTA (logged out) ── */
.nav-get-started {
  background: linear-gradient(135deg, #38bdf8, #6366f1) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 8px !important;
  padding: 9px 20px !important;
  font-weight: 700 !important;
  box-shadow: 0 0 14px rgba(56,189,248,0.3) !important;
  transition: box-shadow 0.2s, transform 0.15s !important;
  white-space: nowrap;
}
.nav-get-started:hover {
  box-shadow: 0 0 24px rgba(56,189,248,0.5) !important;
  transform: translateY(-1px) !important;
}

/* ── UPGRADE LINK ── */
.nav-upgrade-link {
  color: #f59e0b !important;
  font-weight: 700 !important;
  font-size: 0.85rem !important;
}

/* ── PLAN BADGES ── */
.nav-plan-badge {
  font-size: 0.72rem !important;
  font-weight: 700 !important;
  padding: 3px 10px !important;
  border-radius: 999px !important;
  text-decoration: none !important;
}
.nav-plan-starter { background: rgba(0,212,255,0.12); color: #00d4ff; border: 1px solid rgba(0,212,255,0.3); }
.nav-plan-pro     { background: rgba(124,58,237,0.15); color: #a78bfa; border: 1px solid rgba(124,58,237,0.4); }
.nav-plan-team    { background: rgba(34,197,94,0.12); color: #86efac; border: 1px solid rgba(34,197,94,0.3); }

/* ── MOBILE CTAs ── */
.mobile-primary-cta {
  background: linear-gradient(135deg, #38bdf8, #6366f1) !important;
  color: #fff !important;
  text-align: center; width: 100%; padding: 14px 0 !important;
  font-size: 1rem !important; border-radius: 10px !important;
  display: block !important; margin-bottom: 8px !important;
  font-weight: 700 !important;
  box-shadow: 0 0 18px rgba(56,189,248,0.3) !important;
}
.mobile-workspace-cta {
  background: rgba(255,255,255,0.05) !important;
  color: var(--text-primary, #eef2ff) !important;
  border: 1px solid rgba(255,255,255,0.1) !important;
  text-align: center; width: 100%; padding: 12px 0 !important;
  font-size: 0.95rem !important; border-radius: 10px !important;
  display: block !important; margin-bottom: 8px !important;
  font-weight: 600 !important;
}
.mobile-upgrade-cta {
  background: rgba(245,158,11,0.08) !important;
  color: #f59e0b !important;
  border: 1px solid rgba(245,158,11,0.25) !important;
  text-align: center; width: 100%; padding: 11px 0 !important;
  font-size: 0.88rem !important; border-radius: 10px !important;
  display: block !important; margin-bottom: 4px !important;
  font-weight: 700 !important;
}
.mobile-nav-divider {
  height: 1px; background: rgba(255,255,255,0.06);
  margin: 12px 0;
}

/* ── AQUA AI LINK ── */
.aqua-ai-link { display: flex; align-items: center; gap: 6px; }
.aqua-ai-link img { width: 15px; height: 15px; object-fit: contain; filter: drop-shadow(0 0 4px rgba(56,189,248,0.4)); }
.aqua-ai-link:hover img { filter: drop-shadow(0 0 8px rgba(56,189,248,0.7)); }

/* ── USER MENU ── */
.nav-user-menu { position: relative; }
.nav-user-btn {
  background: none; border: 1px solid rgba(255,255,255,0.12); border-radius: 50%;
  width: 34px; height: 34px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: border-color 0.2s;
}
.nav-user-btn:hover { border-color: rgba(56,189,248,0.5); }
.nav-avatar {
  width: 26px; height: 26px; border-radius: 50%;
  background: linear-gradient(135deg, #38bdf8, #6366f1);
  color: #fff; font-size: 0.72rem; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.nav-user-dropdown {
  display: none; position: absolute; top: calc(100% + 10px); right: 0;
  background: #0f0f1e; border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px; min-width: 200px; padding: 8px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.55); z-index: 9999;
}
.nav-user-dropdown.open { display: block; }
.nav-user-email { padding: 8px 12px 4px; font-size: 0.78rem; color: rgba(255,255,255,0.45); word-break: break-all; }
.nav-user-plan-row { padding: 4px 12px 10px; }
.nav-inline-badge { font-size: 0.7rem; font-weight: 700; padding: 2px 8px; border-radius: 999px; display: inline-block; }
.nav-plan-free    { background: rgba(255,255,255,0.08); color: #aaa; }
.nav-plan-starter { background: rgba(0,212,255,0.12); color: #00d4ff; border: 1px solid rgba(0,212,255,0.3); }
.nav-plan-pro     { background: rgba(124,58,237,0.15); color: #a78bfa; border: 1px solid rgba(124,58,237,0.4); }
.nav-plan-team    { background: rgba(34,197,94,0.12); color: #86efac; border: 1px solid rgba(34,197,94,0.3); }
.nav-dropdown-item {
  display: block; padding: 9px 12px; border-radius: 8px;
  font-size: 0.85rem; color: rgba(255,255,255,0.72);
  text-decoration: none; transition: background 0.15s;
}
.nav-dropdown-item:hover { background: rgba(255,255,255,0.07); color: #fff; }
.nav-dropdown-item.upgrade { color: #f59e0b; font-weight: 600; }
.nav-dropdown-item.upgrade:hover { background: rgba(245,158,11,0.08); }
.nav-dropdown-divider { height: 1px; background: rgba(255,255,255,0.07); margin: 6px 0; }

.mobile-menu { box-sizing: border-box; overflow-x: hidden; }
</style>

<script>
function toggleMenu() {
  const menu   = document.getElementById("mobileMenu");
  const toggle = document.querySelector(".menu-toggle");
  if (!menu) return;
  const isOpen = menu.classList.toggle("active");
  if (toggle) toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
}

document.addEventListener("click", function(e) {
  const menu   = document.getElementById("mobileMenu");
  const toggle = document.querySelector(".menu-toggle");
  if (!menu || !menu.classList.contains("active")) return;
  if (!menu.contains(e.target) && !toggle.contains(e.target)) {
    menu.classList.remove("active");
    toggle.setAttribute("aria-expanded", "false");
  }
});

function toggleUserMenu(e) {
  e.stopPropagation();
  const dd  = document.getElementById("navUserDropdown");
  const btn = e.currentTarget;
  if (!dd) return;
  const isOpen = dd.classList.toggle("open");
  btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
}

document.addEventListener("click", function(e) {
  const dd = document.getElementById("navUserDropdown");
  if (dd && dd.classList.contains("open")) {
    if (!dd.contains(e.target) && !e.target.closest(".nav-user-btn")) {
      dd.classList.remove("open");
    }
  }
});
</script>
