<link rel="stylesheet" href="/css/platform.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;550;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500&display=swap" rel="stylesheet">

<header class="px-nav">
  <div class="px-nav-inner">

    <a href="/" class="px-nav-logo" aria-label="Aquiplex home">
      <img src="/logo/logo.png" alt="">
      <span class="px-nav-wordmark">AQUIPLEX</span>
    </a>

    <nav class="px-nav-links" aria-label="Main navigation">
      <a href="/aqua" class="px-nav-link">Aqua AI</a>
      <a href="/bundles" class="px-nav-link">Projects</a>
      <a href="/pricing" class="px-nav-link">Pricing</a>
      <div class="px-nav-more" id="pxNavMore">
        <button type="button" onclick="pxToggleMore(event)" aria-expanded="false" aria-controls="pxMoreDropdown">
          Company
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="px-nav-dropdown" id="pxMoreDropdown" role="menu">
          <a href="/about" role="menuitem">About</a>
          <a href="/founders" role="menuitem">Founders</a>
          <a href="/blogs" role="menuitem">Blog</a>
        </div>
      </div>
    </nav>

    <div class="px-nav-actions">
      <% if (typeof user !== "undefined" && user) { %>

        <% if (user.plan && user.plan !== 'free') { %>
          <a href="/billing" class="px-nav-plan plan-<%= user.plan %>"><%= user.plan.toUpperCase() %></a>
        <% } else { %>
          <a href="/pricing" class="px-nav-plan">Upgrade</a>
        <% } %>

        <a href="/aqua" class="px-btn px-btn-primary px-btn-sm">Open Aqua</a>

        <div class="px-nav-user">
          <button class="px-nav-avatar-btn" onclick="toggleUserMenu(event)" aria-label="Account menu" aria-expanded="false" aria-controls="navUserDropdown">
            <%= (user.username || user.email || 'U')[0].toUpperCase() %>
          </button>
          <div class="px-nav-user-dropdown" id="navUserDropdown" role="menu">
            <div class="px-nav-user-meta">
              <div class="px-nav-user-email"><%= user.email || user.username %></div>
            </div>
            <div class="px-nav-user-planrow">
              <span class="px-badge <%= (user.plan && user.plan !== 'free') ? 'px-badge-accent' : '' %>"><%= (user.plan || 'free').toUpperCase() %></span>
            </div>
            <div class="px-nav-divider"></div>
            <a href="/billing" class="px-nav-item" role="menuitem">Billing &amp; credits</a>
            <a href="/wallet" class="px-nav-item" role="menuitem">Wallet</a>
            <a href="/pricing" class="px-nav-item" role="menuitem">Upgrade plan</a>
            <div class="px-nav-divider"></div>
            <a href="/logout" class="px-nav-item" role="menuitem">Log out</a>
          </div>
        </div>

      <% } else { %>
        <a href="/login" class="px-btn px-btn-ghost px-btn-sm">Log in</a>
        <a href="/signup" class="px-btn px-btn-primary px-btn-sm">Get started</a>
      <% } %>

      <button class="px-nav-burger" onclick="toggleMenu()" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      </button>
    </div>

  </div>

  <div class="px-nav-mobile" id="mobileMenu" role="navigation" aria-label="Mobile navigation">
    <% if (typeof user !== "undefined" && user) { %>
      <a href="/aqua" class="px-btn px-btn-primary">Open Aqua</a>
      <% if (user.plan === 'free' || !user.plan) { %>
        <a href="/pricing" class="px-btn px-btn-secondary">Upgrade plan</a>
      <% } else { %>
        <a href="/billing" class="px-btn px-btn-secondary"><%= (user.plan || 'free').toUpperCase() %> plan · Billing</a>
      <% } %>
    <% } else { %>
      <a href="/signup" class="px-btn px-btn-primary">Get started</a>
      <a href="/login" class="px-btn px-btn-secondary">Log in</a>
    <% } %>

    <div class="px-nav-mobile-divider"></div>
    <a href="/aqua">Aqua AI</a>
    <a href="/bundles">Projects</a>
    <a href="/pricing">Pricing</a>
    <div class="px-nav-mobile-divider"></div>
    <a href="/about">About</a>
    <a href="/founders">Founders</a>
    <a href="/blogs">Blog</a>
    <% if (typeof user !== "undefined" && user) { %>
      <div class="px-nav-mobile-divider"></div>
      <a href="/logout">Log out</a>
    <% } %>
  </div>
</header>

<script>
function toggleMenu() {
  var menu = document.getElementById("mobileMenu");
  var toggle = document.querySelector(".px-nav-burger");
  if (!menu) return;
  var isOpen = menu.classList.toggle("open");
  document.body.classList.toggle("px-menu-open", isOpen);
  if (toggle) toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
}
function toggleUserMenu(e) {
  e.stopPropagation();
  var dd = document.getElementById("navUserDropdown");
  if (!dd) return;
  var isOpen = dd.classList.toggle("open");
  e.currentTarget.setAttribute("aria-expanded", isOpen ? "true" : "false");
}
function pxToggleMore(e) {
  e.stopPropagation();
  var wrap = document.getElementById("pxNavMore");
  if (!wrap) return;
  var isOpen = wrap.classList.toggle("open");
  e.currentTarget.setAttribute("aria-expanded", isOpen ? "true" : "false");
}
document.addEventListener("click", function (e) {
  var menu = document.getElementById("mobileMenu");
  var toggle = document.querySelector(".px-nav-burger");
  if (menu && menu.classList.contains("open") && !menu.contains(e.target) && toggle && !toggle.contains(e.target)) {
    menu.classList.remove("open");
    document.body.classList.remove("px-menu-open");
    toggle.setAttribute("aria-expanded", "false");
  }
  var dd = document.getElementById("navUserDropdown");
  if (dd && dd.classList.contains("open") && !dd.contains(e.target) && !e.target.closest(".px-nav-avatar-btn")) {
    dd.classList.remove("open");
  }
  var more = document.getElementById("pxNavMore");
  if (more && more.classList.contains("open") && !more.contains(e.target)) {
    more.classList.remove("open");
  }
});
document.addEventListener("keydown", function (e) {
  if (e.key !== "Escape") return;
  ["mobileMenu", "navUserDropdown", "pxNavMore"].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.classList.remove("open");
  });
  document.body.classList.remove("px-menu-open");
});
</script>
