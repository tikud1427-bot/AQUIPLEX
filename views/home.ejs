<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Workspace — Aquiplex</title>
  <meta name="description" content="Your Aquiplex workspace — continue with Aqua, pick up projects, and see your usage at a glance.">
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

<%- include("partials/nav") %>

<main class="px-dash">
  <div class="px-container">

    <!-- header -->
    <div class="px-dash-head">
      <h1>Workspace</h1>
      <p>Pick up where you left off, or start something new with Aqua.</p>
    </div>

    <!-- continue with Aqua -->
    <section class="px-continue">
      <div>
        <h2>Continue with Aqua</h2>
        <p>Aqua remembers your projects, preferences, and context. Ask, plan, and execute — all in one place.</p>
      </div>
      <div class="px-continue-actions">
        <a href="/aqua" class="px-btn px-btn-primary px-btn-lg">Open Aqua</a>
        <a href="/bundles" class="px-btn px-btn-secondary px-btn-lg">New project</a>
      </div>
    </section>

    <!-- quick actions -->
    <div class="px-quick-grid">
      <a href="/aqua" class="px-quick">
        <div class="px-quick-icon"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M2 3h12v8H6l-3 3v-3H2V3z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg></div>
        <h3>New chat</h3>
        <p>Start a conversation with full memory of your work.</p>
      </a>
      <a href="/aqua" class="px-quick">
        <div class="px-quick-icon"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 2h7l3 3v9H3V2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M10 2v3h3" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg></div>
        <h3>Upload knowledge</h3>
        <p>Bring archives, PDFs, and docs — Aqua reasons over them.</p>
      </a>
      <a href="/bundles" class="px-quick">
        <div class="px-quick-icon"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M2 6h12M6 6v8" stroke="currentColor" stroke-width="1.2"/></svg></div>
        <h3>Start a project</h3>
        <p>Turn a goal into a plan Aqua executes step by step.</p>
      </a>
    </div>

    <div class="px-dash-grid">

      <!-- left: activity -->
      <div>

        <!-- recent conversations -->
        <section class="px-card px-card-pad px-dash-sec">
          <div class="px-dash-sec-head" style="margin-bottom:8px;">
            <h2>Recent conversations</h2>
            <a href="/aqua">Open Aqua →</a>
          </div>
          <div class="px-list" id="convList">
            <div class="px-skel wide"></div>
            <div class="px-skel wide"></div>
            <div class="px-skel wide"></div>
          </div>
        </section>

        <!-- projects -->
        <section class="px-card px-card-pad px-dash-sec">
          <div class="px-dash-sec-head" style="margin-bottom:8px;">
            <h2>Projects</h2>
            <a href="/bundles">All projects →</a>
          </div>
          <% if (bundles && bundles.length) { %>
            <div class="px-list">
              <% bundles.forEach(function (b) { %>
                <a href="/resume/<%= b._id %>" class="px-list-row">
                  <div style="min-width:0;">
                    <div class="px-list-title"><%= b.title %></div>
                    <div class="px-list-sub"><%= (b.steps || []).length %> steps</div>
                  </div>
                  <span class="status-pill <%= b.status === 'completed' ? 'completed' : (b.status === 'running' ? 'pending' : '') %>"><%= b.status || 'draft' %></span>
                </a>
              <% }); %>
            </div>
          <% } else { %>
            <div class="px-empty">No projects yet. <a href="/bundles">Describe a goal</a> and Aqua will plan and execute it.</div>
          <% } %>
        </section>

        <!-- knowledge & uploads -->
        <section class="px-card px-card-pad px-dash-sec">
          <div class="px-dash-sec-head" style="margin-bottom:8px;">
            <h2>Knowledge &amp; workspaces</h2>
            <a href="/aqua">Manage in Aqua →</a>
          </div>
          <div class="px-list" id="wsList">
            <div class="px-skel wide"></div>
            <div class="px-skel wide"></div>
          </div>
        </section>

      </div>

      <!-- right: usage overview -->
      <aside>
        <section class="px-card px-card-pad px-dash-sec">
          <div class="px-dash-sec-head" style="margin-bottom:14px;">
            <h2>Usage</h2>
            <a href="/wallet">Wallet →</a>
          </div>

          <div class="px-stat" style="border:0; padding:0 0 16px;">
            <div class="px-stat-label">Credits available</div>
            <div class="px-stat-value" id="uCredits"><span class="px-skel"></span></div>
            <div class="px-stat-sub" id="uCreditsSub"></div>
            <div class="px-bar-track"><div class="px-bar-fill" id="uFreeBar" style="width:0%"></div></div>
          </div>

          <div class="px-stat" style="border:0; border-top:1px solid var(--px-line); border-radius:0; padding:16px 0 0;">
            <div class="px-stat-label">Free credits reset</div>
            <div class="px-stat-value" style="font-size:16px;" id="uReset"><span class="px-skel"></span></div>
            <div class="px-stat-sub">Free credits refresh daily at midnight.</div>
          </div>

          <a href="/pricing" class="px-btn px-btn-secondary px-btn-block" style="margin-top:20px;">Buy credits</a>
        </section>
      </aside>

    </div>

  </div>
</main>

<%- include("partials/footer") %>

<script>
(function () {
  function esc(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }
  function ago(ts) {
    if (!ts) return '';
    var d = Date.now() - Number(ts);
    if (d < 60e3) return 'just now';
    if (d < 3600e3) return Math.floor(d / 60e3) + 'm ago';
    if (d < 86400e3) return Math.floor(d / 3600e3) + 'h ago';
    return Math.floor(d / 86400e3) + 'd ago';
  }

  // Recent conversations (Aqua engine, per-user)
  fetch('/api/aqua/conversations?limit=6', { credentials: 'include' })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      var el = document.getElementById('convList');
      if (!el) return;
      var rows = (d && d.conversations) || [];
      if (!rows.length) {
        el.innerHTML = '<div class="px-empty">No conversations yet. <a href="/aqua">Start one with Aqua</a>.</div>';
        return;
      }
      el.innerHTML = rows.map(function (c) {
        var title = (c.meta && (c.meta.title || c.meta.name)) || 'Conversation';
        var when  = ago(c.meta && c.meta.createdAt);
        return '<a class="px-list-row" href="/aqua">'
          + '<div style="min-width:0;"><div class="px-list-title">' + esc(title) + '</div>'
          + '<div class="px-list-sub">' + (c.messageCount || 0) + ' messages</div></div>'
          + '<span class="px-list-sub">' + esc(when) + '</span></a>';
      }).join('');
    })
    .catch(function () {
      var el = document.getElementById('convList');
      if (el) el.innerHTML = '<div class="px-empty">Couldn\'t load conversations. <a href="/aqua">Open Aqua</a>.</div>';
    });

  // Workspaces / knowledge (Aqua project intelligence)
  fetch('/api/aqua/project/workspaces', { credentials: 'include' })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      var el = document.getElementById('wsList');
      if (!el) return;
      var rows = (d && (d.workspaces || d.data)) || [];
      if (!rows.length) {
        el.innerHTML = '<div class="px-empty">No uploads yet. <a href="/aqua">Upload a codebase or documents</a> and Aqua builds an intelligence layer over them.</div>';
        return;
      }
      el.innerHTML = rows.slice(0, 5).map(function (w) {
        var name = w.name || w.id || 'Workspace';
        var files = w.fileCount != null ? (w.fileCount + ' files') : '';
        return '<a class="px-list-row" href="/aqua">'
          + '<div style="min-width:0;"><div class="px-list-title">' + esc(name) + '</div>'
          + '<div class="px-list-sub">' + esc(files) + '</div></div>'
          + '<span class="px-list-sub">Open →</span></a>';
      }).join('');
    })
    .catch(function () {
      var el = document.getElementById('wsList');
      if (el) el.innerHTML = '<div class="px-empty">Couldn\'t load workspaces right now.</div>';
    });

  // Usage overview (wallet)
  fetch('/api/billing/status', { credentials: 'include' })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      var b = (d && d.billing) || {};
      var free  = Number(b.freeCredits || 0);
      var paid  = Number(b.paidCredits || 0);
      var max   = Number(b.freeDailyMax || 200);
      var c  = document.getElementById('uCredits');
      var cs = document.getElementById('uCreditsSub');
      var bar = document.getElementById('uFreeBar');
      var rst = document.getElementById('uReset');
      if (c)  c.textContent  = (free + paid).toLocaleString();
      if (cs) cs.textContent = free.toLocaleString() + ' free today · ' + paid.toLocaleString() + ' purchased';
      if (bar) bar.style.width = (max > 0 ? Math.min(100, Math.round(free / max * 100)) : 0) + '%';
      if (rst) rst.textContent = b.freeResetAt ? new Date(b.freeResetAt).toLocaleString(undefined, { hour: 'numeric', minute: '2-digit', day: 'numeric', month: 'short' }) : 'Midnight';
    })
    .catch(function () {
      var c = document.getElementById('uCredits');
      var rst = document.getElementById('uReset');
      if (c) c.textContent = '—';
      if (rst) rst.textContent = 'Midnight';
    });
})();
</script>

</body>
</html>
