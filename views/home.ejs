<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AQUIPLEX | Discover the Best AI Tools</title>

    <!-- GLOBAL STYLES -->
    <link rel="stylesheet" href="/css/styles.css">

    <!-- HOME PAGE STYLES -->
    <link rel="stylesheet" href="/css/home.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#020617">

    <!-- ICONS -->
    <link rel="icon" href="/logo/icon-192.png" sizes="192x192">
<link rel="shortcut icon" href="/logo/icon-192.png">
<link rel="apple-touch-icon" href="/logo/icon-192.png">
  </head>

<body>

<%- include("partials/nav") %>

<!-- 🌊 FLOATING BUTTON -->
  <div class="aqua-float pulse" onclick="openAquaAI()">
    💬 Ask AI
  </div>

<!-- 💬 AQUA AI POPUP -->
<div id="aquaPopup" class="aqua-popup hidden">
  <div class="popup-header">
    <span>🌊 Aqua AI</span>
    <button onclick="closeAquaAI()" ontouchstart="closeAquaAI()">✖</button>
  </div>

  <div class="popup-body">
    <p>Ask anything. Get powerful answers instantly ⚡</p>

    <a href="/chatbot" class="btn primary">
      Open Aqua AI
    </a>
  </div>
</div>

<!-- HERO -->
  <section class="hero new-hero">
    <div class="hero-glow"></div>

    <div class="hero-content">
      <h1>
        The AI OS for the Internet ⚡
      </h1>

      <p>
        Discover. Compare. Use AI tools — or just ask Aqua AI.
      </p>

      <div class="hero-input-box">
        <input 
          type="text" 
          placeholder="Try: Build a startup, create an app, grow Instagram..."
          id="heroPrompt"
        >
        <button onclick="runHeroAI()">⚡ Generate</button>
      </div>

      

      <div class="hero-buttons">
        <button onclick="openAquaAI()" class="btn ghost">
          💬 Open Chat
        </button>
      </div>
      <div class="hero-stats">
        <span>🔥 100+ Tools</span>
        <span>⚡ Instant AI Answers</span>
        <span>🌍 Global Users</span>
      </div>
      <div class="cursor-glow"></div>
    </div>
  </section>
  <section class="section core-powers">

    <h2 class="section-title">⚡ Your AI Superpowers</h2>

    <div class="features">

      <div class="feature-card highlight">
        <h3>💬 Aqua AI Chat</h3>
        <p>Multi-model AI answers instantly.</p>
      </div>

      <div class="feature-card highlight">
        <h3>✨ Prompt Refiner</h3>
        <p>Turn basic ideas into powerful prompts.</p>
      </div>

      <div class="feature-card highlight">
        <h3>🏗️ Project Engine</h3>
        <p>Generate full workflows with tools.</p>
      </div>

    </div>

  </section>
  <!-- 🔥 TRUST STRIP -->
  <section class="trust-strip">
    <p>Trusted by 10,000+ users worldwide 🌍</p>
    <div class="trust-icons">
      <span>🚀 Fast</span>
      <span>🔒 Secure</span>
      <span>⚡ AI Powered</span>
      <span>💡 Smart Results</span>
    </div>
  </section>
  <section class="section">
    <h2 class="section-title">Why AQUIPLEX?</h2>

    <div class="features">

      <div class="feature-card">
        <h3>⚡ Instant AI Answers</h3>
        <p>No need to search multiple tools.</p>
      </div>

      <div class="feature-card">
        <h3>🧠 Smart Discovery</h3>
        <p>Find the best AI tools instantly.</p>
      </div>

      <div class="feature-card">
        <h3>🚀 All-in-One Platform</h3>
        <p>Everything AI in one place.</p>
      </div>

    </div>
  </section>
  <!-- 🔥 USE CASES -->
  <section class="section use-cases">

    <h2 class="section-title">🔥 What You Can Do</h2>

    <div class="grid">

      <div class="tool-card">
        <h3>🚀 Build a Startup</h3>
        <p>Get full roadmap + tools in seconds.</p>
      </div>

      <div class="tool-card">
        <h3>🎬 Create Content</h3>
        <p>Scripts, posts, videos — instantly.</p>
      </div>

      <div class="tool-card">
        <h3>💻 Build Apps</h3>
        <p>Generate code + workflows.</p>
      </div>

      <div class="tool-card">
        <h3>📈 Grow Online</h3>
        <p>Marketing strategies powered by AI.</p>
      </div>

    </div>

  </section>
  <!-- 🔥 TRENDING -->
  <section class="section">
    <h2 class="section-title">🔥 Trending AI Tools</h2>
    <p class="section-sub">
      Discover what people are using right now
    </p>

    <div class="grid">

      <% if (tools && tools.length > 0) { %>

        <% tools.slice(0, 4).forEach(function(tool){ %>

          <div class="tool-card">

            <div class="logo-box">
              <img src="<%= tool.logo %>" alt="<%= tool.name %>">
            </div>

            <h3><%= tool.name %></h3>
            <p><%= tool.description %></p>

          </div>

        <% }) %>

      <% } %>

    </div>
  </section>

<!-- MAIN CONTENT -->
<div class="container">

  <!-- CATEGORIES -->
  <section class="section">
    <h2 class="section-title">Explore by Category</h2>

    <div class="categories">

      <%
      const categories = [
        { name: "Writing AI", icon: "✍️" },
        { name: "Image AI", icon: "🎨" },
        { name: "Video AI", icon: "🎬" },
        { name: "Coding AI", icon: "💻" },
        { name: "ML AI", icon: "🤖" }
      ];
      %>

      <!-- Explore All -->
      <a class="category-card explore-all" href="/categories">
        <div class="category-icon">🌐</div>
        <div class="category-name">Explore All</div>
      </a>

      <% categories.forEach(function(category){ %>

        <a class="category-card" href="/tools/category/<%= category.name.toLowerCase().replace(/\s+/g, '-') %>">
          <div class="category-icon"><%= category.icon %></div>
          <div class="category-name"><%= category.name %></div>
        </a>

      <% }) %>

    </div>
  </section>

  <!-- FEATURED TOOLS -->
  <section class="section">
    <h2 class="section-title">⭐ Featured Tools</h2>

    <div class="grid">

      <% if (tools && tools.length > 0) { %>

      <% tools.forEach(function(tool){ %>

      <div class="tool-card">

        <div class="logo-box">
          <img src="<%= tool.logo %>" alt="<%= tool.name %>">
        </div>

        <a href="/tool/<%= tool._id %>" class="tool-link">
          <h3><%= tool.name %></h3>
        </a>

        <p><%= tool.description %></p>

        <div class="tool-actions">
          <a href="/tool/<%= tool._id %>" class="details-btn">
            View Details
          </a>

          <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">
            Visit Tool
          </a>
        </div>

      </div>

      <% }) %>

      <% } else { %>
      <p style="text-align:center;">No tools available yet.</p>
      <% } %>

    </div>
  </section>

</div>
        <!-- ⚙️ HOW IT WORKS -->
        <section class="section">
          <h2 class="section-title">How It Works</h2>

          <div class="features">

            <div class="feature-card">
              <h3>1. Search or Ask</h3>
              <p>Use Aqua AI or explore tools.</p>
            </div>

            <div class="feature-card">
              <h3>2. Discover</h3>
              <p>Find the best AI tools instantly.</p>
            </div>

            <div class="feature-card">
              <h3>3. Use & Grow</h3>
              <p>Boost productivity with AI.</p>
            </div>

          </div>
        </section>
<!-- 📲 DOWNLOAD -->
        <section class="section final-cta">

          <h1>
            Stop Searching. Start Building ⚡
          </h1>

          <p class="hero-sub">
            Join thousands using AI to build startups, apps, and content — instantly.
          </p>

          <div class="cta-buttons">
            <button onclick="openAquaAI()" class="btn primary big-btn pulse">
              🚀 Try Aqua AI Now
            </button>

            <a href="/download" class="btn ghost big-btn secondary">
              📲 Download App
            </a>
          </div>

          <p style="margin-top:10px; opacity:0.7;">
            ⚡ Takes 10 seconds. No setup required.
          </p>

        </section>

<!-- FOOTER -->
<footer class="footer">
  <p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>
</footer>

<!-- JS -->
<script>
  function openAquaAI() {
    document.getElementById("aquaPopup").classList.remove("hidden");
  }

  function closeAquaAI() {
    const popup = document.getElementById("aquaPopup");
    popup.style.opacity = "0";
    popup.style.transform = "translateY(20px)";

    setTimeout(() => {
      popup.classList.add("hidden");
    }, 200);
  }

  // AUTO POPUP (conversion boost)
  setTimeout(() => {
    openAquaAI();
  }, 4000);
</script>
        <script>
          document.addEventListener("touchstart", function(){}, true);
        </script>
        <script>
        const glow = document.querySelector(".cursor-glow");
        const hero = document.querySelector(".new-hero");

        hero.addEventListener("mousemove", (e) => {
          const rect = hero.getBoundingClientRect();
          glow.style.left = (e.clientX - rect.left) + "px";
          glow.style.top = (e.clientY - rect.top) + "px";
        });
        </script>
        <script>
        function runHeroAI() {
          const input = document.getElementById("heroPrompt").value.trim();
          if (!input) return;

          const btn = document.querySelector(".hero-input-box button");
          btn.innerText = "Redirecting...";

          localStorage.setItem("aqua_goal", input);

          setTimeout(() => {
            window.location.href = "/bundles";
          }, 300);
        }
        </script>

        
</body>
</html>