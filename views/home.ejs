<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AQUIPLEX | Discover the Best AI Tools</title>

    <!-- GLOBAL STYLES -->
    <link rel="stylesheet" href="/css/styles.css">

    <!-- HOME PAGE STYLES -->
    <link rel="stylesheet" href="/css/home.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#020617">

    <!-- ICONS -->
    <link rel="icon" href="/logo/logo.png">
    <link rel="apple-touch-icon" href="/logo/icon-192.png">
  </head>

<body>

<%- include("partials/nav") %>

<!-- 🤖 FLOATING BUTTON -->
<div class="aqua-float" onclick="openAquaAI()">🤖</div>

<!-- 💬 AQUA AI POPUP -->
<div id="aquaPopup" class="aqua-popup hidden">
  <div class="popup-header">
    <span>🌊 Aqua AI</span>
    <button onclick="closeAquaAI()" ontouchstart="closeAquaAI()">✖</button>
  </div>

  <div class="popup-body">
    <p>Ask anything. Get powerful answers instantly ⚡</p>

    <a href="/chatbot" class="btn primary">
      Open Aqua AI
    </a>
  </div>
</div>

<!-- HERO -->
  <section class="hero new-hero">
    <div class="hero-glow"></div>

    <div class="hero-content">
      <h1>
        The AI OS for the Internet ⚡
      </h1>

      <p>
        Discover. Compare. Use AI tools — or just ask Aqua AI.
      </p>

      <div class="hero-buttons">
        <button onclick="openAquaAI()" class="btn primary">
          
          🚀 Start with Aqua AI
        </button>

        <a href="/tools" class="btn ghost">
          Explore 100+ Tools
        </a>
      </div>

      <div class="hero-stats">
        <span>🔥 10K+ Tools</span>
        <span>⚡ Instant AI Answers</span>
        <span>🌍 Global Users</span>
      </div>
    </div>
  </section>
 
  <section class="section">
    <h2 class="section-title">Why AQUIPLEX?</h2>

    <div class="features">

      <div class="feature-card">
        <h3>⚡ Instant AI Answers</h3>
        <p>No need to search multiple tools.</p>
      </div>

      <div class="feature-card">
        <h3>🧠 Smart Discovery</h3>
        <p>Find the best AI tools instantly.</p>
      </div>

      <div class="feature-card">
        <h3>🚀 All-in-One Platform</h3>
        <p>Everything AI in one place.</p>
      </div>

    </div>
  </section>
<!-- 🔥 TRENDING -->
<section class="section">
  <h2 class="section-title">🔥 Trending AI Tools</h2>
  <p class="section-sub">
    Discover what people are using right now
  </p>
</section>

<!-- MAIN CONTENT -->
<div class="container">

  <!-- CATEGORIES -->
  <section class="section">
    <h2 class="section-title">Explore by Category</h2>

    <div class="categories">

      <%    
      const categories = [    
        { name: "Writing AI", icon: "✍️" },    
        { name: "Image AI", icon: "🎨" },    
        { name: "Video AI", icon: "🎬" },    
        { name: "Coding AI", icon: "💻" },    
        { name: "ML AI", icon: "🤖" }    
      ];    

      categories.forEach(function(category){     
      %>    

      <a class="category-card" href="/tools/category/<%= encodeURIComponent(category.name) %>">
        <div class="category-icon"><%= category.icon %></div>
        <div class="category-name"><%= category.name %></div>
      </a>

      <% }) %>

    </div>
  </section>

  <!-- FEATURED TOOLS -->
  <section class="section">
    <h2 class="section-title">⭐ Featured Tools</h2>

    <div class="grid">

      <% if (tools && tools.length > 0) { %>

      <% tools.forEach(function(tool){ %>

      <div class="tool-card">

        <div class="logo-box">
          <img src="<%= tool.logo %>" alt="<%= tool.name %>">
        </div>

        <a href="/tool/<%= tool._id %>" class="tool-link">
          <h3><%= tool.name %></h3>
        </a>

        <p><%= tool.description %></p>

        <div class="tool-actions">
          <a href="/tool/<%= tool._id %>" class="details-btn">
            View Details
          </a>

          <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">
            Visit Tool
          </a>
        </div>

      </div>

      <% }) %>

      <% } else { %>
      <p style="text-align:center;">No tools available yet.</p>
      <% } %>

    </div>
  </section>

</div>

<!-- 📲 DOWNLOAD -->
        <section class="section final-cta">
          <h2>Start Using AI Smarter Today ⚡</h2>

          <div class="cta-buttons">
            <button onclick="openAquaAI()" class="btn primary big-btn">
              Try Aqua AI
            </button>

            <a href="/download" class="btn ghost big-btn">
              Download App
            </a>
          </div>
        </section>

<!-- FOOTER -->
<footer class="footer">
  <p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>
</footer>

<!-- JS -->
<script>
  function openAquaAI() {
    document.getElementById("aquaPopup").classList.remove("hidden");
  }

  function closeAquaAI() {
    const popup = document.getElementById("aquaPopup");
    popup.style.opacity = "0";
    popup.style.transform = "translateY(20px)";

    setTimeout(() => {
      popup.classList.add("hidden");
    }, 200);
  }

  // AUTO POPUP (conversion boost)
  setTimeout(() => {
    openAquaAI();
  }, 4000);
</script>
        <script>
          document.addEventListener("touchstart", function(){}, true);
        </script>


</body>
</html>