  <style>

  /* ── Build with Aquiplex section ── */
  .build-section {
    padding: 80px 24px;
    text-align: center;
  }
  .build-section-inner {
    max-width: 720px;
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(56,189,248,0.07) 0%, rgba(99,102,241,0.07) 100%);
    border: 1px solid rgba(56,189,248,0.18);
    border-radius: 20px;
    padding: 56px 40px;
    position: relative;
    overflow: hidden;
  }
  .build-section-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% -20%, rgba(56,189,248,0.12), transparent 65%);
    pointer-events: none;
  }
  .build-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #38bdf8;
    margin-bottom: 16px;
    background: rgba(56,189,248,0.1);
    border: 1px solid rgba(56,189,248,0.25);
    padding: 4px 14px;
    border-radius: 20px;
  }
  .build-heading {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    color: #f1f5f9;
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .build-heading span {
    background: linear-gradient(90deg, #38bdf8, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .build-desc {
    font-size: 1rem;
    color: #94a3b8;
    margin: 0 0 36px;
    line-height: 1.7;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .build-features {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 36px;
  }
  .build-feature-chip {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 0.82rem;
    color: #cbd5e1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 8px 14px;
  }
  .build-cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-workspace-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: linear-gradient(135deg, #38bdf8, #6366f1);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 0 24px rgba(56,189,248,0.4);
    transition: box-shadow 0.2s, transform 0.15s;
  }
  .btn-workspace-primary:hover {
    box-shadow: 0 0 36px rgba(56,189,248,0.6);
    transform: translateY(-2px);
  }
  .btn-workspace-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: rgba(255,255,255,0.04);
    color: #94a3b8;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    font-size: 0.95rem;
