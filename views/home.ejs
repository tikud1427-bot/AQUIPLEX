<!DOCTYPE html>    
<html lang="en">    

  <head>    

  <meta charset="UTF-8">    
    <meta name="viewport" content="width=device-width, initial-scale=1.0">    
  <title>AQUIPLEX | Discover the Best AI Tools</title>    

  <link rel="stylesheet" href="/css/styles.css">    

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">    

  <!-- ✅ PWA CONFIG (ADD THIS) -->    
  <link rel="manifest" href="/manifest.json">    
  <meta name="theme-color" content="#020617">    

  <!-- ✅ ICONS -->    
  <link rel="icon" href="/logo/logo.png">    
  <link rel="apple-touch-icon" href="/logo/icon-192.png">    

  </head>    

<body>    

  <%- include("partials/nav") %>    


<!-- HERO -->    

    <section class="hero hooked-hero">

      <div class="hero-main">

        <h1>
          Stop Searching. <span>Start Using AI.</span>
        </h1>

        <p class="hero-sub">
          One prompt → Multiple AI answers instantly ⚡
        </p>

        <!-- 🔥 MAIN AI BOX -->
        <div class="ai-box hero-ai">

          <form id="aiForm">
            <input 
              type="text" 
              id="aiPrompt" 
              placeholder="Ask anything... (e.g. startup idea)" 
              required
            >
            <button type="submit">Generate</button>
          </form>

        </div>

    
        <section class="section" id="history-container">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <h2 class="section-title">🕘 Recent Prompts</h2>
            <button class="history-toggle" onclick="toggleHistory()">
              🕘 View History
            </button>
          </div>

          <div id="history" class="history-list history-hidden">
            <p>Loading...</p>
          </div>
        </section>

        <!-- 🔥 CTA -->
        <div class="hero-cta">
          <a href="/tools" class="btn primary">Explore Tools</a>
          <a href="/trending" class="btn ghost">🔥 Trending</a>
        </div>

      </div>

    </section>

    <section class="section">
      <h2 class="section-title">⚡ AI Results</h2>

      <div id="aiResults" class="ai-grid">

        <!-- SMART -->
        <div class="ai-card">
          <h3>🧠 Smart</h3>
          <p id="smartText">Waiting...</p>

          <div class="ai-actions">
            <button onclick="copyText('smartText', this)">📋</button>
            <button onclick="shareText('smartText')">🔗</button>

            <div class="chat-box">
              <input id="smartInput" placeholder="Continue chat..." />
              <button onclick="continueChat('smart')">➤</button>
            </div>
          </div>

        <!-- CREATIVE -->
        <div class="ai-card">
          <h3>🎨 Creative</h3>
          <p id="creativeText">Waiting...</p>

          <div class="ai-actions">
            <button onclick="copyText('creativeText', this)">📋</button>
            <button onclick="shareText('creativeText')">🔗</button>

            <div class="chat-box">
              <input id="creativeInput" placeholder="Continue chat..." />
              <button type="button" onclick="continueChat('creative')">➤</button>
            </div>
          </div>

        <!-- FAST -->
        <div class="ai-card">
          <h3>⚡ Fast</h3>
          <p id="fastText">Waiting...</p>

          <div class="ai-actions">
            <button onclick="copyText('fastText', this)">📋</button>
            <button onclick="shareText('fastText')">🔗</button>

            <div class="chat-box">
              <input id="fastInput" placeholder="Continue chat..." />
              <button type="button" onclick="continueChat('fast')">➤</button>
            </div>
          </div>

      </div>
    </section>

    <section class="section">
      <h2 class="section-title">🔥 Trending AI Tools</h2>
      <p style="text-align:center; opacity:0.7;">
        Discover what everyone is using right now
      </p>
    </section>

    
    <div class="container">    

      <!-- CATEGORY SECTION -->    
      <section class="section">    
        <h2 class="section-title">Explore by Category</h2>    

        <div class="categories">    

          <%    
          const categories = [    
            { name: "Writing AI", icon: "✍️" },    
            { name: "Image AI", icon: "🎨" },    
            { name: "Video AI", icon: "🎬" },    
            { name: "Coding AI", icon: "💻" },    
            { name: "ML AI", icon: "🤖" }    
          ];    

          categories.forEach(function(category){     
          %>    

          <a class="category-card"    
             href="/tools/category/<%= encodeURIComponent(category.name) %>">    

            <div class="category-icon"><%= category.icon %></div>    
            <div class="category-name"><%= category.name %></div>    

          </a>    

          <% }) %>    

        </div>    
      </section>    


      <!-- FEATURED TOOLS -->    
      <section class="section">    

        <h2>Featured Tools</h2>    

        <div class="grid">    

          <% if (tools && tools.length > 0) { %>    

          <% tools.forEach(function(tool){ %>    

          <div class="tool-card">    

            <div class="logo-box">    
              <img src="<%= tool.logo %>" alt="<%= tool.name %>">    
            </div>    

            <a href="/tool/<%= tool._id %>" class="tool-link">    
              <h3><%= tool.name %></h3>    
            </a>    

            <p><%= tool.description %></p>    

            <div class="tool-actions">    

              <a href="/tool/<%= tool._id %>" class="details-btn">    
                View Details    
              </a>    

              <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">    
                Visit Tool    
              </a>    

            </div>    

          </div>    

          <% }) %>    

          <% } else { %>    

          <p style="text-align:center;">No tools available yet.</p>    

          <% } %>    

        </div>    

      </section>    

    </div>    

            <!-- INSTALL SECTION -->    
            <section class="section">    
              <h2 class="section-title">📲 How to Install</h2>    

              <div style="max-width:600px; margin:auto; text-align:center; opacity:0.9;">    
                <p>1. Download the APK</p>    
                <p>2. Open the file</p>    
                <p>3. Allow "Install from unknown sources"</p>    
                <p>4. Install & enjoy 🚀</p>    
              </div>    
            </section>    

            <!-- 📲 DOWNLOAD APP CTA -->
            <section class="section apk-section">
              <h2 class="section-title">🚀 Get AQUIPLEX App</h2>

              <div style="text-align:center; margin-top:20px;">
                <a href="/download" class="btn primary" style="font-size:18px; padding:14px 28px;">
                  📥 Download APK
                </a>

                <p style="margin-top:10px; opacity:0.7;">
                  Fast. Lightweight. Built for AI explorers.
                </p>
              </div>
            </section>

<!-- FOOTER -->    

     <footer class="footer">    
<p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>    

</footer>    


            <script>
              const chats = {
                smart: [],
                creative: [],
                fast: []
              };

          
              document.addEventListener("DOMContentLoaded", () => {

              const form = document.getElementById("aiForm");

              if (form) {
                form.addEventListener("submit", async (e) => {
                  e.preventDefault();

                  const prompt = document.getElementById("aiPrompt").value;

                  document.getElementById("smartText").innerText = "🧠 Thinking...";
                  document.getElementById("creativeText").innerText = "🎨 Creating...";
                  document.getElementById("fastText").innerText = "⚡ Answering...";

                  try {
                    // ✅ reset chats FIRST
                    chats.smart = [{ role: "user", content: prompt }];
                    chats.creative = [{ role: "user", content: prompt }];
                    chats.fast = [{ role: "user", content: prompt }];

                    const res = await fetch("/multi-generate", {
                      method: "POST",
                      headers: { "Content-Type": "application/json" },
                      body: JSON.stringify({
                        messages: chats.smart
                      })
                    });
                    const data = await res.json();

                   data.responses.forEach(r => {
                     if (r.model.includes("Smart")) {
                       chats.smart.push({ role: "assistant", content: r.output });
                       document.getElementById("smartText").innerText = r.output;
                     }

                     if (r.model.includes("Creative")) {
                       chats.creative.push({ role: "assistant", content: r.output });
                       document.getElementById("creativeText").innerText = r.output;
                     }

                     if (r.model.includes("Fast")) {
                       chats.fast.push({ role: "assistant", content: r.output });
                       document.getElementById("fastText").innerText = r.output;
                     }
                   });

                    loadHistory();

                  } catch (err) {
                    document.getElementById("smartText").innerText = "❌ Error";
                    document.getElementById("creativeText").innerText = "❌ Error";
                    document.getElementById("fastText").innerText = "❌ Error";
                  }
                });
              }

              async function loadHistory() {
                try {
                  const res = await fetch("/history");
                  const container = document.getElementById("history");

                  if (!container) return;

                  const text = await res.text();

                  // detect HTML (login page)
                  if (text.startsWith("<!DOCTYPE")) {
                    container.innerHTML = "<p>Login to see history</p>";
                    return;
                  }

                  const data = JSON.parse(text);

                  if (!data.length) {
                    container.innerHTML = "<p>No history yet</p>";
                    return;
                  }

                  container.innerHTML = data.slice(0, 5).map(item => `
                    <div class="history-item">
                      <p class="prompt">${item.prompt}</p>
                      <button onclick="reusePrompt('${item.prompt.replace(/'/g, "\\'")}')">
                        Reuse
                      </button>
                    </div>
                  `).join("");

                } catch (err) {
                  console.log(err);
                }
              }
              loadHistory();

            });

            /* REUSE */
            function reusePrompt(text) {
              const input = document.getElementById("aiPrompt");
              if (input) {
                input.value = text;
                input.focus();
              }
            }

            /* TOGGLE HISTORY */
              function toggleHistory() {
                const history = document.getElementById("history");
                const button = document.querySelector(".history-toggle");

                if (!history || !button) return;

                history.classList.toggle("history-show");
                history.classList.toggle("history-hidden");

                button.innerText = history.classList.contains("history-show")
                  ? "❌ Hide Recent Prompts"
                  : "🕘 Show Recent Prompts";
              }

            /* COPY */
              async function copyText(id, btn) {
                const el = document.getElementById(id);
                if (!el) return;

                const text = el.innerText.trim();

                if (!text || text === "Waiting...") {
                  alert("Nothing to copy yet!");
                  return;
                }

                try {
                  await navigator.clipboard.writeText(text);
                } catch {
                  // fallback
                  const textarea = document.createElement("textarea");
                  textarea.value = text;
                  document.body.appendChild(textarea);
                  textarea.select();
                  document.execCommand("copy");
                  document.body.removeChild(textarea);
                }

                if (btn) {
                  btn.innerText = "✅ Copied";
                  setTimeout(() => (btn.innerText = "Copy"), 2000);
                }
              }

            /* SHARE */
              async function shareText(id) {
                const el = document.getElementById(id);
                if (!el) return;

                const text = el.innerText.trim();

                if (!text || text === "Waiting...") {
                  alert("Nothing to share yet!");
                  return;
                }

                // ✅ TRY NATIVE SHARE
                if (navigator.share) {
                  try {
                    await navigator.share({
                      title: "Aquiplex AI Result",
                      text: text,
                      url: window.location.href
                    });
                    return;
                  } catch (err) {
                    console.log("Share cancelled or failed");
                  }
                }

                // ✅ FALLBACK 1 → COPY
                try {
                  await navigator.clipboard.writeText(text);
                  alert("📋 Copied! Now paste & share 🚀");
                } catch {
                  // ✅ FALLBACK 2 → WHATSAPP SHARE
                  const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(text)}`;
                  window.open(whatsappUrl, "_blank");
                }
              }

              async function continueChat(type) {
                const inputEl = document.getElementById(type + "Input");
                const input = inputEl.value;

                if (!input) return;

                const el = document.getElementById(type + "Text");

                // show user message immediately
                el.innerText += "\n\nYou: " + input;

                chats[type].push({
                  role: "user",
                  content: input
                });

                // show loading
                el.innerText += "\nAI: ⏳ Thinking...";

                try {
                  const res = await fetch("/multi-generate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                      messages: chats[type],
                      aiType: type
                    })
                  });

                  const data = await res.json();
                  const aiResponse = data.responses[0];

                  if (aiResponse) {
                    chats[type].push({
                      role: "assistant",
                      content: aiResponse.output
                    });

                    // replace last "Thinking..." with actual response
                    el.innerText = el.innerText.replace(
                      "⏳ Thinking...",
                      aiResponse.output
                    );
                  }

                  inputEl.value = "";

                } catch {
                  el.innerText += "\n❌ Error";
                }
              }
          
            </script>
  </body>    
</html>