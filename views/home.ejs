<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>AQUIPLEX | Discover the Best AI Tools</title>

<link rel="stylesheet" href="/css/styles.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

</head>

<body>

  <%- include("partials/nav") %>


<!-- HERO -->

    <section class="hero">

      <div class="hero-box">

        <h1>
          Discover the Future of <span>AI Tools</span>
        </h1>

        <p>
          Explore the best AI tools for productivity, creativity, and development — all in one place.
        </p>

        <!-- SEARCH -->
        <form action="/tools" method="GET" class="search-bar">
          <input 
            type="text" 
            name="q" 
            placeholder="Search AI tools like ChatGPT, Midjourney..." 
            required
          >
          <button type="submit">Search</button>
        </form>

      </div>

      <div class="ai-box">
        <form id="aiForm">
          <input type="text" id="aiPrompt" placeholder="Ask multiple AIs at once..." required>
          <button type="submit">Generate</button>
        </form>

        <div id="aiResults"></div>
      </div>
    </section>

    <div class="container">

      <!-- CATEGORY SECTION -->
      <section class="section">
        <h2 class="section-title">Explore by Category</h2>

        <div class="categories">

          <%
          const categories = [
            { name: "Writing AI", icon: "✍️" },
            { name: "Image AI", icon: "🎨" },
            { name: "Video AI", icon: "🎬" },
            { name: "Coding AI", icon: "💻" },
            { name: "ML AI", icon: "🤖" }
          ];

          categories.forEach(function(category){ 
          %>

          <a class="category-card"
             href="/tools/category/<%= encodeURIComponent(category.name) %>">

            <div class="category-icon"><%= category.icon %></div>
            <div class="category-name"><%= category.name %></div>

          </a>

          <% }) %>

        </div>
      </section>


      <!-- FEATURED TOOLS -->
      <section class="section">

        <h2>Featured Tools</h2>

        <div class="grid">

          <% if (tools && tools.length > 0) { %>

          <% tools.forEach(function(tool){ %>

          <div class="tool-card">

            <div class="logo-box">
              <img src="<%= tool.logo %>" alt="<%= tool.name %>">
            </div>

            <a href="/tool/<%= tool._id %>" class="tool-link">
              <h3><%= tool.name %></h3>
            </a>

            <p><%= tool.description %></p>

            <div class="tool-actions">

              <a href="/tool/<%= tool._id %>" class="details-btn">
                View Details
              </a>

              <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">
                Visit Tool
              </a>

            </div>

          </div>

          <% }) %>

          <% } else { %>

          <p style="text-align:center;">No tools available yet.</p>

          <% } %>

        </div>

      </section>

    </div>


<!-- FOOTER -->

     <footer class="footer">
<p>© <%= new Date().getFullYear() %> AQUIPLEX All rights reserved.</p>

</footer>

            <script>
            document.getElementById("aiForm").addEventListener("submit", async (e) => {
              e.preventDefault();

              const prompt = document.getElementById("aiPrompt").value;
              const resultsDiv = document.getElementById("aiResults");

              resultsDiv.innerHTML = "⏳ Generating responses from multiple AIs...";

              try {
                const res = await fetch("/multi-generate", {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({ prompt })
                });

                const data = await res.json();

                resultsDiv.innerHTML = "";

                // ❌ Safety check
                if (!data.responses) {
                  resultsDiv.innerHTML = "❌ Failed to get AI responses";
                  return;
                }

                data.responses.forEach(r => {
                  const div = document.createElement("div");
                  div.classList.add("ai-card");

                  // 🧠 Clean names instead of ugly model names
                  let modelName = "🤖 AI";
                  if (r.model.includes("llama")) modelName = "🧠 Smart AI";
                  else if (r.model.includes("mistral")) modelName = "🎨 Creative AI";
                  else if (r.model.includes("openchat")) modelName = "📚 Detailed AI";

                  div.innerHTML = `
                    <h3>
                      ${modelName}
                      ${r.model === data.recommended ? "🔥 AQUIPLEX Recommended" : ""}
                    </h3>
                    <p>${r.output}</p>
                  `;

                  resultsDiv.appendChild(div);
                });

              } catch (err) {
                console.error(err);
                resultsDiv.innerHTML = "❌ Something went wrong";
              }
            });
            </script>
</body>
</html>