  <script>
    // ── CURSOR ──
    (function() {
      const cursor = document.getElementById('cursor');
      const ring = document.getElementById('cursor-ring');
      if (!cursor || !ring) return;
      let mx = -100, my = -100, rx = -100, ry = -100;
      document.addEventListener('mousemove', function(e) {
        mx = e.clientX; my = e.clientY;
        cursor.style.left = mx + 'px';
        cursor.style.top = my + 'px';
      });
      function animRing() {
        rx += (mx - rx) * 0.12;
        ry += (my - ry) * 0.12;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(animRing);
      }
      animRing();
      document.addEventListener('mouseleave', function() {
        cursor.style.opacity = '0'; ring.style.opacity = '0';
      });
      document.addEventListener('mouseenter', function() {
        cursor.style.opacity = '1'; ring.style.opacity = '1';
      });
    })();

    // ── SCROLL REVEALS ──
    (function() {
      const els = document.querySelectorAll('.reveal');
      const io = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      els.forEach(function(el) { io.observe(el); });
    })();

    // ── HERO 3D TILT (desktop only) ──
    (function() {
      const visual = document.querySelector('.hero-visual');
      if (!visual || window.innerWidth < 768) return;
      const wrap = document.querySelector('.hero-visual-wrap');
      if (!wrap) return;
      wrap.addEventListener('mousemove', function(e) {
        const r = wrap.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        visual.style.transform = 'perspective(1200px) rotateY(' + (-x * 10 - 6) + 'deg) rotateX(' + (y * 6 + 2) + 'deg)';
      });
      wrap.addEventListener('mouseleave', function() {
        visual.style.transform = 'perspective(1200px) rotateY(-6deg) rotateX(2deg)';
      });
    })();

    // ── AQUA POPUP ──
    document.addEventListener("touchstart", function(){}, true);
    function openAquaAI() {
      const p = document.getElementById("aquaPopup");
      if (p) p.classList.remove("hidden");
    }
    function closeAquaAI() {
      const p = document.getElementById("aquaPopup");
      if (p) p.classList.add("hidden");
    }
    document.addEventListener("keydown", function(e) { if (e.key === "Escape") closeAquaAI(); });
    document.addEventListener("click", function(e) {
      const popup = document.getElementById("aquaPopup");
      const floatBtn = document.querySelector(".aqua-float");
      if (popup && !popup.classList.contains("hidden")) {
        if (!popup.contains(e.target) && !floatBtn.contains(e.target)) closeAquaAI();
      }
    });

    // ── ANIMATED CHAT TYPING (hero) ──
    (function() {
      const msgs = document.querySelectorAll('#heroChat .visual-msg');
      msgs.forEach(function(msg, i) {
        msg.style.opacity = '0';
        setTimeout(function() {
          msg.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          msg.style.transform = 'translateY(10px)';
          msg.style.opacity = '0';
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              msg.style.opacity = '1';
              msg.style.transform = 'translateY(0)';
            });
          });
        }, 800 + i * 600);
      });
    })();
  </script>

