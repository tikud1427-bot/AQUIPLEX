        <div class="build-feature-chip"><span aria-hidden="true">📦</span> Execution Bundles</div>
        <div class="build-feature-chip"><span aria-hidden="true">💾</span> Live File Editor</div>
        <div class="build-feature-chip"><span aria-hidden="true">↗</span> Instant Preview</div>
