<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AQUIPLEX | The AI Operating System</title>

  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/home.css">

  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">

  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#03050f">

  <!-- FAVICON (correct based on your files) -->
<link rel="icon" type="image/png" sizes="96x96" href="https://aquiplex.com/logo/favicon-96x96.png">
<link rel="icon" type="image/svg+xml" href="https://aquiplex.com/logo/favicon.svg">
<link rel="shortcut icon" href="https://aquiplex.com/logo/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="https://aquiplex.com/logo/apple-touch-icon.png">
</head>

<body>

  <!-- AMBIENT SYSTEM -->
  <div class="ambient">
    <div class="ambient-orb ambient-orb-1"></div>
    <div class="ambient-orb ambient-orb-2"></div>
    <div class="ambient-orb ambient-orb-3"></div>
  </div>
  <div class="grid-underlay"></div>

  <%- include("partials/nav") %>

  <!-- FLOAT BUTTON -->
  <button class="aqua-float" onclick="openAquaAI()">
    <span>💬</span>
    <span>Ask Aqua</span>
  </button>

  <!-- AQUA POPUP -->
  <div id="aquaPopup" class="aqua-popup hidden">
    <div class="popup-header">
      <span>🌊 Aqua AI</span>
      <button onclick="closeAquaAI()" ontouchstart="closeAquaAI()">✕</button>
    </div>
    <div class="popup-body">
      <p>Your AI operating system is ready. Ask anything — build anything.</p>
      <a href="/chatbot" class="btn-primary-os">
        Open Aqua AI →
      </a>
    </div>
  </div>

  <!-- ═══ HERO ═══ -->
  <section class="hero-os">

    <div class="status-chip">
      <span class="status-dot"></span>
      Aqua AI — Online & Ready
    </div>

    <h1 class="hero-headline">
      <span class="word-plain">You think it.</span>
      <span class="word-gradient">Aqua builds it.</span>
    </h1>

    <p class="hero-sub">
      The AI OS that turns raw ideas into real outcomes — instantly, intelligently, without friction.
    </p>

    <!-- COMMAND BAR -->
    <div class="command-dock">
      <div class="command-bar">
        <span class="command-icon">⚡</span>
        <input
          class="command-input"
          type="text"
          id="heroPrompt"
          placeholder="What do you want to build today?"
          autocomplete="off"
          spellcheck="false"
        >
        <button class="command-run" onclick="runHeroAI()">
          <span class="run-label">Generate</span>
          <span class="run-icon">→</span>
        </button>
      </div>

      <!-- SUGGESTION CHIPS -->
      <div class="suggestion-chips">
        <button class="chip" onclick="setPrompt('Build a startup roadmap')">🚀 Build a startup</button>
        <button class="chip" onclick="setPrompt('Create an app from scratch')">💻 Create an app</button>
        <button class="chip" onclick="setPrompt('Design a study plan')">📚 Study plan</button>
        <button class="chip" onclick="setPrompt('Automate my workflow')">⚙️ Automate workflow</button>
        <button class="chip" onclick="setPrompt('Grow my online presence')">📈 Grow online</button>
      </div>
    </div>

    <!-- HERO OUTPUT (hidden until used) -->
    <div class="hero-output-wrap" id="heroOutputWrap" style="display:none;">
      <div class="hero-output-box" id="heroOutput"></div>
    </div>

  </section>

  <hr class="os-divider">

  <!-- ═══ INTELLIGENCE LAYER ═══ -->
  <section class="intelligence-layer">
    <span class="section-eyebrow">Aqua Intelligence</span>
    <h2 class="section-heading">Not a tool. An operating system.</h2>
    <p class="section-body">
      Aqua AI doesn't just answer questions. It maps ideas to execution — combining reasoning, workflow generation, and the internet's best tools into one fluid experience.
    </p>

    <div class="capability-grid">

      <div class="capability-cell">
        <span class="cap-number">01</span>
        <span class="cap-icon">🧠</span>
        <div class="cap-title">Think in Systems</div>
        <p class="cap-desc">Turn vague goals into structured execution paths with multi-step reasoning.</p>
      </div>

      <div class="capability-cell">
        <span class="cap-number">02</span>
        <span class="cap-icon">⚡</span>
        <div class="cap-title">Execute Instantly</div>
        <p class="cap-desc">Generate full project workflows, content plans, and code — in seconds.</p>
      </div>

      <div class="capability-cell">
        <span class="cap-number">03</span>
        <span class="cap-icon">🌐</span>
        <div class="cap-title">Connect Everything</div>
        <p class="cap-desc">Surface the right AI tools for every step, curated from 100+ options.</p>
      </div>

    </div>
  </section>

  <hr class="os-divider">

  <!-- ═══ TRENDING TOOLS (dynamic from backend) ═══ -->
  <% if (tools && tools.length > 0) { %>
  <section class="tools-section">
    <span class="section-eyebrow">Trending Now</span>
    <h2 class="section-heading">Tools people are building with</h2>

    <div class="tools-grid">
      <% tools.slice(0, 4).forEach(function(tool){ %>
      <div class="tool-card-os">
        <img class="tool-logo-os" src="<%= tool.logo %>" alt="<%= tool.name %>">
        <div class="tool-name-os"><%= tool.name %></div>
        <p class="tool-desc-os"><%= tool.description %></p>
        <div class="tool-actions-os">
          <a href="/tool/<%= tool._id %>" class="tool-btn primary-tool">Details</a>
          <a href="/visit/<%= tool._id %>" target="_blank" class="tool-btn ghost-tool">Visit →</a>
        </div>
      </div>
      <% }) %>
    </div>
  </section>

  <hr class="os-divider">
  <% } %>

  <!-- ═══ FEATURED TOOLS (full list) ═══ -->
  <% if (tools && tools.length > 0) { %>
  <section class="tools-section">
    <span class="section-eyebrow">Full Directory</span>
    <h2 class="section-heading">Every AI tool, curated for you</h2>

    <%
    const categories = [
      { name: "Writing AI", icon: "✍️" },
      { name: "Image AI", icon: "🎨" },
      { name: "Video AI", icon: "🎬" },
      { name: "Coding AI", icon: "💻" },
      { name: "ML AI", icon: "🤖" }
    ];
    %>

    <div class="categories-os">
      <a class="category-pill explore-all" href="/categories">🌐 Explore All</a>
      <% categories.forEach(function(category){ %>
      <a class="category-pill" href="/tools/category/<%= category.name.toLowerCase().replace(/\s+/g, '-') %>">
        <%= category.icon %> <%= category.name %>
      </a>
      <% }) %>
    </div>

    <div class="tools-grid" style="margin-top: 32px;">
      <% tools.forEach(function(tool){ %>
      <div class="tool-card-os">
        <img class="tool-logo-os" src="<%= tool.logo %>" alt="<%= tool.name %>">
        <div class="tool-name-os"><%= tool.name %></div>
        <p class="tool-desc-os"><%= tool.description %></p>
        <div class="tool-actions-os">
          <a href="/tool/<%= tool._id %>" class="tool-btn primary-tool">Details</a>
          <a href="/visit/<%= tool._id %>" target="_blank" class="tool-btn ghost-tool">Visit →</a>
        </div>
      </div>
      <% }) %>
    </div>
  </section>

  <hr class="os-divider">
  <% } %>

  <!-- ═══ MEMORY SIGNAL ═══ -->
  <section class="memory-signal">
    <div class="memory-card">
      <div class="memory-icon-wrap">🧬</div>
      <p class="memory-text">
        <strong>Aqua learns with you.</strong> Every session, it gets more attuned to how you think and what you build.
      </p>
    </div>
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <section class="final-os">
    <div class="final-os-inner">
      <h2>Stop searching.<br>Start executing.</h2>
      <p>You have an idea. Aqua has everything else. Let's build.</p>
      <div class="final-actions">
        <button onclick="openAquaAI()" class="btn-primary-os">
          🚀 Open Aqua AI
        </button>
        <a href="/download" class="btn-ghost-os">
          📲 Get the App
        </a>
      </div>
    </div>
  </section>

  <%- include("partials/footer") %>

  <!-- JS -->
  <script>
    document.addEventListener("touchstart", function(){}, true);

    // Aqua popup
    function openAquaAI() {
      const popup = document.getElementById("aquaPopup");
      popup.classList.remove("hidden");
    }

    function closeAquaAI() {
      const popup = document.getElementById("aquaPopup");
      popup.classList.add("hidden");
    }

    // Auto-popup after delay
    setTimeout(openAquaAI, 4000);

    // Chip → input fill
    function setPrompt(text) {
      const input = document.getElementById("heroPrompt");
      input.value = text;
      input.focus();
    }

    // Hero AI handler
    function runHeroAI() {
      const input = document.getElementById("heroPrompt").value.trim();
      if (!input) return;

      const btn = document.querySelector(".command-run");
      btn.innerHTML = '<span class="run-label">Thinking</span><span class="run-icon">...</span>';
      btn.style.opacity = "0.7";

      localStorage.setItem("aqua_goal", input);

      setTimeout(() => {
        window.location.href = "/bundles";
      }, 350);
    }

    // Enter key on input
    document.getElementById("heroPrompt").addEventListener("keydown", function(e) {
      if (e.key === "Enter") runHeroAI();
    });

    // Cursor glow on hero
    (function() {
      const hero = document.querySelector(".hero-os");
      if (!hero) return;
      let glow = document.createElement("div");
      glow.style.cssText = "position:absolute;width:350px;height:350px;background:radial-gradient(circle,rgba(56,189,248,0.12),transparent 70%);pointer-events:none;border-radius:50%;transform:translate(-50%,-50%);z-index:0;transition:left 0.1s,top 0.1s;";
      hero.appendChild(glow);
      hero.addEventListener("mousemove", function(e) {
        const r = hero.getBoundingClientRect();
        glow.style.left = (e.clientX - r.left) + "px";
        glow.style.top = (e.clientY - r.top) + "px";
      });
    })();
  </script>

</body>
</html>
