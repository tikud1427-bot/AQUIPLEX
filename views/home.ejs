<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>AIDEX | Discover the Best AI Tools</title>

<link rel="stylesheet" href="/css/styles.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

</head>

<body>

  <%- include("partials/header") %>


<!-- HERO -->

    <section class="hero">
      <div class="hero-content">

        <h1>Discover the Best AI Tools</h1>

        <p>
          Explore powerful AI tools for writing, coding, design, and more —             all in one place.
        </p>

        <div class="hero-actions">
          <input type="text" placeholder="Search AI tools..." class="search-             box">
          <button class="btn btn-primary">Search</button>
        </div>

      </div>
    </section>


    <div class="container">

      <!-- CATEGORY SECTION -->
      <section class="section">
        <h2>Explore by Category</h2>

        <div class="categories">

          <%
          const categories = [
          "Writing AI",
          "Image AI",
          "Video AI",
          "Coding AI",
          "ML AI"
          ];

          categories.forEach(function(category){ 
          %>

          <a class="category-card"
          href="/tools/category/<%= encodeURIComponent(category) %>">
          <%= category %>
          </a>

          <% }) %>

        </div>
      </section>


      <!-- FEATURED TOOLS -->
      <section class="section">

        <h2>Featured Tools</h2>

        <div class="grid">

          <% if (tools && tools.length > 0) { %>

          <% tools.forEach(function(tool){ %>

          <div class="tool-card">

            <div class="logo-box">
              <img src="<%= tool.logo %>" alt="<%= tool.name %>">
            </div>

            <a href="/tool/<%= tool._id %>" class="tool-link">
              <h3><%= tool.name %></h3>
            </a>

            <p><%= tool.description %></p>

            <div class="tool-actions">

              <a href="/tool/<%= tool._id %>" class="details-btn">
                View Details
              </a>

              <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">
                Visit Tool
              </a>

            </div>

          </div>

          <% }) %>

          <% } else { %>

          <p style="text-align:center;">No tools available yet.</p>

          <% } %>

        </div>

      </section>

    </div>


<!-- FOOTER -->

     <footer class="footer">
<p>© <%= new Date().getFullYear() %> AIDEX. All rights reserved.</p>

</footer>


<!-- MOBILE MENU SCRIPT -->

<script>

document.addEventListener("DOMContentLoaded", function(){

const menuBtn = document.querySelector(".menu-toggle");
const mobileMenu = document.querySelector(".mobile-menu");
const overlay = document.querySelector(".menu-overlay");

if(menuBtn && mobileMenu){
  menuBtn.addEventListener("click", function(){
    mobileMenu.classList.toggle("active");
    if(overlay) overlay.classList.toggle("active");
  });
}

if(overlay && mobileMenu){
  overlay.addEventListener("click", function(){
    mobileMenu.classList.remove("active");
    overlay.classList.remove("active");
  });
}

});

</script>

</body>
</html>