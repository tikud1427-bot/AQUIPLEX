<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>🔥 Trending AI Tools | AIDEX</title>

  <link rel="stylesheet" href="/css/styles.css">

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- FAVICON (correct based on your files) -->
<link rel="icon" type="image/png" sizes="96x96" href="https://aquiplex.com/logo/favicon-96x96.png">
<link rel="icon" type="image/svg+xml" href="https://aquiplex.com/logo/favicon.svg">
<link rel="shortcut icon" href="https://aquiplex.com/logo/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="https://aquiplex.com/logo/apple-touch-icon.png">
</head>

<body>

  <!-- HEADER -->
  <%- include("partials/nav") %>

  <main class="container">

    <!-- PAGE TITLE -->
    <section class="section">
      <h1 style="margin-bottom:10px;">🔥 Trending AI Tools</h1>
      <p style="color:#94a3b8;">Most popular tools in the last 24 hours</p>
    </section>

    <!-- GRID -->
    <div class="grid">

      <% if (tools && tools.length > 0) { %>

        <% tools.forEach((tool, index) => { %>

          <div class="tool-card">

            <!-- TOP ROW -->
            <div class="tool-top">

              <!-- LOGO -->
              <img src="<%= tool.logo %>" alt="<%= tool.name %>" class="tool-logo">

              <!-- RANK -->
              <div class="rank">#<%= index + 1 %></div>

            </div>

            <!-- CONTENT -->
            <div class="tool-content">
              <h3><%= tool.name %></h3>

              <p class="tool-category"><%= tool.category %></p>

              <p><%= tool.description %></p>

              <p class="click-count">
                🔥 <%= tool.trendingScore || 0 %> clicks (24h)
              </p>
            </div>

            <!-- ACTIONS -->
            <div class="tool-footer">
              <a href="/tool/<%= tool._id %>" class="details-btn">Details</a>
              <a href="/visit/<%= tool._id %>" target="_blank" class="visit-btn">Visit</a>
            </div>

          </div>

        <% }) %>

      <% } else { %>

        <p style="text-align:center;">No trending tools yet.</p>

      <% } %>

    </div>

  </main>

  <!-- FOOTER -->
        <%- include("partials/footer") %>

</body>
</html>