<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🔥 Trending AI Tools | Aquiplex</title>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" sizes="96x96" href="https://aquiplex.com/logo/favicon-96x96.png">
  <link rel="icon" type="image/svg+xml" href="https://aquiplex.com/logo/favicon.svg">
  <link rel="shortcut icon" href="https://aquiplex.com/logo/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="https://aquiplex.com/logo/apple-touch-icon.png">
  <style>
    .trending-hero{text-align:center;padding:48px 0 32px}
    .trending-hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:700;margin-bottom:8px;color:#f1f5f9}
    .trending-hero h1 span{background:linear-gradient(135deg,#fb923c,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .trending-hero p{color:#94a3b8;font-size:.95rem}
    .live-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:#f87171;font-size:.72rem;font-weight:600;padding:4px 12px;border-radius:20px;margin-top:12px}
    .live-dot{width:7px;height:7px;background:#ef4444;border-radius:50%;animation:livepulse 1.2s ease-in-out infinite}
    @keyframes livepulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.85)}}

    .trending-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;margin-bottom:48px}

    .trend-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:22px;display:flex;flex-direction:column;gap:14px;position:relative;overflow:hidden;transition:all .25s}
    .trend-card::after{content:'';position:absolute;inset:0;opacity:0;transition:opacity .25s;pointer-events:none}
    .trend-card:hover{transform:translateY(-4px);box-shadow:0 16px 48px rgba(0,0,0,.35)}

    .trend-card:nth-child(1){border-color:rgba(251,191,36,.25)}
    .trend-card:nth-child(1):hover{box-shadow:0 16px 48px rgba(251,191,36,.12)}
    .trend-card:nth-child(2){border-color:rgba(148,163,184,.2)}
    .trend-card:nth-child(2):hover{box-shadow:0 16px 48px rgba(148,163,184,.1)}
    .trend-card:nth-child(3){border-color:rgba(251,146,60,.2)}
    .trend-card:nth-child(3):hover{box-shadow:0 16px 48px rgba(251,146,60,.1)}

    .card-header{display:flex;align-items:center;gap:14px}

    .rank-badge{display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:12px;font-size:1rem;font-weight:800;flex-shrink:0}
    .rank-1{background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#1a1a1a}
    .rank-2{background:linear-gradient(135deg,#94a3b8,#64748b);color:#fff}
    .rank-3{background:linear-gradient(135deg,#fb923c,#ea580c);color:#fff}
    .rank-other{background:rgba(255,255,255,.07);color:#64748b;font-size:.85rem}

    .tool-logo-wrap{position:relative;flex-shrink:0}
    .tool-logo-wrap img{width:52px;height:52px;border-radius:14px;object-fit:cover;border:1px solid rgba(255,255,255,.1)}
    .trending-fire{position:absolute;bottom:-4px;right:-4px;font-size:.75rem;line-height:1;background:#1a1a2e;border-radius:50%;padding:2px}

    .card-meta{flex:1;min-width:0}
    .card-meta h3{font-size:1rem;font-weight:600;color:#f1f5f9;margin:0 0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .card-meta .cat-tag{font-size:.7rem;font-weight:500;color:#60a5fa;background:rgba(96,165,250,.1);border-radius:6px;padding:2px 8px;display:inline-block}

    .score-row{display:flex;align-items:center;gap:8px}
    .score-bar-wrap{flex:1;height:4px;background:rgba(255,255,255,.08);border-radius:4px;overflow:hidden}
    .score-bar{height:100%;border-radius:4px;background:linear-gradient(90deg,#fb923c,#f472b6);transition:width .6s ease}
    .score-label{font-size:.72rem;color:#94a3b8;white-space:nowrap}
    .score-value{font-size:.72rem;font-weight:600;color:#fb923c;white-space:nowrap}

    .card-desc{font-size:.82rem;color:#94a3b8;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

    .card-footer{display:flex;align-items:center;gap:8px;padding-top:12px;border-top:1px solid rgba(255,255,255,.06);margin-top:auto}
    .details-btn{flex:1;text-align:center;padding:9px;border-radius:9px;font-size:.8rem;font-weight:500;color:#94a3b8;border:1px solid rgba(255,255,255,.1);background:transparent;text-decoration:none;transition:all .2s}
    .details-btn:hover{border-color:#60a5fa;color:#60a5fa}
    .open-btn{flex:1.4;text-align:center;padding:9px;border-radius:9px;font-size:.8rem;font-weight:700;color:#fff;background:linear-gradient(135deg,#fb923c,#f472b6);text-decoration:none;transition:opacity .2s,transform .1s;display:flex;align-items:center;justify-content:center;gap:6px}
    .open-btn:hover{opacity:.88;transform:translateY(-1px)}
    .stat-chip{display:flex;align-items:center;gap:4px;font-size:.72rem;color:#64748b;padding:8px 10px;border-radius:9px;border:1px solid rgba(255,255,255,.07);white-space:nowrap}
    .stat-chip i{font-size:.68rem}

    .empty-state{text-align:center;padding:80px 20px;color:#475569}
    .empty-state i{font-size:3rem;margin-bottom:20px;display:block;opacity:.4}
    .empty-state h3{font-size:1.2rem;color:#64748b;margin-bottom:8px}
    .empty-state p{font-size:.85rem}
    .empty-state a{color:#60a5fa;text-decoration:none}
    .empty-state a:hover{text-decoration:underline}

    @media(max-width:600px){.trending-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>

<%- include("partials/nav") %>

<main class="container">

  <section class="trending-hero">
    <h1>🔥 <span>Trending</span> AI Tools</h1>
    <p>Most-used tools in the last 24 hours, ranked by activity</p>
    <div class="live-badge">
      <div class="live-dot"></div>
      Live rankings
    </div>
  </section>

  <% if (tools && tools.length > 0) { %>

    <%
      var maxScore = Math.max.apply(null, tools.map(function(t){ return t.trendingScore || 0; }));
      if (maxScore === 0) maxScore = 1;
    %>

    <div class="trending-grid">
      <% tools.forEach(function(tool, index){ %>

        <div class="trend-card">

          <div class="card-header">

            <!-- Rank -->
            <div class="rank-badge <%=
              index === 0 ? 'rank-1' :
              index === 1 ? 'rank-2' :
              index === 2 ? 'rank-3' :
              'rank-other'
            %>">
              <%= index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : '#' + (index + 1) %>
            </div>

            <!-- Logo -->
            <div class="tool-logo-wrap">
              <img
                src="<%= tool.logo || '/logos/default.png' %>"
                alt="<%= tool.name %>"
                onerror="this.src='/logos/default.png'"
              >
              <% if (tool.trendingScore > 0) { %>
                <span class="trending-fire">🔥</span>
              <% } %>
            </div>

            <!-- Name + category -->
            <div class="card-meta">
              <h3><%= tool.name %></h3>
              <% if (tool.category) { %>
                <span class="cat-tag"><%= tool.category %></span>
              <% } %>
            </div>

          </div>

          <!-- Score bar -->
          <div class="score-row">
            <span class="score-value">🔥 <%= tool.trendingScore || 0 %></span>
            <div class="score-bar-wrap">
              <div class="score-bar" style="width:<%= Math.round(((tool.trendingScore || 0) / maxScore) * 100) %>%"></div>
            </div>
            <span class="score-label">clicks / 24h</span>
          </div>

          <!-- Description -->
          <p class="card-desc"><%= tool.description || 'No description available.' %></p>

          <!-- Footer -->
          <div class="card-footer">
            <a href="/tools/<%= tool._id %>" class="details-btn">
              <i class="fa-solid fa-circle-info"></i> Info
            </a>
            <a href="/visit/<%= tool._id %>" target="_blank" class="open-btn">
              Open Tool <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
            <div class="stat-chip">
              <i class="fa-solid fa-heart"></i>
              <%= tool.likes || 0 %>
            </div>
          </div>

        </div>

      <% }) %>
    </div>

  <% } else { %>
    <div class="empty-state">
      <i class="fa-solid fa-chart-line"></i>
      <h3>No trending tools yet</h3>
      <p>Tools gain trending status when users click them.<br><a href="/tools">Browse all tools →</a></p>
    </div>
  <% } %>

</main>

<%- include("partials/footer") %>

</body>
</html>
