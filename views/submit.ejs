<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Submit AI Tool | AQUIPLEX</title>

<link rel="stylesheet" href="/css/styles.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

</head>

<body>

<%- include('partials/nav') %>

<main class="container">

  <section class="section">

    <h1>Submit a Tool</h1>
    <p class="auth-subtitle">Share useful AI tools with the community</p>

    <form action="/submit" method="POST" enctype="multipart/form-data" class="submit-form">

      <input type="text" name="name" placeholder="Tool name" required>

      <input type="text" name="category" placeholder="Category (e.g. Writing AI)" required>

      <input type="url" name="url" placeholder="Website URL" required>

      <textarea name="description" rows="4" placeholder="Short description" required></textarea>

      <label>Upload Logo</label>
      <input type="file" name="logo" accept="image/*" required>

      <button type="submit">Submit Tool 🚀</button>

    </form>

  </section>

</main>

<%- include("partials/footer") %>

</body>
</html>
