<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing — Aquiplex</title>
  <meta name="description" content="Simple prepaid pricing for Aqua. Free credits every day, and one-time credit packs that never expire. No subscriptions.">
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>
<body class="px-page">

<%- include('partials/nav') %>

<div class="toast" id="toast"></div>

<!-- Hero -->
<section class="px-pricing-hero">
  <div class="px-container">
    <div class="px-badge px-badge-accent"><span class="px-badge-dot" aria-hidden="true"></span> Prepaid credits</div>
    <h1>Pay once. Build forever.</h1>
    <p>No subscriptions. No recurring charges. Buy credits when you need them — they never expire.</p>

    <div class="px-free-callout">
      <div>
        <h3>Free plan — always available</h3>
        <p><%= process.env.FREE_DAILY_CREDITS || 200 %> free credits every day, reset at midnight. No card required.</p>
      </div>
      <a href="/signup" class="px-btn px-btn-secondary">Start free</a>
    </div>
  </div>
</section>

<!-- Packs -->
<div class="packs-grid" id="packsGrid" style="margin-top:56px;">
  <div class="px-skel wide" style="height:220px;"></div>
  <div class="px-skel wide" style="height:220px;"></div>
  <div class="px-skel wide" style="height:220px;"></div>
  <div class="px-skel wide" style="height:220px;"></div>
</div>

<!-- Credit cost table -->
<section class="px-credit-table-sec">
  <h2>What credits cover</h2>
  <table class="px-table">
    <thead>
      <tr>
        <th>Action in Aqua</th>
        <th style="text-align:right;">Credits</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>Chat message</td><td style="text-align:right;">5</td></tr>
      <tr><td>Chat with file analysis</td><td style="text-align:right;">8</td></tr>
      <tr><td>Code review</td><td style="text-align:right;">10</td></tr>
      <tr><td>Code generation</td><td style="text-align:right;">20</td></tr>
      <tr><td>Section / component generation</td><td style="text-align:right;">15–20</td></tr>
      <tr><td>Feature update</td><td style="text-align:right;">25</td></tr>
      <tr><td>Image generation</td><td style="text-align:right;">30</td></tr>
      <tr><td>Deep research</td><td style="text-align:right;">40</td></tr>
      <tr><td>Full app generation</td><td style="text-align:right;">150</td></tr>
      <tr><td>Multi-agent orchestration</td><td style="text-align:right;">200</td></tr>
    </tbody>
  </table>
</section>

<%- include('partials/footer') %>

<script>
(function () {
  const RZP_KEY    = '<%= process.env.RAZORPAY_KEY_ID || "" %>';
  const USER_EMAIL = '<%= pricingUser?.email || "" %>';
  const USER_PHONE = '<%= pricingUser?.phone || "" %>';
  const IS_LOGGED  = !!USER_EMAIL;

  function fmt(n) { return Number(n).toLocaleString('en-IN'); }

  function showToast(msg, type = 'success') {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.className   = 'toast ' + type;
    clearTimeout(el._t);
    el._t = setTimeout(() => { el.className = 'toast'; }, 4200);
  }

  async function loadPacks() {
    try {
      const r = await fetch('/api/billing/packs');
      const d = await r.json();
      renderPacks(d.packs || []);
    } catch (e) {
      document.getElementById('packsGrid').innerHTML =
        '<div class="px-state" style="grid-column:1/-1;">Couldn\'t load credit packs right now. Please refresh in a moment.</div>';
    }
  }

  function renderPacks(packs) {
    const grid = document.getElementById('packsGrid');
    grid.innerHTML = packs.map(p => {
      const cpr  = (p.priceINR / p.credits * 100).toFixed(1);
      const badge = p.badge === 'MOST POPULAR'
        ? `<span class="popular-badge">Most popular</span>`
        : p.badge === 'BEST DEAL'
          ? `<span class="best-deal-badge">Best deal</span>`
          : '';

      return `<div class="pack-card ${p.badge === 'MOST POPULAR' ? 'popular' : ''}">
        ${badge}
        <div class="pack-price">₹${p.priceINR}</div>
        <div class="pack-credits-line">${fmt(p.credits)} credits</div>
        <div class="pack-name">${p.name}</div>
        <div class="pack-meta">₹${cpr} per 100 credits · never expires</div>
        <button class="btn-pack" onclick="buyPack('${p.id}', this)">
          ${IS_LOGGED ? 'Buy now' : 'Sign up to buy'}
        </button>
      </div>`;
    }).join('');
  }

  window.buyPack = async function (packId, btn) {
    if (!IS_LOGGED) {
      window.location.href = '/signup?next=/pricing';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Preparing…';

    try {
      const r = await fetch('/api/billing/create-order', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ packId }),
      });
      const d = await r.json();
      if (!d.success) throw new Error(d.message || 'Order creation failed');

      const order = d.order;

      const rzp = new Razorpay({
        key:         RZP_KEY,
        order_id:    order.orderId,
        amount:      order.amount,
        currency:    'INR',
        name:        'Aquiplex',
        description: order.packName + ' — ' + fmt(order.credits) + ' credits',
        image:       '/logo/favicon.ico',
        prefill: { email: USER_EMAIL, contact: USER_PHONE },
        theme:       { color: '#4fa3b8' },
        modal: {
          backdropclose: false,
          ondismiss() {
            btn.disabled = false;
            btn.textContent = 'Buy now';
          },
        },
        handler: async function (response) {
          btn.textContent = 'Verifying…';
          try {
            const vr = await fetch('/api/billing/verify-payment', {
              method:  'POST',
              headers: { 'Content-Type': 'application/json' },
              body:    JSON.stringify({
                razorpay_order_id:   response.razorpay_order_id,
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_signature:  response.razorpay_signature,
              }),
            });
            const vd = await vr.json();
            if (vd.success) {
              showToast(fmt(vd.credits) + ' credits added. Redirecting…');
              setTimeout(() => { window.location.href = '/wallet'; }, 1800);
            } else {
              showToast('Payment error: ' + (vd.error || 'Unknown'), 'error');
              btn.disabled = false;
              btn.textContent = 'Buy now';
            }
          } catch (e) {
            showToast('Verification failed. Contact support.', 'error');
            btn.disabled = false;
            btn.textContent = 'Buy now';
          }
        },
      });

      rzp.on('payment.failed', (resp) => {
        showToast('Payment failed: ' + (resp.error?.description || 'Try again'), 'error');
        btn.disabled = false;
        btn.textContent = 'Buy now';
      });

      rzp.open();

    } catch (e) {
      showToast(e.message || 'Something went wrong', 'error');
      btn.disabled = false;
      btn.textContent = 'Buy now';
    }
  };

  loadPacks();
})();
</script>

</body>
</html>
