<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= blog.title %> — Aquiplex Blog</title>
  <meta name="description" content="<%= (blog.description || 'Aquiplex blog').replace(/"/g, '') %>">
  <meta property="og:title" content="<%= blog.title %>">
  <meta property="og:description" content="<%= (blog.description || 'Aquiplex blog').replace(/"/g, '') %>">
  <meta property="og:type" content="article">
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "<%= blog.title %>",
  "author": {
    "@type": "Person",
    "name": "<%= blog.author || 'Guest Author' %>"
  },
  "datePublished": "<%= blog.createdAt %>",
  "description": "<%= (blog.description || '').replace(/"/g, '\\"') %>"
}
  </script>
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

<%- include("partials/nav") %>

<main style="padding:clamp(104px,15vw,132px) 0 clamp(80px,13vw,120px);">
  <article class="px-prose">
    <a href="/blogs" class="px-btn px-btn-ghost px-btn-sm" style="margin-bottom:26px;">← All posts</a>
    <h1><%= blog.title %></h1>
    <div class="px-blog-meta" style="margin-bottom:36px;">
      <%= blog.readTime %> · <%= blog.createdAt %><% if (blog.author) { %> · <%= blog.author %><% } %>
    </div>
    <div class="px-prose-body"><%= blog.content %></div>
  </article>
</main>

<%- include("partials/footer") %>

</body>
</html>
