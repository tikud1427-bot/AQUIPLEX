<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aquiplex — AI Workflows Made Simple</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="landing-page">

  <!-- 🔝 NAVBAR -->
  <header class="navbar">
    <div class="logo">⚡ Aquiplex</div>

    <div class="nav-right">
      <a href="/app" class="nav-btn">Use Now</a>
    </div>
  </header>

  <!-- 🚀 HERO -->
  <section class="hero">

    <!-- floating blur orbs -->
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>

    <h1>
      Build the Perfect <br>
      <span class="gradient-text">AI Workflow</span> for Anything
    </h1>

    <p>
      Tell us your goal — Aquiplex builds your perfect set of AI tools instantly.
    </p>

    <div class="hero-buttons">
      <a href="/app">
        <button class="primary-btn">🚀 Use Now — No Signup</button>
      </a>

      <button class="secondary-btn">▶ See How It Works</button>
    </div>

    <!-- 🔥 INTERACTIVE INPUT -->
    <div class="demo-box">
      <input id="demoInput" type="text" placeholder="Create a YouTube video..." readonly>
      <button>Generate</button>
    </div>

    <div class="examples">
      <span>Write an essay</span>
      <span>Start a business</span>
      <span>Grow on Instagram</span>
    </div>

  </section>

  <!-- 💡 HOW IT WORKS -->
  <section class="how-it-works">
    <h2>How It Works</h2>

    <div class="steps">

      <div class="step">
        <div class="step-icon">🎯</div>
        <h3>Tell Your Goal</h3>
        <p>Describe what you want to achieve in simple words.</p>
      </div>

      <div class="step">
        <div class="step-icon">⚙️</div>
        <h3>Get AI Bundle</h3>
        <p>We generate the best tools for your exact task.</p>
      </div>

      <div class="step">
        <div class="step-icon">🚀</div>
        <h3>Start Creating</h3>
        <p>Use tools instantly and get results faster.</p>
      </div>

    </div>
  </section>

  <!-- ✨ WHY -->
  <section class="why">
    <h2>Why Aquiplex?</h2>

    <div class="features">

      <div class="feature-card">
        <h3>⚡ Save Hours</h3>
        <p>No more searching. We do the work for you.</p>
      </div>

      <div class="feature-card">
        <h3>🧠 Smart AI</h3>
        <p>Real workflows, not random tool lists.</p>
      </div>

      <div class="feature-card">
        <h3>🧰 Workspace</h3>
        <p>Save and reuse your workflows anytime.</p>
      </div>

    </div>
  </section>

  <!-- 🌍 USE CASES -->
  <section class="use-cases">
    <h2>Use Cases</h2>

    <div class="use-grid">
      <div>🎥 YouTube Content</div>
      <div>📚 Study & Essays</div>
      <div>💼 Online Income</div>
      <div>📱 Social Growth</div>
      <div>🧑‍💻 Coding Projects</div>
    </div>
  </section>

  <!-- 🚀 CTA -->
  <section class="final-cta">

    <h2>Stop Searching. Start Creating.</h2>
    <p>Build your AI workflow in seconds.</p>

    <a href="/app">
      <button class="primary-btn big-btn">🚀 Use Now</button>
    </a>

  </section>

  <!-- 🧭 FOOTER -->
  <footer class="footer">
    <p>© 2026 Aquiplex</p>
  </footer>

  <!-- ✨ JS (TYPING EFFECT) -->
  <script>
    const texts = [
      "Create a YouTube video...",
      "Write an essay...",
      "Start an online business...",
      "Grow on Instagram..."
    ];

    let i = 0;
    const input = document.getElementById("demoInput");

    setInterval(() => {
      input.placeholder = texts[i];
      i = (i + 1) % texts.length;
    }, 2000);
  </script>

</body>
</html>