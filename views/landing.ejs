  <!-- Cursor glow -->
  <script>
    if (window.matchMedia('(pointer:fine)').matches) {
      var glow = document.getElementById('cursorGlow');
      var cx = 0, cy = 0, tx = 0, ty = 0;
      document.addEventListener('mousemove', function(e) { tx = e.clientX; ty = e.clientY; });
      (function loop() {
        cx += (tx - cx) * 0.08;
        cy += (ty - cy) * 0.08;
        glow.style.left = cx + 'px';
        glow.style.top  = cy + 'px';
        requestAnimationFrame(loop);
      })();
    }
  </script>

  <!-- Navbar scroll + Scroll reveal -->
  <script>
    (function() {
      var navbar = document.getElementById('navbar');
      window.addEventListener('scroll', function() {
        navbar.classList.toggle('scrolled', window.scrollY > 20);
      }, { passive: true });

      var revealEls = document.querySelectorAll('.reveal');
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.06 });
      revealEls.forEach(function(el) { obs.observe(el); });
    })();
  </script>

  <!-- Animated chat in hero visual -->
  <script>
    (function() {
      var chatBody = document.getElementById('chatBody');
      if (!chatBody) return;

      var convos = [
        [
          { from:'user', text:'Build me a SaaS landing page with auth and billing' },
          { from:'aqua', text:'On it. Scaffolding Next.js + Razorpay + Auth.js...', delay:1200 },
          { from:'code', lines:[
            '<span class="code-comment"># Generated in 11.2s</span>',
            '<span class="code-keyword">✓</span> <span class="code-string">pages/index.jsx</span> — Hero + CTA',
            '<span class="code-keyword">✓</span> <span class="code-string">api/auth.js</span> — Next-Auth config',
            '<span class="code-keyword">✓</span> <span class="code-fn">billing/webhook.js</span> — Razorpay'
          ], delay:2600 },
          { from:'aqua', text:'47 files ready. Live preview available.', delay:3800 }
        ],
        [
          { from:'user', text:'Write a pitch deck for my AI startup' },
          { from:'aqua', text:'Analyzing your context and building slide structure...', delay:1000 },
          { from:'aqua', text:'12-slide deck created: Problem → Solution → Market → Traction → Ask. Export to PDF?', delay:2400 }
        ],
        [
          { from:'user', text:'Explain quantum entanglement simply' },
          { from:'aqua', text:'Imagine two coins that always land opposite — no matter how far apart. That\'s entanglement: measuring one instantly determines the other.', delay:1100 },
          { from:'aqua', text:'Want me to go deeper into the Bell theorem or EPR paradox?', delay:2600 }
        ]
      ];

      var convoIndex = 0;

      function runConvo() {
        chatBody.innerHTML = '';
        var msgs = convos[convoIndex % convos.length];
        convoIndex++;

        // Typing indicator first
        var typingEl = createTypingIndicator();
        chatBody.appendChild(typingEl);
        setTimeout(function() { typingEl.classList.add('show'); }, 100);

        var baseDelay = 600;

        msgs.forEach(function(msg, i) {
          var delay = baseDelay + (msg.delay || i * 900);
          setTimeout(function() {
            if (i === 0) { typingEl.remove(); }

            var el = createMsgEl(msg);
            chatBody.appendChild(el);
            chatBody.scrollTop = chatBody.scrollHeight;

            setTimeout(function() { el.classList.add('show'); }, 40);

            // Show typing indicator between messages
            if (i < msgs.length - 1 && msgs[i+1] && msgs[i+1].from !== 'user') {
              var t2 = createTypingIndicator();
              chatBody.appendChild(t2);
              setTimeout(function() {
                t2.classList.add('show');
                chatBody.scrollTop = chatBody.scrollHeight;
              }, 80);
              setTimeout(function() { t2.remove(); }, (msgs[i+1].delay || 900) - (msg.delay || 0) - 200);
            }
          }, delay);
        });

        // Next convo
        var totalDuration = msgs.reduce(function(max, m) { return Math.max(max, m.delay || 0); }, 0) + baseDelay + 4200;
        setTimeout(runConvo, totalDuration);
      }

      function createTypingIndicator() {
        var wrap = document.createElement('div');
        wrap.className = 'chat-msg';
        wrap.innerHTML = '<div class="chat-avatar aqua">A</div><div class="chat-bubble aqua-bubble"><div class="typing-dots"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>';
        return wrap;
      }

      function createMsgEl(msg) {
        if (msg.from === 'code') {
          var el = document.createElement('div');
          el.className = 'chat-code';
          el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
          el.style.opacity = '0';
          el.style.transform = 'translateY(8px)';
          el.innerHTML = msg.lines.map(function(l) { return '<span class="code-line">' + l + '</span>'; }).join('');
          setTimeout(function() { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }, 40);
          return el;
        }
        var wrap = document.createElement('div');
        wrap.className = 'chat-msg';
        if (msg.from === 'user') {
          wrap.innerHTML = '<div class="chat-avatar user">U</div><div class="chat-bubble user-bubble">' + escHtml(msg.text) + '</div>';
        } else {
          wrap.innerHTML = '<div class="chat-avatar aqua">A</div><div class="chat-bubble aqua-bubble">' + escHtml(msg.text) + '</div>';
        }
        return wrap;
      }

      function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      setTimeout(runConvo, 800);
    })();
  </script>

