<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>About | AIDEX</title>

<link rel="stylesheet" href="/css/styles.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

/* HERO */
.about-hero {
  background: linear-gradient(135deg, #0f172a, #1e293b);
  color: white;
  padding: 80px 20px;
  text-align: center;
}

.about-hero h1 {
  font-size: 2.8rem;
  margin-bottom: 15px;
}

.about-hero p {
  color: #cbd5f5;
  max-width: 600px;
  margin: auto;
}

.hero-buttons {
  margin-top: 25px;
}

.hero-buttons a {
  margin: 0 10px;
}

/* SECTIONS */
.page-container {
  max-width: 1100px;
  margin: auto;
  padding: 60px 20px;
}

section {
  margin-bottom: 70px;
}

/* STATS */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 20px;
  text-align: center;
}

.stat {
  background: #0f172a;
  color: white;
  padding: 25px;
  border-radius: 12px;
}

.stat h2 {
  font-size: 2rem;
}

/* FEATURES */
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
}

.feature-card {
  background: #111827;
  color: white;
  padding: 25px;
  border-radius: 12px;
  transition: 0.3s;
}

.feature-card:hover {
  transform: translateY(-5px);
}

.feature-icon {
  font-size: 28px;
  margin-bottom: 10px;
}

/* TEAM */
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
}

.team-card {
  background: #111827;
  color: white;
  padding: 25px;
  border-radius: 12px;
  text-align: center;
}

.avatar {
  width: 60px;
  height: 60px;
  background: #6366f1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: auto;
  font-size: 22px;
  margin-bottom: 10px;
}

/* CTA */
.about-cta {
  text-align: center;
  background: #0f172a;
  color: white;
  padding: 50px;
  border-radius: 12px;
}

.primary-btn {
  background: #6366f1;
  color: white;
  padding: 12px 22px;
  border-radius: 8px;
  text-decoration: none;
}

.secondary-btn {
  border: 1px solid #6366f1;
  padding: 12px 22px;
  border-radius: 8px;
  color: white;
  text-decoration: none;
}

</style>

</head>

<body>

<%- include('partials/nav') %>

<!-- HERO -->
<section class="about-hero">
  <h1>Building the Future of AI Discovery</h1>
  <p>AIDEX helps you discover the best AI tools faster and smarter.</p>

  <div class="hero-buttons">
    <a href="/tools" class="primary-btn">Explore Tools</a>
    <a href="/submit" class="secondary-btn">Submit Tool</a>
  </div>
</section>

<main class="page-container">

<!-- STATS -->
<section>
  <div class="stats-grid">
    <div class="stat"><h2>500+</h2><p>Tools</p></div>
    <div class="stat"><h2>50+</h2><p>Categories</p></div>
    <div class="stat"><h2>10k+</h2><p>Users</p></div>
  </div>
</section>

<!-- MISSION -->
<section>
  <h2>Our Mission</h2>
  <p>We make AI discovery simple, fast, and accessible to everyone.</p>
</section>

<!-- FEATURES -->
<section>
  <h2>What We Do</h2>
  <div class="features-grid">

    <div class="feature-card">
      <div class="feature-icon">🔎</div>
      <h3>Discover</h3>
      <p>Find powerful AI tools instantly.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">🔥</div>
      <h3>Trending</h3>
      <p>See what's popular right now.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">⭐</div>
      <h3>Workspace</h3>
      <p>Save your favorite tools.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">📤</div>
      <h3>Submit</h3>
      <p>Share your AI tools.</p>
    </div>

  </div>
</section>

<!-- TEAM -->
<section>
  <h2>Team</h2>
  <div class="team-grid">

    <div class="team-card">
      <div class="avatar">A</div>
      <h3>Ananya</h3>
      <p>CEO</p>
    </div>

    <div class="team-card">
      <div class="avatar">C</div>
      <h3>Chhanda</h3>
      <p>Co-Founder</p>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="about-cta">
  <h2>Start Exploring</h2>
  <p>Join thousands discovering AI tools.</p>
  <a href="/tools" class="primary-btn">Browse Tools</a>
</section>

</main>

<%- include("partials/footer") %>

</body>
</html>