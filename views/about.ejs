<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO -->
  <title>About Aquiplex | Discover AI Tools Platform</title>
  <meta name="description" content="Aquiplex is the ultimate platform to discover, explore, and share AI tools. Find the best AI tools in one place.">
  <meta name="keywords" content="AI tools, artificial intelligence, AI directory, Aquiplex">
  <meta name="author" content="Aquiplex">

  <!-- Open Graph -->
  <meta property="og:title" content="Aquiplex - Discover AI Tools">
  <meta property="og:description" content="Explore the best AI tools in one place.">
  <meta property="og:image" content="/images/preview.png">
  <meta property="og:url" content="https://www.aquiplex.com">
  <meta property="og:type" content="website">

  <link rel="stylesheet" href="/css/styles.css">
  <!-- FAVICON (correct based on your files) -->
<link rel="icon" type="image/png" sizes="96x96" href="https://aquiplex.com/logo/favicon-96x96.png">
<link rel="icon" type="image/svg+xml" href="https://aquiplex.com/logo/favicon.svg">
<link rel="shortcut icon" href="https://aquiplex.com/logo/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="https://aquiplex.com/logo/apple-touch-icon.png">

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

  <!-- NAVBAR -->
  <%- include("partials/nav") %>

  <!-- HERO -->
  <section class="hero premium-hero">
    <div class="hero-content">
      <h1>Discover AI Tools Like Never Before</h1>
      <p>
        Explore, compare, and use the best AI tools in one powerful platform.
      </p>

      <div class="hero-buttons">
        <a href="/tools" class="btn primary">Explore Tools</a>
        <a href="/submit" class="btn secondary">Submit Tool</a>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="about-section">
    <div class="container">
      <h2>Our Mission</h2>
      <p>
        We aim to simplify AI for everyone. AQUIPLEX helps developers,
        creators, and businesses discover the right tools without
        wasting time.
      </p>

      <h2>Our Vision</h2>
      <p>
        To become the world's #1 AI discovery platform — where innovation
        meets simplicity.
      </p>
    </div>
  </section>

  <!-- WHY AQUIPLEX -->
  <section class="about-section">
    <div class="container">
      <h2>Why Aquiplex?</h2>
      <p>
        Unlike traditional AI directories, Aquiplex combines discovery,
        usability, and a real-time experience — helping users not just find
        tools, but actually use them seamlessly.
      </p>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-section">
    <div class="container stats-grid">
      <div class="stat-card">
        <h3 data-count="100">100+</h3>
        <p>AI Tools</p>
      </div>
      <div class="stat-card">
        <h3 data-count="10000">10K+</h3>
        <p>Users</p>
      </div>
      <div class="stat-card">
        <h3>24/7</h3>
        <p>Access</p>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="team-section">
    <div class="container">

      <h2>Leadership</h2>

      <div class="team-grid">

        <!-- CEO -->
        <div class="team-card premium-card">
          <div class="avatar gradient-avatar" aria-label="Ananya Prabal Das">A</div>
          <h3>Ananya Prabal Das</h3>
          <p class="role">CEO & Co-Founder</p>
          <p>
            Leading AQUIPLEX with vision and strategy, focused on making AI
            accessible and impactful for everyone.
          </p>
        </div>

        <!-- CO-FOUNDER -->
        <div class="team-card premium-card">
          <div class="avatar gradient-avatar" aria-label="Chhanda Prabal Das">C</div>
          <h3>Chhanda Prabal Das</h3>
          <p class="role">Co-Founder & Advisor</p>
          <p>
            Driving innovation, product development, and guiding the
            platform toward excellence.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <h2>Start Exploring AI Tools Today</h2>
    <a href="/tools" class="btn primary">Get Started</a>
  </section>

    <section class="about-links">

      <h2>Explore Aquiplex</h2>

      <div class="grid">

        <div class="card">
          <h3>Aqua AI</h3>
          <p>Generate content, code, and ideas using AI.</p>
          <a href="/aqua-ai">Learn more →</a>
        </div>

        <div class="card">
          <h3>Aqua Project Engine</h3>
          <p>Turn ideas into real projects with AI.</p>
          <a href="/aqua-project-engine">Explore →</a>
        </div>

        <div class="card">
          <h3>Meet the Founders</h3>
          <p>Learn about the vision behind Aquiplex.</p>
          <a href="/founders">Read story →</a>
        </div>

      </div>

    </section>

  <!-- FOOTER -->
    <%- include("partials/footer") %>

</body>
</html>