<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Something went wrong — Aquiplex</title>
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

  <main class="px-error-wrap">
    <p class="px-error-code">500</p>
    <h1>Something went wrong</h1>
    <p>An unexpected error occurred on our side. Your work is safe — please try again in a moment.</p>
    <div class="px-btn-row center">
      <a href="javascript:location.reload()" class="px-btn px-btn-primary">Try again</a>
      <a href="/" class="px-btn px-btn-secondary">Go home</a>
    </div>
  </main>


<script src="/js/sw-cleanup.js" defer></script>
</body>
</html>
