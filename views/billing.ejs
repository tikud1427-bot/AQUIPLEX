<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Billing &amp; credits — Aquiplex</title>
  <meta name="description" content="Manage your Aqua credits, daily usage, and transaction history.">
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

<%- include('partials/nav') %>

<div class="toast" id="toast"></div>

<main class="px-account">
  <div class="px-container" style="max-width:860px;">

    <div class="px-dash-head">
      <h1>Billing &amp; credits</h1>
      <p>Manage your Aqua credits and daily usage.</p>
    </div>

    <!-- Status error -->
    <div class="px-card px-state" id="status-error" style="display:none; margin-bottom:20px;">
      We couldn't load your billing information right now.
      <strong style="display:block; color:var(--px-text); margin-top:4px;">Basic chat is still available for free.</strong>
      <button class="px-btn px-btn-secondary px-btn-sm" onclick="loadStatus()">Retry</button>
    </div>

    <!-- Plan + credits -->
    <div class="px-stat-grid" style="margin-bottom:14px;">
      <div class="px-stat">
        <div class="px-stat-label">Current plan</div>
        <div style="margin:6px 0 8px;">
          <span class="px-badge" id="plan-badge">
            <%= ((typeof billingUser !== 'undefined' && billingUser ? billingUser.plan : (typeof user !== 'undefined' && user ? user.plan : null)) || 'free').toUpperCase() %>
          </span>
        </div>
        <div class="px-stat-sub" id="plan-status-text"><span class="px-skel"></span></div>
      </div>

      <div class="px-stat">
        <div class="px-stat-label">Aqua credits</div>
        <div class="px-stat-value" id="credits-val"><span class="px-skel"></span></div>
        <div class="px-stat-sub" id="credits-sub"><span class="px-skel"></span></div>
        <div class="px-bar-track"><div class="px-bar-fill" id="credits-fill"></div></div>
      </div>
    </div>

    <div class="px-stat-grid" style="margin-bottom:20px;">
      <div class="px-stat">
        <div class="px-stat-label">Free daily quota</div>
        <div class="px-stat-value" id="daily-val"><span class="px-skel"></span></div>
        <div class="px-stat-sub" id="daily-sub"><span class="px-skel"></span></div>
        <div class="px-bar-track"><div class="px-bar-fill" id="daily-fill"></div></div>
      </div>

      <div class="px-stat">
        <div class="px-stat-label">Free credits reset</div>
        <div class="px-stat-value" style="font-size:17px;" id="renewal-val"><span class="px-skel"></span></div>
        <div class="px-stat-sub" id="renewal-sub"><span class="px-skel"></span></div>
      </div>
    </div>

    <!-- Feature usage -->
    <div class="px-card px-card-pad" style="margin-bottom:20px;">
      <div class="px-stat-label" style="margin-bottom:2px;">Today's feature usage</div>
      <div class="px-stat-sub" style="margin-bottom:16px;">Free plan daily limits · resets at midnight</div>
      <div class="px-usage-grid" id="usage-grid">
        <div class="px-skel wide"></div>
        <div class="px-skel wide"></div>
        <div class="px-skel wide"></div>
      </div>
    </div>

    <!-- Actions -->
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:36px;">
      <a href="/pricing" class="px-btn px-btn-primary">Buy credits</a>
      <a href="/wallet" class="px-btn px-btn-secondary">Open wallet</a>
    </div>

    <!-- Transaction history -->
    <div class="px-card px-card-pad" style="margin-bottom:24px;">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:10px;">
        <div class="px-stat-label" style="margin:0;">Transaction history</div>
        <button class="px-btn px-btn-ghost px-btn-sm" id="history-retry-btn" onclick="loadHistory()" style="display:none;">Retry</button>
      </div>

      <div id="history-loading">
        <div class="px-skel wide"></div>
        <div class="px-skel wide"></div>
        <div class="px-skel wide"></div>
      </div>

      <div class="px-state" id="history-error" style="display:none;">
        Unable to load transaction history. Please try again in a moment.
        <br><button class="px-btn px-btn-secondary px-btn-sm" onclick="loadHistory()">Retry</button>
      </div>

      <div class="px-empty" id="history-empty" style="display:none;">
        No transactions yet. Credits you purchase or use will appear here.
      </div>

      <div id="history-table-wrap" style="display:none; overflow-x:auto;">
        <table class="px-table">
          <thead>
            <tr><th>Type</th><th>Credits</th><th>Status</th><th>Date</th></tr>
          </thead>
          <tbody id="history-body"></tbody>
        </table>
      </div>
    </div>

  </div>
</main>

<%- include('partials/footer') %>

<script>
// ── Utilities ──────────────────────────────────────────────────────────────────
function fetchWT(url, opts, ms) {
  ms = ms || 12000;
  var ctrl = new AbortController();
  var t = setTimeout(function () { ctrl.abort(); }, ms);
  var fetchOpts = Object.assign({ credentials: 'include', signal: ctrl.signal }, opts || {});
  return fetch(url, fetchOpts).then(function (res) {
    clearTimeout(t);
    return res;
  }).catch(function (err) {
    clearTimeout(t);
    throw err;
  });
}

function fmtDate(iso) {
  if (!iso) return '—';
  try { return new Date(iso).toLocaleDateString(undefined, { day: 'numeric', month: 'short' }); }
  catch (_) { return '—'; }
}
function fmtDateTime(iso) {
  if (!iso) return '—';
  try { return new Date(iso).toLocaleString(undefined, { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' }); }
  catch (_) { return '—'; }
}
function fmtNum(n) { return Number(n || 0).toLocaleString('en-IN'); }
function timeUntil(iso) {
  var ms = new Date(iso) - Date.now();
  if (isNaN(ms) || ms <= 0) return 'soon';
  var h = Math.floor(ms / 3600e3), m = Math.floor((ms % 3600e3) / 60e3);
  return h > 0 ? ('in ' + h + 'h ' + m + 'm') : ('in ' + m + 'm');
}
function showToast(msg, type) {
  var el = document.getElementById('toast');
  if (!el) return;
  el.textContent = msg;
  el.className = 'toast ' + (type || 'success');
  clearTimeout(el._t);
  el._t = setTimeout(function () { el.className = 'toast'; }, 4200);
}

var FEATURE_LABELS = {
  imageGen:    { label: 'Image generation' },
  codeMode:    { label: 'Code mode' },
  webSearch:   { label: 'Web search' },
  websiteGen:  { label: 'Website build' },
  websiteEdit: { label: 'Website edit' },
};

// ── Render status ──────────────────────────────────────────────────────────────
function renderStatus(b) {
  b = b || {};

  var badge = document.getElementById('plan-badge');
  if (badge) {
    var plan = (b.plan || 'free').toLowerCase();
    badge.className = 'px-badge' + (plan !== 'free' ? ' px-badge-accent' : '');
    badge.textContent = plan.toUpperCase();
  }

  var planText = document.getElementById('plan-status-text');
  if (planText) {
    planText.textContent = b.isUnlimited
      ? 'Unlimited access active'
      : 'Active — free credits reset at midnight';
  }

  var free = Number(b.freeCredits || 0);
  var paid = Number(b.paidCredits || 0);
  var total = free + paid;
  var freeDailyMax = Number(b.freeDailyMax || 200);

  var cv = document.getElementById('credits-val');
  if (cv) cv.textContent = fmtNum(total);

  var cs = document.getElementById('credits-sub');
  if (cs) cs.textContent = fmtNum(free) + ' free + ' + fmtNum(paid) + ' paid';

  var cf = document.getElementById('credits-fill');
  if (cf) {
    var pct = freeDailyMax > 0 ? Math.min(100, Math.round((free / freeDailyMax) * 100)) : 0;
    cf.style.width = pct + '%';
    cf.className = 'px-bar-fill' + (pct < 20 ? ' warning' : '');
  }

  var dailyUsage = b.dailyUsage || {};
  var freeLimits = b.freeLimits || {};
  var totalUsed = 0, totalLimit = 0;
  Object.keys(FEATURE_LABELS).forEach(function (key) {
    var info = dailyUsage[key] || {};
    totalUsed  += Number(info.used  || 0);
    totalLimit += Number(info.limit || freeLimits[key] || 0);
  });

  var dv = document.getElementById('daily-val');
  if (dv) dv.textContent = totalUsed + ' / ' + totalLimit;

  var ds = document.getElementById('daily-sub');
  if (ds) ds.textContent = 'features used today';

  var df = document.getElementById('daily-fill');
  if (df) {
    var dpct = totalLimit > 0 ? Math.min(100, Math.round((totalUsed / totalLimit) * 100)) : 0;
    df.style.width = dpct + '%';
    df.className = 'px-bar-fill' + (dpct >= 80 ? ' warning' : '');
  }

  var rv = document.getElementById('renewal-val');
  var rs = document.getElementById('renewal-sub');
  if (rv) rv.textContent = b.freeResetAt ? fmtDate(b.freeResetAt) : 'Daily';
  if (rs) rs.textContent = b.freeResetAt ? ('Resets ' + timeUntil(b.freeResetAt)) : 'Free credits reset at midnight';

  renderUsageGrid(dailyUsage, freeLimits);

  var se = document.getElementById('status-error');
  if (se) se.style.display = 'none';
}

function renderUsageGrid(dailyUsage, freeLimits) {
  var grid = document.getElementById('usage-grid');
  if (!grid) return;
  grid.innerHTML = '';

  Object.keys(FEATURE_LABELS).forEach(function (key) {
    var meta  = FEATURE_LABELS[key];
    var info  = dailyUsage[key] || {};
    var used  = Number(info.used  || 0);
    var limit = Number(info.limit || freeLimits[key] || 0);
    var rem   = Math.max(0, limit - used);
    var pct   = limit > 0 ? Math.min(100, Math.round((used / limit) * 100)) : 0;
    var full  = pct >= 100;

    var item = document.createElement('div');
    item.className = 'px-usage-item';
    item.innerHTML =
      '<div class="u-label">' + meta.label + '</div>' +
      '<div class="u-val">' + used + ' / ' + limit + '</div>' +
      '<div class="u-bar"><div class="u-fill' + (full ? ' full' : '') + '" style="width:' + pct + '%"></div></div>' +
      '<div class="u-note">' + (full ? 'Limit reached today' : (rem + ' remaining')) + '</div>';
    grid.appendChild(item);
  });
}

// ── Load status ────────────────────────────────────────────────────────────────
function clearSkeletons() {
  ['credits-val', 'daily-val', 'renewal-val'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el && el.querySelector('.px-skel')) el.textContent = '—';
  });
  ['credits-sub', 'daily-sub', 'renewal-sub', 'plan-status-text'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el && el.querySelector('.px-skel')) el.textContent = '';
  });
  var grid = document.getElementById('usage-grid');
  if (grid) grid.innerHTML = '';
}

function loadStatus() {
  var se = document.getElementById('status-error');
  if (se) se.style.display = 'none';

  fetchWT('/api/billing/status').then(function (res) {
    if (!res.ok) throw new Error('HTTP ' + res.status);
    return res.json();
  }).then(function (data) {
    if (data && data.success) {
      renderStatus(data.billing || {});
    } else {
      throw new Error('API error');
    }
  }).catch(function (err) {
    console.error('[Billing] status failed:', err.message || err);
    clearSkeletons();
    var se2 = document.getElementById('status-error');
    if (se2) se2.style.display = 'block';
  });
}

// ── Load history ───────────────────────────────────────────────────────────────
function loadHistory() {
  var loadEl   = document.getElementById('history-loading');
  var errEl    = document.getElementById('history-error');
  var emptyEl  = document.getElementById('history-empty');
  var tableEl  = document.getElementById('history-table-wrap');
  var retryBtn = document.getElementById('history-retry-btn');

  if (loadEl)  loadEl.style.display  = 'block';
  if (errEl)   errEl.style.display   = 'none';
  if (emptyEl) emptyEl.style.display = 'none';
  if (tableEl) tableEl.style.display = 'none';
  if (retryBtn) retryBtn.style.display = 'none';

  fetchWT('/api/billing/history?limit=30').then(function (res) {
    if (!res.ok) throw new Error('HTTP ' + res.status);
    return res.json();
  }).then(function (data) {
    if (loadEl) loadEl.style.display = 'none';
    if (!data || !data.success) throw new Error('API error');

    var history = Array.isArray(data.history) ? data.history : [];

    if (history.length === 0) {
      if (emptyEl) emptyEl.style.display = 'block';
      return;
    }

    var tbody = document.getElementById('history-body');
    if (!tbody) return;
    tbody.innerHTML = '';

    var typeLabels = {
      'debit':    'Used',
      'purchase': 'Purchased',
      'refund':   'Refund',
      'wallet':   'Wallet',
      'bonus':    'Bonus',
    };

    history.forEach(function (tx) {
      var type    = (tx.type || 'wallet').toLowerCase();
      var credits = Number(tx.credits || tx.amount || 0);
      var status  = (tx.status || 'completed').toLowerCase();
      var date    = fmtDateTime(tx.createdAt);

      var label = typeLabels[type] || (type.charAt(0).toUpperCase() + type.slice(1));
      var credDisplay = type === 'debit'
        ? '<span class="px-txn-debit">−' + fmtNum(Math.abs(credits)) + '</span>'
        : '<span class="px-txn-credit">+' + fmtNum(Math.abs(credits)) + '</span>';

      var tr = document.createElement('tr');
      tr.innerHTML =
        '<td>' + label + '</td>' +
        '<td>' + credDisplay + '</td>' +
        '<td><span class="status-pill ' + status + '">' + status + '</span></td>' +
        '<td>' + date + '</td>';
      tbody.appendChild(tr);
    });

    if (tableEl) tableEl.style.display = 'block';

  }).catch(function (err) {
    console.error('[Billing] history failed:', err.message || err);
    if (loadEl)  loadEl.style.display  = 'none';
    if (errEl)   errEl.style.display   = 'block';
    if (retryBtn) retryBtn.style.display = 'inline-flex';
  });
}

// ── Init ───────────────────────────────────────────────────────────────────────
loadStatus();
loadHistory();
</script>

</body>
</html>
