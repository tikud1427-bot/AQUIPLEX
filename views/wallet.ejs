<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wallet — Aquiplex</title>
  <meta name="description" content="Your Aqua credit wallet — free daily credits, purchased credits, and transaction history.">
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

<%- include('partials/nav') %>

<div class="toast" id="toast"></div>

<main class="px-account">
  <div class="px-container" style="max-width:860px;">

    <div class="px-dash-head">
      <h1>Wallet</h1>
      <p>Free credits reset every day at midnight. Purchased credits never expire.</p>
    </div>

    <!-- summary -->
    <div class="px-stat-grid" style="margin-bottom:20px;">
      <div class="px-stat">
        <div class="px-stat-label">Free credits today</div>
        <div class="px-stat-value" id="statFree"><span class="px-skel"></span></div>
        <div class="px-stat-sub" id="statFreeReset">Resets daily</div>
        <div class="px-bar-track"><div class="px-bar-fill" id="freeBar" style="width:0%"></div></div>
      </div>
      <div class="px-stat">
        <div class="px-stat-label">Purchased credits</div>
        <div class="px-stat-value" id="statPaid"><span class="px-skel"></span></div>
        <div class="px-stat-sub">Never expires</div>
      </div>
      <div class="px-stat">
        <div class="px-stat-label">Total available</div>
        <div class="px-stat-value" id="statTotal"><span class="px-skel"></span></div>
        <div class="px-stat-sub" id="statSpent"></div>
      </div>
    </div>

    <!-- how credits work -->
    <div class="px-card px-card-pad" style="display:flex; gap:16px; align-items:flex-start; margin-bottom:36px;">
      <div class="px-quick-icon" style="flex-shrink:0;"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1v6l4 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="8" cy="8" r="6.4" stroke="currentColor" stroke-width="1.2"/></svg></div>
      <div>
        <h3 style="font-size:14.5px; margin-bottom:4px;">How credits work</h3>
        <p style="font-size:13.5px; color:var(--px-text-2); margin:0; line-height:1.6;">
          Free credits are used first, then purchased credits. A chat message costs 5 credits, code generation 20, a full app build 150. See the <a href="/pricing" style="color:var(--px-accent-strong);">full credit table</a>.
        </p>
      </div>
    </div>

    <!-- buy credits -->
    <div class="px-dash-sec-head">
      <h2>Buy credits</h2>
      <span class="px-badge">One-time · no subscription</span>
    </div>
    <div class="packs-grid" id="packsGrid" style="padding:0; margin:0 0 44px;">
      <div class="px-skel wide" style="height:180px;"></div>
      <div class="px-skel wide" style="height:180px;"></div>
    </div>

    <!-- history -->
    <div class="px-dash-sec-head">
      <h2>Transaction history</h2>
    </div>
    <div class="px-card">
      <div id="txnLoading" style="padding:20px;">
        <div class="px-skel wide"></div>
        <div class="px-skel wide"></div>
        <div class="px-skel wide"></div>
      </div>
      <div class="px-state" id="txnError" style="display:none;">
        Couldn't load your history right now.
        <br><button class="px-btn px-btn-secondary px-btn-sm" onclick="loadHistory()">Retry</button>
      </div>
      <div class="px-empty" id="txnEmpty" style="display:none;">No transactions yet. Credits you purchase or use will appear here.</div>
      <div id="txnTableWrap" style="display:none; overflow-x:auto;">
        <table class="px-table">
          <thead>
            <tr><th>Type</th><th>Credits</th><th>Status</th><th>Date</th></tr>
          </thead>
          <tbody id="txnBody"></tbody>
        </table>
      </div>
    </div>

  </div>
</main>

<%- include('partials/footer') %>

<script>
(function () {
  function fmt(n) { return Number(n || 0).toLocaleString('en-IN'); }
  function fmtDateTime(iso) {
    if (!iso) return '—';
    try { return new Date(iso).toLocaleString(undefined, { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' }); }
    catch (_) { return '—'; }
  }
  function timeUntil(iso) {
    var ms = new Date(iso) - Date.now();
    if (isNaN(ms) || ms <= 0) return 'soon';
    var h = Math.floor(ms / 3600e3), m = Math.floor((ms % 3600e3) / 60e3);
    return h > 0 ? ('in ' + h + 'h ' + m + 'm') : ('in ' + m + 'm');
  }

  // ── Wallet summary ────────────────────────────────────────────────
  function loadStatus() {
    fetch('/api/billing/status', { credentials: 'include' })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var b = (d && d.billing) || {};
        var free = Number(b.freeCredits || 0);
        var paid = Number(b.paidCredits || 0);
        var max  = Number(b.freeDailyMax || 200);

        document.getElementById('statFree').textContent  = fmt(free);
        document.getElementById('statPaid').textContent  = fmt(paid);
        document.getElementById('statTotal').textContent = fmt(free + paid);
        document.getElementById('freeBar').style.width =
          (max > 0 ? Math.min(100, Math.round(free / max * 100)) : 0) + '%';
        if (b.freeResetAt) document.getElementById('statFreeReset').textContent = 'Resets ' + timeUntil(b.freeResetAt);
        if (b.totalSpent != null) document.getElementById('statSpent').textContent = fmt(b.totalSpent) + ' spent lifetime';
      })
      .catch(function () {
        ['statFree','statPaid','statTotal'].forEach(function (id) {
          document.getElementById(id).textContent = '—';
        });
      });
  }

  // ── Packs ─────────────────────────────────────────────────────────
  function loadPacks() {
    fetch('/api/billing/packs')
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var packs = (d && d.packs) || [];
        var grid = document.getElementById('packsGrid');
        grid.innerHTML = packs.map(function (p) {
          return '<div class="pack-card' + (p.badge === 'MOST POPULAR' ? ' popular' : '') + '">'
            + (p.badge === 'MOST POPULAR' ? '<span class="popular-badge">Most popular</span>' : '')
            + (p.badge === 'BEST DEAL' ? '<span class="best-deal-badge">Best deal</span>' : '')
            + '<div class="pack-price">₹' + p.priceINR + '</div>'
            + '<div class="pack-credits-line">' + fmt(p.credits) + ' credits</div>'
            + '<div class="pack-name">' + p.name + '</div>'
            + '<a class="btn-pack" style="display:block; text-align:center; text-decoration:none;" href="/pricing">Buy on pricing page</a>'
            + '</div>';
        }).join('');
      })
      .catch(function () {
        document.getElementById('packsGrid').innerHTML =
          '<div class="px-state" style="grid-column:1/-1;">Couldn\'t load packs. <a href="/pricing">Open pricing</a>.</div>';
      });
  }

  // ── History ───────────────────────────────────────────────────────
  window.loadHistory = function () {
    var loading = document.getElementById('txnLoading');
    var err     = document.getElementById('txnError');
    var empty   = document.getElementById('txnEmpty');
    var wrap    = document.getElementById('txnTableWrap');
    loading.style.display = 'block';
    err.style.display = 'none';
    empty.style.display = 'none';
    wrap.style.display = 'none';

    fetch('/api/billing/history?limit=30', { credentials: 'include' })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        loading.style.display = 'none';
        if (!d || !d.success) throw new Error('API error');
        var history = Array.isArray(d.history) ? d.history : [];
        if (!history.length) { empty.style.display = 'block'; return; }

        var labels = { debit: 'Used', purchase: 'Purchased', refund: 'Refund', wallet: 'Wallet', bonus: 'Bonus' };
        var body = document.getElementById('txnBody');
        body.innerHTML = '';
        history.forEach(function (tx) {
          var type = (tx.type || 'wallet').toLowerCase();
          var credits = Number(tx.credits || tx.amount || 0);
          var status = (tx.status || 'completed').toLowerCase();
          var tr = document.createElement('tr');
          tr.innerHTML =
            '<td>' + (labels[type] || type.charAt(0).toUpperCase() + type.slice(1)) + '</td>' +
            '<td>' + (type === 'debit'
              ? '<span class="px-txn-debit">−' + fmt(Math.abs(credits)) + '</span>'
              : '<span class="px-txn-credit">+' + fmt(Math.abs(credits)) + '</span>') + '</td>' +
            '<td><span class="status-pill ' + status + '">' + status + '</span></td>' +
            '<td>' + fmtDateTime(tx.createdAt) + '</td>';
          body.appendChild(tr);
        });
        wrap.style.display = 'block';
      })
      .catch(function () {
        loading.style.display = 'none';
        err.style.display = 'block';
      });
  };

  loadStatus();
  loadPacks();
  loadHistory();
})();
</script>

</body>
</html>
