<!DOCTYPE html>    
<html lang="en">    

<head>    
<meta charset="UTF-8">    
<meta name="viewport" content="width=device-width, initial-scale=1.0">    
<title>Workspace | AIDEX</title>    

<link rel="stylesheet" href="/css/styles.css">    
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">    
</head>    

<body>    

<%- include('partials/nav') %>    

<main class="container">    

  <!-- HEADER -->    
  <section class="workspace-header">
    <h1>Your Workspace</h1>
    <p>Quick access to your saved AI tools</p>
  </section>    

  <div id="active-tools" class="active-tools-panel"></div>

  <section class="bundle-section">
    <h2 class="section-title">Your AI Workflows</h2>

    <% if (bundles && bundles.length > 0) { %>
      <div class="bundle-grid">
        <% bundles.forEach(bundle => { %>
          <p class="bundle-preview">
            <%= bundle.steps.length %> steps • AI workflow
          </p>
          <div class="bundle-card" id="bundle-<%= bundle._id %>">
            <h3><%= bundle.title %></h3>

            <div class="bundle-actions">
              <button onclick='viewBundle(<%- JSON.stringify(bundle) %>)'>
                👀 View
              </button>

              <button onclick="removeBundle('<%= bundle._id %>')" class="remove-btn">
                ✖ Remove
              </button>
            </div>
          </div>
    <% } else { %>
      <p class="muted">No bundles saved yet</p>
    <% } %>
  </section>

 <!-- GRID -->    
  <div class="workspace-grid" id="workspaceGrid">    

  <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>    

    <% workspace.tools.forEach(function(tool){ %>    

    <div class="workspace-card" id="tool-<%= tool._id %>">    

      <!-- TOP -->    
      <div class="workspace-top">    
        <img     
          src="<%= tool.logo || '/logos/default.png' %>"     
          onerror="this.src='/logos/default.png'"     
          class="workspace-logo"    
          alt="<%= tool.name || 'Tool logo' %>"    
        >    
      </div>    

      <!-- CONTENT -->    
      <div class="workspace-content">    
        <h3><%= tool.name || 'Unnamed Tool' %></h3>

        <% if (tool.description) { %>
          <p class="tool-desc">
            <%= tool.description.substring(0, 80) %>...
          </p>
        <% } else { %>
          <p class="tool-desc muted">No description available</p>
        <% } %>
      </div>    

      <!-- ACTIONS -->    
      <div class="workspace-actions">    

        <button     
          class="launch-btn"   
          onclick="launchTool('<%= tool.name %>', '<%= tool.url || '' %>')"
         >    
          🚀 Launch    
        </button>    

        <button     
          onclick="removeTool('<%= tool._id %>')"     
          class="remove-btn"    
        >    
          ✖ Remove    
        </button>    

      </div>    

    </div>    

    <% }) %>    

  <% } else { %>    

    <div class="empty-workspace" id="emptyState">    
      <h2>No tools saved</h2>    
      <p>Add tools from the tools page to build your workspace</p>    
      <a href="/tools" class="browse-tools-btn">Browse Tools</a>    
    </div>    

  <% } %>    

  </div>    

</main>    


    <!-- 🔥 FAKE BROWSER -->
    <div id="workspace-browser" class="browser hidden">

      <div class="browser-top">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <div class="address-bar" id="browser-url">Loading...</div>
      </div>

      <div class="browser-body">
        <div class="browser-loading">
          <div class="spinner"></div>
          <p>Launching AI tool...</p>
        </div>
      </div>

    </div> <!-- ✅ THIS LINE WAS MISSING -->

    <!-- ✅ SCRIPT STARTS HERE -->
      <script>

      const activeTools = {};

      // 🚀 Launch Tool
      function launchTool(name, url){
        if(!url){
          alert("No URL found");
          return;
        }

        if(!url.startsWith("http")){
          url = "https://" + url;
        }

        const browser = document.getElementById("workspace-browser");
        const urlBar = document.getElementById("browser-url");

        browser.classList.remove("hidden");
        urlBar.innerText = url;

        activeTools[name] = { url };
        saveTools(); // ✅ persist

        setTimeout(() => {
          window.open(url, "_blank");
          browser.classList.add("hidden");
          updateWorkspaceUI();
        }, 500);
      }

      // 🔁 Resume tool
      function resumeTool(url){
        window.open(url, "_blank");
      }

      // ❌ Close tool
      function closeTool(name){
        delete activeTools[name];
        saveTools(); // ✅ persist
        updateWorkspaceUI();
      }

      // 🧠 Render active tools (TABS UI)
      function updateWorkspaceUI(){
        const container = document.getElementById("active-tools");
        container.innerHTML = "";

        Object.keys(activeTools).forEach(name => {
          const tool = activeTools[name];

          const div = document.createElement("div");
          div.className = "active-tool";

          div.innerHTML = `
            <span>🧠 ${name}</span>
            <div class="tab-actions">
              <button onclick="resumeTool('${tool.url}')">Open</button>
              <button onclick="closeTool('${name}')">✕</button>
            </div>
          `;

          container.appendChild(div);
        });
      }

      // 💾 Save tools
      function saveTools(){
        localStorage.setItem("activeTools", JSON.stringify(activeTools));
      }

      // 🔄 Load tools on refresh
      window.addEventListener("load", () => {
        const saved = localStorage.getItem("activeTools");

        if(saved){
          Object.assign(activeTools, JSON.parse(saved));
        }

        updateWorkspaceUI();
      });

      // 🗑️ Remove Tool (your existing feature)
      async function removeTool(toolId){
        try {
          const res = await fetch("/workspace/remove/" + toolId, {
            method: "POST"
          });

          if(res.ok){
            const card = document.getElementById("tool-" + toolId);

            if(card){
              card.style.transition = "all 0.3s ease";
              card.style.opacity = "0";
              card.style.transform = "scale(0.8)";

              setTimeout(() => {
                card.remove();

                const grid = document.getElementById("workspaceGrid");
                const remaining = grid.querySelectorAll(".workspace-card");

                if(remaining.length === 0){
                  grid.innerHTML = `
                    <div class="empty-workspace">
                      <h2>No tools saved</h2>
                      <p>Add tools from the tools page</p>
                      <a href="/tools" class="browse-tools-btn">Browse Tools</a>
                    </div>
                  `;
                }

              }, 300);
            }

          } else {
            alert("Failed to remove tool");
          }

        } catch (err){
          console.error(err);
          alert("Error removing tool");
        }
      }

        function viewBundle(bundle){
          let html = `<h2>${bundle.title}</h2>`;

          bundle.steps.forEach(step => {
            html += `
              <div class="step">
                <h3>${step.title}</h3>
                <p>${step.description}</p>
              </div>
            `;
          });

          document.body.innerHTML += `
            <div class="modal">
              ${html}
            </div>
          `;// later upgrade to modal UI
        }

        async function removeBundle(id){
          if(!confirm("Remove this bundle?")) return;

          try {
            const res = await fetch("/bundle/remove/" + id, {
              method: "POST"
            });

            if(res.ok){
              const card = document.getElementById("bundle-" + id);

              card.style.opacity = "0";
              card.style.transform = "scale(0.9)";

              setTimeout(() => card.remove(), 300);

            } else {
              alert("Failed to remove bundle");
            }

          } catch(err){
            console.error(err);
            alert("Error removing bundle");
          }
        }

      </script>

    </body>
    </html>