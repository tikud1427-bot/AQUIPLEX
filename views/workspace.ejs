/* ═══════════════════════════════════════════════════════
   MEMORY / INSIGHT / OUTPUT PANELS
═══════════════════════════════════════════════════════ */
function renderMemoryPanel(b) {
  const mem  = b.memory || {};
  const keys = Object.keys(mem);
  document.getElementById("memBundleCount").textContent = keys.length + " keys";
  document.getElementById("memBundleEntries").innerHTML = keys.length
    ? keys.map(k => `
        <div class="aq-mem-kv">
          <div class="aq-mem-k">${esc(k)}</div>
          <div class="aq-mem-v">${esc(String(mem[k] ?? ""))}</div>
        </div>`).join("")
    : `<div class="aq-empty" style="padding:8px 0;font-size:0.64rem;">No bundle memory yet.</div>`;

  if (b.contextSummary) {
    document.getElementById("memContextBox").textContent     = b.contextSummary;
    document.getElementById("memContextBox").style.display   = "";
    document.getElementById("memContextEmpty").style.display = "none";
  } else {
    document.getElementById("memContextBox").style.display   = "none";
    document.getElementById("memContextEmpty").style.display = "";
  }
  renderWsMemory();
}

function renderWsMemory() {
  const wsM    = STATE.wsMemory || {};
  const wsKeys = Object.keys(wsM);
  document.getElementById("memWsCount").textContent = wsKeys.length + " keys";
  document.getElementById("memWsEntries").innerHTML = wsKeys.length
    ? wsKeys.map(k => `
        <div class="aq-mem-kv" style="border-left-color:var(--accent3)">
          <div class="aq-mem-k" style="color:var(--accent3)">${esc(k)}</div>
          <div class="aq-mem-v">${esc(String(wsM[k] ?? ""))}</div>
        </div>`).join("")
    : `<div class="aq-empty" style="padding:8px 0;font-size:0.64rem;">No workspace memory yet.</div>`;
}

function renderInsightPanel(b) {
  const outputs = Array.isArray(b.outputs) ? b.outputs : [];
  const all = [];
  outputs.forEach(o => {
    (o && o.keyInsights ? o.keyInsights : []).forEach(k => {
      if (k) all.push({ text: k, confidence: o.confidenceScore || 0 });
    });
  });
  all.sort((a, b) => b.confidence - a.confidence);
  document.getElementById("insightList").innerHTML = all.length
    ? all.map(({ text, confidence }) => {
        const badge = confidence
          ? `<span style="font-family:var(--mono);font-size:0.56rem;color:var(--accent2);margin-left:auto;flex-shrink:0;">${Math.round(confidence*100)}%</span>`
          : "";
        return `<div class="aq-insight-item">${esc(text)}${badge}</div>`;
      }).join("")
    : `<div class="aq-empty">Insights from step outputs will appear here.</div>`;
}

function renderOutputFeed(outputs) {
  const feed = document.getElementById("outputFeed");
  if (!outputs || !outputs.length) { feed.innerHTML = `<div class="aq-empty">No outputs yet.</div>`; return; }
  feed.innerHTML = outputs.map(o => `
    <div class="aq-feed-item">
      <div class="aq-feed-meta">
        <span class="aq-feed-step">Step ${(o.stepIndex ?? 0) + 1}${o.stepTitle ? ' · ' + esc(o.stepTitle) : ''}</span>
        <span class="aq-feed-bundle">${esc(o.bundleTitle || '')}</span>
      </div>
      <div class="aq-feed-preview">${esc(o.preview || o.content || '')}</div>
    </div>`).join("");
}

function prependOutputFeed(bundleTitle, stepIndex, stepTitle, content) {
  const feed  = document.getElementById("outputFeed");
  const empty = feed.querySelector(".aq-empty");
  if (empty) empty.remove();
  const item = document.createElement("div");
  item.className = "aq-feed-item aq-feed-item-new";
  item.innerHTML = `
    <div class="aq-feed-meta">
      <span class="aq-feed-step">Step ${stepIndex + 1}${stepTitle ? ' · ' + esc(stepTitle) : ''}</span>
      <span class="aq-feed-bundle">${esc(bundleTitle)}</span>
    </div>
    <div class="aq-feed-preview">${esc((content || '').substring(0, 240))}</div>`;
  feed.prepend(item);
  requestAnimationFrame(() => item.classList.add("visible"));
}

/* ═══════════════════════════════════════════════════════
   DOM HELPERS
═══════════════════════════════════════════════════════ */
function updateBreadcrumb(title) { document.getElementById("topBreadcrumb").textContent = title || "Bundle"; }
function updatePinBtn(id) {
  const el = document.getElementById("btnPin");
  if (el) el.textContent = STATE.pinnedIds.some(p => String(p) === String(id)) ? "★ PIN" : "☆ PIN";
}
function updateBundleRowDot(id, status) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const dot = row.querySelector(".aq-dot");
  if (!dot) return;
  dot.className = "aq-dot " + (
    status === "active"    ? "aq-dot-active"    :
    status === "paused"    ? "aq-dot-paused"    :
    status === "completed" ? "aq-dot-completed" : "aq-dot-draft"
  );
}
function updateBundleRowProgress(id, bundle) {
  const row  = document.getElementById("brow-" + id);
  if (!row) return;
  const steps = Array.isArray(bundle.steps)    ? bundle.steps    : [];
  const prog  = Array.isArray(bundle.progress) ? bundle.progress : [];
  const done  = prog.filter(p => p && p.status === "completed").length;
  const pct   = steps.length ? Math.round((done / steps.length) * 100) : 0;
  const fill  = row.querySelector(".aq-bundle-fill");
  const pctEl = row.querySelector(".aq-bundle-pct");
  if (fill)  fill.style.width  = pct + "%";
  if (pctEl) pctEl.textContent = pct + "%";
  updateBundleRowDot(id, bundle.status);
}
function launchTool(url) {
  if (!url) return;
  if (!url.startsWith("http")) url = "https://" + url;
  window.open(url, "_blank", "noopener,noreferrer");
}

/* ═══════════════════════════════════════════════════════
   SANITIZATION & FORMATTING
═══════════════════════════════════════════════════════ */
function esc(str) {
  if (str == null) return "";
  return String(str)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}
function formatOutput(text) {
  if (!text) return "";
  return esc(text)
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/^## (.+)$/gm, '<span class="aq-out-h2">$1</span>')
    .replace(/^- (.+)$/gm, '<span class="aq-out-li">• $1</span>')
    .replace(/`([^`]+)`/g, '<code class="aq-out-code">$1</code>')
    .replace(/\n/g, "<br/>");
}

/* ═══════════════════════════════════════════════════════
   TOAST
═══════════════════════════════════════════════════════ */
function toast(msg, type = "info") {
  const root = document.getElementById("aq-toast-root");
  const el   = document.createElement("div");
  el.className   = `aq-toast ${type}`;
  el.textContent = msg;
  root.appendChild(el);
  setTimeout(() => {
    el.classList.add("fadeout");
    setTimeout(() => el.remove(), 320);
  }, 3000);
}

