<script>
// ── AGENT PANEL ──────────────────────────────────────────────────────────────

function showAgentPanel() {
  const panel = document.getElementById("agentPanel");
  if (panel) { panel.classList.remove("hidden"); }
}

function hideAgentPanel() {
  const panel = document.getElementById("agentPanel");
  if (panel) { panel.classList.add("hidden"); }
}

function logAgentEvent(event) {
  showAgentPanel();
  const log  = document.getElementById("agentLog");
  if (!log) return;

  const agentKey  = (event.agent || "system").replace(/-agent$/, "").split("-")[0];
  const statusCls = event.status === "done" || event.status === "complete" ? "done"
    : event.status === "error" ? "error"
    : event.status === "started" ? "started"
    : "";

  const el = document.createElement("div");
  el.className = "ap-event";
  el.innerHTML = `
    <span class="ap-badge ${agentKey}">${agentKey}</span>
    <div>
      <div class="ap-text">${event.detail || ""}</div>
      <div class="ap-status ${statusCls}">${event.status}</div>
    </div>`;
  log.appendChild(el);
  log.scrollTop = log.scrollHeight;
}

// ── AGENT-GEN (streaming) ────────────────────────────────────────────────────

async function runAgentGen(projectId, prompt) {
  if (!projectId || !prompt) return;
  document.getElementById("agentLog").innerHTML = "";
  showAgentPanel();

  const url = `/workspace/project/${encodeURIComponent(projectId)}/agent-gen/stream`;
  try {
    const res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify({ prompt }),
    });

    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    const reader  = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = "";

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });
      const lines = buf.split("\n");
      buf = lines.pop() || "";

      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed.startsWith("data:")) continue;
        const payload = trimmed.slice(5).trim();
        if (!payload || payload === "[DONE]") continue;
        try {
          const ev = JSON.parse(payload);
          if (ev.type === "status")      logAgentEvent(ev);
          if (ev.type === "files_saved") logAgentEvent({ agent: "system", status: "saved", detail: `${ev.count} files written` });
          if (ev.type === "complete") {
            logAgentEvent({ agent: "system", status: "complete", detail: `Done in ${(ev.durationMs/1000).toFixed(1)}s` });
            setTimeout(() => { if (typeof loadProject === "function") loadProject(ev.projectId); }, 800);
          }
          if (ev.type === "error") logAgentEvent({ agent: "system", status: "error", detail: ev.message });
        } catch {}
      }
    }
  } catch (e) {
    logAgentEvent({ agent: "system", status: "error", detail: e.message });
  }
}

// ── PLAN VIEWER ──────────────────────────────────────────────────────────────

async function viewProjectPlan() {
  if (!STATE.projectId) { toast("No project open", "error"); return; }
  try {
    const res = await fetch(`/workspace/project/${encodeURIComponent(STATE.projectId)}/graph`, { credentials: "same-origin" });
    const data = await res.json();
    if (!data.success || !data.graphs?.architecture) { toast("No plan found — generate project first", "info"); return; }

    const arch = data.graphs.architecture;
    const info = [
      `📦 ${arch.title}`,
      `Type: ${arch.type} | Complexity: ${arch.complexity}`,
      `Stack: ${arch.stack?.framework}/${arch.stack?.runtime}`,
      `Files: ${(arch.files||[]).join(", ")}`,
      `Design: ${arch.designSystem?.theme}`,
    ].join("\n");

    alert(info);
  } catch (e) {
    toast(`Graph fetch failed: ${e.message}`, "error");
  }
}

