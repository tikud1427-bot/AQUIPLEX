const SB = {
  projectId:      null,
  projectName:    null,
  files:          [],
  activeFile:     null,
  busy:           false,
  lastPrompt:     null,
  detectedIntent: null,
};

const SB_INTENT_KEYWORDS = {
  calculator:   ["calculator","calc","calculate","math","arithmetic","bmi","tip calculator","loan","mortgage","converter","percentage","interest","tax"],
  portfolio:    ["portfolio","personal site","personal website","about me","resume","cv","my work","showcase","developer portfolio","designer portfolio","freelancer","hire me"],
  dashboard:    ["dashboard","admin panel","analytics","metrics","stats","statistics","control panel","management","monitor","overview panel","data panel"],
  blog:         ["blog","article","post","news","newsletter","magazine","editorial","writing","journal"],
  form:         ["form","contact form","sign up","signup","registration","survey","quiz","questionnaire","feedback form","application form","booking form"],
  landing_page: ["landing","landing page","saas","startup","product page","marketing","sales page","waitlist","coming soon","app landing","hero","promo"],
};

const SB_INTENT_LABELS = {
  calculator:   "🔬 Calculator",
  portfolio:    "💼 Portfolio",
  dashboard:    "📊 Dashboard",
  blog:         "📝 Blog",
  form:         "📬 Form",
  landing_page: "🚀 Landing Page",
};

function _detectIntentClient(prompt) {
  if (!prompt) return null;
  const lower = prompt.toLowerCase();
  for (const [intent, keywords] of Object.entries(SB_INTENT_KEYWORDS)) {
    for (const kw of keywords) {
      if (lower.includes(kw)) return intent;
    }
  }
  return null;
}

function _showIntentBadge(intent) {
  const badge = document.getElementById("sbIntentBadge");
  if (!badge) return;
  if (intent && SB_INTENT_LABELS[intent]) {
    badge.textContent = SB_INTENT_LABELS[intent];
    badge.classList.add("visible");
  } else {
    badge.classList.remove("visible");
  }
}

