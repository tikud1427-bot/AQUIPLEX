<!DOCTYPE html>    
<html lang="en">    

<head>    
<meta charset="UTF-8">    
<meta name="viewport" content="width=device-width, initial-scale=1.0">    
<title>Workspace | AIDEX</title>    

<link rel="stylesheet" href="/css/styles.css">    
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">    
</head>    

<body>    

<%- include('partials/nav') %>    

<main class="container">    

  <!-- HEADER -->    
  <section class="workspace-header">
    <h1>Your Workspace</h1>
    <p>Quick access to your saved AI tools</p>
  </section>    

  <!-- GRID -->    
  <div class="workspace-grid" id="workspaceGrid">    

  <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>    

    <% workspace.tools.forEach(function(tool){ %>    

    <div class="workspace-card" id="tool-<%= tool._id %>">    

      <!-- TOP -->    
      <div class="workspace-top">    
        <img     
          src="<%= tool.logo || '/logos/default.png' %>"     
          onerror="this.src='/logos/default.png'"     
          class="workspace-logo"    
          alt="<%= tool.name || 'Tool logo' %>"    
        >    
      </div>    

      <!-- CONTENT -->    
      <div class="workspace-content">    
        <h3><%= tool.name || 'Unnamed Tool' %></h3>

        <% if (tool.description) { %>
          <p class="tool-desc">
            <%= tool.description.substring(0, 80) %>...
          </p>
        <% } else { %>
          <p class="tool-desc muted">No description available</p>
        <% } %>
      </div>    

      <!-- ACTIONS -->    
      <div class="workspace-actions">    

        <button     
          class="launch-btn"     
          onclick="launchTool('<%= tool.url || '' %>')"    
        >    
          🚀 Launch    
        </button>    

        <button     
          onclick="removeTool('<%= tool._id %>')"     
          class="remove-btn"    
        >    
          ✖ Remove    
        </button>    

      </div>    

    </div>    

    <% }) %>    

  <% } else { %>    

    <div class="empty-workspace" id="emptyState">    
      <h2>No tools saved</h2>    
      <p>Add tools from the tools page to build your workspace</p>    
      <a href="/tools" class="browse-tools-btn">Browse Tools</a>    
    </div>    

  <% } %>    

  </div>    

</main>    

<script>    

// 🚀 Launch Tool
function launchTool(url){    
  if(!url){
    alert("No URL found for this tool");
    return;
  }

  if(!url.startsWith("http")){    
    url = "https://" + url;    
  }    

  window.open(url, "_blank");    
}    

// 🗑️ Remove Tool (Smooth + Smart UI)
async function removeTool(toolId){    
  try {    
    const res = await fetch("/workspace/remove/" + toolId, {    
      method: "POST"    
    });    

    if(res.ok){    
      const card = document.getElementById("tool-" + toolId);

      if(card){
        card.style.transition = "all 0.25s ease";
        card.style.opacity = "0";
        card.style.transform = "scale(0.85)";

        setTimeout(() => {
          card.remove();

          const grid = document.getElementById("workspaceGrid");

          // 🔥 Check remaining cards (ignore empty state)
          const remainingCards = grid.querySelectorAll(".workspace-card");

          if(remainingCards.length === 0){
            grid.innerHTML = `
              <div class="empty-workspace">
                <h2>No tools saved</h2>
                <p>Add tools from the tools page to build your workspace</p>
                <a href="/tools" class="browse-tools-btn">Browse Tools</a>
              </div>
            `;
          }

        }, 250);
      }

    } else {    
      alert("Failed to remove tool");    
    }    

  } catch (err){    
    console.error(err);    
    alert("Error removing tool");    
  }    
}    

</script>    

</body>    
</html>