<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Workspace | AIDEX</title>

<link rel="stylesheet" href="/css/styles.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<%- include('partials/nav') %>

<main class="container">

  <!-- HEADER -->
  <section class="workspace-header">
    <h1>Your Workspace</h1>
    <p>Quick access to your saved AI tools</p>
  </section>

  <!-- GRID -->
  <div class="workspace-grid">

  <% if(workspace && workspace.tools && workspace.tools.length > 0){ %>

    <% workspace.tools.forEach(function(tool){ %>

    <div class="workspace-card">

      <!-- TOP -->
      <div class="workspace-top">
        <img src="<%= tool.logo %>" 
             onerror="this.src='/logos/default.png'" 
             class="workspace-logo">
      </div>

      <!-- CONTENT -->
      <div class="workspace-content">
        <h3><%= tool.name %></h3>
      </div>

      <!-- ACTIONS -->
      <div class="workspace-actions">

        <button class="launch-btn" onclick="launchTool('<%= tool.url %>')">
          🚀 Launch
        </button>

        <button onclick="removeTool('<%= tool.toolId %>')" class="remove-btn">
          Remove
        </button>

      </div>

    </div>

    <% }) %>

  <% } else { %>

    <div class="empty-workspace">
      <h2>No tools saved</h2>
      <p>Add tools from the tools page to build your workspace</p>
      <a href="/tools" class="browse-tools-btn">Browse Tools</a>
    </div>

  <% } %>

  </div>

</main>

<script>
function launchTool(url){
  window.open(url, "_blank");
}

async function removeTool(toolId){
  const res = await fetch("/workspace/remove/" + toolId, { method: "POST" });
  if(res.ok){
    location.reload();
  }
}
</script>

</body>
</html>