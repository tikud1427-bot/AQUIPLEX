<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Workspace | Aquiplex</title>
<link rel="stylesheet" href="/css/styles.css">
<link rel="stylesheet" href="/css/workspace.css">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<script src="/socket.io/socket.io.js"></script>

<style>
/* ═══════════════════════════════════════════════════════
   ACCORDION FIX — core rules that override workspace.css
   The body element uses CSS transitions on max-height.
   overflow must be HIDDEN during both open AND close.
   We use data-state="open|closed" as source of truth.
═══════════════════════════════════════════════════════ */
.aq-step-body {
  max-height: 0;
  overflow: hidden;
  /* Smooth, natural easing for expand/collapse */
  transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: max-height;
}

/* When a body is "expanding" we set a px value and keep overflow hidden */
.aq-step-body[data-state="open"] {
  /* max-height is set inline via JS scrollHeight */
  overflow: hidden;
}

/* After transition ends, if still open, let content breathe */
.aq-step-body[data-state="settled"] {
  max-height: none !important;
  overflow: visible;
}

/* Spinner micro-animation */
@keyframes aq-spin {
  to { transform: rotate(360deg); }
}
.aq-mini-spinner,
.aq-spinner {
  animation: aq-spin 0.75s linear infinite;
}

/* Feed item entrance */
@keyframes feedIn {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.aq-feed-item-new.visible {
  animation: feedIn 0.24s ease forwards;
}

/* Right section fade */
.aq-right-section {
  transition: opacity 0.18s ease;
}

/* Loading bar */
.aq-loading-bar { transition: opacity 0.2s ease; }

/* ═══ SITE BUILDER STYLES ═══════════════════════════════════════════════════ */
.aq-site-list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px 6px;
  border-bottom: 1px solid #1e293b;
}
.aq-site-list-title { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: #64748b; text-transform: uppercase; }

/* Sidebar site item rows */
.aq-site-item {
  padding: 10px 14px;
  border-bottom: 1px solid #0f172a;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: background 0.15s;
}
.aq-site-item:hover { background: #0f172a; }
.aq-site-item.active { background: #1e293b; }
.aq-site-item-icon { font-size: 1rem; flex-shrink: 0; }
.aq-site-item-info { flex: 1; min-width: 0; }
.aq-site-item-name { font-size: 0.78rem; font-weight: 600; color: #e2e8f0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.aq-site-item-meta { font-size: 0.62rem; color: #475569; margin-top: 2px; }
.aq-site-item-del { background: none; border: none; color: #475569; cursor: pointer; padding: 4px; font-size: 0.8rem; flex-shrink: 0; opacity: 0; transition: opacity 0.15s; }
.aq-site-item:hover .aq-site-item-del { opacity: 1; }
.aq-site-item-del:hover { color: #f87171; }

/* Site Builder Panel */
.aq-site-builder {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  background: #020617;
}
.aq-sb-header {
  padding: 16px 20px 14px;
  border-bottom: 1px solid #1e293b;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.aq-sb-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}
.aq-sb-title {
  font-size: 1rem;
  font-weight: 700;
  color: #f1f5f9;
  letter-spacing: -0.01em;
}
.aq-sb-subtitle {
  font-size: 0.7rem;
  color: #475569;
  margin-top: 2px;
  font-family: 'IBM Plex Mono', monospace;
}
.aq-sb-generate-bar,
.aq-sb-edit-bar {
  display: flex;
  gap: 8px;
  align-items: center;
}
.aq-sb-input {
  flex: 1;
  padding: 10px 14px;
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 8px;
  color: #f1f5f9;
  font-size: 0.84rem;
  outline: none;
  transition: border-color 0.2s;
  font-family: inherit;
}
.aq-sb-input:focus { border-color: #38bdf8; }
.aq-sb-input::placeholder { color: #334155; }
.aq-sb-file-select {
  padding: 9px 10px;
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 8px;
  color: #94a3b8;
  font-size: 0.75rem;
  outline: none;
  cursor: pointer;
  font-family: 'IBM Plex Mono', monospace;
  min-width: 100px;
}
.aq-btn-run {
  background: linear-gradient(135deg, #0ea5e9, #6366f1);
  color: #fff;
  border: none;
  white-space: nowrap;
}
.aq-btn-run:hover { opacity: 0.88; }
.aq-btn-run:disabled { opacity: 0.5; cursor: not-allowed; }

/* Body: file tree + preview */
.aq-sb-body {
  flex: 1;
  display: flex;
  overflow: hidden;
  min-height: 0;
}
.aq-sb-filetree {
  width: 180px;
  flex-shrink: 0;
  border-right: 1px solid #1e293b;
  overflow-y: auto;
  background: #050e1a;
}
.aq-sb-filetree-header {
  padding: 8px 12px;
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #334155;
  border-bottom: 1px solid #1e293b;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.aq-sb-file-item {
  padding: 8px 12px;
  font-size: 0.75rem;
  font-family: 'IBM Plex Mono', monospace;
  color: #94a3b8;
  cursor: pointer;
  border-bottom: 1px solid #0a1628;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: background 0.12s, color 0.12s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.aq-sb-file-item:hover { background: #0f172a; color: #e2e8f0; }
.aq-sb-file-item.active { background: #1e293b; color: #38bdf8; }
.aq-sb-file-icon { font-size: 0.8rem; flex-shrink: 0; }

/* Preview panel */
.aq-sb-preview-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}
.aq-sb-preview-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  background: #0a1628;
  border-bottom: 1px solid #1e293b;
  flex-shrink: 0;
}
.aq-sb-preview-dots {
  display: flex;
  gap: 5px;
}
.aq-sb-preview-dots span {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  display: inline-block;
}
.aq-sb-preview-url {
  flex: 1;
  font-size: 0.72rem;
  font-family: 'IBM Plex Mono', monospace;
  color: #475569;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.aq-sb-iframe-wrap {
  flex: 1;
  position: relative;
  overflow: hidden;
}
.aq-sb-iframe {
  width: 100%;
  height: 100%;
  border: none;
  background: #fff;
}
.aq-sb-preview-loading {
  position: absolute;
  inset: 0;
  background: rgba(2,6,23,0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  font-size: 0.85rem;
  color: #94a3b8;
}

/* Empty state */
.aq-sb-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 24px;
  text-align: center;
}
.aq-sb-empty-icon {
  font-size: 2.5rem;
  margin-bottom: 12px;
  opacity: 0.5;
}
.aq-sb-empty-title {
  font-size: 1.1rem;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 8px;
}
.aq-sb-empty-sub {
  font-size: 0.82rem;
  color: #475569;
  max-width: 360px;
  line-height: 1.5;
  margin-bottom: 22px;
}
.aq-sb-empty-examples {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
}
.aq-sb-empty-examples span {
  padding: 6px 14px;
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 20px;
  font-size: 0.75rem;
  color: #94a3b8;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
}
.aq-sb-empty-examples span:hover {
  border-color: #38bdf8;
  color: #38bdf8;
}

/* Generating overlay spinner animation (reuse aq-spin) */
@keyframes aq-spin { to { transform: rotate(360deg); } }

</style>
</head>
<body>

<%- include('partials/nav') %>

<!-- Top loading bar (thin progress indicator) -->
<div class="aq-loading-bar" id="aqLoadingBar"></div>

<!-- Toast root -->
<div id="aq-toast-root"></div>

<!-- ═══════════ STEP RUN MODAL ═══════════ -->
<div class="aq-modal-backdrop" id="aqRunModal">
  <div class="aq-modal">
    <div class="aq-modal-hdr">
      <span class="aq-modal-title" id="runModalTitle">Running Step…</span>
      <button class="aq-modal-close" onclick="closeRunModal()">✕</button>
    </div>
    <div class="aq-modal-body">
      <div class="aq-run-spinner" id="runModalSpinner">
        <div class="aq-spinner"></div>
        <span>Executing step…</span>
      </div>
      <div class="aq-run-output" id="runModalOutput" style="display:none;">
        <div class="aq-run-output-label">⚡ Output</div>
        <div class="aq-run-output-content" id="runModalOutputContent"></div>
      </div>
    </div>
    <div class="aq-modal-footer" id="runModalFooter" style="display:none;">
      <button class="aq-btn aq-btn-sm aq-btn-success" onclick="closeRunModal()">✓ Done</button>
    </div>
  </div>
</div>

<!-- ═══════════ COMMAND PALETTE ═══════════ -->
<div class="aq-palette-backdrop" id="aqPalette" onclick="closePalette(event)">
  <div class="aq-palette">
    <input class="aq-palette-input" id="aqPaletteInput" placeholder="Type a command…"
           oninput="filterPalette(this.value)" onkeydown="paletteKeydown(event)"/>
    <div class="aq-palette-list" id="aqPaletteList"></div>
  </div>
</div>

<!-- ═══════════ CONFIRM MODAL ═══════════ -->
<div class="aq-confirm-backdrop" id="aqConfirm">
  <div class="aq-confirm-box">
    <div class="aq-confirm-title" id="aqConfirmTitle">Are you sure?</div>
    <div class="aq-confirm-msg"   id="aqConfirmMsg"></div>
    <div class="aq-confirm-actions">
      <button class="aq-btn aq-btn-sm" onclick="resolveConfirm(false)">Cancel</button>
      <button class="aq-btn aq-btn-sm aq-btn-danger" id="aqConfirmOk" onclick="resolveConfirm(true)">Confirm</button>
    </div>
  </div>
</div>

<!-- Drawer overlay (mobile) -->
<div class="aq-drawer-overlay" id="drawerOverlay" onclick="closeSidebar()"></div>

<div class="aq-workspace">

  <!-- ═══════════ TOPBAR ═══════════ -->
  <div class="aq-topbar">
    <button class="aq-menu-btn" id="menuBtn" onclick="openSidebar()" aria-label="Open menu">☰</button>
    <div class="aq-logo">AQUI<span class="aq-logo-sep">PLEX</span></div>
    <div class="aq-breadcrumb">
      <span>WS</span>
      <span class="sep">›</span>
      <span class="cur" id="topBreadcrumb">Overview</span>
    </div>
    <div class="aq-topbar-right">
      <div class="aq-status-pill">
        <div class="aq-status-dot"></div>
        <span>ONLINE</span>
      </div>
      <select id="bundleSwitcher" class="aq-switcher" title="Switch bundle" style="display:none;"></select>
      <button class="aq-btn aq-btn-sm" onclick="openPalette()" title="⌘K" id="paletteBtn">⌘K</button>
    </div>
  </div>

  <!-- ═══════════ BODY ═══════════ -->
  <div class="aq-body">

    <!-- LEFT SIDEBAR -->
    <div class="aq-sidebar" id="aqSidebar">
      <div class="aq-sidebar-header">
        <span class="aq-sidebar-title">Navigation</span>
        <button class="aq-sidebar-close" onclick="closeSidebar()" aria-label="Close">✕</button>
      </div>

      <div class="aq-sidebar-tabs">
        <button class="aq-sidebar-tab active" onclick="switchLeftTab('bundles', this)">BUNDLES</button>
        <button class="aq-sidebar-tab"        onclick="switchLeftTab('tools',   this)">TOOLS</button>
        <button class="aq-sidebar-tab"        onclick="switchLeftTab('sites',   this)">SITES</button>
      </div>

      <!-- BUNDLES LIST -->
      <div class="aq-sidebar-list" id="leftBundleList">
        <% if (bundles && bundles.length > 0) { %>
          <% bundles.forEach(function(b) {
            const completed = (b.progress || []).filter(p => p && p.status === 'completed').length;
            const total     = (b.steps || []).length;
            const pct       = total > 0 ? Math.round((completed / total) * 100) : 0;
            const dotCls    = b.status === 'active'    ? 'aq-dot-active'
                            : b.status === 'paused'    ? 'aq-dot-paused'
                            : b.status === 'completed' ? 'aq-dot-completed'
                            : 'aq-dot-draft';
          %>
          <div class="aq-bundle-item" id="brow-<%= b._id %>"
               onclick="selectBundleById('<%= b._id %>')">
            <div class="aq-bundle-row1">
              <div class="aq-dot <%= dotCls %>"></div>
              <div class="aq-bundle-title"><%= b.title %></div>
            </div>
            <div class="aq-bundle-meta">
              <div class="aq-bundle-track">
                <div class="aq-bundle-fill" style="width:<%= pct %>%"></div>
              </div>
              <div class="aq-bundle-pct"><%= pct %>%</div>
            </div>
            <div class="aq-bundle-actions" onclick="event.stopPropagation()">
              <button class="aq-bundle-act-btn pin"
                onclick="pinBundleById('<%= b._id %>')" title="Pin/Unpin">☆ PIN</button>
              <button class="aq-bundle-act-btn del"
                onclick="deleteBundleById('<%= b._id %>')" title="Delete">✕ DEL</button>
            </div>
          </div>
          <% }) %>
        <% } else { %>
          <div class="aq-empty">
            <span class="aq-empty-icon">📦</span>
            No bundles yet.<br/>
            <a href="/bundles">Create one →</a>
          </div>
        <% } %>
      </div>

      <!-- TOOLS LIST -->
      <div class="aq-sidebar-list" id="leftToolList" style="display:none;">
        <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>
          <% workspace.tools.forEach(function(tool) { %>
          <div class="aq-tool-item" id="trow-<%= tool._id %>">
            <img src="<%= tool.logo || '/logos/default.png' %>"
                 onerror="this.src='/logos/default.png'"
                 class="aq-tool-logo" alt="<%= tool.name %>"/>
            <span class="aq-tool-name"><%= tool.name %></span>
            <div class="aq-tool-btns">
              <!-- FIX: use tool.url safely -->
              <button class="aq-tool-btn"
                onclick="launchTool('<%= (tool.url || '').replace(/'/g, "\\'") %>')">OPEN</button>
              <!-- FIX: route is /workspace/tools/:id — matches DELETE handler -->
              <button class="aq-tool-btn rm"
                onclick="removeTool('<%= tool._id %>')">RM</button>
            </div>
          </div>
          <% }) %>
        <% } else { %>
          <div class="aq-empty">
            <span class="aq-empty-icon">🔧</span>
            No tools saved.<br/>
            <a href="/tools">Browse tools →</a>
          </div>
        <% } %>
      </div>
      <!-- SITES LIST -->
      <div class="aq-sidebar-list" id="leftSiteList" style="display:none;">
        <div class="aq-site-list-header">
          <span class="aq-site-list-title">AI Site Projects</span>
          <button class="aq-btn aq-btn-sm" onclick="openSiteBuilder()" style="font-size:0.65rem;padding:4px 10px;">+ NEW</button>
        </div>
        <div id="sidebarSiteItems">
          <div class="aq-empty" style="margin-top:8px;">
            <span class="aq-empty-icon">&#127760;</span>
            No sites yet.<br/>
            <button onclick="openSiteBuilder()" style="background:none;border:none;color:#38bdf8;cursor:pointer;font-size:0.8rem;margin-top:6px;">Build one &#8594;</button>
          </div>
        </div>
      </div>
    </div><!-- /aq-sidebar -->

    <!-- MAIN -->
    <div class="aq-main">

      <!-- SITE BUILDER PANEL -->
      <div class="aq-site-builder" id="wsSiteBuilder" style="display:none;">
        <div class="aq-sb-header">
          <div class="aq-sb-title-row">
            <div>
              <div class="aq-sb-title">&#127760; AI Site Builder</div>
              <div class="aq-sb-subtitle" id="sbProjectName">No project loaded</div>
            </div>
            <div class="aq-sb-actions">
              <button class="aq-btn aq-btn-sm" onclick="closeSiteBuilder()" title="Back to bundles">&#10005; CLOSE</button>
            </div>
          </div>
          <div class="aq-sb-generate-bar" id="sbGenerateBar">
            <input class="aq-sb-input" id="sbPromptInput"
                   placeholder="Describe the website you want to build&#8230; e.g. &#39;A portfolio for a UX designer&#39;"
                   onkeydown="if(event.key===&#39;Enter&#39;)generateSite()"/>
            <button class="aq-btn aq-btn-run" id="sbGenerateBtn" onclick="generateSite()">
              <span id="sbGenerateBtnText">&#9889; BUILD SITE</span>
            </button>
          </div>
          <div class="aq-sb-edit-bar" id="sbEditBar" style="display:none;">
            <input class="aq-sb-input" id="sbCommandInput"
                   placeholder="Command: &#39;Change background to black&#39;, &#39;Add a contact form&#39;&#8230;"
                   onkeydown="if(event.key===&#39;Enter&#39;)editSite()"/>
            <select class="aq-sb-file-select" id="sbFileSelect" title="File to edit"></select>
            <button class="aq-btn aq-btn-sm" id="sbEditBtn" onclick="editSite()">
              <span id="sbEditBtnText">&#9998; EDIT</span>
            </button>
          </div>
        </div>
        <div class="aq-sb-body" id="sbBody" style="display:none;">
          <div class="aq-sb-filetree">
            <div class="aq-sb-filetree-header">
              <span>FILES</span>
              <span id="sbFileCount" style="color:#64748b;font-size:0.65rem;"></span>
            </div>
            <div class="aq-sb-filetree-list" id="sbFileList"></div>
          </div>
          <div class="aq-sb-preview-panel">
            <div class="aq-sb-preview-header">
              <div class="aq-sb-preview-dots">
                <span style="background:#ff5f57;"></span>
                <span style="background:#ffbd2e;"></span>
                <span style="background:#28c940;"></span>
              </div>
              <div class="aq-sb-preview-url" id="sbPreviewUrl"></div>
              <button class="aq-btn aq-btn-sm" onclick="refreshPreview()" title="Reload preview" style="padding:3px 9px;font-size:0.65rem;">&#8635;</button>
            </div>
            <div class="aq-sb-iframe-wrap">
              <iframe id="sbPreviewFrame" class="aq-sb-iframe" sandbox="allow-scripts allow-same-origin" title="Site Preview"></iframe>
              <div class="aq-sb-preview-loading" id="sbPreviewLoading" style="display:none;">
                <div class="aq-spinner"></div>
                <span>Generating site&#8230;</span>
              </div>
            </div>
          </div>
        </div>
        <div class="aq-sb-empty" id="sbEmpty">
          <div class="aq-sb-empty-icon">&#127760;</div>
          <div class="aq-sb-empty-title">AI Website Execution Engine</div>
          <div class="aq-sb-empty-sub">Describe a website above and Aqua AI will generate, write, and run it live.</div>
          <div class="aq-sb-empty-examples">
            <span onclick="setSbPrompt(&#39;A stunning portfolio for a UI/UX designer&#39;)">&#10022; UI/UX Portfolio</span>
            <span onclick="setSbPrompt(&#39;A SaaS landing page for an AI writing tool&#39;)">&#10022; SaaS Landing Page</span>
            <span onclick="setSbPrompt(&#39;A minimal blog for a travel photographer&#39;)">&#10022; Travel Blog</span>
            <span onclick="setSbPrompt(&#39;A dark-themed personal resume website&#39;)">&#10022; Resume Site</span>
          </div>
        </div>
      </div><!-- /wsSiteBuilder -->

      <!-- WELCOME STATE -->
      <div class="aq-welcome" id="wsWelcome">
        <div class="aq-welcome-glyph">⚡</div>
        <h2>Execution Control</h2>
        <p>Select a bundle from the sidebar to view its execution state, step timeline, outputs, and memory.</p>
        <div class="aq-welcome-actions">
          <button class="aq-btn" onclick="openSidebar()">☰ Open Bundles</button>
          <button class="aq-btn" onclick="window.location.href='/bundles'">+ New Bundle</button>
        </div>
        <div class="aq-welcome-hint">Press ⌘K for commands</div>
      </div>

      <!-- LOADING STATE (skeleton) -->
      <div id="wsLoading" style="display:none;" class="aq-welcome">
        <div style="display:flex;flex-direction:column;gap:10px;width:100%;max-width:320px;">
          <div class="aq-skeleton" style="height:18px;width:60%;"></div>
          <div class="aq-skeleton" style="height:12px;width:80%;"></div>
          <div class="aq-skeleton" style="height:12px;width:50%;"></div>
          <div class="aq-skeleton" style="height:60px;margin-top:8px;"></div>
          <div class="aq-skeleton" style="height:60px;"></div>
          <div class="aq-skeleton" style="height:60px;"></div>
        </div>
      </div>

      <!-- ERROR STATE -->
      <div id="wsError" style="display:none;" class="aq-welcome">
        <div class="aq-error-state">
          <div style="font-size:1.6rem;margin-bottom:8px;">⚠</div>
          <div id="wsErrorMsg">Something went wrong loading this bundle.</div>
          <button class="aq-btn" onclick="retryLoad()" style="margin-top:14px;">↺ Retry</button>
        </div>
      </div>

      <!-- EXEC VIEW -->
      <div class="aq-exec" id="wsExec" style="display:none;">

        <!-- Header -->
        <div class="aq-exec-hdr">
          <div class="aq-exec-hdr-top">
            <div style="flex:1;min-width:0;">
              <div class="aq-exec-title" id="execTitle">—</div>
              <div class="aq-exec-goal"  id="execGoal">—</div>
            </div>
            <div class="aq-exec-actions">
              <button class="aq-btn aq-btn-sm aq-btn-run"    id="btnRun"    onclick="runCurrentBundle()">▶ RUN</button>
              <button class="aq-btn aq-btn-sm"               id="btnPause"  onclick="pauseCurrentBundle()"  style="display:none;">⏸ PAUSE</button>
              <button class="aq-btn aq-btn-sm"               id="btnResume" onclick="resumeCurrentBundle()" style="display:none;">↺ RESUME</button>
              <button class="aq-btn aq-btn-sm"               id="btnAutoRun" onclick="autoRunSteps()">⚡ AUTO</button>
              <button class="aq-btn aq-btn-sm"               id="btnPin"    onclick="pinCurrentBundle()">☆ PIN</button>
              <button class="aq-btn aq-btn-sm aq-btn-danger" onclick="deleteCurrentBundle()">⌫</button>
            </div>
          </div>

          <!-- Stats row -->
          <div class="aq-stats-row">
            <div class="aq-stat">
              <div class="aq-stat-val c-accent"  id="statSteps">—</div>
              <div class="aq-stat-lbl">Steps</div>
            </div>
            <div class="aq-stat">
              <div class="aq-stat-val c-green"   id="statDone">—</div>
              <div class="aq-stat-lbl">Done</div>
            </div>
            <div class="aq-stat">
              <div class="aq-stat-val"            id="statPct">—</div>
              <div class="aq-stat-lbl">Pct</div>
            </div>
            <div class="aq-stat">
              <div class="aq-stat-val c-amber"   id="statStatus">—</div>
              <div class="aq-stat-lbl">Status</div>
            </div>
            <div class="aq-stat">
              <div class="aq-stat-val c-purple"  id="statConfidence">—</div>
              <div class="aq-stat-lbl">Conf</div>
            </div>
          </div>

          <!-- Animated progress bar -->
          <div class="aq-progress-track">
            <div class="aq-progress-fill" id="mainProgressFill" style="width:0%"></div>
            <div class="aq-progress-glow" id="mainProgressGlow" style="left:0%"></div>
          </div>
        </div>

        <!-- Content grid -->
        <div class="aq-exec-content">

          <!-- Steps panel -->
          <div class="aq-steps-panel">
            <div class="aq-timeline" id="execTimeline"></div>
            <div class="aq-steps-scroll" id="execSteps"></div>
          </div>

          <!-- Right panel -->
          <div class="aq-right-panel">
            <div class="aq-right-tabs">
              <button class="aq-right-tab active" data-tab="outputs"  onclick="switchRightTab('outputs',  this)">OUTPUTS</button>
              <button class="aq-right-tab"         data-tab="memory"   onclick="switchRightTab('memory',   this)">MEMORY</button>
              <button class="aq-right-tab"         data-tab="insights" onclick="switchRightTab('insights', this)">INSIGHTS</button>
            </div>
            <div class="aq-right-body">

              <div class="aq-right-section active" id="rtab-outputs">
                <div id="outputFeed">
                  <div class="aq-empty">Run a bundle step to see outputs.</div>
                </div>
              </div>

              <div class="aq-right-section" id="rtab-memory">
                <div class="aq-mem-hdr">Bundle Memory <span id="memBundleCount">0 keys</span></div>
                <div id="memBundleEntries"></div>
                <div class="aq-mem-hdr" style="margin-top:14px;">Context Summary</div>
                <div class="aq-context-box" id="memContextBox"    style="display:none;"></div>
                <div class="aq-empty"        id="memContextEmpty" style="padding:6px 0;font-size:0.64rem;">No context summary yet.</div>
                <div class="aq-mem-hdr" style="margin-top:14px;">Workspace Memory <span id="memWsCount">0 keys</span></div>
                <div id="memWsEntries"></div>
              </div>

              <div class="aq-right-section" id="rtab-insights">
                <div id="insightList">
                  <div class="aq-empty">Insights from step outputs appear here.</div>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div><!-- /wsExec -->

    </div><!-- /aq-main -->

  </div><!-- /aq-body -->

  <!-- MOBILE BOTTOM NAV -->
  <div class="aq-bottom-nav">
    <button class="aq-bottom-tab active" id="mnavBundles" onclick="mobileNav('bundles')">
      <span class="icon">📦</span>
      <span>Bundles</span>
    </button>
    <button class="aq-bottom-tab" id="mnavSteps" onclick="mobileNav('steps')">
      <span class="icon">⚡</span>
      <span>Steps</span>
    </button>
    <button class="aq-bottom-tab" id="mnavOutputs" onclick="mobileNav('outputs')">
      <span class="icon">📤</span>
      <span>Outputs</span>
    </button>
    <button class="aq-bottom-tab" id="mnavCmd" onclick="openPalette()">
      <span class="icon">⌘</span>
      <span>Commands</span>
    </button>
  </div>

</div><!-- /aq-workspace -->

<%- include("partials/footer") %>

<script>
"use strict";

/* ═══════════════════════════════════════════════════════
   GLOBAL STATE
   Single source of truth for all UI and data.
═══════════════════════════════════════════════════════ */
const STATE = {
  bundle:       null,   // current loaded bundle object
  wsMemory:     {},     // workspace-level memory (flat object)
  pinnedIds:    [],     // array of pinned bundle id strings
  selectedStep: null,   // currently focused step index
  openSteps:    new Set(), // set of step indices that are open
  loading:      false,  // global loading flag
  lastBundleId: null,   // for retry logic
  stepRunning:  new Set(), // set of step indices actively running
  // FIX: track all known bundles (SSR + dynamically fetched)
  allBundles:   [],
};

// Inject SSR bundle list — kept in sync with dynamic fetches
const _ejsBundles = <%- JSON.stringify(bundles || []) %>;
STATE.allBundles = _ejsBundles.slice();

/* ═══════════════════════════════════════════════════════
   LOADING / ERROR UI
═══════════════════════════════════════════════════════ */
function showLoading()  {
  document.getElementById("aqLoadingBar").classList.add("visible");
  STATE.loading = true;
}
function hideLoading()  {
  document.getElementById("aqLoadingBar").classList.remove("visible");
  STATE.loading = false;
}

function showBundleLoading() {
  document.getElementById("wsWelcome").style.display = "none";
  document.getElementById("wsLoading").style.display = "flex";
  document.getElementById("wsExec").style.display    = "none";
  document.getElementById("wsError").style.display   = "none";
}
function showBundleError(msg) {
  document.getElementById("wsLoading").style.display = "none";
  document.getElementById("wsError").style.display   = "flex";
  document.getElementById("wsErrorMsg").textContent  = msg || "Failed to load bundle.";
}
function showBundleExec() {
  document.getElementById("wsLoading").style.display = "none";
  document.getElementById("wsError").style.display   = "none";
  document.getElementById("wsWelcome").style.display = "none";
  document.getElementById("wsExec").style.display    = "flex";
}
function showWelcome() {
  document.getElementById("wsWelcome").style.display = "";
  document.getElementById("wsLoading").style.display = "none";
  document.getElementById("wsExec").style.display    = "none";
  document.getElementById("wsError").style.display   = "none";
}
function retryLoad() {
  if (STATE.lastBundleId) {
    // FIX: search allBundles not just SSR list
    const b = STATE.allBundles.find(x => String(x._id) === String(STATE.lastBundleId));
    if (b) selectBundle(b);
  }
}

/* ═══════════════════════════════════════════════════════
   CONFIRM DIALOG
═══════════════════════════════════════════════════════ */
let _confirmResolve = null;

function showConfirm(title, msg, okLabel = "Confirm") {
  return new Promise(resolve => {
    _confirmResolve = resolve;
    document.getElementById("aqConfirmTitle").textContent = title;
    document.getElementById("aqConfirmMsg").textContent   = msg;
    document.getElementById("aqConfirmOk").textContent    = okLabel;
    document.getElementById("aqConfirm").classList.add("open");
  });
}
function resolveConfirm(val) {
  document.getElementById("aqConfirm").classList.remove("open");
  if (_confirmResolve) { _confirmResolve(val); _confirmResolve = null; }
}

/* ═══════════════════════════════════════════════════════
   RUN MODAL
═══════════════════════════════════════════════════════ */
function openRunModal(title) {
  document.getElementById("runModalTitle").textContent       = title || "Running Step…";
  document.getElementById("runModalSpinner").style.display   = "flex";
  document.getElementById("runModalOutput").style.display    = "none";
  document.getElementById("runModalFooter").style.display    = "none";
  document.getElementById("runModalOutputContent").innerHTML = "";
  document.getElementById("aqRunModal").classList.add("open");
}
function showRunModalOutput(content) {
  document.getElementById("runModalSpinner").style.display   = "none";
  document.getElementById("runModalOutput").style.display    = "block";
  document.getElementById("runModalFooter").style.display    = "flex";
  document.getElementById("runModalOutputContent").innerHTML = formatOutput(content);
}
function closeRunModal() {
  document.getElementById("aqRunModal").classList.remove("open");
}

/* ═══════════════════════════════════════════════════════
   SIDEBAR DRAWER
═══════════════════════════════════════════════════════ */
function openSidebar() {
  document.getElementById("aqSidebar").classList.add("open");
  document.getElementById("drawerOverlay").classList.add("open");
}
function closeSidebar() {
  document.getElementById("aqSidebar").classList.remove("open");
  document.getElementById("drawerOverlay").classList.remove("open");
}

/* ═══════════════════════════════════════════════════════
   MOBILE BOTTOM NAV
═══════════════════════════════════════════════════════ */
function mobileNav(tab) {
  document.querySelectorAll(".aq-bottom-tab").forEach(b => b.classList.remove("active"));
  if (tab === "bundles") {
    document.getElementById("mnavBundles").classList.add("active");
    openSidebar();
  } else if (tab === "steps") {
    document.getElementById("mnavSteps").classList.add("active");
    closeSidebar();
    const s = document.getElementById("execSteps");
    if (s) s.scrollIntoView({ behavior: "smooth", block: "start" });
  } else if (tab === "outputs") {
    document.getElementById("mnavOutputs").classList.add("active");
    switchRightTab("outputs");
  }
}

/* ═══════════════════════════════════════════════════════
   INIT — Page load
═══════════════════════════════════════════════════════ */
window.addEventListener("DOMContentLoaded", async () => {
  initBundleSwitcher();
  try {
    const res  = await fetch("/workspace/state");
    if (!res.ok) throw new Error("State load failed: " + res.status);
    const data = await res.json();

    // Hydrate workspace memory
    const rawMem   = (data.workspace && data.workspace.workspaceMemory) || {};
    STATE.wsMemory = rawMem instanceof Map ? Object.fromEntries(rawMem) : rawMem;

    // Hydrate pinned list
    STATE.pinnedIds = (data.workspace && data.workspace.pinnedBundleIds) || [];

    // Render WS memory section
    renderWsMemory();

    // Hydrate output feed with recent history
    const recentOutputs = data.workspace && data.workspace.recentOutputs;
    if (recentOutputs && recentOutputs.length) renderOutputFeed(recentOutputs);

    // FIX: merge server bundles into allBundles for accurate searches
    if (data.bundles && data.bundles.length) {
      data.bundles.forEach(sb => {
        const idx = STATE.allBundles.findIndex(b => String(b._id) === String(sb._id));
        if (idx !== -1) STATE.allBundles[idx] = sb;
        else            STATE.allBundles.push(sb);
      });
    }

    // Auto-select last open bundle or first active
    const lastId  = data.workspace && data.workspace.lastOpenBundleId;
    const bundles = data.bundles || STATE.allBundles;

    if (lastId) {
      const b = bundles.find(x => String(x._id) === String(lastId));
      if (b) { await selectBundle(b); return; }
    }
    const active = bundles.find(b => b.status === "active");
    if (active) await selectBundle(active);

  } catch (e) {
    console.warn("[AQ] State init failed:", e.message);
  }
});

/* ═══════════════════════════════════════════════════════
   BUNDLE SWITCHER (topbar dropdown)
═══════════════════════════════════════════════════════ */
function initBundleSwitcher() {
  const sw = document.getElementById("bundleSwitcher");
  if (!sw) return;
  if (_ejsBundles.length > 0) {
    sw.style.display = "";
    sw.innerHTML = '<option value="">Select bundle…</option>' +
      _ejsBundles.map(b => `<option value="${b._id}">${esc(b.title)}</option>`).join("");
    const saved = localStorage.getItem("aq_activeBundle");
    if (saved) sw.value = saved;
    sw.onchange = () => {
      const id    = sw.value;
      // FIX: search full allBundles list
      const found = STATE.allBundles.find(b => String(b._id) === id);
      if (found) { localStorage.setItem("aq_activeBundle", id); selectBundle(found); }
    };
  }
}

/* ═══════════════════════════════════════════════════════
   TAB SWITCHES
═══════════════════════════════════════════════════════ */
function switchLeftTab(tab, btn) {
  document.querySelectorAll(".aq-sidebar-tab").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("leftBundleList").style.display = tab === "bundles" ? "" : "none";
  document.getElementById("leftToolList").style.display   = tab === "tools"   ? "" : "none";
}

function switchRightTab(tab, btn) {
  document.querySelectorAll(".aq-right-tab").forEach(b => b.classList.remove("active"));
  document.querySelectorAll(".aq-right-section").forEach(s => s.classList.remove("active"));

  if (btn) {
    btn.classList.add("active");
  } else {
    const tabEl = document.querySelector(`.aq-right-tab[data-tab="${tab}"]`);
    if (tabEl) tabEl.classList.add("active");
  }

  const section = document.getElementById("rtab-" + tab);
  if (section) {
    section.classList.add("active");
    section.style.opacity = "0";
    requestAnimationFrame(() => {
      requestAnimationFrame(() => { section.style.opacity = "1"; });
    });
  }
}

/* ═══════════════════════════════════════════════════════
   SELECT BUNDLE
═══════════════════════════════════════════════════════ */
async function selectBundle(bundle) {
  if (!bundle || !bundle._id) return;

  STATE.lastBundleId = bundle._id;
  STATE.openSteps.clear();
  STATE.stepRunning.clear();

  // Highlight sidebar row
  document.querySelectorAll(".aq-bundle-item").forEach(r => r.classList.remove("selected"));
  const row = document.getElementById("brow-" + bundle._id);
  if (row) row.classList.add("selected");

  // Sync switcher
  const sw = document.getElementById("bundleSwitcher");
  if (sw) sw.value = bundle._id;
  localStorage.setItem("aq_activeBundle", bundle._id);

  showBundleLoading();
  showLoading();

  try {
    // Always fetch fresh from server so data is accurate
    const res = await fetch("/workspace/bundle/" + bundle._id);
    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    if (data && data.bundle) bundle = data.bundle;
  } catch (e) {
    showBundleError("Could not load bundle. Check your connection.");
    hideLoading();
    return;
  }

  hideLoading();
  STATE.bundle       = bundle;
  STATE.selectedStep = null;

  // FIX: merge into allBundles so retry and switcher work correctly
  const idx = STATE.allBundles.findIndex(b => String(b._id) === String(bundle._id));
  if (idx !== -1) STATE.allBundles[idx] = bundle;
  else            STATE.allBundles.push(bundle);

  // Default open: current step (or first pending step)
  const currentStep = bundle.currentStep || 0;
  STATE.openSteps.add(currentStep);

  showBundleExec();
  renderExecPanel(bundle);
  renderMemoryPanel(bundle);
  renderInsightPanel(bundle);
  updateBreadcrumb(bundle.title);
  updatePinBtn(bundle._id);

  if (window.innerWidth < 900) closeSidebar();
}

async function selectBundleById(id) {
  // FIX: use allBundles (includes dynamically fetched) not just SSR _ejsBundles
  const bundle = STATE.allBundles.find(b => String(b._id) === String(id));
  // If not found locally, still attempt to select with a stub (selectBundle fetches fresh anyway)
  if (bundle) await selectBundle(bundle);
  else        await selectBundle({ _id: id });
}

/* ═══════════════════════════════════════════════════════
   RENDER EXEC PANEL
═══════════════════════════════════════════════════════ */
function renderExecPanel(b) {
  const steps    = Array.isArray(b.steps)    ? b.steps    : [];
  const progress = Array.isArray(b.progress) ? b.progress : [];
  const outputs  = Array.isArray(b.outputs)  ? b.outputs  : [];

  const done  = progress.filter(p => p && p.status === "completed").length;
  const total = steps.length;
  const pct   = total ? Math.round((done / total) * 100) : 0;

  const scores  = outputs.map(o => o && o.confidenceScore).filter(s => typeof s === "number");
  const avgConf = scores.length
    ? (scores.reduce((a, s) => a + s, 0) / scores.length * 100).toFixed(0) + "%"
    : "—";

  document.getElementById("execTitle").textContent      = b.title  || "Untitled";
  document.getElementById("execGoal").textContent       = b.goal   || "";
  document.getElementById("statSteps").textContent      = total;
  document.getElementById("statDone").textContent       = done;
  document.getElementById("statPct").textContent        = pct + "%";
  document.getElementById("statStatus").textContent     = (b.status || "draft").toUpperCase();
  document.getElementById("statConfidence").textContent = avgConf;
  document.getElementById("mainProgressFill").style.width = pct + "%";
  document.getElementById("mainProgressGlow").style.left  = pct + "%";

  const btnRun    = document.getElementById("btnRun");
  const btnPause  = document.getElementById("btnPause");
  const btnResume = document.getElementById("btnResume");
  btnRun.style.display = btnPause.style.display = btnResume.style.display = "none";
  if      (b.status === "active")    { btnPause.style.display  = ""; }
  else if (b.status === "paused")    { btnResume.style.display = ""; }
  else if (b.status === "completed") { /* all hidden */ }
  else                               { btnRun.style.display    = ""; }

  renderTimeline(steps, progress, b.currentStep || 0);
  renderStepCards(steps, progress, outputs, b.currentStep || 0);
}

/* ═══════════════════════════════════════════════════════
   TIMELINE
═══════════════════════════════════════════════════════ */
function renderTimeline(steps, progress, currentStep) {
  const tl = document.getElementById("execTimeline");
  if (!steps.length) { tl.innerHTML = ""; return; }

  tl.innerHTML = steps.map((step, i) => {
    const prog   = progress.find(p => p && p.step === i);
    const status = prog ? prog.status : (i === currentStep ? "in-progress" : "pending");
    const dotCls = status === "completed"   ? "done"
                 : status === "in-progress" ? "running"
                 : i === currentStep        ? "running" : "";
    const icon   = status === "completed"   ? "✓"
                 : status === "in-progress" ? "…" : (i + 1);
    const lineCls = status === "completed" ? "done" : "";
    const conn    = i < steps.length - 1 ? `<div class="aq-tl-line ${lineCls}"></div>` : "";
    return `
      <div class="aq-tl-step" title="${esc(step.title || 'Step '+(i+1))}" onclick="jumpToStep(${i})">
        <div class="aq-tl-dot ${dotCls}">${icon}</div>
      </div>${conn}`;
  }).join("");
}

/* ═══════════════════════════════════════════════════════
   STEP CARDS — PRODUCTION ACCORDION

   FIX STRATEGY:
   1. Render all cards with max-height:0 (closed by default)
   2. After DOM paint, open the steps in STATE.openSteps
   3. Use data-state attribute to track open/closing/settled
   4. Never use max-height:none during animation — only after transition ends
   5. Single RAF to batch DOM reads before writes
═══════════════════════════════════════════════════════ */
function renderStepCards(steps, progress, outputs, currentStep) {
  const container = document.getElementById("execSteps");
  if (!steps.length) {
    container.innerHTML = `<div class="aq-empty"><span class="aq-empty-icon">📋</span>No steps defined.</div>`;
    return;
  }

  container.innerHTML = steps.map((step, i) => {
    const prog      = progress.find(p => p && p.step === i) || {};
    const status    = prog.status || (i === currentStep ? "in-progress" : "pending");
    const output    = outputs.find(o => o && o.stepIndex === i);
    const isRunning = STATE.stepRunning.has(i);

    const cardCls  = status === "completed"   ? "done"
                   : status === "in-progress" ? "running"
                   : i === currentStep        ? "active" : "";
    const badgeCls = status === "completed"   ? "wb-done"
                   : isRunning               ? "wb-running"
                   : status === "in-progress" ? "wb-running"
                   : status === "failed"      ? "wb-failed" : "wb-pending";
    const badgeTxt = status === "completed"   ? "DONE"
                   : isRunning               ? "RUNNING…"
                   : status === "in-progress" ? "RUNNING"
                   : status === "failed"      ? "FAILED" : "PENDING";
    const numCls   = status === "completed"   ? "done"
                   : status === "in-progress" ? "running" : "";
    const numIcon  = status === "completed"   ? "✓"
                   : isRunning               ? `<div class="aq-mini-spinner"></div>` : (i + 1);

    const resources  = step.resources || step.tools || [];
    const toolsHtml  = resources.length
      ? `<div class="aq-tool-chips">${resources.map(r =>
          typeof r === "string"
            ? `<span class="aq-tool-chip">🔗 ${esc(r)}</span>`
            : `<a class="aq-tool-chip" href="${esc(r.url||'#')}" target="_blank" rel="noopener">🔗 ${esc(r.name||'Tool')}</a>`
        ).join("")}</div>` : "";

    let outputHtml = "";
    if (output && output.content) {
      const confBadge = typeof output.confidenceScore === "number"
        ? `<span class="aq-out-meta-badge green">${Math.round(output.confidenceScore * 100)}% conf</span>`
        : "";
      const durBadge = output.durationMs
        ? `<span class="aq-out-meta-badge muted">${output.durationMs}ms</span>`
        : "";
      const insights = (output.keyInsights || []).slice(0, 4)
        .map(k => `<span class="aq-insight-chip">${esc(k)}</span>`).join("");

      outputHtml = `
        <div class="aq-output-block">
          <div class="aq-output-hdr">
            <span class="aq-output-label">⚡ Output</span>
            <div class="aq-output-badges">${confBadge}${durBadge}</div>
            <div class="aq-output-dot"></div>
          </div>
          <div class="aq-output-content">${formatOutput(output.content)}</div>
        </div>
        ${insights ? `<div class="aq-insight-chips">${insights}</div>` : ""}`;
    } else if (isRunning) {
      outputHtml = `
        <div class="aq-output-block aq-output-loading">
          <div class="aq-spinner-row">
            <div class="aq-spinner aq-spinner-sm"></div>
            <span>Executing step — please wait…</span>
          </div>
        </div>`;
    } else {
      outputHtml = `<div class="aq-empty-inline">No output yet. Run or mark this step done to proceed.</div>`;
    }

    const actionDisabled = isRunning ? "disabled" : "";
    let actionHtml = "";
    if (status !== "completed") {
      actionHtml = `
        <button class="aq-step-act-btn run-step ${isRunning ? 'loading' : ''}" ${actionDisabled}
          onclick="event.stopPropagation();runStep(${i})">
          ${isRunning ? '<div class="aq-mini-spinner"></div> Running…' : '▶ Run Step'}
        </button>
        <button class="aq-step-act-btn done-btn" ${actionDisabled}
          onclick="event.stopPropagation();markStepDone(${i})">✅ Mark Done</button>`;
    } else {
      actionHtml = `
        <button class="aq-step-act-btn rerun" onclick="event.stopPropagation();rerunStep(${i})">↺ Re-run</button>`;
    }

    // All bodies start closed (max-height:0, data-state="closed")
    // JS will open STATE.openSteps after paint
    return `
      <div class="aq-step-card ${cardCls}" id="scard-${i}" data-step="${i}">
        <div class="aq-step-hdr" onclick="toggleCard(${i})">
          <div class="aq-step-num ${numCls}">${numIcon}</div>
          <div class="aq-step-info">
            <div class="aq-step-title">${esc(step.title || 'Step ' + (i+1))}</div>
            <div class="aq-step-desc">${esc(step.description || '')}</div>
          </div>
          <span class="aq-badge ${badgeCls}">${badgeTxt}</span>
          <span class="aq-step-toggle">▾</span>
        </div>
        <div class="aq-step-body" id="sbody-${i}" data-state="closed">
          <div class="aq-step-body-inner" id="sbody-inner-${i}">
            ${toolsHtml}
            ${outputHtml}
            <div class="aq-step-actions">${actionHtml}</div>
          </div>
        </div>
      </div>`;
  }).join("");

  // FIX: After full DOM paint, open all steps in STATE.openSteps.
  // Use double-RAF to ensure layout has calculated scrollHeights.
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      STATE.openSteps.forEach(idx => _openCard(idx, /* animate= */ false));
    });
  });
}

/* ═══════════════════════════════════════════════════════
   ACCORDION ENGINE — Perfect expand/collapse

   RULES:
   - Only one step open at a time (close others before opening new)
   - During animation: overflow=hidden, max-height=px value
   - After animation settles (open): max-height=none, overflow=visible
     This is critical so dynamic content (outputs) renders without clipping
   - On close: snap max-height back to px first, then animate to 0
     This is needed because max-height=none cannot animate to 0
═══════════════════════════════════════════════════════ */
function toggleCard(idx) {
  if (STATE.openSteps.has(idx)) {
    _closeCard(idx);
  } else {
    // Close all other open cards first (single-open accordion)
    const others = Array.from(STATE.openSteps).filter(i => i !== idx);
    others.forEach(i => _closeCard(i));
    _openCard(idx, /* animate= */ true);
  }
}

function _openCard(idx, animate = true) {
  const body   = document.getElementById("sbody-" + idx);
  const inner  = document.getElementById("sbody-inner-" + idx);
  const toggle = document.querySelector(`#scard-${idx} .aq-step-toggle`);
  if (!body || !inner) return;

  STATE.openSteps.add(idx);
  if (toggle) toggle.classList.add("open");

  // Measure content height while element is still in DOM
  body.style.overflow  = "hidden";
  body.style.maxHeight = "0";  // reset before measuring
  body.setAttribute("data-state", "open");

  // Get actual scroll height after potential content change
  const targetH = inner.scrollHeight + 40; // 40px padding buffer

  if (animate) {
    // Trigger transition by setting target height
    // Use requestAnimationFrame to ensure browser registers the 0 → targetH change
    requestAnimationFrame(() => {
      body.style.maxHeight = targetH + "px";
    });
  } else {
    // No animation — snap open immediately
    body.style.maxHeight = targetH + "px";
  }

  // After transition: remove cap so content (outputs) can grow freely
  const onTransitionEnd = (e) => {
    if (e.propertyName !== "max-height") return;
    body.removeEventListener("transitionend", onTransitionEnd);
    // Only settle if still open (user might have closed during animation)
    if (STATE.openSteps.has(idx)) {
      body.style.maxHeight = "none";
      body.style.overflow  = "visible";
      body.setAttribute("data-state", "settled");
    }
  };
  body.addEventListener("transitionend", onTransitionEnd);

  if (!animate) {
    // No transition fires — settle immediately
    body.style.maxHeight = "none";
    body.style.overflow  = "visible";
    body.setAttribute("data-state", "settled");
  }
}

function _closeCard(idx) {
  const body   = document.getElementById("sbody-" + idx);
  const toggle = document.querySelector(`#scard-${idx} .aq-step-toggle`);
  if (!body) return;

  STATE.openSteps.delete(idx);
  if (toggle) toggle.classList.remove("open");
  body.setAttribute("data-state", "closed");

  // FIX: If max-height is "none" (settled state), we MUST snap to a px value first
  // before animating to 0. CSS cannot transition from "none" to a number.
  if (body.style.maxHeight === "none" || body.style.maxHeight === "") {
    const inner = document.getElementById("sbody-inner-" + idx);
    const h     = inner ? inner.scrollHeight + 40 : 200;
    body.style.overflow  = "hidden";
    body.style.maxHeight = h + "px";

    // Force layout recalc, then animate to 0
    body.getBoundingClientRect(); // triggers reflow
    requestAnimationFrame(() => {
      body.style.maxHeight = "0";
    });
  } else {
    body.style.overflow  = "hidden";
    body.style.maxHeight = "0";
  }

  if (STATE.selectedStep === idx) STATE.selectedStep = null;
}

/* FIX: After dynamic content updates (output rendered), recalculate open card height */
function _recalcOpenCard(idx) {
  if (!STATE.openSteps.has(idx)) return;
  const body  = document.getElementById("sbody-" + idx);
  const inner = document.getElementById("sbody-inner-" + idx);
  if (!body || !inner) return;

  // If already settled (no max-height cap), nothing to do — content expands naturally
  if (body.getAttribute("data-state") === "settled") return;

  // Still mid-animation — update target height
  const targetH = inner.scrollHeight + 40;
  body.style.maxHeight = targetH + "px";
}

function jumpToStep(idx) {
  STATE.selectedStep = idx;
  const card = document.getElementById("scard-" + idx);
  if (!card) return;
  card.scrollIntoView({ behavior: "smooth", block: "center" });
  if (!STATE.openSteps.has(idx)) {
    setTimeout(() => toggleCard(idx), 180);
  }
}

/* ═══════════════════════════════════════════════════════
   RUN STEP (Execution Engine)
   FIX: POST to /workspace/step/:bundleId/:stepIndex (correct route)
   FIX: Keep card open post-run; recalc height after output appears
═══════════════════════════════════════════════════════ */
async function runStep(stepIndex) {
  const b = STATE.bundle;
  if (!b || STATE.stepRunning.has(stepIndex)) return;

  const stepTitle = (b.steps && b.steps[stepIndex] && b.steps[stepIndex].title) || ("Step " + (stepIndex + 1));

  STATE.stepRunning.add(stepIndex);
  openRunModal(`▶ ${stepTitle}`);

  // Show running state immediately — optimistic UI
  _patchStepCardRunning(stepIndex, true);

  try {
    // FIX: Correct route — POST /workspace/step/:bundleId/:stepIndex
    const res  = await fetch(`/workspace/step/${b._id}/${stepIndex}`, {
      method:  "POST",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify({ title: stepTitle }),
    });

    if (!res.ok) {
      const errData = await res.json().catch(() => ({}));
      throw new Error(errData.error || `HTTP ${res.status}`);
    }

    const data = await res.json();
    if (data.error) throw new Error(data.error);

    // Update state
    STATE.bundle = data.bundle;
    if (data.workspace && data.workspace.workspaceMemory) {
      STATE.wsMemory = data.workspace.workspaceMemory;
    }

    STATE.stepRunning.delete(stepIndex);
    // Keep card open to show fresh output
    STATE.openSteps.add(stepIndex);

    // Full re-render (updates all panels + step cards)
    renderExecPanel(data.bundle);
    renderMemoryPanel(data.bundle);
    renderInsightPanel(data.bundle);
    updateBundleRowProgress(b._id, data.bundle);

    // FIX: recalc open card height AFTER re-render adds the output block
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        _openCard(stepIndex, false); // re-settle with new content height
      });
    });

    const output = data.output || (data.bundle.outputs || []).find(o => o && o.stepIndex === stepIndex);
    if (output && output.content) {
      showRunModalOutput(output.content);
      prependOutputFeed(data.bundle.title || "Bundle", output.stepIndex, output.stepTitle, output.content);
    } else {
      closeRunModal();
    }

    if (data.bundle.status === "completed") toast("🎉 Bundle complete!", "success");
    else toast(`Step ${stepIndex + 1} complete ✓`, "success");

  } catch (e) {
    STATE.stepRunning.delete(stepIndex);
    toast("Error running step: " + e.message, "error");
    console.error("[AQ] runStep error:", e);
    closeRunModal();
    // Re-render to restore non-running state
    if (STATE.bundle) renderExecPanel(STATE.bundle);
  }
}

/* Optimistic patch — update only the specific step card during run, avoiding full re-render */
function _patchStepCardRunning(stepIndex, isRunning) {
  const card = document.getElementById("scard-" + stepIndex);
  if (!card) return;

  const badge = card.querySelector(".aq-badge");
  const num   = card.querySelector(".aq-step-num");
  const btn   = card.querySelector(".aq-step-act-btn.run-step");

  if (badge) { badge.className = "aq-badge wb-running"; badge.textContent = "RUNNING…"; }
  if (num)   { num.innerHTML   = `<div class="aq-mini-spinner"></div>`; }
  if (btn)   { btn.disabled    = isRunning; btn.innerHTML = isRunning ? '<div class="aq-mini-spinner"></div> Running…' : '▶ Run Step'; }

  // Show loading output block
  const inner = document.getElementById("sbody-inner-" + stepIndex);
  if (inner && isRunning) {
    // Remove existing empty-inline placeholder and add spinner
    const emptyEl = inner.querySelector(".aq-empty-inline");
    if (emptyEl) {
      emptyEl.outerHTML = `
        <div class="aq-output-block aq-output-loading" id="stepLoadingBlock-${stepIndex}">
          <div class="aq-spinner-row">
            <div class="aq-spinner aq-spinner-sm"></div>
            <span>Executing step — please wait…</span>
          </div>
        </div>`;
    }
    // Recalculate open card height to fit new loading block
    _recalcOpenCard(stepIndex);
  }
}

/* ═══════════════════════════════════════════════════════
   AUTO RUN ALL STEPS
═══════════════════════════════════════════════════════ */
async function autoRunSteps() {
  const b = STATE.bundle;
  if (!b || !b.steps) { toast("Select a bundle first", "info"); return; }
  const ok = await showConfirm(
    "Auto-Run All Steps",
    `Auto-run all ${b.steps.length} steps sequentially?`,
    "▶ Auto Run"
  );
  if (!ok) return;

  for (let i = 0; i < b.steps.length; i++) {
    const latest   = STATE.bundle;
    const progress = Array.isArray(latest.progress) ? latest.progress : [];
    const prog     = progress.find(p => p && p.step === i);
    if (prog && prog.status === "completed") continue;
    await markStepDone(i);
    await new Promise(r => setTimeout(r, 600));
  }
  toast("✅ All steps completed", "success");
}

/* ═══════════════════════════════════════════════════════
   MARK STEP DONE
   FIX: Same route as runStep — /workspace/step/:bundleId/:stepIndex
═══════════════════════════════════════════════════════ */
async function markStepDone(stepIndex) {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  showLoading();
  try {
    const stepTitle = (b.steps && b.steps[stepIndex] && b.steps[stepIndex].title) || ("Step " + (stepIndex + 1));
    const res  = await fetch(`/workspace/step/${b._id}/${stepIndex}`, {
      method:  "POST",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify({ title: stepTitle }),
    });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }

    STATE.bundle = data.bundle;
    if (data.workspace && data.workspace.workspaceMemory) STATE.wsMemory = data.workspace.workspaceMemory;

    STATE.openSteps.add(stepIndex);
    renderExecPanel(data.bundle);
    renderMemoryPanel(data.bundle);
    renderInsightPanel(data.bundle);
    updateBundleRowProgress(b._id, data.bundle);

    requestAnimationFrame(() => {
      requestAnimationFrame(() => _openCard(stepIndex, false));
    });

    if (data.output) prependOutputFeed(data.bundle.title || "Bundle", data.output.stepIndex, data.output.stepTitle, data.output.content);

    if (data.bundle.status === "completed") toast("🎉 Bundle complete!", "success");
    else toast(`Step ${stepIndex + 1} complete ✓`, "success");
  } catch (e) {
    toast("Error marking step", "error");
    console.error(e);
  } finally { hideLoading(); }
}

/* ═══════════════════════════════════════════════════════
   RE-RUN STEP (local state reset — no backend call)
═══════════════════════════════════════════════════════ */
function rerunStep(stepIndex) {
  const b = STATE.bundle;
  if (!b) return;
  if (Array.isArray(b.progress)) {
    const entry = b.progress.find(p => p && p.step === stepIndex);
    if (entry) entry.status = "pending";
  }
  if (Array.isArray(b.outputs)) {
    b.outputs = b.outputs.filter(o => o && o.stepIndex !== stepIndex);
  }
  STATE.openSteps.add(stepIndex);
  renderExecPanel(b);
  toast(`Step ${stepIndex + 1} reset — click Run Step`, "info");
}

/* ═══════════════════════════════════════════════════════
   BUNDLE ACTIONS
═══════════════════════════════════════════════════════ */
async function runCurrentBundle() {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  showLoading();
  try {
    const res  = await fetch("/workspace/run/" + b._id, { method: "POST" });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    if (data.workspace && data.workspace.workspaceMemory) STATE.wsMemory = data.workspace.workspaceMemory;
    renderExecPanel(data.bundle);
    updateBundleRowDot(b._id, "active");
    toast("Bundle started ▶", "success");
  } catch (e) { toast("Failed to run bundle", "error"); }
  finally { hideLoading(); }
}

async function pauseCurrentBundle() {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  showLoading();
  try {
    const res  = await fetch("/workspace/pause/" + b._id, { method: "POST" });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    const updated = data.bundle || { ...STATE.bundle, status: "paused" };
    STATE.bundle  = updated;
    renderExecPanel(updated);
    updateBundleRowDot(b._id, "paused");
    toast("Paused ⏸", "info");
  } catch (e) { toast("Failed to pause", "error"); }
  finally { hideLoading(); }
}

async function resumeCurrentBundle() {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  showLoading();
  try {
    const res  = await fetch("/workspace/resume/" + b._id, { method: "POST" });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    if (data.workspace && data.workspace.workspaceMemory) STATE.wsMemory = data.workspace.workspaceMemory;
    renderExecPanel(data.bundle);
    updateBundleRowDot(b._id, "active");
    toast("Resumed ▶", "success");
  } catch (e) { toast("Failed to resume", "error"); }
  finally { hideLoading(); }
}

async function pinCurrentBundle()   { const b = STATE.bundle; if (!b) return; await _togglePin(b._id); }
async function pinBundleById(id)    { await _togglePin(id); }

async function _togglePin(id) {
  const isPinned = STATE.pinnedIds.some(p => String(p) === String(id));
  const endpoint = isPinned ? "unpin" : "pin";
  try {
    const res  = await fetch(`/workspace/${endpoint}/${id}`, { method: "POST" });
    const data = await res.json();
    // Update local pinned state from server response
    if (data.pinnedBundleIds) STATE.pinnedIds = data.pinnedBundleIds;
    else if (!isPinned)       STATE.pinnedIds.push(id);
    else                      STATE.pinnedIds = STATE.pinnedIds.filter(x => String(x) !== String(id));

    if (STATE.bundle && String(STATE.bundle._id) === String(id)) updatePinBtn(id);

    // Update sidebar row button label
    const rowEl = document.getElementById("brow-" + id);
    if (rowEl) {
      const pinBtn = rowEl.querySelector(".aq-bundle-act-btn.pin");
      const nowPinned = STATE.pinnedIds.some(p => String(p) === String(id));
      if (pinBtn) pinBtn.textContent = nowPinned ? "★ PINNED" : "☆ PIN";
    }
    toast(isPinned ? "Unpinned" : "Pinned ★", isPinned ? "info" : "success");
  } catch { toast("Pin action failed", "error"); }
}

async function deleteCurrentBundle() {
  const b  = STATE.bundle;
  const id = b && b._id;
  if (!id) return;
  const ok = await showConfirm("Delete Bundle", "Delete this bundle? This cannot be undone.", "Delete");
  if (!ok) return;
  await _doDeleteBundle(id);
}

async function deleteBundleById(id) {
  if (!id) return;
  const ok = await showConfirm("Delete Bundle", "Delete this bundle? This cannot be undone.", "Delete");
  if (!ok) return;
  await _doDeleteBundle(id);
}

async function _doDeleteBundle(id) {
  showLoading();
  try {
    const res = await fetch("/bundle/" + id, { method: "DELETE" });
    if (!res.ok) throw new Error("Delete failed: " + res.status);

    // Remove from DOM
    const rowEl = document.getElementById("brow-" + id);
    if (rowEl) rowEl.remove();
    const sw = document.getElementById("bundleSwitcher");
    if (sw) { const opt = sw.querySelector(`option[value="${id}"]`); if (opt) opt.remove(); }

    // Remove from local state
    STATE.allBundles = STATE.allBundles.filter(b => String(b._id) !== String(id));

    if (STATE.bundle && String(STATE.bundle._id) === String(id)) {
      STATE.bundle = null;
      localStorage.removeItem("aq_activeBundle");
      showWelcome();
      updateBreadcrumb("Overview");
    }
    toast("Bundle deleted", "info");
  } catch (e) {
    toast("Failed to delete bundle", "error");
    console.error(e);
  } finally { hideLoading(); }
}

/* ═══════════════════════════════════════════════════════
   TOOL ACTIONS
   FIX: Use /workspace/tools/:id (DELETE) — NOT /tool/:id
═══════════════════════════════════════════════════════ */
async function removeTool(id) {
  if (!id) return;
  const ok = await showConfirm("Remove Tool", "Remove this tool from your workspace?", "Remove");
  if (!ok) return;
  showLoading();
  try {
    // FIX: canonical route is DELETE /workspace/tools/:id
    const res = await fetch(`/workspace/tools/${id}`, { method: "DELETE" });
    if (!res.ok) throw new Error("Remove failed: " + res.status);
    const el = document.getElementById("trow-" + id);
    if (el) el.remove();
    toast("Tool removed", "info");
  } catch (e) {
    toast("Failed to remove tool", "error");
    console.error(e);
  } finally { hideLoading(); }
}

/* ═══════════════════════════════════════════════════════
   MEMORY / INSIGHT / OUTPUT PANELS
═══════════════════════════════════════════════════════ */
function renderMemoryPanel(b) {
  const mem  = b.memory || {};
  const keys = Object.keys(mem);
  document.getElementById("memBundleCount").textContent = keys.length + " keys";
  document.getElementById("memBundleEntries").innerHTML = keys.length
    ? keys.map(k => `
        <div class="aq-mem-kv">
          <div class="aq-mem-k">${esc(k)}</div>
          <div class="aq-mem-v">${esc(String(mem[k] ?? ""))}</div>
        </div>`).join("")
    : `<div class="aq-empty" style="padding:8px 0;font-size:0.64rem;">No bundle memory yet.</div>`;

  if (b.contextSummary) {
    document.getElementById("memContextBox").textContent     = b.contextSummary;
    document.getElementById("memContextBox").style.display   = "";
    document.getElementById("memContextEmpty").style.display = "none";
  } else {
    document.getElementById("memContextBox").style.display   = "none";
    document.getElementById("memContextEmpty").style.display = "";
  }
  renderWsMemory();
}

function renderWsMemory() {
  const wsM    = STATE.wsMemory || {};
  const wsKeys = Object.keys(wsM);
  document.getElementById("memWsCount").textContent = wsKeys.length + " keys";
  document.getElementById("memWsEntries").innerHTML = wsKeys.length
    ? wsKeys.map(k => `
        <div class="aq-mem-kv" style="border-left-color:var(--accent3)">
          <div class="aq-mem-k" style="color:var(--accent3)">${esc(k)}</div>
          <div class="aq-mem-v">${esc(String(wsM[k] ?? ""))}</div>
        </div>`).join("")
    : `<div class="aq-empty" style="padding:8px 0;font-size:0.64rem;">No workspace memory yet.</div>`;
}

function renderInsightPanel(b) {
  const outputs = Array.isArray(b.outputs) ? b.outputs : [];
  const all     = [];
  outputs.forEach(o => {
    (o && o.keyInsights ? o.keyInsights : []).forEach(k => {
      if (k) all.push({ text: k, confidence: o.confidenceScore || 0 });
    });
  });
  all.sort((a, b) => b.confidence - a.confidence);
  document.getElementById("insightList").innerHTML = all.length
    ? all.map(({ text, confidence }) => {
        const badge = confidence
          ? `<span style="font-family:var(--mono);font-size:0.56rem;color:var(--accent2);margin-left:auto;flex-shrink:0;">${Math.round(confidence*100)}%</span>`
          : "";
        return `<div class="aq-insight-item">${esc(text)}${badge}</div>`;
      }).join("")
    : `<div class="aq-empty">Insights from step outputs will appear here.</div>`;
}

function renderOutputFeed(outputs) {
  const feed = document.getElementById("outputFeed");
  if (!outputs || !outputs.length) {
    feed.innerHTML = `<div class="aq-empty">No outputs yet.</div>`;
    return;
  }
  feed.innerHTML = outputs.map(o => `
    <div class="aq-feed-item">
      <div class="aq-feed-meta">
        <span class="aq-feed-step">Step ${(o.stepIndex ?? 0) + 1}${o.stepTitle ? ' · ' + esc(o.stepTitle) : ''}</span>
        <span class="aq-feed-bundle">${esc(o.bundleTitle || '')}</span>
      </div>
      <div class="aq-feed-preview">${esc(o.preview || o.content || '')}</div>
    </div>`).join("");
}

function prependOutputFeed(bundleTitle, stepIndex, stepTitle, content) {
  const feed  = document.getElementById("outputFeed");
  const empty = feed.querySelector(".aq-empty");
  if (empty) empty.remove();
  const item = document.createElement("div");
  item.className = "aq-feed-item aq-feed-item-new";
  item.innerHTML = `
    <div class="aq-feed-meta">
      <span class="aq-feed-step">Step ${stepIndex + 1}${stepTitle ? ' · ' + esc(stepTitle) : ''}</span>
      <span class="aq-feed-bundle">${esc(bundleTitle)}</span>
    </div>
    <div class="aq-feed-preview">${esc((content || '').substring(0, 240))}</div>`;
  feed.prepend(item);
  requestAnimationFrame(() => item.classList.add("visible"));
}

/* ═══════════════════════════════════════════════════════
   DOM HELPERS
═══════════════════════════════════════════════════════ */
function updateBreadcrumb(title) {
  document.getElementById("topBreadcrumb").textContent = title || "Bundle";
}

function updatePinBtn(id) {
  const el = document.getElementById("btnPin");
  if (el) el.textContent = STATE.pinnedIds.some(p => String(p) === String(id)) ? "★ PIN" : "☆ PIN";
}

function updateBundleRowDot(id, status) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const dot = row.querySelector(".aq-dot");
  if (!dot) return;
  dot.className = "aq-dot " + (
    status === "active"    ? "aq-dot-active"    :
    status === "paused"    ? "aq-dot-paused"    :
    status === "completed" ? "aq-dot-completed" : "aq-dot-draft"
  );
}

function updateBundleRowProgress(id, bundle) {
  const row  = document.getElementById("brow-" + id);
  if (!row) return;
  const steps = Array.isArray(bundle.steps)    ? bundle.steps    : [];
  const prog  = Array.isArray(bundle.progress) ? bundle.progress : [];
  const done  = prog.filter(p => p && p.status === "completed").length;
  const pct   = steps.length ? Math.round((done / steps.length) * 100) : 0;
  const fill  = row.querySelector(".aq-bundle-fill");
  const pctEl = row.querySelector(".aq-bundle-pct");
  if (fill)  fill.style.width  = pct + "%";
  if (pctEl) pctEl.textContent = pct + "%";
  updateBundleRowDot(id, bundle.status);
}

function launchTool(url) {
  if (!url) return;
  if (!url.startsWith("http")) url = "https://" + url;
  window.open(url, "_blank", "noopener,noreferrer");
}

/* ═══════════════════════════════════════════════════════
   SANITIZATION & FORMATTING
═══════════════════════════════════════════════════════ */
function esc(str) {
  if (str == null) return "";
  return String(str)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function formatOutput(text) {
  if (!text) return "";
  return esc(text)
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/^## (.+)$/gm, '<span class="aq-out-h2">$1</span>')
    .replace(/^- (.+)$/gm, '<span class="aq-out-li">• $1</span>')
    .replace(/`([^`]+)`/g, '<code class="aq-out-code">$1</code>')
    .replace(/\n/g, "<br/>");
}

/* ═══════════════════════════════════════════════════════
   TOAST
═══════════════════════════════════════════════════════ */
function toast(msg, type = "info") {
  const root = document.getElementById("aq-toast-root");
  const el   = document.createElement("div");
  el.className   = `aq-toast ${type}`;
  el.textContent = msg;
  root.appendChild(el);
  setTimeout(() => {
    el.classList.add("fadeout");
    setTimeout(() => el.remove(), 320);
  }, 3000);
}

/* ═══════════════════════════════════════════════════════
   COMMAND PALETTE
═══════════════════════════════════════════════════════ */
const PALETTE_COMMANDS = [
  { label: "▶ Run Bundle",          hint: "R",  action: () => runCurrentBundle() },
  { label: "⏸ Pause Bundle",        hint: "P",  action: () => pauseCurrentBundle() },
  { label: "↺ Resume Bundle",       hint: "RS", action: () => resumeCurrentBundle() },
  { label: "⚡ Auto-run All Steps",  hint: "A",  action: () => autoRunSteps() },
  { label: "☆ Pin / Unpin",         hint: "PI", action: () => pinCurrentBundle() },
  { label: "⌫ Delete Bundle",       hint: "D",  action: () => deleteCurrentBundle() },
  { label: "☰ Open Bundles",        hint: "B",  action: () => openSidebar() },
  { label: "← Go to Bundles",       hint: "G",  action: () => { window.location.href = "/bundles"; } },
];

function openPalette() {
  document.getElementById("aqPalette").classList.add("open");
  document.getElementById("aqPaletteInput").value = "";
  renderPaletteList(PALETTE_COMMANDS);
  document.getElementById("aqPaletteInput").focus();
}
function closePalette(e) {
  if (e && e.target !== document.getElementById("aqPalette")) return;
  document.getElementById("aqPalette").classList.remove("open");
}
function renderPaletteList(cmds) {
  document.getElementById("aqPaletteList").innerHTML = cmds.map((c, i) => `
    <div class="aq-palette-cmd" data-idx="${i}">
      ${esc(c.label)}
      <span class="key">${esc(c.hint)}</span>
    </div>`).join("");
  document.querySelectorAll(".aq-palette-cmd").forEach(el => {
    el.onclick = () => {
      cmds[parseInt(el.dataset.idx)].action();
      document.getElementById("aqPalette").classList.remove("open");
    };
  });
}
function filterPalette(val) {
  const lower    = val.toLowerCase();
  const filtered = PALETTE_COMMANDS.filter(c => c.label.toLowerCase().includes(lower));
  renderPaletteList(filtered);
}
function paletteKeydown(e) {
  if (e.key === "Escape") document.getElementById("aqPalette").classList.remove("open");
}

/* Global keyboard shortcuts */
document.addEventListener("keydown", e => {
  if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") {
    e.preventDefault(); openPalette();
  }
  if (e.key === "Escape") {
    document.getElementById("aqPalette").classList.remove("open");
    document.getElementById("aqConfirm").classList.remove("open");
    document.getElementById("aqRunModal").classList.remove("open");
  }
});

/* ═══════════════════════════════════════════════════════
   REALTIME (socket.io)
   FIX: on bundle:update, fetch fresh + re-render
   Preserves open step state across real-time updates
═══════════════════════════════════════════════════════ */
(function initRealtime() {
  if (typeof io === "undefined") return;
  try {
    const socket = io();
    socket.on("bundle:update", data => {
      if (!STATE.bundle) return;
      if (String(data.bundleId) !== String(STATE.bundle._id)) return;
      fetch("/workspace/bundle/" + STATE.bundle._id)
        .then(r => r.json())
        .then(d => {
          if (!d.bundle) return;
          STATE.bundle = d.bundle;
          // FIX: preserve open steps across real-time re-renders
          renderExecPanel(d.bundle);
          renderMemoryPanel(d.bundle);
          renderInsightPanel(d.bundle);
        }).catch(() => {});
    });
  } catch { /* socket.io not configured — polling fallback active */ }
})();

/* ═══════════════════════════════════════════════════════
   POLLING FALLBACK (every 10s when socket not available)
   Only runs if bundle is selected and not currently loading
═══════════════════════════════════════════════════════ */
setInterval(async () => {
  if (!STATE.bundle || STATE.loading || STATE.stepRunning.size > 0) return;
  try {
    const res  = await fetch("/workspace/bundle/" + STATE.bundle._id);
    const data = await res.json();
    if (!data.bundle) return;
    // FIX: Only re-render if data actually changed (check completionPercent)
    const prevDone = (STATE.bundle.progress || []).filter(p => p && p.status === "completed").length;
    const nextDone = (data.bundle.progress || []).filter(p => p && p.status === "completed").length;
    if (nextDone !== prevDone || data.bundle.status !== STATE.bundle.status) {
      STATE.bundle = data.bundle;
      renderExecPanel(data.bundle);
    }
  } catch {}
}, 10000);

/* ═══════════════════════════════════════════════════════
   SITE BUILDER ENGINE
   State, API calls, and UI management for the AI website
   execution engine embedded inside the workspace.
═══════════════════════════════════════════════════════ */

const SB = {
  projectId:   null,   // current project UUID
  projectName: null,   // display name
  files:       [],     // list of filenames
  activeFile:  null,   // currently previewed file
  busy:        false,  // prevent concurrent AI calls
};

// ── Open / Close ──────────────────────────────────────────────────────────────

function openSiteBuilder() {
  // Switch sidebar to SITES tab
  document.querySelectorAll(".aq-sidebar-tab").forEach(t => t.classList.remove("active"));
  const sitesTab = Array.from(document.querySelectorAll(".aq-sidebar-tab")).find(t => t.textContent.trim() === "SITES");
  if (sitesTab) sitesTab.classList.add("active");
  switchLeftTab("sites", sitesTab);

  // Show site builder, hide others
  document.getElementById("wsWelcome").style.display     = "none";
  document.getElementById("wsLoading").style.display     = "none";
  document.getElementById("wsExec").style.display        = "none";
  document.getElementById("wsError").style.display       = "none";
  document.getElementById("wsSiteBuilder").style.display = "flex";
}

function closeSiteBuilder() {
  document.getElementById("wsSiteBuilder").style.display = "none";
  showWelcome();
}

// ── Sidebar: left tab switch override ────────────────────────────────────────
// Patch switchLeftTab to handle the new "sites" tab

const _originalSwitchLeftTab = typeof switchLeftTab === "function" ? switchLeftTab : null;
function switchLeftTab(tab, btn) {
  // Update tab button active states
  document.querySelectorAll(".aq-sidebar-tab").forEach(t => t.classList.remove("active"));
  if (btn) btn.classList.add("active");

  // Hide/show sidebar panels
  const bundleList = document.getElementById("leftBundleList");
  const toolList   = document.getElementById("leftToolList");
  const siteList   = document.getElementById("leftSiteList");

  if (bundleList) bundleList.style.display = tab === "bundles" ? "" : "none";
  if (toolList)   toolList.style.display   = tab === "tools"   ? "" : "none";
  if (siteList)   siteList.style.display   = tab === "sites"   ? "" : "none";
}

// ── Load project list into sidebar ───────────────────────────────────────────

async function loadSiteList() {
  try {
    const res  = await fetch("/workspace/project/list");
    const data = await res.json();
    if (!data.success) return;

    const container = document.getElementById("sidebarSiteItems");
    if (!data.projects || data.projects.length === 0) {
      container.innerHTML = `<div class="aq-empty" style="margin-top:8px;">
        <span class="aq-empty-icon">&#127760;</span>
        No sites yet.<br/>
        <button onclick="openSiteBuilder()" style="background:none;border:none;color:#38bdf8;cursor:pointer;font-size:0.8rem;margin-top:6px;">Build one &#8594;</button>
      </div>`;
      return;
    }

    container.innerHTML = data.projects.map(p => `
      <div class="aq-site-item ${SB.projectId === p.projectId ? 'active' : ''}"
           id="srow-${p.projectId}"
           onclick="loadExistingProject('${p.projectId}', '${esc(p.name)}')">
        <span class="aq-site-item-icon">&#127760;</span>
        <div class="aq-site-item-info">
          <div class="aq-site-item-name">${esc(p.name)}</div>
          <div class="aq-site-item-meta">${p.files.length} file${p.files.length !== 1 ? 's' : ''}</div>
        </div>
        <button class="aq-site-item-del" onclick="event.stopPropagation();deleteSite('${p.projectId}')" title="Delete">&#10005;</button>
      </div>`).join("");
  } catch (err) {
    console.warn("[SB] loadSiteList:", err.message);
  }
}

// ── Load an existing project into the builder ─────────────────────────────────

async function loadExistingProject(projectId, name) {
  openSiteBuilder();

  SB.projectId   = projectId;
  SB.projectName = name;
  document.getElementById("sbProjectName").textContent = name;

  try {
    const res  = await fetch(`/workspace/project/${projectId}/files`);
    const data = await res.json();
    if (!data.success) throw new Error(data.error);
    SB.files = data.files;
    renderFileTree(data.files);
    showEditBar();
    // Load index.html by default
    const indexFile = data.files.find(f => f === "index.html") || data.files[0];
    if (indexFile) loadFilePreview(indexFile);
    // Highlight sidebar row
    document.querySelectorAll(".aq-site-item").forEach(el => el.classList.remove("active"));
    const row = document.getElementById("srow-" + projectId);
    if (row) row.classList.add("active");
  } catch (err) {
    toast("Failed to load project: " + err.message, "error");
  }
}

// ── Generate a new site ───────────────────────────────────────────────────────

async function generateSite() {
  if (SB.busy) return;
  const prompt = document.getElementById("sbPromptInput").value.trim();
  if (!prompt) { toast("Please describe the website first", "error"); return; }

  SB.busy = true;
  setBtnLoading("sbGenerateBtn", "sbGenerateBtnText", "&#9889; Generating&#8230;", true);
  showGeneratingOverlay(true);
  document.getElementById("sbEmpty").style.display = "none";

  try {
    // 1. Create project
    const name      = prompt.slice(0, 40);
    const createRes = await fetch("/workspace/project/create", {
      method:  "POST",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify({ name }),
    });
    const createData = await createRes.json();
    if (!createData.success) throw new Error(createData.error);

    SB.projectId   = createData.projectId;
    SB.projectName = createData.name;
    document.getElementById("sbProjectName").textContent = createData.name;

    // 2. Generate files
    const genRes = await fetch("/workspace/project/generate", {
      method:  "POST",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify({ projectId: SB.projectId, prompt }),
    });
    const genData = await genRes.json();
    if (!genData.success) throw new Error(genData.error);

    SB.files = genData.files;
    renderFileTree(genData.files);
    showEditBar();
    loadFilePreview("index.html");
    showGeneratingOverlay(false);
    document.getElementById("sbBody").style.display = "flex";

    // Refresh sidebar
    await loadSiteList();
    toast("Site generated! (" + genData.files.length + " files)", "success");

  } catch (err) {
    showGeneratingOverlay(false);
    document.getElementById("sbEmpty").style.display = "flex";
    toast("Generation failed: " + err.message, "error");
  } finally {
    SB.busy = false;
    setBtnLoading("sbGenerateBtn", "sbGenerateBtnText", "&#9889; BUILD SITE", false);
  }
}

// ── Edit the site via natural language ────────────────────────────────────────

async function editSite() {
  if (SB.busy || !SB.projectId) return;
  const command  = document.getElementById("sbCommandInput").value.trim();
  const filename = document.getElementById("sbFileSelect").value || "index.html";
  if (!command) { toast("Please enter an edit command", "error"); return; }

  SB.busy = true;
  setBtnLoading("sbEditBtn", "sbEditBtnText", "Editing&#8230;", true);
  showGeneratingOverlay(true);

  try {
    const res = await fetch("/workspace/project/edit", {
      method:  "POST",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify({ projectId: SB.projectId, command, filename }),
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.error);

    // Reload the preview
    loadFilePreview(filename);
    document.getElementById("sbCommandInput").value = "";
    toast("Edit applied to " + filename, "success");

  } catch (err) {
    toast("Edit failed: " + err.message, "error");
  } finally {
    SB.busy = false;
    showGeneratingOverlay(false);
    setBtnLoading("sbEditBtn", "sbEditBtnText", "&#9998; EDIT", false);
  }
}

// ── Delete a site project ─────────────────────────────────────────────────────

async function deleteSite(projectId) {
  const confirmed = await showConfirm("Delete Site", "This will permanently delete the project and all its files.", "Delete");
  if (!confirmed) return;
  try {
    const res = await fetch(`/workspace/project/${projectId}`, { method: "DELETE" });
    const data = await res.json();
    if (!data.success) throw new Error(data.error);
    if (SB.projectId === projectId) {
      SB.projectId = null;
      SB.files = [];
      document.getElementById("sbBody").style.display  = "none";
      document.getElementById("sbEmpty").style.display = "flex";
      document.getElementById("sbEditBar").style.display    = "none";
      document.getElementById("sbGenerateBar").style.display = "";
      document.getElementById("sbProjectName").textContent  = "No project loaded";
      document.getElementById("sbPreviewFrame").src = "about:blank";
    }
    await loadSiteList();
    toast("Project deleted", "success");
  } catch (err) {
    toast("Delete failed: " + err.message, "error");
  }
}

// ── Preview helpers ───────────────────────────────────────────────────────────

function loadFilePreview(filename) {
  if (!SB.projectId || !filename) return;
  SB.activeFile = filename;

  const url   = `/workspace/project/${SB.projectId}/${filename}`;
  const frame = document.getElementById("sbPreviewFrame");
  const urlEl = document.getElementById("sbPreviewUrl");

  frame.src = url + "?v=" + Date.now(); // cache bust
  if (urlEl) urlEl.textContent = url;

  // Highlight active file in tree
  document.querySelectorAll(".aq-sb-file-item").forEach(el => {
    el.classList.toggle("active", el.dataset.filename === filename);
  });

  // Update file select
  const sel = document.getElementById("sbFileSelect");
  if (sel) sel.value = filename;
}

function refreshPreview() {
  if (SB.activeFile) loadFilePreview(SB.activeFile);
}

// ── File tree rendering ───────────────────────────────────────────────────────

function renderFileTree(files) {
  const list = document.getElementById("sbFileList");
  const cnt  = document.getElementById("sbFileCount");
  if (cnt) cnt.textContent = files.length + " files";

  const iconMap = { ".html": "&#128196;", ".css": "&#127912;", ".js": "&#9881;", ".json": "&#128202;", ".svg": "&#128444;", ".png": "&#128444;", ".jpg": "&#128444;" };
  const ext = f => { const i = f.lastIndexOf("."); return i !== -1 ? f.slice(i) : ""; };

  list.innerHTML = files.map(f => `
    <div class="aq-sb-file-item ${f === SB.activeFile ? 'active' : ''}"
         data-filename="${esc(f)}"
         onclick="loadFilePreview('${esc(f)}')">
      <span class="aq-sb-file-icon">${iconMap[ext(f)] || "&#128196;"}</span>
      ${esc(f)}
    </div>`).join("");

  // Sync select dropdown
  const sel = document.getElementById("sbFileSelect");
  if (sel) {
    sel.innerHTML = files.map(f => `<option value="${esc(f)}">${esc(f)}</option>`).join("");
    if (SB.activeFile) sel.value = SB.activeFile;
  }
}

// ── UI state helpers ──────────────────────────────────────────────────────────

function showEditBar() {
  document.getElementById("sbGenerateBar").style.display = "none";
  document.getElementById("sbEditBar").style.display     = "";
  document.getElementById("sbBody").style.display        = "flex";
  document.getElementById("sbEmpty").style.display       = "none";
}

function showGeneratingOverlay(show) {
  const el = document.getElementById("sbPreviewLoading");
  if (el) el.style.display = show ? "flex" : "none";
}

function setBtnLoading(btnId, textId, label, disabled) {
  const btn  = document.getElementById(btnId);
  const span = document.getElementById(textId);
  if (btn)  btn.disabled      = disabled;
  if (span) span.innerHTML    = label;
}

function setSbPrompt(text) {
  const input = document.getElementById("sbPromptInput");
  if (input) { input.value = text; input.focus(); }
}

// ── Init: load site list on page load ────────────────────────────────────────

(async function sbInit() {
  await loadSiteList();
})();

</script>
