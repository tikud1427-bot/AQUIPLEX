<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Workspace | Aquiplex</title>
<link rel="stylesheet" href="/css/styles.css">
<link rel="stylesheet" href="/css/workspace.css">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<style>
  /* UI FIX: Reduce blur to max 6px, improve contrast */
  .wp-shell { backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
  .wp-sidebar { backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
  .wp-right-panel { backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
  .wp-step-card { backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px); }
  /* Improve text contrast */
  .wp-step-desc { opacity: 1; filter: brightness(1.3); }
  .wp-mem-v { opacity: 1; color: #d0d0d0; }
  .wp-bundle-title { color: #f0f0f0; }
  .wp-exec-goal { color: #c8c8c8; }
  .wp-feed-preview { color: #c0c0c0; }
  .wp-output-content { color: #dcdcdc; }
</style>
</head>

<body>
<%- include('partials/nav') %>

<div class="workspace-page">
<div class="wp-shell">

  <!-- ═══════════════ TOP BAR ═══════════════ -->
  <div class="wp-topbar">
    <div class="wp-logo">
      AQUI<span class="wp-logo-sep">PLEX</span> // WORKSPACE
    </div>
    <div class="wp-breadcrumb">
      <span>Workspace</span>
      <span class="sep">›</span>
      <span class="active" id="topBreadcrumb">Overview</span>
    </div>
    <div class="wp-topbar-right">
      <div class="wp-status-pill">
        <div class="wp-status-dot"></div>
        <span id="topStatusText">ONLINE</span>
      </div>
      <div style="display:flex; gap:10px; margin-left:20px;">

        <button class="wp-btn wp-btn-ghost" onclick="goToBundles()">
          ← Bundles
        </button>

        <select id="bundleSwitcher" class="wp-btn wp-btn-ghost"></select>

        <button class="wp-btn wp-btn-ghost" onclick="deleteCurrentBundle()">
          Delete
        </button>

      </div>
    </div>
  </div>

  <!-- ═══════════════ BODY ═══════════════ -->
  <div class="wp-body">

    <!-- ─────── LEFT SIDEBAR ─────── -->
    <div class="wp-sidebar">
      <div class="wp-sidebar-tabs">
        <button class="wp-sidebar-tab active" onclick="switchLeftTab('bundles', this)">BUNDLES</button>
        <button class="wp-sidebar-tab" onclick="switchLeftTab('tools', this)">TOOLS</button>
      </div>

      <!-- BUNDLES -->
      <div class="wp-sidebar-list" id="leftBundleList">
        <% if (bundles && bundles.length > 0) { %>
          <% bundles.forEach(function(b) {
            const completed = (b.progress || []).filter(p => p && p.status === 'completed').length;
            const total     = (b.steps || []).length;
            const pct       = total > 0 ? Math.round((completed / total) * 100) : 0;
            const dotCls    = b.status === 'active'    ? 'wi-active'
                            : b.status === 'paused'    ? 'wi-paused'
                            : b.status === 'completed' ? 'wi-completed'
                            : 'wi-draft';
          %>
          <div class="wp-bundle-item" id="brow-<%= b._id %>"
               onclick="selectBundle(<%- JSON.stringify({
                 _id:      b._id,
                 title:    b.title,
                 goal:     b.goal,
                 status:   b.status,
                 steps:    b.steps,
                 progress: b.progress,
                 outputs:  b.outputs || [],
                 memory:   b.memory  || {},
                 currentStep: b.currentStep || 0
               }).replace(/</g,'\\u003c') %>)">
            <div class="wp-bundle-title"><%= b.title %></div>
            <div class="wp-bundle-meta">
              <div class="wp-status-icon <%= dotCls %>"></div>
              <div class="wp-bundle-prog-track">
                <div class="wp-bundle-prog-fill" style="width:<%= pct %>%"></div>
              </div>
              <div class="wp-bundle-pct"><%= pct %>%</div>
              <!-- FIX: Delete button now correctly inside .wp-bundle-item -->
              <button class="wp-bundle-delete-btn"
                onclick="event.stopPropagation(); deleteBundle('<%= b._id %>')"
                title="Delete bundle"
                style="background:none;border:none;color:#888;font-size:10px;cursor:pointer;padding:0 2px;margin-left:4px;line-height:1;">✕</button>
            </div>
          </div>
          <% }) %>
        <% } else { %>
          <div class="wp-empty">
            No bundles yet.<br/>
            <a class="wp-empty-link" href="/bundles">Create one →</a>
          </div>
        <% } %>
      </div>

      <!-- TOOLS -->
      <div class="wp-sidebar-list" id="leftToolList" style="display:none;">
        <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>
          <% workspace.tools.forEach(function(tool) { %>
          <!-- FIX: Remove button is now correctly inside .wp-tool-item -->
          <div class="wp-tool-item" style="position:relative;">
            <img src="<%= tool.logo || '/logos/default.png' %>"
                 onerror="this.src='/logos/default.png'"
                 class="wp-tool-logo" alt=""/>
            <span class="wp-tool-name"><%= tool.name %></span>
            <button class="wp-tool-open"
                    onclick="event.stopPropagation(); launchTool('<%= (tool.url || '').replace(/'/g, '') %>')">
              OPEN
            </button>
            <button class="wp-tool-open"
                    style="margin-left:4px; opacity:0.7;"
                    onclick="event.stopPropagation(); removeTool('<%= tool._id %>')">
              Remove
            </button>
          </div>
          <% }) %>
        <% } else { %>
          <div class="wp-empty">
            No tools saved.<br/>
            <a class="wp-empty-link" href="/tools">Browse tools →</a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- ─────── MAIN ─────── -->
    <div class="wp-main">

      <!-- WELCOME -->
      <div class="wp-welcome" id="wsWelcome">
        <div class="wp-welcome-glyph">⚡</div>
        <h2>Execution Control</h2>
        <p>Select a bundle from the sidebar to view its execution state, step timeline, outputs, and memory.</p>
      </div>

      <!-- EXEC VIEW -->
      <div class="wp-exec" id="wsExec" style="display:none;">

        <!-- Header -->
        <div class="wp-exec-header">
          <div class="wp-exec-header-top">
            <div class="wp-exec-title-block">
              <div class="wp-exec-title" id="execTitle">—</div>
              <div class="wp-exec-goal"  id="execGoal">—</div>
            </div>
            <div class="wp-exec-actions">
              <button class="wp-btn wp-btn-run"   id="btnRun"    onclick="runCurrentBundle()">▶ RUN</button>
              <button class="wp-btn wp-btn-pause"  id="btnPause"  onclick="pauseCurrentBundle()"  style="display:none;">⏸ PAUSE</button>
              <button class="wp-btn wp-btn-ghost"  id="btnResume" onclick="resumeCurrentBundle()" style="display:none;">↺ RESUME</button>
              <button class="wp-btn wp-btn-ghost"  id="btnPin"    onclick="pinCurrentBundle()">☆ PIN</button>
            </div>
          </div>

          <div class="wp-stats-row">
            <div class="wp-stat">
              <div class="wp-stat-val c-accent" id="statSteps">—</div>
              <div class="wp-stat-lbl">Steps</div>
            </div>
            <div class="wp-stat-divider"></div>
            <div class="wp-stat">
              <div class="wp-stat-val c-green" id="statDone">—</div>
              <div class="wp-stat-lbl">Done</div>
            </div>
            <div class="wp-stat-divider"></div>
            <div class="wp-stat">
              <div class="wp-stat-val" id="statPct">—</div>
              <div class="wp-stat-lbl">Complete</div>
            </div>
            <div class="wp-stat-divider"></div>
            <div class="wp-stat">
              <div class="wp-stat-val c-amber" id="statStatus">—</div>
              <div class="wp-stat-lbl">Status</div>
            </div>
            <div class="wp-stat-divider"></div>
            <div class="wp-stat">
              <div class="wp-stat-val c-purple" id="statConfidence">—</div>
              <div class="wp-stat-lbl">Confidence</div>
            </div>
          </div>

          <div class="wp-exec-progress">
            <div class="wp-progress-track">
              <div class="wp-progress-fill" id="mainProgressFill" style="width:0%"></div>
            </div>
          </div>
        </div>

        <!-- Content grid -->
        <div class="wp-exec-content">

          <!-- Steps column -->
          <div class="wp-steps-panel">
            <div class="wp-timeline-strip" id="execTimeline"></div>
            <div class="wp-steps-scroll"  id="execSteps"></div>
          </div>

          <!-- Right panel -->
          <div class="wp-right-panel">
            <div class="wp-right-tabs">
              <button class="wp-right-tab active" onclick="switchRightTab('outputs', this)">OUTPUTS</button>
              <button class="wp-right-tab"         onclick="switchRightTab('memory', this)">MEMORY</button>
              <button class="wp-right-tab"         onclick="switchRightTab('insights', this)">INSIGHTS</button>
            </div>

            <div class="wp-right-body">

              <!-- Outputs -->
              <div class="wp-right-section active" id="rtab-outputs">
                <div id="outputFeed">
                  <div class="wp-empty" style="padding:32px 0;">Run a bundle step to see outputs here.</div>
                </div>
              </div>

              <!-- Memory -->
              <div class="wp-right-section" id="rtab-memory">
                <div class="wp-mem-hdr">
                  Bundle Memory
                  <span class="wp-mem-hdr-count" id="memBundleCount">0 keys</span>
                </div>
                <div id="memBundleEntries"></div>

                <div class="wp-mem-hdr" style="margin-top:18px;">
                  Context Summary
                </div>
                <div class="wp-context-box" id="memContextBox"   style="display:none;"></div>
                <div class="wp-empty"        id="memContextEmpty" style="padding:8px 0;">No context summary yet.</div>

                <div class="wp-mem-hdr" style="margin-top:18px;">
                  Workspace Memory
                  <span class="wp-mem-hdr-count" id="memWsCount">0 keys</span>
                </div>
                <div id="memWsEntries"></div>
              </div>

              <!-- Insights -->
              <div class="wp-right-section" id="rtab-insights">
                <div id="insightList">
                  <div class="wp-empty" style="padding:32px 0;">Key insights from step outputs will appear here.</div>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</div>
</div><!-- /.workspace-page -->

<%- include("partials/footer") %>

<!-- ═══════════════════════════════════════
     AQUIPLEX WORKSPACE ENGINE
═══════════════════════════════════════ -->
<script>
// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
const STATE = {
  bundle:       null,
  wsMemory:     {},
  pinnedIds:    [],
  selectedStep: null,
  loading:      false,
};

// ═══════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════
window.addEventListener("DOMContentLoaded", async () => {
  // FIX: Init bundle switcher before async state fetch
  initBundleSwitcher();

  try {
    const res  = await fetch("/workspace/state");
    if (!res.ok) throw new Error("State load failed");
    const data = await res.json();

    STATE.wsMemory  = (data.workspace && data.workspace.workspaceMemory) || {};
    STATE.pinnedIds = (data.workspace && data.workspace.pinnedBundleIds)  || [];

    renderWsMemory();

    if (data.workspace && data.workspace.recentOutputs && data.workspace.recentOutputs.length) {
      renderOutputFeed(data.workspace.recentOutputs);
    }

    const lastId = data.workspace && data.workspace.lastOpenBundleId;
    const bundles = data.bundles || [];

    if (lastId) {
      const b = bundles.find(x => String(x._id) === String(lastId));
      if (b) { selectBundle(b); return; }
    }

    const active = bundles.find(b => b.status === "active");
    if (active) selectBundle(active);
  } catch (e) {
    console.warn("[WS] State init failed:", e.message);
  }
});

// ═══════════════════════════════════════════
// BUNDLE SWITCHER — FIX: instant switch via fetch, no page reload
// ═══════════════════════════════════════════
// FIX: bundles array is injected once from EJS, used by switcher and sidebar
const _ejsBundles = <%- JSON.stringify(bundles || []) %>;

function initBundleSwitcher() {
  const switcher = document.getElementById("bundleSwitcher");
  if (!switcher) return;

  switcher.innerHTML = _ejsBundles.map(b =>
    `<option value="${b._id}">${esc(b.title)}</option>`
  ).join("");

  const saved = localStorage.getItem("activeBundle");
  if (saved) switcher.value = saved;

  // FIX: Use selectBundle via fetch instead of page reload
  switcher.onchange = () => {
    const id = switcher.value;
    localStorage.setItem("activeBundle", id);
    const found = _ejsBundles.find(b => String(b._id) === String(id));
    if (found) selectBundle(found);
  };
}

// ═══════════════════════════════════════════
// TAB SWITCHES
// ═══════════════════════════════════════════
function switchLeftTab(tab, btn) {
  document.querySelectorAll(".workspace-page .wp-sidebar-tab").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("leftBundleList").style.display = tab === "bundles" ? "" : "none";
  document.getElementById("leftToolList").style.display   = tab === "tools"   ? "" : "none";
}

function switchRightTab(tab, btn) {
  document.querySelectorAll(".workspace-page .wp-right-tab").forEach(b => b.classList.remove("active"));
  document.querySelectorAll(".workspace-page .wp-right-section").forEach(s => s.classList.remove("active"));
  btn.classList.add("active");
  const section = document.getElementById("rtab-" + tab);
  if (section) section.classList.add("active");
}

// ═══════════════════════════════════════════
// SELECT BUNDLE
// ═══════════════════════════════════════════
async function selectBundle(bundle) {
  if (!bundle || !bundle._id) return;

  document.querySelectorAll(".workspace-page .wp-bundle-item").forEach(r => r.classList.remove("selected"));
  const row = document.getElementById("brow-" + bundle._id);
  if (row) row.classList.add("selected");

  // Sync switcher dropdown
  const switcher = document.getElementById("bundleSwitcher");
  if (switcher) switcher.value = bundle._id;
  localStorage.setItem("activeBundle", bundle._id);

  // Always fetch fresh state from server
  try {
    const res  = await fetch("/workspace/bundle/" + bundle._id);
    if (res.ok) {
      const data = await res.json();
      if (data && data.bundle) bundle = data.bundle;
    }
  } catch (_) {}

  STATE.bundle       = bundle;
  STATE.selectedStep = null;

  document.getElementById("wsWelcome").style.display = "none";
  document.getElementById("wsExec").style.display    = "flex";

  renderExecPanel(bundle);
  renderMemoryPanel(bundle);
  renderInsightPanel(bundle);
  updateBreadcrumb(bundle.title);
  updatePinBtn(bundle._id);
}

// ═══════════════════════════════════════════
// RENDER EXEC PANEL
// ═══════════════════════════════════════════
function renderExecPanel(b) {
  const steps    = Array.isArray(b.steps)    ? b.steps    : [];
  const progress = Array.isArray(b.progress) ? b.progress : [];
  const outputs  = Array.isArray(b.outputs)  ? b.outputs  : [];

  const done  = progress.filter(p => p && p.status === "completed").length;
  const total = steps.length;
  const pct   = total ? Math.round((done / total) * 100) : 0;

  // Compute avg confidence
  const scores = outputs.map(o => o && o.confidenceScore).filter(s => typeof s === "number");
  const avgConf = scores.length
    ? (scores.reduce((a, s) => a + s, 0) / scores.length * 100).toFixed(0) + "%"
    : "—";

  document.getElementById("execTitle").textContent      = b.title  || "Untitled";
  document.getElementById("execGoal").textContent       = b.goal   || "";
  document.getElementById("statSteps").textContent      = total;
  document.getElementById("statDone").textContent       = done;
  document.getElementById("statPct").textContent        = pct + "%";
  document.getElementById("statStatus").textContent     = (b.status || "draft").toUpperCase();
  document.getElementById("statConfidence").textContent = avgConf;
  document.getElementById("mainProgressFill").style.width = pct + "%";

  const btnRun    = document.getElementById("btnRun");
  const btnPause  = document.getElementById("btnPause");
  const btnResume = document.getElementById("btnResume");

  btnRun.style.display    = "";
  btnPause.style.display  = "none";
  btnResume.style.display = "none";

  if (b.status === "active") {
    btnRun.style.display   = "none";
    btnPause.style.display = "";
  } else if (b.status === "paused") {
    btnRun.style.display    = "none";
    btnResume.style.display = "";
  } else if (b.status === "completed") {
    btnRun.style.display    = "none";
  }

  renderTimeline(steps, progress, b.currentStep || 0);
  renderStepCards(steps, progress, outputs, b.currentStep || 0);
}

// ═══════════════════════════════════════════
// TIMELINE
// ═══════════════════════════════════════════
function renderTimeline(steps, progress, currentStep) {
  const tl = document.getElementById("execTimeline");
  if (!steps || !steps.length) { tl.innerHTML = ""; return; }

  tl.innerHTML = steps.map((step, i) => {
    const prog   = progress.find(p => p && p.step === i);
    const status = prog ? prog.status : "pending";
    const dotCls = status === "completed"   ? "tl-done"
                 : status === "in-progress" ? "tl-running"
                 : i === currentStep        ? "tl-running"
                 : "";
    const icon = status === "completed" ? "✓"
               : status === "in-progress" ? "…"
               : (i + 1);

    const lineCls   = status === "completed" ? "tl-done" : "";
    const connector = i < steps.length - 1
      ? `<div class="wp-tl-line ${lineCls}"></div>` : "";

    return `
      <div class="wp-tl-step" title="${esc(step.title || 'Step ' + (i+1))}" onclick="jumpToStep(${i})">
        <div class="wp-tl-dot ${dotCls}">${icon}</div>
      </div>${connector}
    `;
  }).join("");
}

// ═══════════════════════════════════════════
// STEP CARDS
// ═══════════════════════════════════════════
function renderStepCards(steps, progress, outputs, currentStep) {
  const container = document.getElementById("execSteps");
  if (!steps || !steps.length) {
    container.innerHTML = `<div class="wp-empty">No steps defined.</div>`;
    return;
  }

  container.innerHTML = steps.map((step, i) => {
    const prog   = progress.find(p => p && p.step === i) || {};
    const status = prog.status || "pending";
    const output = outputs.find(o => o && o.stepIndex === i);

    const cardCls  = status === "in-progress" ? "sc-running"
                   : status === "completed"   ? "sc-done"
                   : i === currentStep        ? "sc-active" : "";

    const badgeCls = status === "completed"   ? "wb-done"
                   : status === "in-progress" ? "wb-running"
                   : status === "failed"      ? "wb-failed"
                   : "wb-pending";

    const badgeTxt = status === "completed"   ? "DONE"
                   : status === "in-progress" ? "RUNNING"
                   : status === "failed"      ? "FAILED"
                   : "PENDING";

    const numCls   = status === "completed"   ? "sn-done"
                   : status === "in-progress" ? "sn-running" : "";
    const numIcon  = status === "completed" ? "✓" : (i + 1);

    // Resources / tools chips
    const resources = step.resources || step.tools || [];
    const toolsHtml = resources.length
      ? `<div class="wp-step-tools">${resources.map(r => {
          if (typeof r === "string") {
            return `<span class="wp-tool-chip">🔗 ${esc(r)}</span>`;
          }
          return `<a class="wp-tool-chip" href="${esc(r.url||'#')}" target="_blank">🔗 ${esc(r.name||'Tool')}</a>`;
        }).join("")}</div>`
      : "";

    let outputHtml = "";
    if (output && output.content) {
      const confBadge = typeof output.confidenceScore === "number"
        ? `<span style="font-family:var(--wp-mono);font-size:0.57rem;color:var(--wp-accent2);margin-left:auto;">
             ${Math.round(output.confidenceScore * 100)}% conf
           </span>`
        : "";
      const durationBadge = output.durationMs
        ? `<span style="font-family:var(--wp-mono);font-size:0.57rem;color:var(--wp-muted);margin-left:8px;">
             ${output.durationMs}ms
           </span>`
        : "";

      const insights = (output.keyInsights || []).slice(0, 4).map(k =>
        `<span class="wp-insight-chip">${esc(k)}</span>`
      ).join("");

      outputHtml = `
        <div class="wp-output-block">
          <div class="wp-output-hdr">
            <span class="wp-output-label">⚡ Output</span>
            ${confBadge}${durationBadge}
            <div class="wp-output-dot"></div>
          </div>
          <div class="wp-output-content">${formatOutput(output.content)}</div>
        </div>
        ${insights ? `<div class="wp-step-insights">${insights}</div>` : ""}
      `;
    }

    const actionHtml = status !== "completed"
      ? `<button class="wp-step-btn wsb-done"  onclick="event.stopPropagation(); markStepDone(${i})">✅ Mark Done</button>`
      : `<button class="wp-step-btn wsb-rerun" onclick="event.stopPropagation(); rerunStep(${i})">↺ Re-run</button>`;

    const isOpen = i === currentStep || i === STATE.selectedStep;

    return `
      <div class="wp-step-card ${cardCls}" id="scard-${i}">
        <div class="wp-step-card-hdr" onclick="toggleCard(${i})">
          <div class="wp-step-num ${numCls}">${numIcon}</div>
          <div class="wp-step-info">
            <div class="wp-step-title">${esc(step.title || 'Step ' + (i+1))}</div>
            <div class="wp-step-desc">${esc(step.description || '')}</div>
          </div>
          <span class="wp-badge ${badgeCls}">${badgeTxt}</span>
          <span class="wp-step-toggle ${isOpen ? 'open' : ''}">▾</span>
        </div>
        <div class="wp-step-body ${isOpen ? 'open' : ''}" id="sbody-${i}">
          ${toolsHtml}
          ${outputHtml}
          <div class="wp-step-actions">${actionHtml}</div>
        </div>
      </div>
    `;
  }).join("");
}

// ═══════════════════════════════════════════
// MEMORY PANEL
// ═══════════════════════════════════════════
function renderMemoryPanel(b) {
  const mem  = b.memory || {};
  const keys = mem instanceof Map ? [...mem.keys()] : Object.keys(mem);

  document.getElementById("memBundleCount").textContent = keys.length + " keys";
  document.getElementById("memBundleEntries").innerHTML = keys.length
    ? keys.map(k => {
        const val = mem instanceof Map ? mem.get(k) : mem[k];
        return `
          <div class="wp-mem-kv">
            <div class="wp-mem-k">${esc(k)}</div>
            <div class="wp-mem-v">${esc(String(val || ""))}</div>
          </div>`;
      }).join("")
    : `<div class="wp-empty" style="padding:10px 0;">No bundle memory yet.</div>`;

  if (b.contextSummary) {
    document.getElementById("memContextBox").textContent    = b.contextSummary;
    document.getElementById("memContextBox").style.display  = "";
    document.getElementById("memContextEmpty").style.display = "none";
  } else {
    document.getElementById("memContextBox").style.display  = "none";
    document.getElementById("memContextEmpty").style.display = "";
  }

  renderWsMemory();
}

function renderWsMemory() {
  const wsM    = STATE.wsMemory || {};
  const wsKeys = Object.keys(wsM);
  document.getElementById("memWsCount").textContent = wsKeys.length + " keys";
  document.getElementById("memWsEntries").innerHTML = wsKeys.length
    ? wsKeys.map(k => `
        <div class="wp-mem-kv" style="border-left-color:var(--wp-accent3)">
          <div class="wp-mem-k" style="color:var(--wp-accent3)">${esc(k)}</div>
          <div class="wp-mem-v">${esc(String(wsM[k] || ""))}</div>
        </div>`).join("")
    : `<div class="wp-empty" style="padding:10px 0;">No workspace memory yet.</div>`;
}

// ═══════════════════════════════════════════
// INSIGHTS PANEL
// ═══════════════════════════════════════════
function renderInsightPanel(b) {
  const outputs = Array.isArray(b.outputs) ? b.outputs : [];
  const all     = [];

  outputs.forEach(o => {
    (o && o.keyInsights ? o.keyInsights : []).forEach(k => { if (k) all.push({ text: k, confidence: o.confidenceScore || 0 }); });
  });

  // Sort by confidence descending
  all.sort((a, b) => b.confidence - a.confidence);

  document.getElementById("insightList").innerHTML = all.length
    ? all.map(({ text, confidence }) => {
        const badge = confidence
          ? `<span style="font-family:var(--wp-mono);font-size:0.55rem;color:var(--wp-accent2);margin-left:8px;">${Math.round(confidence*100)}%</span>`
          : "";
        return `<div class="wp-insight-item"><span>${esc(text)}${badge}</span></div>`;
      }).join("")
    : `<div class="wp-empty" style="padding:32px 0;">Insights from step outputs will appear here.</div>`;
}

// ═══════════════════════════════════════════
// OUTPUT FEED
// ═══════════════════════════════════════════
function renderOutputFeed(outputs) {
  const feed = document.getElementById("outputFeed");
  if (!outputs || !outputs.length) {
    feed.innerHTML = `<div class="wp-empty" style="padding:32px 0;">No outputs yet.</div>`;
    return;
  }
  feed.innerHTML = outputs.map(o => `
    <div class="wp-feed-item">
      <div class="wp-feed-meta">
        <span class="wp-feed-step">Step ${((o.stepIndex) ?? 0) + 1}${o.stepTitle ? ' · ' + esc(o.stepTitle) : ''}</span>
        <span class="wp-feed-bundle">${esc(o.bundleTitle || '')}</span>
      </div>
      <div class="wp-feed-preview">${esc(o.preview || '')}</div>
    </div>`).join("");
}

function prependOutputFeed(bundleTitle, stepIndex, stepTitle, content) {
  const feed  = document.getElementById("outputFeed");
  const empty = feed.querySelector(".wp-empty");
  if (empty) empty.remove();

  const item = document.createElement("div");
  item.className = "wp-feed-item";
  item.innerHTML = `
    <div class="wp-feed-meta">
      <span class="wp-feed-step">Step ${stepIndex + 1}${stepTitle ? ' · ' + esc(stepTitle) : ''}</span>
      <span class="wp-feed-bundle">${esc(bundleTitle)}</span>
    </div>
    <div class="wp-feed-preview">${esc((content || '').substring(0, 240))}</div>
  `;
  feed.prepend(item);
}

// ═══════════════════════════════════════════
// ACTIONS
// ═══════════════════════════════════════════
async function runCurrentBundle() {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  STATE.loading = true;

  try {
    const res  = await fetch("/workspace/run/" + b._id, { method: "POST" });
    const data = await res.json();

    if (data.error) { toast(data.error, "error"); return; }

    STATE.bundle = data.bundle;
    if (data.workspace && data.workspace.workspaceMemory) {
      STATE.wsMemory = data.workspace.workspaceMemory;
    }

    renderExecPanel(data.bundle);
    updateBundleRowDot(b._id, "active");
    toast("Bundle started ▶", "success");
  } catch (e) {
    toast("Failed to run bundle", "error");
    console.error(e);
  } finally {
    STATE.loading = false;
  }
}

async function pauseCurrentBundle() {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  STATE.loading = true;

  try {
    const res  = await fetch("/workspace/pause/" + b._id, { method: "POST" });
    const data = await res.json();

    if (data.error) { toast(data.error, "error"); return; }

    if (data.bundle) STATE.bundle = data.bundle;
    else STATE.bundle.status = "paused";

    renderExecPanel(STATE.bundle);
    updateBundleRowDot(b._id, "paused");
    toast("Paused ⏸", "info");
  } catch (e) {
    toast("Failed to pause", "error");
  } finally {
    STATE.loading = false;
  }
}

async function resumeCurrentBundle() {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  STATE.loading = true;

  try {
    const res  = await fetch("/workspace/resume/" + b._id, { method: "POST" });
    const data = await res.json();

    if (data.error) { toast(data.error, "error"); return; }

    STATE.bundle = data.bundle;
    if (data.workspace && data.workspace.workspaceMemory) {
      STATE.wsMemory = data.workspace.workspaceMemory;
    }

    renderExecPanel(data.bundle);
    updateBundleRowDot(b._id, "active");
    toast("Resumed ▶", "success");
  } catch (e) {
    toast("Failed to resume", "error");
  } finally {
    STATE.loading = false;
  }
}

async function markStepDone(stepIndex) {
  const b = STATE.bundle;
  if (!b || STATE.loading) return;
  STATE.loading = true;

  try {
    const res  = await fetch(`/workspace/step/${b._id}/${stepIndex}`, {
      method:  "POST",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify({
        title: (b.steps && b.steps[stepIndex] && b.steps[stepIndex].title)
          || ("Step " + (stepIndex + 1)),
      }),
    });
    const data = await res.json();

    if (data.error) { toast(data.error, "error"); return; }

    STATE.bundle = data.bundle;

    if (data.workspace && data.workspace.workspaceMemory) {
      STATE.wsMemory = data.workspace.workspaceMemory;
    }

    renderExecPanel(data.bundle);
    renderMemoryPanel(data.bundle);
    renderInsightPanel(data.bundle);
    updateBundleRowProgress(b._id, data.bundle);

    // Push new output to feed
    if (data.output) {
      prependOutputFeed(
        data.bundle.title || "Bundle",
        data.output.stepIndex,
        data.output.stepTitle,
        data.output.content
      );
    }

    if (data.bundle.status === "completed") {
      toast("🎉 Bundle complete!", "success");
    } else {
      toast("Step " + (stepIndex + 1) + " complete ✓", "success");
    }
  } catch (e) {
    toast("Error marking step", "error");
    console.error(e);
  } finally {
    STATE.loading = false;
  }
}

async function rerunStep(stepIndex) {
  const b = STATE.bundle;
  if (!b) return;

  // Optimistic local reset
  if (Array.isArray(b.progress)) {
    const entry = b.progress.find(p => p && p.step === stepIndex);
    if (entry) entry.status = "pending";
  }
  if (Array.isArray(b.outputs)) {
    b.outputs = b.outputs.filter(o => o && o.stepIndex !== stepIndex);
  }

  renderExecPanel(b);
  toast("Step " + (stepIndex + 1) + " reset — mark done to re-run", "info");
}

async function pinCurrentBundle() {
  const b = STATE.bundle;
  if (!b) return;
  const id = b._id;

  try {
    const isPinned = STATE.pinnedIds.includes(id);
    const endpoint = isPinned ? "unpin" : "pin";
    const res      = await fetch(`/workspace/${endpoint}/${id}`, { method: "POST" });
    const data     = await res.json();

    if (data.pinnedBundleIds) STATE.pinnedIds = data.pinnedBundleIds;
    else if (!isPinned) STATE.pinnedIds.push(id);
    else STATE.pinnedIds = STATE.pinnedIds.filter(x => x !== id);

    updatePinBtn(id);
    toast(isPinned ? "Unpinned" : "Pinned ★", isPinned ? "info" : "success");
  } catch (e) {
    toast("Pin action failed", "error");
  }
}

// ═══════════════════════════════════════════
// DELETE BUNDLE — FIX: fully working with UI refresh
// ═══════════════════════════════════════════
async function deleteCurrentBundle() {
  const switcher = document.getElementById("bundleSwitcher");
  const id = switcher ? switcher.value : (STATE.bundle && STATE.bundle._id);
  if (!id) return;
  if (!confirm("Delete this bundle? This cannot be undone.")) return;

  try {
    const res = await fetch("/bundle/" + id, { method: "DELETE" });
    if (!res.ok) throw new Error("Delete failed");
    toast("Bundle deleted", "info");
    setTimeout(() => { window.location.href = "/bundles"; }, 800);
  } catch (e) {
    toast("Failed to delete bundle", "error");
    console.error(e);
  }
}

async function deleteBundle(id) {
  if (!id) return;
  if (!confirm("Delete this bundle? This cannot be undone.")) return;

  try {
    const res = await fetch("/bundle/" + id, { method: "DELETE" });
    if (!res.ok) throw new Error("Delete failed");

    // Remove from sidebar without full reload
    const row = document.getElementById("brow-" + id);
    if (row) row.remove();

    // If it was the selected bundle, show welcome screen
    if (STATE.bundle && String(STATE.bundle._id) === String(id)) {
      STATE.bundle = null;
      document.getElementById("wsWelcome").style.display = "";
      document.getElementById("wsExec").style.display    = "none";
      updateBreadcrumb("Overview");
    }

    // Remove from switcher
    const switcher = document.getElementById("bundleSwitcher");
    if (switcher) {
      const opt = switcher.querySelector(`option[value="${id}"]`);
      if (opt) opt.remove();
    }

    toast("Bundle deleted", "info");
  } catch (e) {
    toast("Failed to delete bundle", "error");
    console.error(e);
  }
}

// ═══════════════════════════════════════════
// REMOVE TOOL — FIX: working fetch + DOM removal
// ═══════════════════════════════════════════
async function removeTool(id) {
  if (!id) return;
  if (!confirm("Remove this tool?")) return;

  try {
    const res = await fetch("/tool/" + id, { method: "DELETE" });
    if (!res.ok) throw new Error("Remove failed");

    // Remove from sidebar without full reload
    const toolList = document.getElementById("leftToolList");
    if (toolList) {
      // Find and remove the parent .wp-tool-item that contains this button
      const allItems = toolList.querySelectorAll(".wp-tool-item");
      allItems.forEach(item => {
        const btn = item.querySelector(`button[onclick*="${id}"]`);
        if (btn) item.remove();
      });
    }

    toast("Tool removed", "info");
  } catch (e) {
    toast("Failed to remove tool", "error");
    console.error(e);
  }
}

// ═══════════════════════════════════════════
// CARD TOGGLES
// ═══════════════════════════════════════════
function toggleCard(idx) {
  const body   = document.getElementById("sbody-"  + idx);
  const toggle = document.querySelector(`#scard-${idx} .wp-step-toggle`);
  if (!body) return;

  const isOpen = body.classList.contains("open");
  body.classList.toggle("open",    !isOpen);
  if (toggle) toggle.classList.toggle("open", !isOpen);
  STATE.selectedStep = !isOpen ? idx : null;
}

function jumpToStep(idx) {
  STATE.selectedStep = idx;
  const card = document.getElementById("scard-" + idx);
  if (card) {
    card.scrollIntoView({ behavior: "smooth", block: "center" });
    const body   = document.getElementById("sbody-"  + idx);
    const toggle = document.querySelector(`#scard-${idx} .wp-step-toggle`);
    if (body)   body.classList.add("open");
    if (toggle) toggle.classList.add("open");
  }
}

// ═══════════════════════════════════════════
// DOM HELPERS
// ═══════════════════════════════════════════
function updateBreadcrumb(title) {
  document.getElementById("topBreadcrumb").textContent = title || "Bundle";
}

function updatePinBtn(id) {
  const el = document.getElementById("btnPin");
  if (el) el.textContent = STATE.pinnedIds.includes(id) ? "★ PINNED" : "☆ PIN";
}

function updateBundleRowDot(id, status) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const icon = row.querySelector(".wp-status-icon");
  if (!icon) return;
  icon.className = "wp-status-icon " + (
    status === "active"    ? "wi-active"    :
    status === "paused"    ? "wi-paused"    :
    status === "completed" ? "wi-completed" : "wi-draft"
  );
}

function updateBundleRowProgress(id, bundle) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const steps = Array.isArray(bundle.steps)    ? bundle.steps    : [];
  const prog  = Array.isArray(bundle.progress) ? bundle.progress : [];
  const done  = prog.filter(p => p && p.status === "completed").length;
  const pct   = steps.length ? Math.round((done / steps.length) * 100) : 0;
  const fill  = row.querySelector(".wp-bundle-prog-fill");
  const pctEl = row.querySelector(".wp-bundle-pct");
  if (fill)  fill.style.width      = pct + "%";
  if (pctEl) pctEl.textContent     = pct + "%";
  updateBundleRowDot(id, bundle.status);
}

function launchTool(url) {
  if (!url) return;
  if (!url.startsWith("http")) url = "https://" + url;
  window.open(url, "_blank", "noopener");
}

function esc(str) {
  if (str === null || str === undefined) return "";
  return String(str)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function formatOutput(text) {
  if (!text) return "";
  return esc(text)
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/^## (.+)$/gm,    '<span style="font-size:0.9rem;font-weight:700;color:var(--wp-bright);display:block;margin-bottom:4px;">$1</span>')
    .replace(/^- (.+)$/gm,     '<span style="display:block;padding-left:12px;">• $1</span>')
    .replace(/`([^`]+)`/g,     `<code style="background:var(--wp-bg);padding:1px 6px;border-radius:4px;font-family:var(--wp-mono);font-size:0.83em;">$1</code>`)
    .replace(/\n/g, "<br/>");
}

// ═══════════════════════════════════════════
// NAV
// ═══════════════════════════════════════════
function goToBundles() {
  window.location.href = "/bundles";
}

// ═══════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════
let _toastTimer;
function toast(msg, type = "info") {
  clearTimeout(_toastTimer);
  document.querySelectorAll(".workspace-page .wp-toast").forEach(e => e.remove());
  const el = document.createElement("div");
  el.className = `wp-toast wt-${type}`;
  el.textContent = msg;
  const page = document.querySelector(".workspace-page");
  if (page) page.appendChild(el);
  _toastTimer = setTimeout(() => el.remove(), 3200);
}
</script>
</body>
</html>
