<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Workspace | Aquiplex</title>
<link rel="stylesheet" href="/css/styles.css"/>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>

<style>
/* ═══════════════════════════════════════════════════════════════
   WORKSPACE PAGE — ALL STYLES SCOPED UNDER .workspace-page
   No global selectors. No conflicts with global stylesheet.
═══════════════════════════════════════════════════════════════ */

/* ── TOKENS ─────────────────────────────────────────────────── */
.workspace-page {
  --wp-bg:           #07090f;
  --wp-surface:      #0c1018;
  --wp-panel:        #111724;
  --wp-panel-2:      #141b27;
  --wp-border:       rgba(255,255,255,0.06);
  --wp-border-lit:   rgba(255,255,255,0.12);
  --wp-border-glow:  rgba(0,210,255,0.25);
  --wp-accent:       #00d2ff;
  --wp-accent2:      #8b5cf6;
  --wp-accent3:      #f43f5e;
  --wp-green:        #10e97a;
  --wp-amber:        #f59e0b;
  --wp-text:         #c4d4e8;
  --wp-muted:        rgba(148,163,184,0.45);
  --wp-bright:       #eef4ff;
  --wp-mono:         'Space Mono', monospace;
  --wp-ui:           'Syne', sans-serif;
  --wp-r:            14px;
  --wp-r-sm:         8px;
  --wp-shadow-glow:  0 0 40px rgba(0,210,255,0.06);
  --wp-shadow-card:  0 4px 24px rgba(0,0,0,0.4);

  font-family: var(--wp-ui);
  background: var(--wp-bg);
  color: var(--wp-text);
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

/* Ambient grid background */
.workspace-page::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,210,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,210,255,0.025) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
  z-index: 0;
}

/* Radial ambient glow top-right */
.workspace-page::after {
  content: '';
  position: fixed;
  top: -200px;
  right: -200px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(139,92,246,0.07) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.workspace-page * {
  box-sizing: border-box;
}

/* ── SHELL ───────────────────────────────────────────────────── */
.workspace-page .wp-shell {
  display: grid;
  grid-template-rows: 56px 1fr;
  height: 100vh;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

/* ── TOP BAR ─────────────────────────────────────────────────── */
.workspace-page .wp-topbar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 24px;
  background: rgba(12,16,24,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--wp-border);
  position: relative;
  z-index: 200;
}

.workspace-page .wp-logo {
  font-family: var(--wp-mono);
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--wp-accent);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8px;
}

.workspace-page .wp-logo-sep {
  color: var(--wp-border-lit);
  font-weight: 400;
}

.workspace-page .wp-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.78rem;
  color: var(--wp-muted);
  flex: 1;
}

.workspace-page .wp-breadcrumb .sep {
  color: var(--wp-border-lit);
  font-size: 0.6rem;
}

.workspace-page .wp-breadcrumb .active {
  color: var(--wp-bright);
  font-weight: 700;
}

.workspace-page .wp-topbar-right {
  display: flex;
  align-items: center;
  gap: 16px;
}

.workspace-page .wp-status-pill {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 5px 12px;
  background: rgba(16,233,122,0.07);
  border: 1px solid rgba(16,233,122,0.2);
  border-radius: 20px;
  font-family: var(--wp-mono);
  font-size: 0.62rem;
  font-weight: 700;
  color: var(--wp-green);
  letter-spacing: 0.1em;
}

.workspace-page .wp-status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--wp-green);
  box-shadow: 0 0 8px var(--wp-green);
  animation: wp-pulse 2s ease-in-out infinite;
}

@keyframes wp-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.8); }
}

@keyframes wp-spin {
  to { transform: rotate(360deg); }
}

@keyframes wp-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

@keyframes wp-slideUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes wp-glow-pulse {
  0%, 100% { box-shadow: 0 0 12px rgba(0,210,255,0.3); }
  50%       { box-shadow: 0 0 24px rgba(0,210,255,0.6); }
}

@keyframes wp-toastIn {
  from { opacity: 0; transform: translateY(10px) scale(0.95); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* ── BODY LAYOUT ─────────────────────────────────────────────── */
.workspace-page .wp-body {
  display: grid;
  grid-template-columns: 260px 1fr;
  overflow: hidden;
}

/* ── LEFT SIDEBAR ────────────────────────────────────────────── */
.workspace-page .wp-sidebar {
  background: var(--wp-surface);
  border-right: 1px solid var(--wp-border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.workspace-page .wp-sidebar-tabs {
  display: flex;
  border-bottom: 1px solid var(--wp-border);
  padding: 0 8px;
  gap: 2px;
}

.workspace-page .wp-sidebar-tab {
  flex: 1;
  padding: 12px 6px;
  background: none;
  border: none;
  color: var(--wp-muted);
  font-family: var(--wp-mono);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.2s ease;
  outline: none;
}

.workspace-page .wp-sidebar-tab.active {
  color: var(--wp-accent);
  border-bottom-color: var(--wp-accent);
  background: rgba(0,210,255,0.04);
}

.workspace-page .wp-sidebar-tab:hover:not(.active) {
  color: var(--wp-text);
}

.workspace-page .wp-sidebar-list {
  flex: 1;
  overflow-y: auto;
  padding: 10px;
}

.workspace-page .wp-sidebar-list::-webkit-scrollbar { width: 2px; }
.workspace-page .wp-sidebar-list::-webkit-scrollbar-thumb {
  background: var(--wp-border-lit);
  border-radius: 2px;
}

/* Bundle item */
.workspace-page .wp-bundle-item {
  padding: 12px;
  border-radius: var(--wp-r-sm);
  cursor: pointer;
  transition: all 0.2s ease;
  border: 1px solid transparent;
  margin-bottom: 4px;
  position: relative;
  overflow: hidden;
}

.workspace-page .wp-bundle-item::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 0;
  background: var(--wp-accent);
  transition: width 0.2s ease;
  border-radius: 0 2px 2px 0;
}

.workspace-page .wp-bundle-item:hover {
  background: var(--wp-panel);
  border-color: var(--wp-border);
}

.workspace-page .wp-bundle-item.selected {
  background: var(--wp-panel);
  border-color: var(--wp-border-lit);
}

.workspace-page .wp-bundle-item.selected::before {
  width: 3px;
}

.workspace-page .wp-bundle-title {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--wp-bright);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 8px;
}

.workspace-page .wp-bundle-meta {
  display: flex;
  align-items: center;
  gap: 8px;
}

.workspace-page .wp-bundle-prog-track {
  flex: 1;
  height: 3px;
  background: var(--wp-border);
  border-radius: 2px;
  overflow: hidden;
}

.workspace-page .wp-bundle-prog-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--wp-accent), var(--wp-accent2));
  border-radius: 2px;
  transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
}

.workspace-page .wp-bundle-pct {
  font-family: var(--wp-mono);
  font-size: 0.6rem;
  color: var(--wp-muted);
  flex-shrink: 0;
  min-width: 28px;
  text-align: right;
}

.workspace-page .wp-status-icon {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

.workspace-page .wi-active    { background: var(--wp-green); box-shadow: 0 0 6px var(--wp-green); animation: wp-pulse 2s infinite; }
.workspace-page .wi-paused    { background: var(--wp-amber); }
.workspace-page .wi-completed { background: var(--wp-accent2); }
.workspace-page .wi-draft     { background: var(--wp-border-lit); }

/* Tool item */
.workspace-page .wp-tool-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 10px;
  border-radius: var(--wp-r-sm);
  cursor: pointer;
  transition: all 0.2s ease;
  margin-bottom: 2px;
}

.workspace-page .wp-tool-item:hover {
  background: var(--wp-panel);
}

.workspace-page .wp-tool-logo {
  width: 28px;
  height: 28px;
  border-radius: 7px;
  object-fit: contain;
  background: var(--wp-panel);
  flex-shrink: 0;
  border: 1px solid var(--wp-border);
}

.workspace-page .wp-tool-name {
  font-size: 0.8rem;
  color: var(--wp-text);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.workspace-page .wp-tool-open {
  background: none;
  border: 1px solid var(--wp-border-lit);
  color: var(--wp-accent);
  padding: 3px 9px;
  border-radius: 5px;
  font-size: 0.62rem;
  font-family: var(--wp-mono);
  cursor: pointer;
  opacity: 0;
  transition: all 0.15s;
  white-space: nowrap;
}

.workspace-page .wp-tool-item:hover .wp-tool-open {
  opacity: 1;
}

.workspace-page .wp-tool-open:hover {
  background: rgba(0,210,255,0.08);
  border-color: var(--wp-accent);
}

/* Empty state */
.workspace-page .wp-empty {
  padding: 28px 10px;
  text-align: center;
  color: var(--wp-muted);
  font-size: 0.78rem;
  line-height: 1.6;
}

.workspace-page .wp-empty-link {
  color: var(--wp-accent);
  text-decoration: none;
  font-family: var(--wp-mono);
  font-size: 0.7rem;
  display: inline-block;
  margin-top: 6px;
  transition: opacity 0.15s;
}

.workspace-page .wp-empty-link:hover { opacity: 0.75; }

/* ── MAIN AREA ───────────────────────────────────────────────── */
.workspace-page .wp-main {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--wp-bg);
}

/* ── WELCOME ─────────────────────────────────────────────────── */
.workspace-page .wp-welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  text-align: center;
  animation: wp-slideUp 0.4s ease;
}

.workspace-page .wp-welcome-glyph {
  width: 72px;
  height: 72px;
  border-radius: 20px;
  background: linear-gradient(135deg, rgba(0,210,255,0.1), rgba(139,92,246,0.1));
  border: 1px solid var(--wp-border-lit);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  margin: 0 auto 24px;
  box-shadow: var(--wp-shadow-glow);
}

.workspace-page .wp-welcome h2 {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--wp-bright);
  margin-bottom: 10px;
  letter-spacing: -0.02em;
}

.workspace-page .wp-welcome p {
  font-size: 0.88rem;
  color: var(--wp-muted);
  max-width: 360px;
  line-height: 1.7;
}

/* ── EXECUTION VIEW ──────────────────────────────────────────── */
.workspace-page .wp-exec {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
  animation: wp-slideUp 0.3s ease;
}

/* ── EXEC HEADER ─────────────────────────────────────────────── */
.workspace-page .wp-exec-header {
  padding: 20px 24px 16px;
  border-bottom: 1px solid var(--wp-border);
  background: rgba(11,16,24,0.9);
  backdrop-filter: blur(10px);
  flex-shrink: 0;
}

.workspace-page .wp-exec-header-top {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 14px;
}

.workspace-page .wp-exec-title-block { flex: 1; min-width: 0; }

.workspace-page .wp-exec-title {
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--wp-bright);
  letter-spacing: -0.02em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 4px;
}

.workspace-page .wp-exec-goal {
  font-size: 0.76rem;
  color: var(--wp-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.workspace-page .wp-exec-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
  align-items: center;
}

/* Action buttons */
.workspace-page .wp-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: var(--wp-r-sm);
  font-family: var(--wp-mono);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  border: 1px solid;
  cursor: pointer;
  transition: all 0.2s ease;
  outline: none;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}

.workspace-page .wp-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0);
  transition: background 0.15s ease;
}

.workspace-page .wp-btn:hover::after {
  background: rgba(255,255,255,0.04);
}

.workspace-page .wp-btn:active {
  transform: scale(0.97);
}

.workspace-page .wp-btn-run {
  background: var(--wp-accent);
  color: #000;
  border-color: var(--wp-accent);
  box-shadow: 0 0 20px rgba(0,210,255,0.25);
}

.workspace-page .wp-btn-run:hover {
  box-shadow: 0 0 30px rgba(0,210,255,0.45);
  transform: translateY(-1px);
}

.workspace-page .wp-btn-pause {
  background: rgba(245,158,11,0.08);
  color: var(--wp-amber);
  border-color: rgba(245,158,11,0.3);
}

.workspace-page .wp-btn-pause:hover {
  background: rgba(245,158,11,0.15);
}

.workspace-page .wp-btn-ghost {
  background: transparent;
  color: var(--wp-text);
  border-color: var(--wp-border-lit);
}

.workspace-page .wp-btn-ghost:hover {
  background: var(--wp-panel);
  border-color: var(--wp-border-glow);
  color: var(--wp-bright);
}

/* Stats row */
.workspace-page .wp-stats-row {
  display: flex;
  gap: 20px;
}

.workspace-page .wp-stat {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.workspace-page .wp-stat-val {
  font-family: var(--wp-mono);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--wp-bright);
  line-height: 1;
}

.workspace-page .wp-stat-val.c-accent  { color: var(--wp-accent); }
.workspace-page .wp-stat-val.c-green   { color: var(--wp-green); }
.workspace-page .wp-stat-val.c-amber   { color: var(--wp-amber); }
.workspace-page .wp-stat-val.c-purple  { color: var(--wp-accent2); }

.workspace-page .wp-stat-lbl {
  font-family: var(--wp-mono);
  font-size: 0.56rem;
  color: var(--wp-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.workspace-page .wp-stat-divider {
  width: 1px;
  height: 28px;
  background: var(--wp-border);
  align-self: center;
}

/* Progress bar */
.workspace-page .wp-exec-progress {
  margin-top: 14px;
}

.workspace-page .wp-progress-track {
  height: 3px;
  background: var(--wp-border);
  border-radius: 2px;
  overflow: hidden;
  position: relative;
}

.workspace-page .wp-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--wp-accent), var(--wp-accent2), #f43f5e);
  background-size: 200% 100%;
  border-radius: 2px;
  transition: width 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.workspace-page .wp-progress-fill::after {
  content: '';
  position: absolute;
  right: 0;
  top: -2px;
  width: 8px;
  height: 7px;
  border-radius: 50%;
  background: var(--wp-accent);
  box-shadow: 0 0 8px var(--wp-accent);
}

/* ── EXEC CONTENT GRID ───────────────────────────────────────── */
.workspace-page .wp-exec-content {
  display: grid;
  grid-template-columns: 1fr 310px;
  flex: 1;
  overflow: hidden;
}

/* ── STEP TIMELINE ───────────────────────────────────────────── */
.workspace-page .wp-timeline-strip {
  padding: 14px 24px;
  border-bottom: 1px solid var(--wp-border);
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
  background: rgba(11,16,24,0.6);
  flex-shrink: 0;
}

.workspace-page .wp-timeline-strip::-webkit-scrollbar { height: 0; }

.workspace-page .wp-tl-step {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  cursor: pointer;
}

.workspace-page .wp-tl-dot {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--wp-mono);
  font-size: 0.6rem;
  font-weight: 700;
  border: 2px solid var(--wp-border-lit);
  background: var(--wp-panel);
  color: var(--wp-muted);
  transition: all 0.25s ease;
  position: relative;
}

.workspace-page .wp-tl-dot:hover {
  border-color: var(--wp-border-glow);
  transform: scale(1.1);
}

.workspace-page .wp-tl-dot.tl-done {
  background: rgba(16,233,122,0.1);
  border-color: var(--wp-green);
  color: var(--wp-green);
  box-shadow: 0 0 12px rgba(16,233,122,0.2);
}

.workspace-page .wp-tl-dot.tl-running {
  background: rgba(0,210,255,0.1);
  border-color: var(--wp-accent);
  color: var(--wp-accent);
  box-shadow: 0 0 14px rgba(0,210,255,0.35);
  animation: wp-glow-pulse 1.5s ease-in-out infinite;
}

.workspace-page .wp-tl-dot.tl-selected {
  border-color: var(--wp-accent2);
  color: var(--wp-accent2);
  background: rgba(139,92,246,0.1);
  transform: scale(1.12);
  box-shadow: 0 0 14px rgba(139,92,246,0.3);
}

.workspace-page .wp-tl-dot.tl-failed {
  background: rgba(244,63,94,0.1);
  border-color: var(--wp-accent3);
  color: var(--wp-accent3);
}

.workspace-page .wp-tl-line {
  height: 2px;
  width: 28px;
  background: var(--wp-border);
  flex-shrink: 0;
  transition: background 0.4s ease;
  position: relative;
}

.workspace-page .wp-tl-line.tl-done {
  background: linear-gradient(90deg, var(--wp-green), rgba(16,233,122,0.3));
}

/* ── STEPS PANEL ─────────────────────────────────────────────── */
.workspace-page .wp-steps-panel {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-right: 1px solid var(--wp-border);
}

.workspace-page .wp-steps-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 16px 20px;
}

.workspace-page .wp-steps-scroll::-webkit-scrollbar { width: 3px; }
.workspace-page .wp-steps-scroll::-webkit-scrollbar-thumb {
  background: var(--wp-border-lit);
  border-radius: 2px;
}

/* Step card */
.workspace-page .wp-step-card {
  border: 1px solid var(--wp-border);
  border-radius: var(--wp-r);
  margin-bottom: 10px;
  background: var(--wp-surface);
  overflow: hidden;
  transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
}

.workspace-page .wp-step-card:hover {
  border-color: var(--wp-border-lit);
  transform: translateY(-1px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.25);
}

.workspace-page .wp-step-card.sc-active {
  border-color: var(--wp-border-lit);
}

.workspace-page .wp-step-card.sc-running {
  border-color: var(--wp-accent);
  box-shadow: 0 0 20px rgba(0,210,255,0.08);
}

.workspace-page .wp-step-card.sc-done {
  border-color: rgba(16,233,122,0.18);
}

.workspace-page .wp-step-card-hdr {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  cursor: pointer;
  user-select: none;
}

.workspace-page .wp-step-num {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--wp-mono);
  font-size: 0.65rem;
  font-weight: 700;
  background: var(--wp-panel);
  border: 1px solid var(--wp-border-lit);
  color: var(--wp-muted);
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.workspace-page .wp-step-num.sn-done {
  background: rgba(16,233,122,0.08);
  border-color: var(--wp-green);
  color: var(--wp-green);
}

.workspace-page .wp-step-num.sn-running {
  background: rgba(0,210,255,0.08);
  border-color: var(--wp-accent);
  color: var(--wp-accent);
  animation: wp-pulse 1.5s ease-in-out infinite;
}

.workspace-page .wp-step-info { flex: 1; min-width: 0; }

.workspace-page .wp-step-title {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--wp-bright);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 3px;
}

.workspace-page .wp-step-desc {
  font-size: 0.73rem;
  color: var(--wp-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.workspace-page .wp-badge {
  padding: 3px 10px;
  border-radius: 20px;
  font-family: var(--wp-mono);
  font-size: 0.57rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  border: 1px solid;
  flex-shrink: 0;
}

.workspace-page .wb-pending  {
  background: var(--wp-panel);
  color: var(--wp-muted);
  border-color: var(--wp-border);
}

.workspace-page .wb-running  {
  background: rgba(0,210,255,0.08);
  color: var(--wp-accent);
  border-color: rgba(0,210,255,0.25);
}

.workspace-page .wb-done     {
  background: rgba(16,233,122,0.08);
  color: var(--wp-green);
  border-color: rgba(16,233,122,0.25);
}

.workspace-page .wb-failed   {
  background: rgba(244,63,94,0.08);
  color: var(--wp-accent3);
  border-color: rgba(244,63,94,0.25);
}

.workspace-page .wp-step-toggle {
  color: var(--wp-muted);
  font-size: 0.65rem;
  flex-shrink: 0;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
}

.workspace-page .wp-step-toggle.open {
  transform: rotate(180deg);
}

/* Step body */
.workspace-page .wp-step-body {
  border-top: 1px solid var(--wp-border);
  padding: 0;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), padding 0.25s ease;
}

.workspace-page .wp-step-body.open {
  max-height: 700px;
  padding: 16px;
}

.workspace-page .wp-step-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 14px;
}

.workspace-page .wp-tool-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 5px 11px;
  background: var(--wp-panel);
  border: 1px solid var(--wp-border-lit);
  border-radius: 6px;
  font-size: 0.71rem;
  color: var(--wp-accent);
  text-decoration: none;
  transition: all 0.15s ease;
}

.workspace-page .wp-tool-chip:hover {
  background: rgba(0,210,255,0.06);
  border-color: var(--wp-accent);
  transform: translateY(-1px);
}

/* Output block */
.workspace-page .wp-output-block {
  background: var(--wp-panel);
  border: 1px solid var(--wp-border);
  border-radius: var(--wp-r-sm);
  overflow: hidden;
  margin-bottom: 12px;
}

.workspace-page .wp-output-hdr {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-bottom: 1px solid var(--wp-border);
  background: rgba(0,210,255,0.03);
}

.workspace-page .wp-output-label {
  font-family: var(--wp-mono);
  font-size: 0.6rem;
  color: var(--wp-accent);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  flex: 1;
}

.workspace-page .wp-output-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--wp-green);
}

.workspace-page .wp-output-content {
  padding: 12px 14px;
  font-size: 0.79rem;
  color: var(--wp-text);
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 220px;
  overflow-y: auto;
}

.workspace-page .wp-output-content::-webkit-scrollbar { width: 2px; }
.workspace-page .wp-output-content::-webkit-scrollbar-thumb { background: var(--wp-border-lit); }

/* Insight chips */
.workspace-page .wp-step-insights {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 14px;
}

.workspace-page .wp-insight-chip {
  padding: 3px 10px;
  background: rgba(139,92,246,0.07);
  border: 1px solid rgba(139,92,246,0.2);
  border-radius: 20px;
  font-size: 0.7rem;
  color: var(--wp-accent2);
}

/* Step actions */
.workspace-page .wp-step-actions {
  display: flex;
  gap: 8px;
}

.workspace-page .wp-step-btn {
  padding: 7px 14px;
  border-radius: 7px;
  font-family: var(--wp-mono);
  font-size: 0.63rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  border: 1px solid;
  cursor: pointer;
  transition: all 0.2s ease;
  outline: none;
}

.workspace-page .wp-step-btn:active { transform: scale(0.96); }

.workspace-page .wsb-done {
  background: rgba(16,233,122,0.06);
  color: var(--wp-green);
  border-color: rgba(16,233,122,0.25);
}

.workspace-page .wsb-done:hover {
  background: rgba(16,233,122,0.14);
  border-color: var(--wp-green);
}

.workspace-page .wsb-rerun {
  background: rgba(0,210,255,0.05);
  color: var(--wp-accent);
  border-color: rgba(0,210,255,0.2);
}

.workspace-page .wsb-rerun:hover {
  background: rgba(0,210,255,0.12);
  border-color: var(--wp-accent);
}

/* ── RIGHT PANEL ─────────────────────────────────────────────── */
.workspace-page .wp-right-panel {
  background: var(--wp-surface);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

.workspace-page .wp-right-panel::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--wp-border-glow), transparent);
}

.workspace-page .wp-right-tabs {
  display: flex;
  border-bottom: 1px solid var(--wp-border);
}

.workspace-page .wp-right-tab {
  flex: 1;
  padding: 12px 4px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--wp-muted);
  font-family: var(--wp-mono);
  font-size: 0.57rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  outline: none;
}

.workspace-page .wp-right-tab.active {
  color: var(--wp-accent);
  border-bottom-color: var(--wp-accent);
  background: rgba(0,210,255,0.03);
}

.workspace-page .wp-right-tab:hover:not(.active) {
  color: var(--wp-text);
}

.workspace-page .wp-right-body {
  flex: 1;
  overflow-y: auto;
  padding: 14px;
}

.workspace-page .wp-right-body::-webkit-scrollbar { width: 2px; }
.workspace-page .wp-right-body::-webkit-scrollbar-thumb { background: var(--wp-border-lit); }

.workspace-page .wp-right-section { display: none; }
.workspace-page .wp-right-section.active { display: block; }

/* Output feed */
.workspace-page .wp-feed-item {
  background: var(--wp-panel);
  border: 1px solid var(--wp-border);
  border-radius: var(--wp-r-sm);
  padding: 11px 13px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.workspace-page .wp-feed-item:hover {
  border-color: var(--wp-border-lit);
  transform: translateX(2px);
}

.workspace-page .wp-feed-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 7px;
}

.workspace-page .wp-feed-step {
  font-family: var(--wp-mono);
  font-size: 0.59rem;
  color: var(--wp-accent);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.workspace-page .wp-feed-bundle {
  font-size: 0.61rem;
  color: var(--wp-muted);
  max-width: 110px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.workspace-page .wp-feed-preview {
  font-size: 0.75rem;
  color: var(--wp-text);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Memory panel */
.workspace-page .wp-mem-hdr {
  font-family: var(--wp-mono);
  font-size: 0.59rem;
  color: var(--wp-muted);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  padding: 8px 0 7px;
  margin-bottom: 7px;
  border-bottom: 1px solid var(--wp-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.workspace-page .wp-mem-hdr-count {
  color: var(--wp-accent);
  font-size: 0.57rem;
}

.workspace-page .wp-mem-kv {
  margin-bottom: 7px;
  padding: 9px 11px;
  background: var(--wp-panel);
  border-radius: 7px;
  border-left: 2px solid var(--wp-accent2);
}

.workspace-page .wp-mem-k {
  font-family: var(--wp-mono);
  font-size: 0.61rem;
  color: var(--wp-accent2);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin-bottom: 3px;
}

.workspace-page .wp-mem-v {
  font-size: 0.77rem;
  color: var(--wp-text);
  line-height: 1.5;
  word-break: break-word;
}

.workspace-page .wp-context-box {
  background: var(--wp-panel);
  border: 1px solid var(--wp-border);
  border-radius: 8px;
  padding: 11px 13px;
  font-size: 0.76rem;
  color: var(--wp-text);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

/* Insight list */
.workspace-page .wp-insight-item {
  display: flex;
  gap: 10px;
  padding: 9px 0;
  border-bottom: 1px solid var(--wp-border);
  font-size: 0.77rem;
  color: var(--wp-text);
  line-height: 1.55;
}

.workspace-page .wp-insight-item::before {
  content: '◆';
  color: var(--wp-accent);
  font-size: 0.55rem;
  flex-shrink: 0;
  margin-top: 4px;
}

/* ── STREAMING ───────────────────────────────────────────────── */
.workspace-page .wp-stream-line {
  font-family: var(--wp-mono);
  font-size: 0.72rem;
  color: var(--wp-accent);
  padding: 10px 13px;
  background: rgba(0,210,255,0.04);
  border-radius: 7px;
  border-left: 2px solid var(--wp-accent);
  min-height: 36px;
}

.workspace-page .wp-cursor {
  display: inline-block;
  width: 6px;
  height: 12px;
  background: var(--wp-accent);
  margin-left: 3px;
  animation: wp-blink 1s step-end infinite;
  vertical-align: middle;
}

/* ── SPINNER ─────────────────────────────────────────────────── */
.workspace-page .wp-spin {
  width: 13px;
  height: 13px;
  border: 2px solid var(--wp-border-lit);
  border-top-color: var(--wp-accent);
  border-radius: 50%;
  animation: wp-spin 0.65s linear infinite;
  display: inline-block;
}

/* ── TOAST ───────────────────────────────────────────────────── */
.workspace-page .wp-toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  padding: 11px 20px;
  border-radius: 10px;
  font-family: var(--wp-mono);
  font-size: 0.73rem;
  z-index: 9999;
  animation: wp-toastIn 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(10px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}

.workspace-page .wt-success {
  background: rgba(16,233,122,0.1);
  border: 1px solid rgba(16,233,122,0.3);
  color: var(--wp-green);
}

.workspace-page .wt-info {
  background: rgba(0,210,255,0.1);
  border: 1px solid rgba(0,210,255,0.3);
  color: var(--wp-accent);
}

.workspace-page .wt-error {
  background: rgba(244,63,94,0.1);
  border: 1px solid rgba(244,63,94,0.3);
  color: var(--wp-accent3);
}

/* ── RESPONSIVE ──────────────────────────────────────────────── */
@media (max-width: 1100px) {
  .workspace-page .wp-body {
    grid-template-columns: 220px 1fr;
  }
  .workspace-page .wp-exec-content {
    grid-template-columns: 1fr 270px;
  }
}

@media (max-width: 860px) {
  .workspace-page .wp-body {
    grid-template-columns: 1fr;
  }
  .workspace-page .wp-sidebar {
    display: none;
  }
  .workspace-page .wp-exec-content {
    grid-template-columns: 1fr;
  }
  .workspace-page .wp-right-panel {
    display: none;
  }
}

@media (max-width: 600px) {
  .workspace-page .wp-exec-header-top {
    flex-direction: column;
    gap: 12px;
  }
  .workspace-page .wp-exec-actions {
    width: 100%;
    justify-content: flex-start;
  }
  .workspace-page .wp-stats-row {
    flex-wrap: wrap;
    gap: 12px;
  }
}
</style>
</head>

<body>
<%- include('partials/nav') %>

<div class="workspace-page">
<div class="wp-shell">

  <!-- ═══════════════ TOP BAR ═══════════════ -->
  <div class="wp-topbar">
    <div class="wp-logo">
      AQUI<span class="wp-logo-sep">PLEX</span> // WORKSPACE
    </div>

    <div class="wp-breadcrumb">
      <span>Workspace</span>
      <span class="sep">›</span>
      <span class="active" id="topBreadcrumb">Overview</span>
    </div>

    <div class="wp-topbar-right">
      <div class="wp-status-pill">
        <div class="wp-status-dot"></div>
        <span id="topStatusText">ONLINE</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════ BODY ═══════════════ -->
  <div class="wp-body">

    <!-- ─────── LEFT SIDEBAR ─────── -->
    <div class="wp-sidebar">
      <div class="wp-sidebar-tabs">
        <button class="wp-sidebar-tab active" onclick="switchLeftTab('bundles', this)">BUNDLES</button>
        <button class="wp-sidebar-tab" onclick="switchLeftTab('tools', this)">TOOLS</button>
      </div>

      <!-- BUNDLES -->
      <div class="wp-sidebar-list" id="leftBundleList">
        <% if (bundles && bundles.length > 0) { %>
          <% bundles.forEach(function(b) {
            const completed = (b.progress || []).filter(p => p.status === 'completed').length;
            const total     = (b.steps || []).length;
            const pct       = total > 0 ? Math.round((completed / total) * 100) : 0;
            const dotCls    = b.status === 'active'    ? 'wi-active'
                            : b.status === 'paused'    ? 'wi-paused'
                            : b.status === 'completed' ? 'wi-completed'
                            : 'wi-draft';
          %>
          <div class="wp-bundle-item" id="brow-<%= b._id %>"
               onclick="selectBundle(<%- JSON.stringify(b).replace(/</g,'\\u003c') %>)">
            <div class="wp-bundle-title"><%= b.title %></div>
            <div class="wp-bundle-meta">
              <div class="wp-status-icon <%= dotCls %>"></div>
              <div class="wp-bundle-prog-track">
                <div class="wp-bundle-prog-fill" style="width:<%= pct %>%"></div>
              </div>
              <div class="wp-bundle-pct"><%= pct %>%</div>
            </div>
          </div>
          <% }) %>
        <% } else { %>
          <div class="wp-empty">
            No bundles yet.<br/>
            <a class="wp-empty-link" href="/bundles">Create one →</a>
          </div>
        <% } %>
      </div>

      <!-- TOOLS -->
      <div class="wp-sidebar-list" id="leftToolList" style="display:none;">
        <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>
          <% workspace.tools.forEach(function(tool) { %>
          <div class="wp-tool-item">
            <img src="<%= tool.logo || '/logos/default.png' %>"
                 onerror="this.src='/logos/default.png'"
                 class="wp-tool-logo" alt=""/>
            <span class="wp-tool-name"><%= tool.name %></span>
            <button class="wp-tool-open"
                    onclick="event.stopPropagation(); launchTool('<%= tool.url || '' %>')">
              OPEN
            </button>
          </div>
          <% }) %>
        <% } else { %>
          <div class="wp-empty">
            No tools saved.<br/>
            <a class="wp-empty-link" href="/tools">Browse tools →</a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- ─────── MAIN ─────── -->
    <div class="wp-main">

      <!-- WELCOME (no bundle selected) -->
      <div class="wp-welcome" id="wsWelcome">
        <div class="wp-welcome-glyph">⚡</div>
        <h2>Execution Control</h2>
        <p>Select a bundle from the sidebar to view its execution state, step timeline, outputs, and memory.</p>
      </div>

      <!-- EXEC VIEW -->
      <div class="wp-exec" id="wsExec" style="display:none;">

        <!-- Header -->
        <div class="wp-exec-header">
          <div class="wp-exec-header-top">
            <div class="wp-exec-title-block">
              <div class="wp-exec-title" id="execTitle">—</div>
              <div class="wp-exec-goal" id="execGoal">—</div>
            </div>
            <div class="wp-exec-actions">
              <button class="wp-btn wp-btn-run" id="btnRun" onclick="runCurrentBundle()">
                ▶ RUN
              </button>
              <button class="wp-btn wp-btn-pause" id="btnPause" onclick="pauseCurrentBundle()" style="display:none;">
                ⏸ PAUSE
              </button>
              <button class="wp-btn wp-btn-ghost" id="btnResume" onclick="resumeCurrentBundle()" style="display:none;">
                ↺ RESUME
              </button>
              <button class="wp-btn wp-btn-ghost" id="btnPin" onclick="pinCurrentBundle()">
                ☆ PIN
              </button>
            </div>
          </div>

          <!-- Stats + progress -->
          <div class="wp-stats-row">
            <div class="wp-stat">
              <div class="wp-stat-val c-accent" id="statSteps">—</div>
              <div class="wp-stat-lbl">Steps</div>
            </div>
            <div class="wp-stat-divider"></div>
            <div class="wp-stat">
              <div class="wp-stat-val c-green" id="statDone">—</div>
              <div class="wp-stat-lbl">Done</div>
            </div>
            <div class="wp-stat-divider"></div>
            <div class="wp-stat">
              <div class="wp-stat-val" id="statPct">—</div>
              <div class="wp-stat-lbl">Complete</div>
            </div>
            <div class="wp-stat-divider"></div>
            <div class="wp-stat">
              <div class="wp-stat-val c-amber" id="statStatus">—</div>
              <div class="wp-stat-lbl">Status</div>
            </div>
          </div>

          <div class="wp-exec-progress">
            <div class="wp-progress-track">
              <div class="wp-progress-fill" id="mainProgressFill" style="width:0%"></div>
            </div>
          </div>
        </div>

        <!-- Content grid (steps + right panel) -->
        <div class="wp-exec-content">

          <!-- Steps column -->
          <div class="wp-steps-panel">
            <!-- Timeline strip -->
            <div class="wp-timeline-strip" id="execTimeline"></div>
            <!-- Step cards -->
            <div class="wp-steps-scroll" id="execSteps"></div>
          </div>

          <!-- Right panel -->
          <div class="wp-right-panel">
            <div class="wp-right-tabs">
              <button class="wp-right-tab active" onclick="switchRightTab('outputs', this)">OUTPUTS</button>
              <button class="wp-right-tab" onclick="switchRightTab('memory', this)">MEMORY</button>
              <button class="wp-right-tab" onclick="switchRightTab('insights', this)">INSIGHTS</button>
            </div>

            <div class="wp-right-body">

              <!-- Outputs -->
              <div class="wp-right-section active" id="rtab-outputs">
                <div id="outputFeed">
                  <div class="wp-empty" style="padding:32px 0;">
                    Run a bundle step to see outputs here.
                  </div>
                </div>
              </div>

              <!-- Memory -->
              <div class="wp-right-section" id="rtab-memory">
                <div class="wp-mem-hdr">
                  Bundle Memory
                  <span class="wp-mem-hdr-count" id="memBundleCount">0 keys</span>
                </div>
                <div id="memBundleEntries"></div>

                <div class="wp-mem-hdr" style="margin-top:18px;">
                  Context Summary
                </div>
                <div class="wp-context-box" id="memContextBox" style="display:none;"></div>
                <div class="wp-empty" id="memContextEmpty" style="padding:8px 0;">No context summary yet.</div>

                <div class="wp-mem-hdr" style="margin-top:18px;">
                  Workspace Memory
                  <span class="wp-mem-hdr-count" id="memWsCount">0 keys</span>
                </div>
                <div id="memWsEntries"></div>
              </div>

              <!-- Insights -->
              <div class="wp-right-section" id="rtab-insights">
                <div id="insightList">
                  <div class="wp-empty" style="padding:32px 0;">
                    Key insights from step outputs will appear here.
                  </div>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</div>
</div><!-- /.workspace-page -->

<%- include("partials/footer") %>

<!-- ═══════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════ -->
<script>
// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
const STATE = {
  bundle:       null,
  wsMemory:     {},
  pinnedIds:    [],
  selectedStep: null,
};

// ═══════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════
window.addEventListener("DOMContentLoaded", async () => {
  try {
    const res  = await fetch("/workspace/state");
    const data = await res.json();
    STATE.wsMemory  = data.workspace.workspaceMemory || {};
    STATE.pinnedIds = data.workspace.pinnedBundleIds  || [];

    renderWsMemory();

    if (data.workspace.recentOutputs && data.workspace.recentOutputs.length) {
      renderOutputFeed(data.workspace.recentOutputs);
    }

    const lastId = data.workspace.lastOpenBundleId;
    if (lastId) {
      const b = (data.bundles || []).find(x => x._id === lastId || x._id.toString() === lastId);
      if (b) { selectBundle(b); return; }
    }

    const active = (data.bundles || []).find(b => b.status === "active");
    if (active) selectBundle(active);
  } catch (e) {
    console.warn("Workspace state load failed", e);
  }
});

// ═══════════════════════════════════════════
// TAB SWITCHES
// ═══════════════════════════════════════════
function switchLeftTab(tab, btn) {
  document.querySelectorAll(".workspace-page .wp-sidebar-tab").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("leftBundleList").style.display = tab === "bundles" ? "" : "none";
  document.getElementById("leftToolList").style.display   = tab === "tools"   ? "" : "none";
}

function switchRightTab(tab, btn) {
  document.querySelectorAll(".workspace-page .wp-right-tab").forEach(b => b.classList.remove("active"));
  document.querySelectorAll(".workspace-page .wp-right-section").forEach(s => s.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("rtab-" + tab).classList.add("active");
}

// ═══════════════════════════════════════════
// SELECT BUNDLE
// ═══════════════════════════════════════════
async function selectBundle(bundle) {
  document.querySelectorAll(".workspace-page .wp-bundle-item").forEach(r => r.classList.remove("selected"));
  const row = document.getElementById("brow-" + (bundle._id || bundle.id));
  if (row) row.classList.add("selected");

  try {
    const res  = await fetch("/workspace/bundle/" + (bundle._id || bundle.id));
    const data = await res.json();
    if (data.bundle) bundle = data.bundle;
  } catch(_) {}

  STATE.bundle       = bundle;
  STATE.selectedStep = null;

  document.getElementById("wsWelcome").style.display = "none";
  document.getElementById("wsExec").style.display    = "flex";

  renderExecPanel(bundle);
  renderMemoryPanel(bundle);
  renderInsightPanel(bundle);
  updateBreadcrumb(bundle.title);
  updatePinBtn(bundle._id || bundle.id);
}

// ═══════════════════════════════════════════
// RENDER EXEC PANEL
// ═══════════════════════════════════════════
function renderExecPanel(b) {
  const steps    = b.steps    || [];
  const progress = b.progress || [];
  const outputs  = b.outputs  || [];

  const done  = progress.filter(p => p.status === "completed").length;
  const total = steps.length;
  const pct   = total ? Math.round((done / total) * 100) : 0;

  document.getElementById("execTitle").textContent = b.title || "Untitled";
  document.getElementById("execGoal").textContent  = b.goal  || "";
  document.getElementById("statSteps").textContent  = total;
  document.getElementById("statDone").textContent   = done;
  document.getElementById("statPct").textContent    = pct + "%";
  document.getElementById("statStatus").textContent = (b.status || "draft").toUpperCase();
  document.getElementById("mainProgressFill").style.width = pct + "%";

  const btnRun    = document.getElementById("btnRun");
  const btnPause  = document.getElementById("btnPause");
  const btnResume = document.getElementById("btnResume");

  if (b.status === "active") {
    btnRun.style.display = "none"; btnPause.style.display = ""; btnResume.style.display = "none";
  } else if (b.status === "paused") {
    btnRun.style.display = "none"; btnPause.style.display = "none"; btnResume.style.display = "";
  } else if (b.status === "completed") {
    btnRun.style.display = "none"; btnPause.style.display = "none"; btnResume.style.display = "none";
  } else {
    btnRun.style.display = ""; btnPause.style.display = "none"; btnResume.style.display = "none";
  }

  renderTimeline(steps, progress, b.currentStep || 0);
  renderStepCards(steps, progress, outputs, b.currentStep || 0);
}

// ═══════════════════════════════════════════
// TIMELINE
// ═══════════════════════════════════════════
function renderTimeline(steps, progress, currentStep) {
  const tl = document.getElementById("execTimeline");
  if (!steps.length) { tl.innerHTML = ""; return; }

  tl.innerHTML = steps.map((step, i) => {
    const prog   = progress.find(p => p.step === i);
    const status = prog ? prog.status : "pending";
    const dotCls = status === "completed"   ? "tl-done"
                 : status === "in-progress" ? "tl-running"
                 : i === STATE.selectedStep  ? "tl-selected"
                 : "";
    const icon = status === "completed" ? "✓" : status === "in-progress" ? "…" : (i + 1);
    const lineCls = status === "completed" ? "tl-done" : "";
    const connector = i < steps.length - 1
      ? `<div class="wp-tl-line ${lineCls}"></div>` : "";

    return `
      <div class="wp-tl-step" title="${esc(step.title || 'Step ' + (i+1))}" onclick="jumpToStep(${i})">
        <div class="wp-tl-dot ${dotCls}">${icon}</div>
      </div>${connector}
    `;
  }).join("");
}

// ═══════════════════════════════════════════
// STEP CARDS
// ═══════════════════════════════════════════
function renderStepCards(steps, progress, outputs, currentStep) {
  const container = document.getElementById("execSteps");
  if (!steps.length) {
    container.innerHTML = `<div class="wp-empty">No steps defined.</div>`;
    return;
  }

  container.innerHTML = steps.map((step, i) => {
    const prog   = progress.find(p => p.step === i);
    const status = prog ? prog.status : "pending";
    const output = outputs.find(o => o.stepIndex === i);

    const cardCls  = status === "in-progress" ? "sc-running"
                   : status === "completed"   ? "sc-done"
                   : i === currentStep        ? "sc-active" : "";
    const badgeCls = status === "completed"   ? "wb-done"
                   : status === "in-progress" ? "wb-running"
                   : status === "failed"      ? "wb-failed"
                   : "wb-pending";
    const badgeTxt = status === "completed"   ? "DONE"
                   : status === "in-progress" ? "RUNNING"
                   : status === "failed"      ? "FAILED"
                   : "PENDING";
    const numCls   = status === "completed"   ? "sn-done"
                   : status === "in-progress" ? "sn-running" : "";
    const numIcon  = status === "completed" ? "✓" : (i + 1);

    const toolsHtml = (step.tools && step.tools.length)
      ? `<div class="wp-step-tools">${step.tools.map(t =>
          `<a class="wp-tool-chip" href="${esc(t.url||'#')}" target="_blank">🔗 ${esc(t.name||'Tool')}</a>`
        ).join("")}</div>`
      : "";

    let outputHtml = "";
    if (output && output.content) {
      const insights = (output.keyInsights || []).slice(0, 4).map(k =>
        `<span class="wp-insight-chip">${esc(k)}</span>`
      ).join("");
      outputHtml = `
        <div class="wp-output-block">
          <div class="wp-output-hdr">
            <span class="wp-output-label">⚡ Output</span>
            <div class="wp-output-dot"></div>
          </div>
          <div class="wp-output-content">${formatOutput(output.content)}</div>
        </div>
        ${insights ? `<div class="wp-step-insights">${insights}</div>` : ""}
      `;
    }

    const actionHtml = status !== "completed"
      ? `<button class="wp-step-btn wsb-done" onclick="event.stopPropagation(); markStepDone(${i})">✅ Mark Done</button>`
      : `<button class="wp-step-btn wsb-rerun" onclick="event.stopPropagation(); rerunStep(${i})">↺ Re-run</button>`;

    const isOpen = i === currentStep || i === STATE.selectedStep;

    return `
      <div class="wp-step-card ${cardCls}" id="scard-${i}">
        <div class="wp-step-card-hdr" onclick="toggleCard(${i})">
          <div class="wp-step-num ${numCls}">${numIcon}</div>
          <div class="wp-step-info">
            <div class="wp-step-title">${esc(step.title || 'Step ' + (i+1))}</div>
            <div class="wp-step-desc">${esc(step.description || '')}</div>
          </div>
          <span class="wp-badge ${badgeCls}">${badgeTxt}</span>
          <span class="wp-step-toggle ${isOpen ? 'open' : ''}">▾</span>
        </div>
        <div class="wp-step-body ${isOpen ? 'open' : ''}" id="sbody-${i}">
          ${toolsHtml}
          ${outputHtml}
          <div class="wp-step-actions">${actionHtml}</div>
        </div>
      </div>
    `;
  }).join("");
}

// ═══════════════════════════════════════════
// MEMORY
// ═══════════════════════════════════════════
function renderMemoryPanel(b) {
  const mem  = b.memory || {};
  const keys = Array.isArray(mem) ? []
             : (mem instanceof Map ? [...mem.keys()] : Object.keys(mem));

  document.getElementById("memBundleCount").textContent = keys.length + " keys";
  document.getElementById("memBundleEntries").innerHTML = keys.length
    ? keys.map(k => `
        <div class="wp-mem-kv">
          <div class="wp-mem-k">${esc(k)}</div>
          <div class="wp-mem-v">${esc(mem instanceof Map ? mem.get(k) : mem[k])}</div>
        </div>`).join("")
    : `<div class="wp-empty" style="padding:10px 0;">No bundle memory yet.</div>`;

  if (b.contextSummary) {
    document.getElementById("memContextBox").textContent   = b.contextSummary;
    document.getElementById("memContextBox").style.display  = "";
    document.getElementById("memContextEmpty").style.display = "none";
  } else {
    document.getElementById("memContextBox").style.display  = "none";
    document.getElementById("memContextEmpty").style.display = "";
  }

  renderWsMemory();
}

function renderWsMemory() {
  const wsM    = STATE.wsMemory || {};
  const wsKeys = Object.keys(wsM);
  document.getElementById("memWsCount").textContent   = wsKeys.length + " keys";
  document.getElementById("memWsEntries").innerHTML   = wsKeys.length
    ? wsKeys.map(k => `
        <div class="wp-mem-kv" style="border-left-color:var(--wp-accent3)">
          <div class="wp-mem-k" style="color:var(--wp-accent3)">${esc(k)}</div>
          <div class="wp-mem-v">${esc(wsM[k])}</div>
        </div>`).join("")
    : `<div class="wp-empty" style="padding:10px 0;">No workspace memory yet.</div>`;
}

// ═══════════════════════════════════════════
// INSIGHTS
// ═══════════════════════════════════════════
function renderInsightPanel(b) {
  const outputs = b.outputs || [];
  const all = [];
  outputs.forEach(o => {
    (o.keyInsights || []).forEach(k => { if (k) all.push(k); });
  });

  document.getElementById("insightList").innerHTML = all.length
    ? all.map(k => `<div class="wp-insight-item"><span>${esc(k)}</span></div>`).join("")
    : `<div class="wp-empty" style="padding:32px 0;">Insights from step outputs will appear here.</div>`;
}

// ═══════════════════════════════════════════
// OUTPUT FEED
// ═══════════════════════════════════════════
function renderOutputFeed(outputs) {
  const feed = document.getElementById("outputFeed");
  if (!outputs || !outputs.length) {
    feed.innerHTML = `<div class="wp-empty" style="padding:32px 0;">No outputs yet.</div>`;
    return;
  }
  feed.innerHTML = outputs.map(o => `
    <div class="wp-feed-item">
      <div class="wp-feed-meta">
        <span class="wp-feed-step">Step ${(o.stepIndex ?? 0) + 1}${o.stepTitle ? ' · ' + esc(o.stepTitle) : ''}</span>
        <span class="wp-feed-bundle">${esc(o.bundleTitle || '')}</span>
      </div>
      <div class="wp-feed-preview">${esc(o.preview || '')}</div>
    </div>`).join("");
}

function pushOutputFeed(bundleTitle, stepIndex, stepTitle, content) {
  const feed = document.getElementById("outputFeed");
  const old  = feed.querySelector(".wp-empty");
  if (old) old.remove();

  const item = document.createElement("div");
  item.className = "wp-feed-item";
  item.innerHTML = `
    <div class="wp-feed-meta">
      <span class="wp-feed-step">Step ${stepIndex + 1}${stepTitle ? ' · ' + esc(stepTitle) : ''}</span>
      <span class="wp-feed-bundle">${esc(bundleTitle)}</span>
    </div>
    <div class="wp-feed-preview">${esc((content || '').substring(0, 240))}</div>
  `;
  feed.prepend(item);
}

// ═══════════════════════════════════════════
// ACTIONS
// ═══════════════════════════════════════════
async function runCurrentBundle() {
  const b = STATE.bundle; if (!b) return;
  try {
    const res  = await fetch("/workspace/run/" + b._id, { method: "POST" });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    renderExecPanel(data.bundle);
    toast("Bundle started ▶", "success");
  } catch(e) { toast("Failed to run", "error"); }
}

async function pauseCurrentBundle() {
  const b = STATE.bundle; if (!b) return;
  try {
    await fetch("/workspace/pause/" + b._id, { method: "POST" });
    STATE.bundle.status = "paused";
    renderExecPanel(STATE.bundle);
    updateBundleRowDot(b._id, "paused");
    toast("Paused ⏸", "info");
  } catch(e) { toast("Failed to pause", "error"); }
}

async function resumeCurrentBundle() {
  const b = STATE.bundle; if (!b) return;
  try {
    const res  = await fetch("/workspace/resume/" + b._id, { method: "POST" });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    renderExecPanel(data.bundle);
    updateBundleRowDot(b._id, "active");
    toast("Resumed ▶", "success");
  } catch(e) { toast("Failed to resume", "error"); }
}

async function markStepDone(stepIndex) {
  const b = STATE.bundle; if (!b) return;
  try {
    const res  = await fetch(`/workspace/step/${b._id}/${stepIndex}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ title: b.steps[stepIndex]?.title || ("Step " + (stepIndex+1)) }),
    });
    const data = await res.json();
    if (data.error) { toast(data.error, "error"); return; }
    STATE.bundle = data.bundle;
    renderExecPanel(data.bundle);
    renderMemoryPanel(data.bundle);
    renderInsightPanel(data.bundle);
    updateBundleRowProgress(b._id, data.bundle);
    toast("Step " + (stepIndex+1) + " complete ✓", "success");
  } catch(e) { toast("Error marking step", "error"); }
}

async function rerunStep(stepIndex) {
  const b = STATE.bundle; if (!b) return;
  (b.progress || []).forEach(p => { if (p.step === stepIndex) p.status = "pending"; });
  b.outputs = (b.outputs || []).filter(o => o.stepIndex !== stepIndex);
  renderExecPanel(b);
  toast("Step " + (stepIndex+1) + " reset — re-run when ready", "info");
}

async function pinCurrentBundle() {
  const b = STATE.bundle; if (!b) return;
  const id = b._id;
  try {
    if (STATE.pinnedIds.includes(id)) {
      await fetch("/workspace/unpin/" + id, { method: "POST" });
      STATE.pinnedIds = STATE.pinnedIds.filter(x => x !== id);
      document.getElementById("btnPin").textContent = "☆ PIN";
      toast("Unpinned", "info");
    } else {
      await fetch("/workspace/pin/" + id, { method: "POST" });
      STATE.pinnedIds.push(id);
      document.getElementById("btnPin").textContent = "★ PINNED";
      toast("Pinned ★", "success");
    }
  } catch(e) {}
}

// ═══════════════════════════════════════════
// CARD TOGGLES
// ═══════════════════════════════════════════
function toggleCard(idx) {
  const body   = document.getElementById("sbody-" + idx);
  const toggle = document.querySelector(`#scard-${idx} .wp-step-toggle`);
  const isOpen = body.classList.contains("open");
  body.classList.toggle("open", !isOpen);
  if (toggle) toggle.classList.toggle("open", !isOpen);
  STATE.selectedStep = !isOpen ? idx : null;
}

function jumpToStep(idx) {
  STATE.selectedStep = idx;
  const card = document.getElementById("scard-" + idx);
  if (card) {
    card.scrollIntoView({ behavior: "smooth", block: "center" });
    const body   = document.getElementById("sbody-" + idx);
    const toggle = document.querySelector(`#scard-${idx} .wp-step-toggle`);
    body.classList.add("open");
    if (toggle) toggle.classList.add("open");
  }
}

// ═══════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════
function updateBreadcrumb(title) {
  document.getElementById("topBreadcrumb").textContent = title || "Bundle";
}

function updatePinBtn(id) {
  document.getElementById("btnPin").textContent =
    STATE.pinnedIds.includes(id) ? "★ PINNED" : "☆ PIN";
}

function updateBundleRowDot(id, status) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const icon = row.querySelector(".wp-status-icon");
  if (!icon) return;
  icon.className = "wp-status-icon " + (
    status === "active"    ? "wi-active"    :
    status === "paused"    ? "wi-paused"    :
    status === "completed" ? "wi-completed" : "wi-draft"
  );
}

function updateBundleRowProgress(id, bundle) {
  const row = document.getElementById("brow-" + id);
  if (!row) return;
  const steps = bundle.steps || [];
  const done  = (bundle.progress || []).filter(p => p.status === "completed").length;
  const pct   = steps.length ? Math.round((done / steps.length) * 100) : 0;
  const fill  = row.querySelector(".wp-bundle-prog-fill");
  const pctEl = row.querySelector(".wp-bundle-pct");
  if (fill)  fill.style.width = pct + "%";
  if (pctEl) pctEl.textContent = pct + "%";
  updateBundleRowDot(id, bundle.status);
}

function launchTool(url) {
  if (!url) return;
  if (!url.startsWith("http")) url = "https://" + url;
  window.open(url, "_blank");
}

function esc(str) {
  if (!str) return "";
  return String(str)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

function formatOutput(text) {
  if (!text) return "";
  return esc(text)
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/`([^`]+)`/g, `<code style="background:var(--wp-bg);padding:1px 6px;border-radius:4px;font-family:var(--wp-mono);font-size:0.83em;">$1</code>`)
    .replace(/\n/g, "<br/>");
}

// ═══════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════
let _toastTimer;
function toast(msg, type = "info") {
  clearTimeout(_toastTimer);
  document.querySelectorAll(".workspace-page .wp-toast").forEach(e => e.remove());
  const el = document.createElement("div");
  el.className = `wp-toast wt-${type}`;
  el.textContent = msg;
  document.querySelector(".workspace-page").appendChild(el);
  _toastTimer = setTimeout(() => el.remove(), 3200);
}
</script>
</body>
</html>
