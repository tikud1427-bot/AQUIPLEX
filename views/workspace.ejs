<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Workspace | AIDEX</title>

<link rel="stylesheet" href="/css/styles.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
.hidden { display: none; }

.workspace-tabs {
  display: flex;
  gap: 10px;
  margin: 20px 0;
}

.workspace-tabs button {
  background: #0f172a;
  border: 1px solid #1e293b;
  padding: 10px 16px;
  border-radius: 8px;
  color: white;
  cursor: pointer;
}

.workspace-tabs button:hover {
  background: #1e293b;
}
  .tool-chip {
    display: inline-block;
    background: #1e293b;
    padding: 5px 10px;
    border-radius: 6px;
    margin: 4px;
    font-size: 12px;
    color: white;
    text-decoration: none;
  }
</style>

</head>

<body>

<%- include('partials/nav') %>

<main class="container">

  <!-- HEADER -->
  <section class="workspace-header">
    <h1>Your Workspace</h1>
    <p>Manage tools, workflows & active sessions</p>
  </section>

  <!-- 🔥 TABS -->
  <div class="workspace-tabs">
    <button onclick="showTab('tools')">🧰 Tools</button>
    <button onclick="showTab('bundles')">⚡ Workflows</button>
    <button onclick="showTab('active')">🧠 Active</button>
    <button onclick="showTab('favorites')">⭐ Favorites</button>
  </div>

  <!-- ================= TOOLS TAB ================= -->
  <div id="tab-tools" class="tab-content">

    <div class="workspace-grid" id="workspaceGrid">

      <% if (workspace && workspace.tools && workspace.tools.length > 0) { %>

        <% workspace.tools.forEach(function(tool){ %>

        <div class="workspace-card" id="tool-<%= tool._id %>">

          <div class="workspace-top">
            <img
              src="<%= tool.logo || '/logos/default.png' %>"
              onerror="this.src='/logos/default.png'"
              class="workspace-logo"
            >
          </div>

          <div class="workspace-content">
            <h3><%= tool.name || 'Unnamed Tool' %></h3>

            <% if (tool.description) { %>
              <p class="tool-desc">
                <%= tool.description.substring(0, 80) %>...
              </p>
            <% } else { %>
              <p class="tool-desc muted">No description available</p>
            <% } %>
          </div>

          <div class="workspace-actions">
            <button class="launch-btn"
              onclick="launchTool('<%= tool.name %>', '<%= tool.url || '' %>')">
              🚀 Launch
            </button>

            <button onclick="removeTool('<%= tool._id %>')" class="remove-btn">
              ✖ Remove
            </button>
          </div>

        </div>

        <% }) %>

      <% } else { %>

        <div class="empty-workspace">
          <h2>No tools saved</h2>
          <p>Add tools from the tools page</p>
          <a href="/tools" class="browse-tools-btn">Browse Tools</a>
        </div>

      <% } %>

    </div>

  </div>

  <!-- ================= BUNDLES TAB ================= -->
  <div id="tab-bundles" class="tab-content hidden">

    <% if (bundles && bundles.length > 0) { %>

      <div class="bundle-grid">

        <% bundles.forEach(bundle => { %>

        <div class="bundle-card" id="bundle-<%= bundle._id %>">

          <h3><%= bundle.title %></h3>

          <%
            const progress = bundle.progress || [];
            const completed = progress.filter(p => p.status === "completed").length;
            const total = bundle.steps ? bundle.steps.length : 0;
          %>

            <p><%= completed %>/<%= total %> steps completed</p>

            <div class="bundle-tools">
              <% bundle.steps.forEach(step => { %>
                <% if(step.tools && step.tools.length > 0){ %>
                  <% step.tools.forEach(tool => { %>
                    <a href="<%= tool.url %>" target="_blank" class="tool-chip">
                      🔗 <%= tool.name %>
                    </a>
                  <% }) %>
                <% } %>
              <% }) %>
            </div>

          <div style="background:#1e293b;height:6px;border-radius:5px;">
            <div style="
              width:<%= total > 0 ? (completed / total) * 100 : 0 %>%;
              height:100%;
              background:limegreen;
              border-radius:5px;
            "></div>
          </div>

          <div class="bundle-actions">
            <button onclick='viewBundle(<%- JSON.stringify(bundle).replace(/"/g, "&quot;") %>)'>
              👀 View
            </button>

            <button onclick="removeBundle('<%= bundle._id %>')" class="remove-btn">
              ✖ Remove
            </button>
          </div>

        </div>

        <% }) %>

      </div>

    <% } else { %>

      <p class="muted">No workflows yet</p>

    <% } %>

  </div>

  <!-- ================= ACTIVE TAB ================= -->
  <div id="tab-active" class="tab-content hidden">
    <div id="active-tools" class="active-tools-panel"></div>
  </div>

  <!-- ================= FAVORITES TAB ================= -->
  <div id="tab-favorites" class="tab-content hidden">
    <h3>⭐ Favorite tools coming soon</h3>
  </div>

</main>

<!-- FAKE BROWSER -->
<div id="workspace-browser" class="browser hidden">
  <div class="browser-top">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
    <div class="address-bar" id="browser-url">Loading...</div>
  </div>

  <div class="browser-body">
    <div class="browser-loading">
      <div class="spinner"></div>
      <p>Launching AI tool...</p>
    </div>
  </div>
</div>

<script>

const activeTools = {};

// TAB SWITCH
function showTab(tab){
  document.querySelectorAll(".tab-content").forEach(el => {
    el.classList.add("hidden");
  });
  document.getElementById("tab-" + tab).classList.remove("hidden");
}

// LAUNCH TOOL
function launchTool(name, url){
  if(!url) return alert("No URL");

  if(!url.startsWith("http")){
    url = "https://" + url;
  }

  const browser = document.getElementById("workspace-browser");
  document.getElementById("browser-url").innerText = url;

  browser.classList.remove("hidden");

  activeTools[name] = { url };
  saveTools();

  setTimeout(() => {
    window.open(url, "_blank");
    browser.classList.add("hidden");
    updateWorkspaceUI();
  }, 500);
}

// ACTIVE UI
function updateWorkspaceUI(){
  const container = document.getElementById("active-tools");
  container.innerHTML = "";

  Object.keys(activeTools).forEach(name => {
    const tool = activeTools[name];

    const div = document.createElement("div");
    div.innerHTML = `
      <span>🧠 ${name}</span>
      <button onclick="window.open('${tool.url}','_blank')">Open</button>
      <button onclick="closeTool('${name}')">✕</button>
    `;

    container.appendChild(div);
  });
}

function closeTool(name){
  delete activeTools[name];
  saveTools();
  updateWorkspaceUI();
}

function saveTools(){
  localStorage.setItem("activeTools", JSON.stringify(activeTools));
}

window.onload = () => {
  const saved = localStorage.getItem("activeTools");
  if(saved) Object.assign(activeTools, JSON.parse(saved));
  updateWorkspaceUI();
};

// REMOVE TOOL
async function removeTool(id){
  await fetch("/workspace/remove/" + id, { method:"POST" });
  document.getElementById("tool-"+id)?.remove();
}

// REMOVE BUNDLE
async function removeBundle(id){
  await fetch("/bundle/remove/" + id, { method:"POST" });
  document.getElementById("bundle-"+id)?.remove();
}

// VIEW BUNDLE
  
  function viewBundle(bundle){

    const progressList = bundle.progress || [];

    let html = `<h2>${bundle.title}</h2>`;

    bundle.steps.forEach(step => {

      const progress = progressList.find(p => p.step === step.step);
      const status = progress ? progress.status : "pending";

      let toolsHTML = "";

      if(step.tools && step.tools.length > 0){
        toolsHTML = step.tools.map(t => `
          <a href="${t.url}" target="_blank" style="
            display:inline-block;
            background:#1e293b;
            padding:5px 10px;
            margin:5px;
            border-radius:6px;
            color:white;
            text-decoration:none;
          ">
            🔗 ${t.name}
          </a>
        `).join("");
      }

      html += `
        <div style="margin:10px 0;">
          <h3>Step ${step.step}: ${step.title}</h3>
          <p>${step.description}</p>

          ${toolsHTML}

          <button onclick="updateStep('${bundle._id}', ${step.step}, 'completed')">
            ✅ Done
          </button>
        </div>
      `;
    });

    html += `<br><button onclick="closeModal()">Close</button>`;

    // remove old modal if exists
    const old = document.getElementById("bundle-modal");
    if(old) old.remove();

    document.body.innerHTML += `
      <div class="modal" id="bundle-modal">
        ${html}
      </div>
    `;
  }
  function closeModal(){
    document.getElementById("bundle-modal")?.remove();
  }

  async function updateStep(id, step, status){
    await fetch("/bundle/progress/" + id, {
      method:"POST",
      headers:{ "Content-Type":"application/json" },
      body: JSON.stringify({ step, status })
    });

    // 🔥 RELOAD UI
    location.reload();
  }
</script>
      <%- include("partials/footer") %>

</body>
</html>