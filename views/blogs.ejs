<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog — Aquiplex</title>
  <meta name="description" content="Notes from the Aquiplex team on building Aqua — memory, planning, execution, and the AI operating system.">
  <meta property="og:title" content="Aquiplex Blog">
  <meta property="og:description" content="Notes on building Aqua — memory, planning, and execution.">
  <meta property="og:type" content="website">
  <link rel="icon" href="/logo/favicon.ico" sizes="any">
  <link rel="stylesheet" href="/css/platform.css">
</head>
<body class="px-page">

<%- include("partials/nav") %>

<section class="px-page-hero">
  <div class="px-narrow" style="display:flex; align-items:flex-end; justify-content:space-between; gap:20px; flex-wrap:wrap;">
    <div>
      <div class="px-eyebrow">Blog</div>
      <h1>Notes from Aquiplex</h1>
      <p>How we're building Aqua — memory, planning, execution, and everything in between.</p>
    </div>
    <a href="/write" class="px-btn px-btn-secondary">Write a post</a>
  </div>
</section>

<main style="padding-bottom:120px;">
  <% if (!blogs || blogs.length === 0) { %>
    <div class="px-narrow">
      <div class="px-empty">No posts yet. Be the first to <a href="/write">write one</a>.</div>
    </div>
  <% } else { %>
    <div class="px-blog-list">
      <% blogs.forEach(function (blog) { %>
        <a class="px-blog-item" href="/blogs/<%= blog.slug %>">
          <h2><%= blog.title %></h2>
          <p><%= blog.description %></p>
          <div class="px-blog-meta">
            <%= blog.readTime %> · <%= blog.createdAt %><% if (blog.author) { %> · <%= blog.author %><% } %>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include("partials/footer") %>

</body>
</html>
