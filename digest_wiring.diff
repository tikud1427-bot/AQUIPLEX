+// ── Context compression ───────────────────────────────────────────────────────
+
+// GET /project/workspace/:id/digest?budget=4000&focus=auth
+//   Token-bounded, hierarchical whole-repo digest (skeleton/signature/rollup).
+router.get('/workspace/:id/digest', (req, res) => {
+  const workspace = getWorkspace(req.params.id);
+  if (!workspace) return res.status(404).json({ success: false, error: 'Workspace not found' });
+  const budget = Math.min(Math.max(parseInt(req.query.budget, 10) || 4000, 200), 32000);
+  const result = buildRepoDigest(req.params.id, { tokenBudget: budget, focus: req.query.focus ?? '' });
+  if (!result) return res.status(409).json({ success: false, error: 'Workspace not indexed yet' });
+  res.json({ success: true, workspaceId: req.params.id, ...result });
+});
+
