2.50\"],\n    ]\n\n    table = Table(data, hAlign=\"LEFT\")\n    table.setStyle(\n        TableStyle(\n            [\n                (\"BACKGROUND\", (0, 0), (-1, 0), colors.lightgrey),\n                (\"GRID\", (0, 0), (-1, -1), 0.5, colors.grey),\n                (\"FONTNAME\", (0, 0), (-1, 0), \"Helvetica-Bold\"),\n                (\"ALIGN\", (1, 1), (-1, -1), \"RIGHT\"),\n            ]\n        )\n    )\n\n    # Build the PDF\n    doc.build([title, intro, table])\n\nif __name__ == \"__main__\":\n    generate_pdf(\"sample_report.pdf\")\n    print(\"PDF created: sample_report.pdf\")\n```\n\n**How to run**\n\n1. Save the script as `make_pdf.py`.  \n2. Open a terminal, navigate to the folder, and run `python make_pdf.py`.  \n3. `sample_report.pdf` will appear in the same directory.\n\n---\n\n## Other common ways to generate PDFs\n\n| Approach | When it shines | Quick tip |\n|----------|----------------|-----------|\n| **ReportLab (Python)** | Full control over layout, tables, graphics | Use `canvas` for low‑level drawing |\n| **FPDF / PyFPDF (Python)** | Very lightweight, simple PDFs | `pdf.cell()` for quick text blocks |\n| **WeasyPrint (Python)** | Convert styled HTML/CSS to PDF | Write HTML + CSS, then `HTML(...).write_pdf()` |\n| **Puppeteer / Playwright (Node.js)** | Render complex web pages (charts, CSS) to PDF | `await page.pdf({path: 'out.pdf', format: 'A4'});` |\n| **jsPDF (browser)** | Generate PDFs client‑side, no server | `doc.text('Hello', 10, 10); doc.save('a.pdf');` |\n| **LibreOffice / Microsoft Word automation** | Users comfortable with office suites | Export → “Save As PDF” or use `un","ts":1784038196026},{"role":"user","content":"Continue exactly from where your previous response was cut off. Do not repeat anything you already wrote.","ts":1784038217828},{"role":"assistant","content":"```python\n# -------------------------------------------------\n# 3. Add a simple bar chart (optional)\n# -------------------------------------------------\nfrom 