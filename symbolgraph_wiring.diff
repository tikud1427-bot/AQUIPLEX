+// ── Symbol graph (routes + data-models) ───────────────────────────────────────
+
+// GET /project/workspace/:id/symbol-graph  → full route + model inventory + stats
+router.get('/workspace/:id/symbol-graph', (req, res) => {
+  const workspace = getWorkspace(req.params.id);
+  if (!workspace) return res.status(404).json({ success: false, error: 'Workspace not found' });
+  const graph = serializeSymbolGraph(req.params.id);
+  res.json({ success: true, workspaceId: req.params.id, built: !!graph, graph, stats: getSymbolGraphStats(req.params.id) });
+});
+
+// GET /project/workspace/:id/routes?method=GET&q=/users
+//   Every endpoint with file:line + handler; optional method / path-substring filter.
+router.get('/workspace/:id/routes', (req, res) => {
+  const workspace = getWorkspace(req.params.id);
+  if (!workspace) return res.status(404).json({ success: false, error: 'Workspace not found' });
+  const { method, q } = req.query;
+  let routes = q ? findRoutes(req.params.id, q) : getRoutes(req.params.id, method ?? null);
+  if (q && method) routes = routes.filter(r => r.method === String(method).toUpperCase());
+  res.json({ success: true, workspaceId: req.params.id, count: routes.length, routes });
+});
+
+// GET /project/workspace/:id/models?orm=mongoose&q=user
+//   Every data-model with file:line; optional ORM / name-substring filter.
+router.get('/workspace/:id/models', (req, res) => {
+  const workspace = getWorkspace(req.params.id);
+  if (!workspace) return res.status(404).json({ success: false, error: 'Workspace not found' });
+  const { orm, q } = req.query;
+  let models = q ? findModels(req.params.id, q) : getModels(req.params.id, orm ?? null);
+  if (q && orm) models = models.filter(m => m.orm === orm);
+  res.json({ success: true, workspaceId: req.params.id, count: models.length, models });
+});
+
