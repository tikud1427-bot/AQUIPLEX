{
  "name": "aqua-ai",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test:edit": "node src/project/tests/editEngine.test.js && node src/project/tests/editRoutes.test.js",
    "test:upload": "node --test src/upload/tests/upload.test.js",
    "test:mind": "node --test src/mind/tests/mind.test.js",
    "test:memory": "node --test \"src/memory/tests/*.test.js\"",
    "test:files": "node --test \"src/files/tests/*.test.js\" \"src/reasoning/tests/*.test.js\"",
    "test:orchestrator": "node --test src/orchestrator/tests/*.test.js src/providers/tests/*.test.js",
    "test:identity": "node --test src/identity/tests/identityLayer.test.js",
    "test:search": "node --test src/search/tests/search.test.js",
    "test:artifacts": "node --test \"src/artifacts/tests/*.test.js\" src/routes/tests/artifactRoutes.test.js",
    "test:pic": "node --test src/pic/tests/pic.test.js",
    "test:account": "node --test src/account/tests/accountPurge.test.js",
    "test:cognition": "node --test src/cognition/tests/cognition.test.js",
    "bench:cognition": "node src/cognition/tests/cognitionBench.js",
    "test:providers": "node --test src/providers/tests/*.test.js src/core/tests/backoff.test.js src/core/tests/health.test.js",
    "soak:providers": "node src/providers/tests/providerResilience.soak.js"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "adm-zip": "^0.5.17",
    "cors": "^2.8.6",
    "dejavu-fonts-ttf": "^2.37.3",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.3.0",
    "mammoth": "^1.12.0",
    "openai": "^6.44.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5"
  }
}